# Database Configuration
# For local development with Docker:
DATABASE_URL="postgresql://ypp:ypp@localhost:5432/ypp_pathways"
DIRECT_URL="postgresql://ypp:ypp@localhost:5432/ypp_pathways"

# For Vercel deployment, use one of these providers:
# - Vercel Postgres: postgres://...@...vercel-storage.com/verceldb?sslmode=require
# - Neon: postgres://...@...neon.tech/neondb?sslmode=require
# - Supabase: postgres://...@...supabase.co:5432/postgres
# - PlanetScale: mysql://...@...planetscale.com/...?sslaccept=strict

# If using connection pooling (recommended for serverless), add:
# DATABASE_URL="postgresql://...?pgbouncer=true&connection_limit=5"
# For Supabase specifically (use the transaction pooler on port 6543):
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&sslmode=require"
# DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"
# NOTE: connection_limit=1 used to be suggested for serverless but deadlocks
# any page that fires >1 parallel Prisma query. Keep it >= 3. `lib/prisma.ts`
# will bump sub-3 values automatically. Override with PRISMA_CONNECTION_LIMIT.
# Optional runtime override (use this only if your pooler URL is temporarily failing):
# PRISMA_RUNTIME_DATABASE_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"

# Supabase Auth Configuration
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Seed password (required for database seeding only)
# SEED_PASSWORD="a-strong-password-for-demo-accounts"
# After seed: see README "Login Accounts (seeded)" — includes Anthea Zamir (full admin, Seattle Chapter) and other demo roles.

# Demo mode — hides all features except hiring (positions, applications, interviews).
# Non-hiring routes redirect to a "not yet rolled out" page. Set to "false" for production.
DEMO_MODE="false"

# Student navigation & home Tool Explorer (default: minimal v1 IA). Set to "true" to show the full catalog for QA.
# STUDENT_FULL_PORTAL_EXPLORER="true"

# Public app URLs used in emails and portal links
# IMPORTANT: Set NEXT_PUBLIC_APP_URL in Vercel → Settings → Environment Variables (Production)
# so all emails link to the correct portal domain.
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="https://youthpassionproject-portal.vercel.app"
# NEXT_PUBLIC_SITE_URL="https://portal.yourdomain.com"
# SITE_URL="https://portal.yourdomain.com"

# Pusher Real-Time Messaging (optional - enables instant message delivery)
# To configure: https://pusher.com → Create app → Get credentials
# When unset, messaging uses standard polling (revalidatePath) - slower but functional
# PUSHER_APP_ID="your_app_id"
# NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
# PUSHER_SECRET="your_pusher_secret"
# NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Native instructor readiness rollout flags
# Set to "false" for staged rollout, then "true" to enforce.
ENABLE_NATIVE_INSTRUCTOR_GATE="true"
ENFORCE_PRE_OFFERING_INTERVIEW="true"

# Interactive Training Journey (Phase 4)
# Default: enabled. Set to "false" (or "0" / "no") to disable the journey shell
# and show a "Coming soon" placeholder for INTERACTIVE_JOURNEY modules instead.
ENABLE_INTERACTIVE_TRAINING_JOURNEY=true

# Instructor Applicant Workflow V1 — reviewer/interviewer assignment, chair review,
# required documents, and timeline audit log. Set "false" for quick kill-switch.
ENABLE_INSTRUCTOR_APPLICANT_WORKFLOW_V1="true"

# Daily digest cron schedule for HIRING_CHAIR users (default: 2 PM Mon–Fri).
# Uses standard cron syntax; consumed by the chair-digest API route.
INSTRUCTOR_CHAIR_DIGEST_CRON="0 14 * * 1-5"

# Unified "all tools" primary-role dashboard
# Set to "false" to temporarily use legacy overview page at "/".
ENABLE_UNIFIED_ALL_TOOLS_DASHBOARD="true"

# AI Comment Drafting (required for mentorship review AI draft generation)
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Email Service (required for password reset and notifications)
# Get your API key from https://resend.com
RESEND_API_KEY="re_..."

# Sender email address (must be verified in Resend or use onboarding@resend.dev for testing)
EMAIL_FROM="Youth Passion Project <noreply@youthpassionproject.org>"

# Shared secret for protected cron routes like scheduling reminders and
# the Instructor Applicant Workflow chair-digest + auto-archive jobs.
# Generate one with: openssl rand -hex 32
CRON_SECRET=""

# Applicant Workflow telemetry — emits structured JSON to stdout when "true".
# Pipe to your log aggregator (Datadog, Logtail, CloudWatch) for dashboards.
# Events: applicant.reviewer.assigned, applicant.interviewer.assigned,
#         applicant.chair.decided, applicant.status.auto_advanced, applicant.materials.ready
TELEMETRY_ENABLED="false"
# Twilio SMS (optional - enables one-way transactional text alerts)
# Find these in Twilio Console → Account Info / Messaging Service
# Use a Messaging Service SID when possible. TWILIO_FROM_NUMBER is a fallback only.
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_MESSAGING_SERVICE_SID="MG..."
# TWILIO_FROM_NUMBER="+15551234567"

# Alternative: SMTP (e.g. Gmail)
# Use this if you do NOT have DNS access to verify a sending domain in Resend.
# Gmail requires a Google "App Password" (not your normal password).
# Set EMAIL_PROVIDER="smtp" to force SMTP, or leave it unset to auto-detect.
# EMAIL_PROVIDER="smtp"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="your-gmail@gmail.com"
# SMTP_PASS="your-16-char-app-password"

# File Storage (required for production uploads)
# In production (Vercel), files MUST be stored in cloud storage.
# Vercel's filesystem is ephemeral - local files are lost on every deployment.

# Storage Provider (optional - auto-detects by default)
# - "auto" (default): Use Blob if configured, fallback to local in development
# - "blob": Force Vercel Blob (recommended for production)
# - "local": Force local disk (development only, DO NOT use in production)
# STORAGE_PROVIDER="auto"

# Vercel Blob Storage (recommended for production)
# This token is automatically set by Vercel when you enable Blob Storage.
# Get it from: Vercel Dashboard → Storage → Blob → Copy Token
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Alternative: AWS S3 (if not using Vercel Blob)
# Note: Current implementation uses Vercel Blob only.
# To add S3 support, extend /lib/storage.ts with S3 provider.
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET="..."
# AWS_REGION="us-east-1"

# Two-Factor Authentication (2FA/TOTP)
# Required when 2FA is enabled. Generate with: openssl rand -hex 32
# TWO_FACTOR_ENCRYPTION_KEY=""

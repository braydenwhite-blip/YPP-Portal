{
  "name": "ypp-pathways-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/maybe-db-sync.mjs && rm -rf .next node_modules/.prisma && prisma generate && node --max-old-space-size=6144 ./node_modules/next/dist/bin/next build",
    "vercel-build": "npm run build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:local": "npm run test:e2e:seed && playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:seed": "tsx scripts/seed-portal-e2e.ts",
    "smoke:release": "node scripts/smoke-release-checks.mjs",
    "email:check": "tsx scripts/check-email.ts",
    "check:release": "npm run build && npm run nav:check && npm run smoke:release",
    "nav:check": "node scripts/validate-nav.mjs",
    "nav:ux-check": "node scripts/validate-nav.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:sync-seed-password": "node scripts/sync-seed-password.mjs",
    "db:studio": "prisma studio",
    "backfill:instructor-readiness": "node scripts/backfill-native-instructor-readiness.mjs",
    "backfill:passion-taxonomy": "node scripts/backfill-passion-taxonomy.mjs",
    "training:seed-content": "node scripts/seed-training-academy-content.mjs",
    "training:validate": "node scripts/validate-training-academy-content.mjs",
    "training:import": "node scripts/import-training-academy-content.mjs",
    "training:export": "node scripts/export-training-academy-content.mjs",
    "training:sync": "npm run training:validate && npm run training:import",
    "backfill:email-verified": "node scripts/backfill-email-verified.mjs",
    "backfill:mentorship-redesign": "node scripts/backfill-mentorship-redesign.mjs",
    "migrate:users:validate-csv": "node scripts/import-users-from-csv.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.6",
    "@prisma/client": "^5.22.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@upstash/ratelimit": "^2.0.8",
    "@vercel/blob": "^2.2.0",
    "@vercel/kv": "^3.0.0",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "next": "^14.2.35",
    "next-auth": "4.24.13",
    "nodemailer": "^7.0.13",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "resend": "^6.9.1",
    "three": "^0.170.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "jsdom": "^28.1.0",
    "prisma": "^5.22.0",
    "tsx": "4.15.6",
    "typescript": "5.5.4",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

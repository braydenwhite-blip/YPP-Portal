// ============================================
// PHASE 3: PROGRESS TRACKING & MILESTONES
// ============================================

// Passion Timeline - Visual journey tracker
model PassionTimeline {
  id          String          @id @default(cuid())
  studentId   String
  passionId   String
  startDate   DateTime        @default(now())
  title       String
  description String?
  isActive    Boolean         @default(true)
  entries     TimelineEntry[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([studentId, passionId])
  @@index([studentId])
  @@index([passionId])
}

// Timeline entries - Events in the passion journey
model TimelineEntry {
  id             String            @id @default(cuid())
  timelineId     String?
  timeline       PassionTimeline?  @relation(fields: [timelineId], references: [id])
  studentId      String
  student        User              @relation("TimelineEntries", fields: [studentId], references: [id])
  passionId      String
  entryType      TimelineEntryType

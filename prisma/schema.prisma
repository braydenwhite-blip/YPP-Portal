// ============================================
// CHAPTER PRESIDENT APPLICATIONS
// ============================================

model ChapterPresidentApplication {
  id          String                            @id @default(cuid())
  applicantId String                            @unique
  applicant   User                              @relation("ChapterPresidentApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  chapterId   String?
  chapter     Chapter?                          @relation(fields: [chapterId], references: [id])
  status      ChapterPresidentApplicationStatus @default(SUBMITTED)

  // --- Core application essays ---
  leadershipExperience String @db.Text
  chapterVision        String @db.Text
  availability         String

  // --- Personal Information ---
  legalName          String?
  preferredFirstName String?
  lastName           String?
  phoneNumber        String?
  dateOfBirth        String?
  hearAboutYPP       String?

  // --- Location ---
  city          String?
  stateProvince String?
  zipCode       String?
  country       String?

  // --- Academic Background ---
  schoolName     String?
  grade          String?
  graduationYear Int?
  gpa            String?
  classRank      String?

  // --- Chapter-specific essays ---
  whyChapterPresident        String? @db.Text
  partnerSchool              String?
  currentYppInvolvement      String? @db.Text
  communityServiceExperience String? @db.Text
  potentialChapterLocation   String?
  firstThreeActions          String? @db.Text
  recruitmentPlan            String? @db.Text
  launchPlan                 String? @db.Text
  extracurriculars           String? @db.Text
  priorOrganizing            String? @db.Text
  specialSkills              String? @db.Text

  // --- Referral ---
  referralEmails String? @db.Text

  // --- Supporting document ---
  documentUrl String? // uploaded résumé / credentials / awards

  // --- Instructor information (optional) ---
  instructorApplicantPosition String? // "Chapter President Only" | "Instructor Only" | "Both"
  classInMind                 String? // class they envision teaching (or N/A)
  instructorTeachingDesc      String? @db.Text // 250-word teaching/empowerment description

  // --- Availability details ---
  hoursPerWeek       Int?
  preferredStartDate String?

  // --- Optional demographics ---
  ethnicity String?

  // --- Reviewer scoring rubric ---
  scoreLeadership        Int?
  scoreVision            Int?
  scoreOrganization      Int?
  scoreCommitment        Int?
  scoreFit               Int?
  scoreRecruiting        Int?
  scoreOverallConfidence Int?

  // --- Interview-specific scoring rubric ---
  scoreCommunication         Int?
  interviewSummary           String? @db.Text
  interviewNotes             String? @db.Text
  interviewScore             Int?
  interviewConcerns          String? @db.Text
  interviewFollowUpQuestions String? @db.Text

  // --- Final recommendation (input to the chair / final decision) ---
  decisionRecommendation  HiringRecommendation?
  recommendationRationale String?               @db.Text
  finalDecisionNote       String?               @db.Text
  decisionMakerId         String?
  decisionMaker           User?                 @relation("ChapterPresidentApplicationDecisionMaker", fields: [decisionMakerId], references: [id], onDelete: SetNull)
  decisionAt              DateTime?
  acceptanceEmailSentAt   DateTime?

  // --- Review workflow ---
  reviewerId              String?
  reviewer                User?                     @relation("ChapterPresidentApplicationReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerNotes           String?                   @db.Text
  infoRequest             String?                   @db.Text
  applicantResponse       String?                   @db.Text
  rejectionReason         String?                   @db.Text
  interviewScheduledAt    DateTime?
  interviewMeetingUrl     String?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  linkedPersonId          String?
  linkedPerson            User?                     @relation("ChapterPresidentApplicationLinkedPerson", fields: [linkedPersonId], references: [id], onDelete: SetNull)
  roleAssignedAt          DateTime?
  mentorAdvisorId         String?
  mentorAdvisor           User?                     @relation("ChapterPresidentApplicationMentorAdvisor", fields: [mentorAdvisorId], references: [id], onDelete: SetNull)
  onboardingStartedAt     DateTime?
  starterActionsCreatedAt DateTime?
  onboardingCompletedAt   DateTime?
  activeAt                DateTime?
  customResponses         ApplicationFormResponse[] @relation("CPAppFormResponses")
  cohortId                String?
  cohort                  ApplicationCohort?        @relation("CPAppCohort", fields: [cohortId], references: [id])

  // --- Automated scheduling ---
  availabilityWindows ApplicantAvailabilityWindow[] @relation("CPAvailabilityWindows")
  schedulingNoMatchAt DateTime?

  // --- External intake (Google Forms / CSV / manual admin entry) ---
  source              ApplicationSource @default(PORTAL)
  externalSubmittedAt DateTime?
  externalImportedAt  DateTime?
  externalResponseUrl String?
  externalAnswersCopy String?           @db.Text
  internalNotes       String?           @db.Text
  importedById        String?
  importedBy          User?             @relation("ChapterPresidentApplicationImportedBy", fields: [importedById], references: [id], onDelete: SetNull)
  manualEmailTasks    ManualEmailTask[] @relation("ManualEmailTasksChapterPresidentApplication")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@index([status])
  @@index([reviewerId])
  @@index([chapterId])
  @@index([cohortId])
  @@index([decisionMakerId])
  @@index([linkedPersonId])
  @@index([mentorAdvisorId])
  @@index([graduationYear])
  @@index([stateProvince])
  @@index([source])
  @@index([importedById])
  @@index([archivedAt])
  @@index([activeAt])
}


enum DifficultyLevel {
  LEVEL_101
  LEVEL_201
  LEVEL_301
  LEVEL_401
}

enum CurriculumSubmissionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  NEEDS_REVISION
}

// Two-stage curriculum approval (Phase 4). The single-stage
// `CurriculumSubmissionStatus` above only ever reached one APPROVED state. The
// Chapter President playbook needs a real CP review → CP approved → Global
// review → Fully approved pipeline, captured on the `CurriculumApproval`
// satellite below so launch readiness can require a TRUE global approval.
enum CurriculumApprovalStage {
  NOT_SUBMITTED // instructor still drafting — nothing waiting on a reviewer
  CP_REVIEW // submitted; the Chapter President owes a review (48h SLA)
  CP_REVISION_REQUESTED // CP sent it back to the instructor to revise
  CP_APPROVED // CP approved; ready to escalate to global leadership
  GLOBAL_REVIEW // escalated; global leadership owes a review
  GLOBAL_REVISION_REQUESTED // global sent it back for revision
  FULLY_APPROVED // global leadership signed off — satisfies launch readiness
}

enum DeliveryMode {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum ClassEnrollmentStatus {
  ENROLLED
  WAITLISTED
  DROPPED
  COMPLETED
}

enum ClassOfferingStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReminderType {
  TWENTY_FOUR_HOUR
  ONE_HOUR
  CUSTOM
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum LaunchTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum RolloutAudience {
  ALL
  INSTRUCTORS
  STUDENTS
  PARENTS
  CHAPTER_LEADS
  STAFF
  MENTORS
}

enum RolloutCampaignStatus {
  DRAFT
  SENT
  FAILED
}

enum FeatureGateScope {
  GLOBAL
  CHAPTER
  USER
  ROLE
}

enum ChapterPathwayRunStatus {
  NOT_OFFERED
  COMING_SOON
  ACTIVE
  PAUSED
}

enum PathwayFallbackRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ClassOfferingApprovalStatus {
  NOT_REQUESTED
  REQUESTED
  UNDER_REVIEW
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

// Class template: reusable curriculum design (Feature #61, #62, #63, #64)
model ClassTemplate {
  id                    String          @id @default(cuid())
  title                 String
  description           String          @db.Text
  interestArea          String // Passion area (matches existing pattern)
  difficultyLevel       DifficultyLevel @default(LEVEL_101)
  learnerFitLabel       String?
  learnerFitDescription String?         @db.Text
  prerequisites         String[] // e.g., ["ART-101", "ART-102"]

  // Curriculum (Feature #61)
  weeklyTopics     Json     @default("[]") // [{week, topic, milestone, materials}]
  learningOutcomes String[] // What students achieve (Feature #63)
  estimatedHours   Int      @default(0) // Total student time commitment
  durationWeeks    Int      @default(8) // Course length in weeks
  sessionsPerWeek  Int      @default(1)

  // Class size optimization (Feature #64)
  minStudents Int     @default(3)
  maxStudents Int     @default(25)
  idealSize   Int     @default(12)
  sizeNotes   String? // Why this size works

  // Delivery (Feature #83)
  deliveryModes String[] @default(["VIRTUAL"]) // IN_PERSON, VIRTUAL, HYBRID

  // YPP Curriculum Template fields (Phase 3)
  targetAgeGroup     String? // e.g., "12-14", "16-18"
  classDurationMin   Int? // Length of each class session in minutes
  engagementStrategy Json? // {energyStyle, differentiationPlan, technologyTools, studentVoiceMoments, assessmentApproach}

  // Submission & review workflow
  submissionStatus CurriculumSubmissionStatus @default(DRAFT)
  submittedAt      DateTime?
  reviewedById     String?
  reviewedBy       User?                      @relation("ClassTemplatesReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes      String?                    @db.Text

  // Meta
  isPublished   Boolean  @default(false)
  // Admin-curated catalog flag — true when this template is part of the
  // Course Library that instructors pick from on /instructor/curriculum-builder.
  isCatalogItem Boolean  @default(false)
  createdById   String
  createdBy     User     @relation("ClassTemplatesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  chapterId     String?
  chapter       Chapter? @relation(fields: [chapterId], references: [id])

  // Set when an instructor picks a course from the library; points at the
  // admin's source template so we can show usage counts and provenance.
  clonedFromId String?
  clonedFrom   ClassTemplate?  @relation("CourseClones", fields: [clonedFromId], references: [id])
  clones       ClassTemplate[] @relation("CourseClones")

  offerings                    ClassOffering[]
  lessonPlans                  LessonPlan[]
  pathwaySteps                 PathwayStep[]                 @relation("ClassTemplateSteps")
  regularInstructorAssignments RegularInstructorAssignment[] @relation("ClassTemplateAssignments")

  // Two-stage curriculum approval (Phase 4). 1:1 satellite, created lazily the
  // first time a reviewer acts. Absent ⇒ the template falls back to its legacy
  // single-stage `submissionStatus`.
  curriculumApproval CurriculumApproval?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interestArea])
  @@index([difficultyLevel])
  @@index([createdById])
  @@index([submissionStatus])
  @@index([isCatalogItem])
  @@index([clonedFromId])
}

// Specific offering of a class template (Feature #80, #83)
model ClassOffering {
  id            String        @id @default(cuid())
  templateId    String
  template      ClassTemplate @relation(fields: [templateId], references: [id])
  instructorId  String
  instructor    User          @relation("ClassOfferingsInstructed", fields: [instructorId], references: [id], onDelete: Cascade)
  pathwayStepId String?
  pathwayStep   PathwayStep?  @relation("PathwayStepOfferings", fields: [pathwayStepId], references: [id])

  // Schedule (Feature #80)
  title       String // Can override template title
  startDate   DateTime
  endDate     DateTime
  meetingDays String[] // ["Monday", "Wednesday"]
  meetingTime String // "16:00-18:00"
  timezone    String   @default("America/New_York")

  // Location (Feature #83)
  deliveryMode        DeliveryMode @default(VIRTUAL)
  locationName        String? // Physical location name
  locationAddress     String?
  room                String? // In-person room or studio (e.g. "Studio B")
  arrivalInstructions String?      @db.Text // What students/parents should do on arrival
  materialsList       String[]     @default([]) // Required/recommended materials per session
  zoomLink            String?
  meetingId           String? // Zoom/Teams meeting ID

  // Instructor class intro media
  introVideoTitle       String?
  introVideoDescription String?        @db.Text
  introVideoProvider    VideoProvider?
  introVideoUrl         String?
  introVideoThumbnail   String?

  // Enrollment
  capacity       Int     @default(25)
  enrollmentOpen Boolean @default(true)

  // Reminders (Feature #81)
  send24HrReminder Boolean @default(true)
  send1HrReminder  Boolean @default(true)

  // Status
  status                         ClassOfferingStatus @default(DRAFT)
  chapterId                      String?
  chapter                        Chapter?            @relation(fields: [chapterId], references: [id])
  // Optional org/school Partner behind this class. Carries the Relationship
  // Lead (Partner.relationshipLead), surfaced on the Action Tracker Classes tab
  // and the admin class detail alongside the Lead Instructor.
  partnerId                      String?
  partner                        Partner?            @relation("PartnerClassOfferings", fields: [partnerId], references: [id])
  semester                       String? // "Spring 2025", "Fall 2025"
  grandfatheredTrainingExemption Boolean             @default(false)

  // Relations
  sessions                     ClassSession[]
  enrollments                  ClassEnrollment[]
  reminders                    ClassReminder[]
  assignments                  ClassAssignment[]
  announcements                ClassAnnouncement[]
  fallbackRequests             PathwayFallbackRequest[]
  approval                     ClassOfferingApproval?
  timeline                     ClassOfferingTimelineEvent[]
  feedback                     ClassFeedback[]
  outcome                      ClassOutcome?
  regularInstructorAssignments RegularInstructorAssignment[] @relation("RegularInstructorAssignmentsForOffering")

  /// Leadership Roles & Contributions — lead-instructor / quality-review
  /// contributions pointing at this offering (ENABLE_LEADERSHIP_ROLES).
  leadershipContributions LeadershipContribution[] @relation("LeadershipContributionOffering")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@index([instructorId])
  @@index([startDate])
  @@index([status])
  @@index([chapterId])
  @@index([pathwayStepId])
  @@index([partnerId])
}

/// An external organization or school partner behind one or more classes.
/// Introduced for the People Strategy "Classes" tab (comment #9): classes must
/// surface a Partner and a Relationship Lead. Kept as a clean, first-class table
/// (rather than overloading free-text fields like `partnerSchool`) so the
/// directory stays tidy and the Relationship Lead is a real `User` relation.
model Partner {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  /// Free-text category, e.g. "School", "Nonprofit", "Corporate".
  type                    String?
  website                 String?
  notes                   String?                  @db.Text
  /// The YPP person who owns this partner relationship.
  relationshipLeadId      String?
  relationshipLead        User?                    @relation("PartnerRelationshipLead", fields: [relationshipLeadId], references: [id], onDelete: SetNull)
  /// The chapter this partner belongs to. Null means it is still in Missing Chapter setup or global work.
  chapterId               String?
  chapter                 Chapter?                 @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  classOfferings          ClassOffering[]          @relation("PartnerClassOfferings")
  meetings                Meeting[]                @relation("MeetingPartner")
  /// Leadership Roles & Contributions — partner-relationship-lead contributions
  /// pointing at this partner (ENABLE_LEADERSHIP_ROLES).
  leadershipContributions LeadershipContribution[] @relation("LeadershipContributionPartner")
  archivedAt              DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  // --- Partner Pipeline (Phase 4 — YPP Operating System pass) -----------------
  // Turns the bare directory into a relationship pipeline. `stage`, `priority`
  // and `partnerType` are TEXT vocabularies validated in app code
  // (lib/partners-constants.ts), mirroring the repo's `actionType` /
  // `relatedEntityType` convention — no Postgres enums, vocabulary stays
  // editable without a migration. All fields are nullable/defaulted so existing
  // rows are unaffected and the feature stays dark until ENABLE_PARTNER_PIPELINE.
  /// Pipeline stage, e.g. NOT_STARTED, REACHED_OUT, MEETING_SCHEDULED, ACTIVE…
  stage                 String?       @default("NOT_STARTED")
  /// LOW | MEDIUM | HIGH | URGENT.
  priority              String?       @default("MEDIUM")
  /// Structured partner type, e.g. CAMP, SCHOOL, COMMUNITY_CENTER, NONPROFIT…
  partnerType           String?
  /// How this partner came to YPP (referral, inbound, outreach list…).
  source                String?
  contactName           String?
  contactTitle          String?
  contactEmail          String?
  contactPhone          String?
  location              String?
  lastContactedAt       DateTime?
  nextFollowUpAt        DateTime?
  meetingDate           DateTime?
  /// Program needs (free text; matched against instructor tags).
  requestedSubjects     String?
  requestedAgeGroups    String?
  requestedDates        String?
  programFormat         String?
  expectedStudents      Int?
  instructorCountNeeded Int?
  constraints           String?       @db.Text
  outcome               String?       @db.Text
  /// Chapter Partner CRM logistics checklist state (Partner Automation). JSON
  /// map of checklist-item key → boolean (e.g. { room: true, supervision: false }).
  /// Validated in app code (lib/partners/logistics.ts); additive + nullable so
  /// existing rows and the admin pipeline board are unaffected.
  logistics             Json?
  pipelineNotes         PartnerNote[]

  // --- Partner Relationship Operations (Knowledge OS V2, Phase 1) ------------
  // Structured contacts, requests/negotiations, and agreements/conditions so
  // partner records support real relationship work, not contact cards.
  // (docs/ypp-organizational-knowledge-os-master-plan.md §10/§23.)
  contacts   PartnerContact[]
  requests   PartnerRequest[]
  agreements PartnerAgreement[]

  @@index([relationshipLeadId])
  @@index([chapterId])
  @@index([archivedAt])
  @@index([stage])
  @@index([nextFollowUpAt])
}

/// Append-only notes / touchpoints / timeline for a Partner relationship.
/// `authorId` is intentionally FK-less (resolved to a name in app code) to
/// mirror the repo's no-FK convention for loosely-coupled references and to
/// avoid adding a back-relation to the large `User` model.
model PartnerNote {
  id        String   @id @default(cuid())
  partnerId String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  authorId  String?
  /// Touchpoint kind: NOTE | FOLLOW_UP | MEETING | CONCERN | WIN | DECISION |
  /// OUTCOME | STAGE_CHANGE plus the Chapter Partner CRM timeline kinds
  /// (OUTREACH_SENT, MEETING_OUTCOME, ISSUE, CHECK_IN, …) — see
  /// lib/partners-constants.ts → PARTNER_NOTE_KINDS.
  kind      String   @default("NOTE")
  body      String   @db.Text
  /// Structured timeline metadata (Partner Automation): meeting outcome type,
  /// issue severity/escalation/resolution, scheduled follow-up date, close
  /// reason, etc. Additive + nullable; legacy notes leave it null.
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([partnerId, createdAt])
}

/// A named contact at a partner organization (Knowledge OS V2). Replaces the
/// single contactName/contactEmail strings on Partner over time. `userId`
/// optionally links to a portal account; user refs are FK-less per the repo's
/// loosely-coupled-reference convention (see PartnerNote).
model PartnerContact {
  id        String   @id @default(cuid())
  partnerId String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  email     String?
  phone     String?
  /// Relationship role: DECISION_MAKER | DAY_TO_DAY | BILLING | OTHER
  /// (TEXT vocabulary, validated in lib/partners-constants.ts).
  role      String?
  isPrimary Boolean  @default(false)
  userId    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId, isPrimary])
}

/// A structured partner ask ("3 instructors for summer camp by June") with a
/// negotiation lifecycle. `status` is a TEXT vocabulary validated in
/// lib/partners-constants.ts: OPEN | IN_NEGOTIATION | AGREED | DECLINED |
/// FULFILLED | EXPIRED. ownerId/createdById are FK-less user references.
model PartnerRequest {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  title       String
  details     String?   @db.Text
  status      String    @default("OPEN")
  ownerId     String?
  dueAt       DateTime?
  resolvedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([partnerId, status])
  @@index([status, dueAt])
}

/// An MOU / contract / informal agreement with a partner. `kind` (MOU |
/// CONTRACT | INFORMAL) and `status` (DRAFT | SENT | SIGNED | EXPIRED |
/// TERMINATED) are TEXT vocabularies validated in lib/partners-constants.ts.
model PartnerAgreement {
  id            String    @id @default(cuid())
  partnerId     String
  partner       Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  kind          String    @default("MOU")
  status        String    @default("DRAFT")
  title         String
  effectiveAt   DateTime?
  expiresAt     DateTime?
  renewalNoteAt DateTime?
  terms         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conditions PartnerAgreementCondition[]

  @@index([partnerId, status])
}

/// One condition on an agreement ("background checks for all instructors"),
/// tracked to completion. `status`: PENDING | SATISFIED | WAIVED | FAILED
/// (TEXT vocabulary, validated in lib/partners-constants.ts).
model PartnerAgreementCondition {
  id          String           @id @default(cuid())
  agreementId String
  agreement   PartnerAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  description String           @db.Text
  status      String           @default("PENDING")
  dueAt       DateTime?
  satisfiedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([agreementId, status])
}

enum ClassOfferingTimelineKind {
  PROPOSAL_SUBMITTED
  PROPOSAL_APPROVED
  PROPOSAL_CHANGES_REQUESTED
  PROPOSAL_REJECTED
  PUBLISHED
  UNPUBLISHED
  ENROLLMENT_OPENED
  ENROLLMENT_CLOSED
  CANCELLED
  COMPLETED
  CAPACITY_CHANGED
  INSTRUCTOR_REASSIGNED
  WAITLIST_PROMOTION
  ENROLLMENT_STATUS_CHANGED
  NOTE
}

// Append-only audit log for admin actions on a ClassOffering. Surfaced on
// the admin class detail page so reviewers can answer "who approved this
// and when" without grepping logs.
model ClassOfferingTimelineEvent {
  id         String                    @id @default(cuid())
  offeringId String
  offering   ClassOffering             @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?                     @relation("ClassOfferingTimelineActor", fields: [actorId], references: [id], onDelete: SetNull)
  kind       ClassOfferingTimelineKind
  // Human-readable one-liner; the payload carries machine-readable detail.
  summary    String?
  payload    Json?
  createdAt  DateTime                  @default(now())

  @@index([offeringId, createdAt])
  @@index([kind, createdAt])
  @@index([actorId])
}

model ClassOfferingApproval {
  id            String                      @id @default(cuid())
  offeringId    String                      @unique
  offering      ClassOffering               @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  status        ClassOfferingApprovalStatus @default(NOT_REQUESTED)
  requestedById String?
  requestedBy   User?                       @relation("ClassOfferingApprovalRequests", fields: [requestedById], references: [id], onDelete: SetNull)
  requestNotes  String?                     @db.Text
  requestedAt   DateTime?
  reviewedById  String?
  reviewedBy    User?                       @relation("ClassOfferingApprovalReviews", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes   String?                     @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([status])
  @@index([requestedById])
  @@index([reviewedById])
}

// Two-stage curriculum approval satellite (Phase 4), 1:1 with ClassTemplate and
// modelled on ClassOfferingApproval. Reviewer identity is stored as plain
// id + denormalized name (a point-in-time snapshot for the audit trail) so this
// feature is fully self-contained and adds no relations to the User model.
model CurriculumApproval {
  id              String                  @id @default(cuid())
  classTemplateId String                  @unique
  classTemplate   ClassTemplate           @relation(fields: [classTemplateId], references: [id], onDelete: Cascade)
  stage           CurriculumApprovalStage @default(NOT_SUBMITTED)

  submittedAt DateTime?

  // Stage 1 — Chapter President review
  cpReviewedById   String?
  cpReviewedByName String?
  cpReviewedAt     DateTime?
  cpReviewNotes    String?   @db.Text

  // Stage 2 — Global leadership review
  sentToGlobalAt       DateTime?
  globalReviewedById   String?
  globalReviewedByName String?
  globalReviewedAt     DateTime?
  globalReviewNotes    String?   @db.Text

  events CurriculumReviewEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
}

// Append-only audit trail for the two-stage curriculum review — every submit /
// revision / approval, with the decision, the actor snapshot, and any notes.
// Powers the "review notes / history" view in the Learning Program room.
model CurriculumReviewEvent {
  id         String                  @id @default(cuid())
  approvalId String
  approval   CurriculumApproval      @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  actorId    String?
  actorName  String?
  actorRole  String // "CHAPTER_PRESIDENT" | "GLOBAL_LEADERSHIP" | "INSTRUCTOR"
  stage      CurriculumApprovalStage // resulting stage after this event
  decision   String // SUBMITTED | CP_APPROVED | CP_REVISION | SENT_TO_GLOBAL | GLOBAL_APPROVED | GLOBAL_REVISION
  notes      String?                 @db.Text
  createdAt  DateTime                @default(now())

  @@index([approvalId, createdAt])
}

// Individual class session (meeting) within an offering
model ClassSession {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  sessionNumber    Int
  date             DateTime
  startTime        String // "16:00"
  endTime          String // "18:00"
  topic            String
  description      String?  @db.Text
  learningOutcomes String[]
  milestone        String? // Key milestone for this session

  // Materials
  materialsUrl String?
  recordingUrl String?
  notesUrl     String?

  // Status
  isCancelled  Boolean @default(false)
  cancelReason String?

  // Attendance
  attendance ClassAttendanceRecord[]

  // Post-session instructor reflection (Phase 5) — 1:1, created on submit.
  reflection ClassSessionReflection?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offeringId, sessionNumber])
  @@index([offeringId])
  @@index([date])
}

// Student enrollment in a class offering
model ClassEnrollment {
  id         String        @id @default(cuid())
  studentId  String
  student    User          @relation("ClassEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id])

  status      ClassEnrollmentStatus @default(ENROLLED)
  enrolledAt  DateTime              @default(now())
  droppedAt   DateTime?
  completedAt DateTime?

  // Progress tracking (Feature #63)
  sessionsAttended Int      @default(0)
  outcomesAchieved String[] // IDs of achieved learning outcomes
  instructorNotes  String?  @db.Text

  // Signup context — what the student told us in the guided fit check at
  // enrollment. Read-only after signup; surfaced to the instructor/admin roster
  // so the people teaching the class know why each student is there.
  signupGoal String? @db.Text
  signupNote String? @db.Text

  // Waitlist position (if waitlisted)
  waitlistPosition Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, offeringId])
  @@index([studentId])
  @@index([offeringId])
  @@index([status])
}

// Attendance for individual class sessions
model ClassAttendanceRecord {
  id        String       @id @default(cuid())
  sessionId String
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User         @relation("ClassAttendanceRecords", fields: [studentId], references: [id], onDelete: Cascade)

  status      AttendanceStatus @default(PRESENT)
  notes       String?
  checkedInAt DateTime         @default(now())

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
}

// Post-session instructor reflection (Phase 5). 1:1 with ClassSession. More than
// a text box: it produces operating signals (needsCpHelp / logistics issues feed
// class interventions; reflection completion clears the "reflection due" runtime
// state; entries surface in Recent Activity). instructorId is FK-less + a
// denormalized instructorName snapshot, matching the repo's loosely-coupled-id
// convention (see PartnerNote / ClassOutcome) to avoid widening the User model.
model ClassSessionReflection {
  id         String       @id @default(cuid())
  sessionId  String       @unique
  session    ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// Denormalized for chapter-/offering-scoped reads without a session join.
  offeringId String

  instructorId   String?
  instructorName String?

  wentWell       String?  @db.Text
  struggled      String?  @db.Text
  studentToWatch String?  @db.Text
  changeNextTime String?  @db.Text
  logisticsIssue String?  @db.Text
  needsCpHelp    Boolean  @default(false)
  /// Instructor confidence after the session, 1–5 (optional).
  confidence     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId, createdAt])
}

// Class reminders (Feature #81)
model ClassReminder {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  sessionId  String? // Specific session, or null for general
  userId     String
  user       User          @relation("ClassRemindersReceived", fields: [userId], references: [id], onDelete: Cascade)

  type         ReminderType
  scheduledFor DateTime
  sentAt       DateTime?
  status       ReminderStatus @default(PENDING)

  // Content
  subject  String
  body     String  @db.Text
  zoomLink String?

  createdAt DateTime @default(now())

  @@index([offeringId])
  @@index([userId])
  @@index([scheduledFor])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Class feedback + completion-outcome layer
//
// Post-class signal for the class program, split by who fills it in:
//   • ClassFeedback — one row per (offering, student): the learner's rating plus
//     what they liked and what they'd improve. The "feedback" half.
//   • ClassOutcome  — one row per offering (1:1): the instructor's wrap-up
//     reflection PLUS the admin's completion outcome and repeat recommendation.
//     The "completion-outcome" half.
//
// Everything is additive and nullable/defaulted, so existing offerings are
// unaffected and the layer simply stays empty until people start filling it in.
// User references (studentId / instructorId / recordedById) are intentionally
// FK-less and resolved to names in app code, mirroring the repo's
// loosely-coupled-id convention (see PartnerNote) to avoid widening the very
// large User model with more back-relations.
// ─────────────────────────────────────────────────────────────────────────────

/// Admin's verdict on how a completed class actually went.
enum ClassOutcomeStatus {
  PENDING // not reviewed yet
  STRONG // clear success
  SOLID // met the bar
  MIXED // uneven — some good, some not
  UNDERPERFORMED // missed the bar (enrollment, attendance, or quality)
  DID_NOT_RUN // cancelled / never really happened
}

/// Should we run this class again? The repeat-recommendation taxonomy that powers
/// the "repeat these" planning panel on /admin/classes/reports.
enum ClassRepeatRecommendation {
  REPEAT_AS_IS // run it again unchanged
  REPEAT_WITH_TWEAKS // run again with small changes
  REPEAT_NEW_INSTRUCTOR // good class, needs a different instructor
  REPEAT_LATER // worth repeating, but not next term
  NEEDS_REWORK // promising, but needs a real redesign first
  DO_NOT_REPEAT // retire it
  UNDECIDED // not decided yet
}

/// Per-student class feedback. One row per (offering, student).
model ClassFeedback {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  studentId  String

  /// 1–5 overall rating.
  rating         Int
  /// What the student liked / what worked for them.
  liked          String?  @db.Text
  /// What the student would improve.
  improve        String?  @db.Text
  /// Would they recommend this class to a friend?
  wouldRecommend Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offeringId, studentId])
  @@index([offeringId])
  @@index([studentId])
  @@index([rating])
}

/// Per-offering completion outcome: instructor reflection (top) + admin
/// completion outcome (bottom). 1:1 with ClassOffering.
model ClassOutcome {
  id         String        @id @default(cuid())
  offeringId String        @unique
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  // ── Instructor wrap-up reflection ──────────────────────────────────────
  instructorId              String?
  instructorWentWell        String?   @db.Text // what went well
  instructorChallenges      String?   @db.Text // what was hard / what they'd change
  instructorStudentImpact   String?   @db.Text // what students got out of it
  instructorWouldTeachAgain Boolean?
  instructorReflectedAt     DateTime?

  // ── Admin completion outcome ───────────────────────────────────────────
  status               ClassOutcomeStatus         @default(PENDING)
  repeatRecommendation ClassRepeatRecommendation?
  /// Admin's quick "this got good feedback" flag — drives the reports highlight panel.
  gotGoodFeedback      Boolean                    @default(false)
  adminNotes           String?                    @db.Text
  recordedById         String?
  recordedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([repeatRecommendation])
  @@index([gotGoodFeedback])
}

model EventReminder {
  id           String         @id @default(cuid())
  eventId      String
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation("EventRemindersReceived", fields: [userId], references: [id], onDelete: Cascade)
  type         ReminderType
  scheduledFor DateTime
  sentAt       DateTime?
  status       ReminderStatus @default(PENDING)
  subject      String
  body         String         @db.Text
  createdAt    DateTime       @default(now())

  @@unique([eventId, userId, type])
  @@index([eventId])
  @@index([userId])
  @@index([scheduledFor])
  @@index([status])
}

model ChapterMilestone {
  id          String          @id @default(cuid())
  chapterId   String
  chapter     Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  dueDate     DateTime
  visibility  EventVisibility @default(INTERNAL)
  createdById String?
  createdBy   User?           @relation("ChapterMilestonesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?           @relation("ChapterMilestonesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  calendarUid String          @unique @default(cuid())
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([chapterId, dueDate])
  @@index([visibility, dueDate])
}

model ChapterCalendarSubscription {
  id        String   @id @default(cuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedToken String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, userId])
  @@index([userId])
}

// Launch timeline task for leadership + chapter rollout coordination
model LaunchTask {
  id          String           @id @default(cuid())
  title       String
  ownerLabel  String
  dueDate     DateTime?
  status      LaunchTaskStatus @default(NOT_STARTED)
  blocker     String?
  scope       String           @default("GLOBAL") // GLOBAL or CHAPTER
  chapterId   String?
  chapter     Chapter?         @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?            @relation("LaunchTasksCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?            @relation("LaunchTasksUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([scope, isActive])
  @@index([chapterId, isActive])
  @@index([status, dueDate])
}

// Outbound rollout campaign log with send metadata
model RolloutCampaign {
  id           String                @id @default(cuid())
  templateKey  String
  title        String
  content      String                @db.Text
  audience     RolloutAudience       @default(ALL)
  targetRoles  RoleType[]
  linkUrl      String?
  chapterId    String?
  chapter      Chapter?              @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                  @relation("RolloutCampaignsCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  status       RolloutCampaignStatus @default(SENT)
  sentAt       DateTime?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([chapterId])
  @@index([audience, status])
  @@index([createdAt])
}

model FeatureGateRule {
  id          String           @id @default(cuid())
  featureKey  String
  scope       FeatureGateScope @default(GLOBAL)
  enabled     Boolean          @default(true)
  chapterId   String?
  chapter     Chapter?         @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?            @relation("FeatureGateRuleTargetUser", fields: [userId], references: [id], onDelete: SetNull)
  role        RoleType?
  startsAt    DateTime?
  endsAt      DateTime?
  note        String?
  createdById String?
  createdBy   User?            @relation("FeatureGateRuleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?            @relation("FeatureGateRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([featureKey, scope, enabled])
  @@index([featureKey, chapterId, enabled])
  @@index([featureKey, userId, enabled])
  @@index([featureKey, role, enabled])
  @@index([startsAt, endsAt])
}

// ============================================
// PHASE 10: ENJOYMENT-FOCUSED ASSIGNMENT SYSTEM
// ============================================

enum ClassAssignmentType {
  PRACTICE // Skill-building exercise
  PROJECT // Creative project
  EXPLORATION // Open-ended exploration
  GROUP // Group collaboration
  REFLECTION // Reflective writing
}

enum FeedbackStyle {
  NARRATIVE // Written narrative feedback
  CHECKLIST // Checklist of skills demonstrated
  VIDEO // Video feedback from instructor
  PEER_REVIEW // Peer-to-peer feedback
}

enum GradingStyle {
  COMPLETION // Completed or not (no judgment)
  FEEDBACK_ONLY // Narrative feedback, no score
  OPTIONAL_GRADE // Student can opt into receiving a grade
}

enum ClassSubmissionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  FEEDBACK_GIVEN
  REVISED
}

// Enjoyment-focused assignment tied to class offerings (Feature #43)
model ClassAssignment {
  id          String        @id @default(cuid())
  offeringId  String
  offering    ClassOffering @relation(fields: [offeringId], references: [id])
  createdById String
  createdBy   User          @relation("ClassAssignmentsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  title       String
  description String              @db.Text
  type        ClassAssignmentType @default(PRACTICE)

  // Enjoyment-focused options
  feedbackStyle FeedbackStyle @default(NARRATIVE)
  gradingStyle  GradingStyle  @default(FEEDBACK_ONLY)

  // Flexible deadlines
  suggestedDueDate     DateTime? // "Aim to complete by..."
  hardDeadline         DateTime? // Only if truly time-sensitive
  allowLateSubmissions Boolean   @default(true)

  // Instructions & materials
  instructions    String?  @db.Text
  referenceLinks  String[] // Links to helpful resources
  exampleWorkUrls String[] // Show examples of what good looks like
  attachmentUrl   String?

  // Group settings
  isGroupAssignment Boolean @default(false)
  groupSize         Int? // Suggested group size
  allowSelfSelect   Boolean @default(true) // Can students pick groups?

  // Encouragement
  encouragementNote String? @db.Text // Instructor message to motivate

  isPublished Boolean @default(true)
  sessionId   String? // Optionally tied to a class session

  // Rubric for grading / self-assessment
  rubricId String?
  rubric   Rubric? @relation("ClassAssignmentRubric", fields: [rubricId], references: [id])

  // Relations
  submissions ClassAssignmentSubmission[]
  groups      GroupProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId])
}

// Student submission with enjoyment metrics instead of grades
model ClassAssignmentSubmission {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   ClassAssignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      User            @relation("ClassSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  groupId      String? // If group assignment
  group        GroupProject?   @relation(fields: [groupId], references: [id])

  // Submission
  workUrl     String? // Link to work (Drive, YouTube, etc.)
  workText    String?   @db.Text // Written work or description
  submittedAt DateTime?

  status ClassSubmissionStatus @default(NOT_STARTED)

  // Instructor feedback (NOT grades)
  instructorFeedback String?   @db.Text // Detailed narrative feedback
  celebratoryNote    String?   @db.Text // "I love how you experimented!"
  suggestionsForNext String?   @db.Text // "Try adding more contrast next time"
  feedbackGivenAt    DateTime?

  // Student self-reflection
  studentReflection String?  @db.Text // "What did you learn?"
  enjoymentRating   Int? // 1-5: "How much fun did you have?"
  difficultyRating  Int? // 1-5: "How challenging was this?"
  whatWentWell      String?  @db.Text
  whatToImprove     String?  @db.Text
  wouldRecommend    Boolean? // "Would you recommend this to a classmate?"

  // Completion celebration (not perfection)
  completionBadge Boolean @default(false) // Earned just for finishing!

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
}

// Group project for collaborative assignments (Feature #69)
model GroupProject {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   ClassAssignment @relation(fields: [assignmentId], references: [id])

  groupName   String
  description String? @db.Text

  // Members
  members GroupMember[]

  // Coordination
  communicationChannel String? // "Slack", "Discord", "Group Text"
  sharedDocLinks       String[] // Links to collaborative docs

  // Milestones
  milestones GroupMilestone[]

  // Final submission
  submissions ClassAssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignmentId])
}

model GroupMember {
  id      String       @id @default(cuid())
  groupId String
  group   GroupProject @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User         @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  // Flexible roles (student-defined, not rigid)
  role     String? // e.g., "Visual Lead", "Research", "Presenter"
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupMilestone {
  id      String       @id @default(cuid())
  groupId String
  group   GroupProject @relation(fields: [groupId], references: [id], onDelete: Cascade)

  title       String
  description String?
  targetDate  DateTime?
  completedAt DateTime?
  isComplete  Boolean   @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
}

// ============================================
// PHASE 11: AI & PERSONALIZATION
// ============================================

enum LearningPathStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum PredictionType {
  LEVEL_UP
  SKILL_MASTERY
  COURSE_COMPLETION
  STREAK_MILESTONE
}

// AI-generated personalized learning roadmap (Feature #8)
model LearningPath {
  id          String @id @default(cuid())
  studentId   String
  student     User   @relation("LearningPaths", fields: [studentId], references: [id], onDelete: Cascade)
  passionArea String

  // Generation info
  generatedBy String @default("ai") // "ai", "instructor", "student"

  // Goals
  targetSkillLevel     String @default("intermediate") // beginner, intermediate, advanced, expert
  timeframeDays        Int    @default(90)
  weeklyHoursAvailable Int    @default(5)

  // Path structure
  milestones         Json     @default("[]") // [{week, goal, resources[], tasks[], isComplete}]
  recommendedClasses String[] // Class offering IDs
  recommendedModules String[] // Module IDs
  practiceGoals      Json     @default("{}") // {drawing: "30min/day", painting: "1hr 3x/week"}

  // Tracking
  status           LearningPathStatus @default(ACTIVE)
  startedAt        DateTime?
  completedAt      DateTime?
  currentMilestone Int                @default(0)
  completionPct    Float              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([passionArea])
  @@index([status])
}

// Point-in-time analytics snapshot for a student (Feature #22)
model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("AnalyticsSnapshots", fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())

  // Core metrics
  totalXP        Int @default(0)
  level          Int @default(1)
  activePassions Int @default(0)

  // Time metrics
  practiceMinutesThisWeek Int   @default(0)
  practiceMinutesLastWeek Int   @default(0)
  practiceMinutesAvg      Float @default(0)
  longestStreak           Int   @default(0)
  currentStreak           Int   @default(0)

  // Productivity patterns
  mostProductiveDay      String? // "Wednesday"
  mostProductiveHour     Int? // 16 (4 PM)
  preferredSessionLength Int? // minutes
  totalSessionsThisMonth Int     @default(0)

  // Skill progression
  skillProgressions Json @default("{}") // {area: {level, weeksAtLevel, trend}}

  // Class engagement
  classesEnrolled        Int    @default(0)
  classesCompleted       Int    @default(0)
  assignmentsCompleted   Int    @default(0)
  averageEnjoymentRating Float?

  // Weekly comparison
  xpGainedThisWeek Int @default(0)
  xpGainedLastWeek Int @default(0)

  createdAt DateTime @default(now())

  @@index([studentId, date])
  @@index([date])
}

// Progress predictions (Feature #25)
model ProgressPrediction {
  id          String  @id @default(cuid())
  studentId   String
  student     User    @relation("ProgressPredictions", fields: [studentId], references: [id], onDelete: Cascade)
  passionArea String?

  predictionType PredictionType
  title          String // "Reach Advanced level in Watercolor"
  description    String?

  // Current and target state
  currentValue Float // e.g., current XP or skill level
  targetValue  Float // e.g., target XP or skill level
  progressPct  Float @default(0) // 0-100

  // Prediction
  predictedDate DateTime
  confidence    Float    @default(0.7) // 0.0 to 1.0

  // Assumptions
  assumedWeeklyHours Float  @default(5)
  assumedPace        String @default("current") // "current", "increased", "decreased"

  // Outcome tracking
  isAchieved    Boolean   @default(false)
  achievedAt    DateTime?
  accuracyScore Float? // How accurate was the prediction (0-1)?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([predictionType])
  @@index([predictedDate])
}

// ============================================
// PHASE 12: CHALLENGES & GAMIFICATION
// ============================================

enum ChallengeType {
  DAILY
  WEEKLY
  THIRTY_DAY
  SEASONAL
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ParticipantStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum StampSource {
  TRY_IT
  CLASS
  PROJECT
  PRACTICE_HOURS
}

enum RarityTier {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum CompetitionStatus {
  UPCOMING
  NEEDS_REVISION
  OPEN_FOR_SUBMISSIONS
  JUDGING
  VOTING
  COMPLETED
}

// 30-Day Challenges, Weekly Challenges, Seasonal Challenges
model Challenge {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  type        ChallengeType

  passionArea String?

  // Timing
  startDate DateTime
  endDate   DateTime

  // Requirements
  dailyGoal          String? // "Sketch for 15 minutes"
  weeklyGoal         String? // "Complete 3 paintings"
  submissionRequired Boolean @default(false)

  // Leaderboard
  trackProgress   Boolean @default(true)
  showLeaderboard Boolean @default(true)

  // Rewards
  completionBadgeId  String?
  xpReward           Int     @default(50)
  specialRecognition String? // "Featured in newsletter"

  // Status
  status ChallengeStatus @default(DRAFT)

  // Weekly challenge specific
  promptText     String?   @db.Text // Monday prompt for weekly challenges
  votingEnabled  Boolean   @default(false)
  votingDeadline DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants ChallengeParticipant[]
  submissions  ChallengeSubmission[]

  @@index([type, status])
  @@index([startDate, endDate])
  @@index([passionArea])
}

// Challenge participant with streak tracking
model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("ChallengeParticipations", fields: [studentId], references: [id], onDelete: Cascade)

  joinedAt      DateTime @default(now())
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  daysCompleted Int      @default(0)
  totalProgress Float    @default(0) // 0.0 to 1.0

  status      ParticipantStatus @default(ACTIVE)
  completedAt DateTime?

  leaderboardRank Int?
  lastCheckIn     DateTime?

  @@unique([challengeId, studentId])
  @@index([studentId])
  @@index([challengeId, status])
  @@index([leaderboardRank])
}

// Challenge submissions (daily check-ins, weekly submissions)
model ChallengeSubmission {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("ChallengeSubmissions", fields: [studentId], references: [id], onDelete: Cascade)

  // Content
  title       String?
  description String? @db.Text
  workUrl     String? // Link to work
  mediaUrl    String? // Image/video upload

  // Check-in data
  dayNumber        Int? // Day 1-30 for 30-day challenges
  minutesPracticed Int?
  reflection       String?

  // Voting (for weekly challenges)
  voteCount Int @default(0)

  submittedAt DateTime @default(now())

  @@index([challengeId, studentId])
  @@index([challengeId, voteCount])
  @@index([submittedAt])
}

// Passion Passport - collecting stamps for exploring sub-areas
model PassionPassport {
  id          String @id @default(cuid())
  studentId   String
  student     User   @relation("PassionPassports", fields: [studentId], references: [id], onDelete: Cascade)
  passionArea String // e.g., "Art", "Music", "Writing"

  totalStamps          Int   @default(0)
  completionPercentage Float @default(0) // 0-100

  stamps PassportStamp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, passionArea])
  @@index([studentId])
}

// Individual stamps in a passion passport
model PassportStamp {
  id         String          @id @default(cuid())
  passportId String
  passport   PassionPassport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  subArea     String // e.g., "Watercolor", "Oil Painting", "Digital Art"
  description String?

  earnedAt DateTime    @default(now())
  earnedBy StampSource

  hoursLogged       Int?
  projectsCompleted Int?
  evidence          String? // URL or description of what earned the stamp

  @@unique([passportId, subArea])
  @@index([passportId])
}

// Badge rarity tracking (updated periodically)
model BadgeRarity {
  id        String @id @default(cuid())
  badgeId   String @unique
  badgeName String

  totalAwarded     Int        @default(0)
  totalStudents    Int        @default(0)
  rarityPercentage Float      @default(100) // % of students who have this badge
  rarityTier       RarityTier @default(COMMON)

  updatedAt DateTime @updatedAt

  @@index([rarityTier])
  @@index([rarityPercentage])
}

// Seasonal competitions (quarterly themed events)
model SeasonalCompetition {
  id          String  @id @default(cuid())
  season      String // "Winter 2025"
  theme       String // "Winter Landscapes"
  passionArea String?

  startDate          DateTime
  endDate            DateTime
  submissionDeadline DateTime

  rules           String @db.Text
  planningDetails Json?
  judgingCriteria Json   @default("[]") // [{name, weight, description}]

  // Judging
  judges              User[]  @relation("CompetitionJudges")
  votingEnabled       Boolean @default(false)
  communityVoteWeight Float   @default(0.3) // 30% community, 70% judges

  status CompetitionStatus @default(UPCOMING)

  // Rewards
  xpReward          Int     @default(100)
  firstPlaceReward  String?
  secondPlaceReward String?
  thirdPlaceReward  String?

  // Instructor draft ownership
  createdById String?
  createdBy   User?   @relation("CompetitionsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  // Review fields
  reviewNotes  String? @db.Text
  reviewedById String?
  reviewedBy   User?   @relation("CompetitionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  entries        CompetitionEntry[]
  votes          CompetitionVote[]
  prepMilestones CompetitionPrepMilestone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([passionArea])
  @@index([startDate, endDate])
}

// Competition entries
model CompetitionEntry {
  id            String              @id @default(cuid())
  competitionId String
  competition   SeasonalCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  studentId     String
  student       User                @relation("CompetitionEntries", fields: [studentId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  workUrl     String?
  mediaUrl    String?

  // Scoring
  judgeScore     Float? // Average of judge scores
  communityScore Float? // Average community vote
  finalScore     Float? // Weighted combination
  placement      Int? // 1st, 2nd, 3rd, etc.

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  votes CompetitionVote[]

  @@unique([competitionId, studentId])
  @@index([competitionId, finalScore])
  @@index([studentId])
}

// Community votes for competition entries
model CompetitionVote {
  id            String              @id @default(cuid())
  competitionId String
  competition   SeasonalCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  entryId       String
  entry         CompetitionEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  voterId       String
  voter         User                @relation("CompetitionVotes", fields: [voterId], references: [id], onDelete: Cascade)

  score   Int // 1-5 stars
  comment String?

  votedAt DateTime @default(now())

  @@unique([entryId, voterId])
  @@index([competitionId])
  @@index([entryId])
}

// ============================================
// PHASE 2 ENGAGEMENT: STUDENT CONTENT SHOWCASE (#24)
// ============================================

enum ContentType {
  VIDEO
  ARTICLE
  PROJECT
  TUTORIAL
  ART
  MUSIC
  CODE
  OTHER
}

enum ContentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  FEATURED
  REJECTED
}

model StudentContent {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation("StudentContents", fields: [studentId], references: [id], onDelete: Cascade)

  title        String
  description  String?     @db.Text
  contentType  ContentType
  mediaUrl     String? // Link to uploaded content
  thumbnailUrl String?
  passionArea  String?

  // Moderation & status
  status       ContentStatus @default(DRAFT)
  reviewedById String?
  reviewNote   String?

  // Engagement
  viewCount  Int       @default(0)
  likeCount  Int       @default(0)
  isFeatured Boolean   @default(false)
  featuredAt DateTime?

  // Rewards
  xpAwarded Int @default(0)

  likes    ContentLike[]
  comments ContentComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([contentType])
  @@index([passionArea])
  @@index([isFeatured])
}

model ContentLike {
  id        String         @id @default(cuid())
  contentId String
  content   StudentContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation("ContentLikes", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([contentId, userId])
  @@index([userId])
}

model ContentComment {
  id        String         @id @default(cuid())
  contentId String
  content   StudentContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation("ContentComments", fields: [authorId], references: [id], onDelete: Cascade)

  text      String
  createdAt DateTime @default(now())

  @@index([contentId])
  @@index([authorId])
}

// ============================================
// PHASE 2 ENGAGEMENT: RANDOM ACTS OF LEARNING (#26)
// ============================================

model RandomReward {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("RandomRewards", fields: [userId], references: [id], onDelete: Cascade)

  rewardType  String // "BONUS_XP", "SURPRISE_BADGE", "STREAK_SHIELD", "DOUBLE_XP"
  title       String
  description String?
  xpAmount    Int     @default(0)
  badgeId     String? // If reward is a badge

  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRedeemed])
}

// ============================================
// PHASE 2 ENGAGEMENT: LEADERBOARDS (#29)
// ============================================

enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

model LeaderboardEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("LeaderboardEntries", fields: [userId], references: [id], onDelete: Cascade)

  category    String // "XP", "STREAKS", "CHALLENGES", "PRACTICE_HOURS", "CONTENT_CREATED"
  period      LeaderboardPeriod
  periodStart DateTime // Start of the period window
  score       Float             @default(0)
  rank        Int?
  passionArea String? // null = global, otherwise passion-specific

  updatedAt DateTime @updatedAt

  @@unique([userId, category, period, periodStart, passionArea])
  @@index([category, period, periodStart])
  @@index([category, period, score])
  @@index([userId])
}

// ============================================
// PHASE 2 ENGAGEMENT: MYSTERY REWARDS (#30)
// ============================================

model MysteryBox {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("MysteryBoxes", fields: [userId], references: [id], onDelete: Cascade)

  // Trigger
  triggerType   String // "STREAK_MILESTONE", "LEVEL_UP", "CHALLENGE_COMPLETE", "RANDOM_DROP"
  triggerDetail String? // e.g. "7_day_streak", "level_5"

  // Reward inside
  rewardType        String // "XP_BOOST", "RARE_BADGE", "TITLE", "THEME_UNLOCK", "STREAK_SHIELD"
  rewardTitle       String
  rewardDescription String?
  xpAmount          Int     @default(0)
  badgeId           String?
  metadata          Json? // Extra reward data

  // State
  isOpened  Boolean   @default(false)
  openedAt  DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isOpened])
}

// ============================================
// PHASE 2 ENGAGEMENT: STUDENT-NOMINATED CHALLENGES (#31)
// ============================================

enum NominationStatus {
  PENDING
  APPROVED
  REJECTED
  PROMOTED // Promoted to official challenge
}

model StudentNominatedChallenge {
  id          String @id @default(cuid())
  nominatorId String
  nominator   User   @relation("ChallengesNominated", fields: [nominatorId], references: [id], onDelete: Cascade)

  title             String
  description       String  @db.Text
  category          String? // Passion area
  difficulty        String  @default("MEDIUM") // EASY, MEDIUM, HARD
  suggestedXp       Int     @default(25)
  suggestedDuration String? // "1 day", "1 week"

  // Voting by community
  upvotes   Int @default(0)
  downvotes Int @default(0)

  // Status
  status              NominationStatus @default(PENDING)
  reviewedById        String?
  reviewNote          String?
  promotedChallengeId String? // ID of created Challenge if promoted

  votes NominationVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nominatorId])
  @@index([status])
  @@index([upvotes])
}

model NominationVote {
  id           String                    @id @default(cuid())
  nominationId String
  nomination   StudentNominatedChallenge @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  userId       String
  user         User                      @relation("NominationVotes", fields: [userId], references: [id], onDelete: Cascade)

  isUpvote Boolean

  createdAt DateTime @default(now())

  @@unique([nominationId, userId])
  @@index([userId])
}

// ============================================
// PASSION PROJECT INCUBATOR (Feature #35)
// ============================================

enum IncubatorPhase {
  IDEATION // Brainstorm, research, define the project
  PLANNING // Set milestones, gather resources, find mentor
  BUILDING // Active work on the project
  FEEDBACK // Submit for peer/mentor feedback rounds
  POLISHING // Refine based on feedback
  SHOWCASE // Present / pitch the final project
}

enum IncubatorCohortStatus {
  DRAFT
  ACCEPTING_APPLICATIONS
  IN_PROGRESS
  SHOWCASE_PHASE
  COMPLETED
  ARCHIVED
}

enum IncubatorAppStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  WAITLISTED
  REJECTED
  WITHDRAWN
}

enum IncubatorMilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
}

enum IncubatorLaunchStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// A cohort / batch of the incubator program
model IncubatorCohort {
  id          String  @id @default(cuid())
  name        String // e.g. "Spring 2026 Cohort"
  description String? @db.Text
  season      String? // FALL, WINTER, SPRING, SUMMER
  year        Int

  // Timing
  applicationOpen  DateTime?
  applicationClose DateTime?
  startDate        DateTime
  endDate          DateTime
  showcaseDate     DateTime?

  // Config
  maxProjects    Int                   @default(20)
  passionAreas   String[] // Legacy values kept for compatibility
  passionAreaIds String[]              @default([]) // Canonical PassionArea IDs
  status         IncubatorCohortStatus @default(DRAFT)

  // Relations
  applications       IncubatorApplication[]
  projects           IncubatorProject[]
  mentorAssignments  IncubatorMentor[]
  milestoneTemplates IncubatorMilestoneTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([year, season])
}

// Student application to join an incubator cohort
model IncubatorApplication {
  id        String          @id @default(cuid())
  cohortId  String
  cohort    IncubatorCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  studentId String
  student   User            @relation("IncubatorApplications", fields: [studentId], references: [id], onDelete: Cascade)

  // Application content
  projectTitle     String
  projectIdea      String  @db.Text // What do you want to build?
  passionArea      String // Legacy label kept for compatibility
  passionId        String?
  whyThisProject   String  @db.Text // Why does this matter to you?
  priorExperience  String? @db.Text // What have you done so far?
  goals            String  @db.Text // What do you hope to achieve?
  needsMentor      Boolean @default(true)
  mentorPreference String? // What kind of mentor help?

  // Review
  status          IncubatorAppStatus @default(SUBMITTED)
  reviewedById    String?
  reviewedBy      User?              @relation("IncubatorApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote      String?
  reviewRubric    Json?
  reviewedAt      DateTime?
  acceptedProject IncubatorProject?  @relation("IncubatorAcceptedFrom")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@unique([cohortId, studentId])
  @@index([studentId])
  @@index([status])
  @@index([passionId])
  @@index([reviewedById])
  @@index([archivedAt])
}

// An active project within the incubator (wraps ProjectTracker with incubator context)
model IncubatorProject {
  id               String                @id @default(cuid())
  cohortId         String
  cohort           IncubatorCohort       @relation(fields: [cohortId], references: [id])
  studentId        String
  student          User                  @relation("IncubatorProjects", fields: [studentId], references: [id], onDelete: Cascade)
  projectTrackerId String? // Links to existing ProjectTracker
  applicationId    String?               @unique
  application      IncubatorApplication? @relation("IncubatorAcceptedFrom", fields: [applicationId], references: [id], onDelete: SetNull)

  // Project info
  title            String
  description      String         @db.Text
  passionArea      String // Legacy label kept for compatibility
  passionId        String?
  currentPhase     IncubatorPhase @default(IDEATION)
  mentorRequired   Boolean        @default(true)
  mentorAssignedAt DateTime?

  // Progress tracking
  ideationComplete  Boolean @default(false)
  planningComplete  Boolean @default(false)
  buildingComplete  Boolean @default(false)
  feedbackComplete  Boolean @default(false)
  polishingComplete Boolean @default(false)
  showcaseComplete  Boolean @default(false)

  // Pitch / Showcase
  pitchVideoUrl      String?
  pitchDeckUrl       String?
  finalShowcaseUrl   String?
  pitchDate          DateTime?
  launchStatus       IncubatorLaunchStatus @default(DRAFT)
  publicSlug         String?               @unique
  launchTitle        String?
  launchTagline      String?
  launchSummary      String?               @db.Text
  problemStatement   String?               @db.Text
  solutionSummary    String?               @db.Text
  targetAudience     String?
  buildHighlights    String[]              @default([])
  launchGalleryUrls  String[]              @default([])
  demoUrl            String?
  repositoryUrl      String?
  waitlistUrl        String?
  launchSubmittedAt  DateTime?
  launchApprovedAt   DateTime?
  launchApprovedById String?
  launchApprovedBy   User?                 @relation("IncubatorLaunchApprovedBy", fields: [launchApprovedById], references: [id], onDelete: SetNull)

  // XP
  xpEarned Int @default(0)

  // Relations
  mentors       IncubatorMentor[]
  updates       IncubatorUpdate[]
  milestones    IncubatorMilestone[]
  pitchFeedback PitchFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cohortId, studentId])
  @@index([cohortId])
  @@index([studentId])
  @@index([currentPhase])
  @@index([passionId])
  @@index([launchStatus])
  @@index([launchApprovedById])
}

model IncubatorMilestoneTemplate {
  id                     String               @id @default(cuid())
  cohortId               String
  cohort                 IncubatorCohort      @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  phase                  IncubatorPhase
  title                  String
  description            String?              @db.Text
  deliverableLabel       String?
  dueDayOffset           Int?
  order                  Int
  requiresMentorApproval Boolean              @default(false)
  requiredForPhase       Boolean              @default(true)
  milestones             IncubatorMilestone[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([cohortId, phase, order])
}

model IncubatorMilestone {
  id                     String                      @id @default(cuid())
  projectId              String
  project                IncubatorProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId             String?
  template               IncubatorMilestoneTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  phase                  IncubatorPhase
  title                  String
  description            String?                     @db.Text
  deliverableLabel       String?
  order                  Int
  dueDate                DateTime?
  requiresMentorApproval Boolean                     @default(false)
  requiredForPhase       Boolean                     @default(true)
  status                 IncubatorMilestoneStatus    @default(NOT_STARTED)
  submissionNote         String?                     @db.Text
  artifactUrls           String[]                    @default([])
  submittedAt            DateTime?
  approvedAt             DateTime?
  approvedById           String?
  approvedBy             User?                       @relation("IncubatorMilestonesApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  completedAt            DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@index([projectId, phase, order])
  @@index([status])
  @@index([approvedById])
}

// Mentor assignment for incubator projects
model IncubatorMentor {
  id        String           @id @default(cuid())
  cohortId  String
  cohort    IncubatorCohort  @relation(fields: [cohortId], references: [id])
  projectId String
  project   IncubatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentorId  String
  mentor    User             @relation("IncubatorMentoring", fields: [mentorId], references: [id], onDelete: Cascade)

  role     String  @default("MENTOR") // MENTOR, ADVISOR, PEER_MENTOR
  notes    String?
  isActive Boolean @default(true)

  assignedAt DateTime @default(now())

  @@unique([projectId, mentorId])
  @@index([mentorId])
  @@index([cohortId])
}

// Progress updates / check-ins posted by students
model IncubatorUpdate {
  id        String           @id @default(cuid())
  projectId String
  project   IncubatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User             @relation("IncubatorUpdates", fields: [authorId], references: [id], onDelete: Cascade)

  title      String
  content    String         @db.Text
  phase      IncubatorPhase // Which phase this update is for
  mediaUrls  String[]
  hoursSpent Float?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

// Feedback on pitches / showcases
model PitchFeedback {
  id         String           @id @default(cuid())
  projectId  String
  project    IncubatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User             @relation("PitchFeedbackGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  // Scoring (1-5)
  clarityScore   Int? // How clear is the project vision?
  passionScore   Int? // How passionate is the student?
  executionScore Int? // How well did they execute?
  impactScore    Int? // What's the potential impact?
  overallScore   Int?

  strengths     String? @db.Text
  improvements  String? @db.Text
  encouragement String? @db.Text

  createdAt DateTime @default(now())

  @@unique([projectId, reviewerId])
  @@index([projectId])
  @@index([reviewerId])
}

// ============================================
// PHASE 13: REAL-WORLD CONNECTIONS
// ============================================

enum InternshipType {
  IN_PERSON
  REMOTE
  HYBRID
}

enum InternshipStatus {
  OPEN
  CLOSED
  FILLED
}

enum ApplicationState {
  APPLIED
  REVIEWING
  INTERVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ServiceProjectStatus {
  RECRUITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CertificationStatus {
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  CERTIFIED
  EXPIRED
}

enum ExchangeListingType {
  OFFER
  REQUEST
}

enum ExchangeListingStatus {
  AVAILABLE
  PENDING
  CLAIMED
  COMPLETED
}

// Portfolio Templates
model PortfolioTemplate {
  id              String  @id @default(cuid())
  name            String
  description     String
  passionArea     String? // null = general template
  previewImageUrl String?

  // Template structure
  layout      String @default("grid") // "grid", "timeline", "showcase", "minimal"
  colorScheme String @default("default") // "default", "dark", "warm", "cool", "vibrant"
  sections    Json   @default("[]") // [{title, type, placeholder, order}]

  // Tips for this template
  tips Json @default("[]") // ["Tip 1", "Tip 2"]

  isActive   Boolean @default(true)
  order      Int     @default(0)
  usageCount Int     @default(0)

  createdAt DateTime @default(now())

  @@index([passionArea])
  @@index([isActive, order])
}

// Internship / Opportunity Board
model InternshipListing {
  id           String  @id @default(cuid())
  title        String
  organization String
  description  String  @db.Text
  passionArea  String?

  type         InternshipType
  location     String? // City, State or "Remote"
  duration     String? // "6 weeks", "Summer 2025"
  hoursPerWeek Int?
  isPaid       Boolean        @default(false)
  compensation String? // "$15/hr", "Stipend"

  // Requirements
  ageRange       String? // "14-18"
  requirements   Json    @default("[]") // ["Portfolio required", "Interview"]
  applicationUrl String? // External link

  // Contact
  contactName  String?
  contactEmail String?

  status   InternshipStatus @default(OPEN)
  deadline DateTime?

  postedById String
  postedBy   User   @relation("InternshipListingsPosted", fields: [postedById], references: [id], onDelete: Cascade)

  applications InternshipApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([passionArea])
  @@index([type])
  @@index([deadline])
}

model InternshipApplication {
  id        String            @id @default(cuid())
  listingId String
  listing   InternshipListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  studentId String
  student   User              @relation("InternshipApplications", fields: [studentId], references: [id], onDelete: Cascade)

  coverLetter  String? @db.Text
  portfolioUrl String?
  resumeUrl    String?

  status      ApplicationState @default(APPLIED)
  reviewNotes String?

  appliedAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@unique([listingId, studentId])
  @@index([studentId])
  @@index([status])
  @@index([archivedAt])
}

// Service Projects (Community Impact)
model ServiceProject {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  passionArea String?

  // Organization
  partnerOrg String? // "Local Library", "Habitat for Humanity"
  location   String?
  chapterId  String?

  // Timing
  startDate      DateTime?
  endDate        DateTime?
  totalHoursGoal Int? // Target volunteer hours

  // Impact tracking
  currentHours     Int     @default(0)
  volunteersNeeded Int     @default(5)
  impactSummary    String? @db.Text

  // Rewards
  xpReward              Int     @default(50)
  certificateOnComplete Boolean @default(false)

  status ServiceProjectStatus @default(RECRUITING)

  createdById String
  createdBy   User   @relation("ServiceProjectsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  volunteers ServiceVolunteer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([passionArea])
  @@index([chapterId])
}

model ServiceVolunteer {
  id        String         @id @default(cuid())
  projectId String
  project   ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studentId String
  student   User           @relation("ServiceVolunteering", fields: [studentId], references: [id], onDelete: Cascade)

  hoursLogged Int       @default(0)
  role        String? // "Team Lead", "Volunteer", "Coordinator"
  reflection  String?   @db.Text
  completedAt DateTime?

  joinedAt DateTime @default(now())

  @@unique([projectId, studentId])
  @@index([studentId])
}

// Instructor Certifications
model InstructorCertification {
  id           String @id @default(cuid())
  instructorId String
  instructor   User   @relation("InstructorCertifications", fields: [instructorId], references: [id], onDelete: Cascade)

  certType    String // "Foundational", "Advanced", "Specialist"
  passionArea String?

  // Requirements tracking
  requirements   Json  @default("[]") // [{name, completed, evidence}]
  totalRequired  Int   @default(5)
  totalCompleted Int   @default(0)
  progressPct    Float @default(0)

  // Submission & Review
  status         CertificationStatus @default(IN_PROGRESS)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewerNotes  String?
  certificateUrl String?

  // Validity
  certifiedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instructorId, certType, passionArea])
  @@index([instructorId])
  @@index([status])
}

// Resource Exchange (Peer-to-Peer)
model ResourceExchangeListing {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("ResourceExchangeListings", fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        ExchangeListingType // OFFER or REQUEST
  category    String // "Instrument", "Art Supplies", "Books", "Equipment", "Software"
  passionArea String?
  imageUrl    String?

  condition      String? // "New", "Like New", "Good", "Fair"
  estimatedValue Float?

  status ExchangeListingStatus @default(AVAILABLE)

  requests ResourceExchangeRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([category])
  @@index([passionArea])
  @@index([userId])
}

model ResourceExchangeRequest {
  id          String                  @id @default(cuid())
  listingId   String
  listing     ResourceExchangeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                    @relation("ResourceExchangeRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  message String?
  status  String  @default("PENDING") // PENDING, ACCEPTED, DECLINED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, requesterId])
  @@index([requesterId])
}

// ============================================
// PATHWAY INTEGRATION MODELS
// ============================================

/// Cohort of students progressing through a pathway together
model PathwayCohort {
  id        String         @id @default(cuid())
  pathwayId String
  pathway   Pathway        @relation("PathwayCohorts", fields: [pathwayId], references: [id])
  name      String // e.g. "Spring 2026 Cohort"
  startDate DateTime?
  endDate   DateTime?
  members   CohortMember[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([pathwayId])
}

/// Membership of a user in a pathway cohort
model CohortMember {
  id       String        @id @default(cuid())
  cohortId String
  cohort   PathwayCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation("PathwayCohortMemberships", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime      @default(now())

  @@unique([cohortId, userId])
  @@index([userId])
}

/// Student reflection written after completing a pathway step
model PathwayReflection {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("PathwayReflections", fields: [userId], references: [id], onDelete: Cascade)
  pathwayId       String
  pathway         Pathway  @relation("PathwayReflections", fields: [pathwayId], references: [id])
  stepOrder       Int // which step this reflection is for
  content         String // the reflection text
  visibleToMentor Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([userId, pathwayId])
}

/// Milestone event tied to a pathway step (e.g. workshops, showcases)
model PathwayEvent {
  id                String                     @id @default(cuid())
  pathwayId         String
  pathway           Pathway                    @relation("PathwayEvents", fields: [pathwayId], references: [id])
  chapterId         String?
  chapter           Chapter?                   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  pathwayStepId     String?
  pathwayStep       PathwayStep?               @relation(fields: [pathwayStepId], references: [id], onDelete: SetNull)
  title             String
  description       String?
  eventDate         DateTime?
  locationOrLink    String?
  maxAttendees      Int?
  requiredStepOrder Int? // student must have reached this step to register
  registrations     PathwayEventRegistration[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([pathwayId])
  @@index([chapterId])
  @@index([pathwayStepId])
}

/// Student registration for a pathway event
model PathwayEventRegistration {
  id           String       @id @default(cuid())
  eventId      String
  event        PathwayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String
  registeredAt DateTime     @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

/// Instructor specialization in a pathway (for mentor matching)
model InstructorPathwaySpec {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("InstructorPathwaySpecs", fields: [userId], references: [id], onDelete: Cascade)
  pathwayId String
  pathway   Pathway  @relation("PathwayInstructorSpecs", fields: [pathwayId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, pathwayId])
  @@index([pathwayId])
}

/// Chapter-level control over which pathways are visible and featured
model ChapterPathway {
  id           String                  @id @default(cuid())
  chapterId    String
  chapter      Chapter                 @relation(fields: [chapterId], references: [id])
  pathwayId    String
  pathway      Pathway                 @relation("PathwayChapterConfigs", fields: [pathwayId], references: [id])
  isAvailable  Boolean                 @default(true) // chapter can hide a global pathway
  isFeatured   Boolean                 @default(false) // featured pathways appear first
  runStatus    ChapterPathwayRunStatus @default(NOT_OFFERED)
  ownerId      String?
  owner        User?                   @relation("ChapterPathwayOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  displayOrder Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([chapterId, pathwayId])
  @@index([chapterId])
}

model PathwayFallbackRequest {
  id               String                       @id @default(cuid())
  studentId        String
  student          User                         @relation("PathwayFallbackRequestStudent", fields: [studentId], references: [id], onDelete: Cascade)
  pathwayId        String
  pathway          Pathway                      @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  pathwayStepId    String
  pathwayStep      PathwayStep                  @relation(fields: [pathwayStepId], references: [id], onDelete: Cascade)
  fromChapterId    String?
  fromChapter      Chapter?                     @relation("PathwayFallbackFromChapter", fields: [fromChapterId], references: [id], onDelete: SetNull)
  toChapterId      String?
  toChapter        Chapter?                     @relation("PathwayFallbackToChapter", fields: [toChapterId], references: [id], onDelete: SetNull)
  targetOfferingId String?
  targetOffering   ClassOffering?               @relation(fields: [targetOfferingId], references: [id], onDelete: SetNull)
  status           PathwayFallbackRequestStatus @default(PENDING)
  note             String?
  reviewedById     String?
  reviewedBy       User?                        @relation("PathwayFallbackReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([studentId])
  @@index([pathwayId])
  @@index([pathwayStepId])
  @@index([targetOfferingId])
  @@index([status])
}

// ============================================
// MENTORSHIP PROGRAM MODELS
// ============================================

/// A goal defined for a specific YPP mentee role, authored by the Mentor Committee.
/// Used as the basis for both self-reflections and goal reviews.
model MentorshipProgramGoal {
  id          String         @id @default(cuid())
  title       String
  description String?
  roleType    MenteeRoleType
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdById String
  createdBy   User           @relation("MentorshipProgramGoalsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  selfReflectionGoalResponses SelfReflectionGoalResponse[]
  goalReviewRatings           GoalReviewRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleType])
}

/// Monthly self-reflection submitted by a mentee (Instructor / CP / Global Leadership).
/// Covers 5 sections from the document. Per-goal responses stored in SelfReflectionGoalResponse.
model MonthlySelfReflection {
  id           String     @id @default(cuid())
  menteeId     String
  mentee       User       @relation("SelfReflectionsSubmitted", fields: [menteeId], references: [id], onDelete: Cascade)
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])

  /// First day of the month this reflection covers
  cycleMonth  DateTime
  /// Sequential cycle number (1, 2, 3…); multiples of 3 are quarterly cycles
  cycleNumber Int

  // Section 1 — Overall Reflection
  overallReflection String

  // Section 2 — Engagement & Fulfillment
  engagementOverall String
  workingWell       String
  supportNeeded     String
  mentorHelpfulness String

  // Section 3 — Leadership Team Collaboration
  collaborationAssessment   String
  teamMembersAboveAndBeyond String?
  collaborationImprovements String?

  // Section 4 — Goal Progress (per-goal responses below)
  goalResponses SelfReflectionGoalResponse[]

  // Section 5 — Additional Reflections
  additionalReflections String?

  submittedAt DateTime @default(now())

  goalReview     MentorGoalReview?
  peopleCheckIns CheckIn[]         @relation("CheckInSelfReflection")

  @@unique([mentorshipId, cycleNumber])
  @@index([menteeId])
  @@index([mentorshipId])
}

/// Per-goal answers within a monthly self-reflection (Section 4).
model SelfReflectionGoalResponse {
  id           String                @id @default(cuid())
  reflectionId String
  reflection   MonthlySelfReflection @relation(fields: [reflectionId], references: [id])
  goalId       String
  goal         MentorshipProgramGoal @relation(fields: [goalId], references: [id])

  progressMade      String
  objectiveAchieved Boolean
  accomplishments   String
  blockers          String?
  nextMonthPlans    String

  createdAt DateTime @default(now())

  @@unique([reflectionId, goalId])
}

/// Mentor's monthly goal review of a mentee, submitted for Mentor Committee Chair approval
/// before being released to the mentee.
model MentorGoalReview {
  id           String     @id @default(cuid())
  mentorId     String
  mentor       User       @relation("GoalReviewsAuthored", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId     String
  mentee       User       @relation("GoalReviewsReceived", fields: [menteeId], references: [id], onDelete: Cascade)
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])

  selfReflectionId String                @unique
  selfReflection   MonthlySelfReflection @relation(fields: [selfReflectionId], references: [id])

  /// First day of the month this review covers
  cycleMonth  DateTime
  /// Matches the self-reflection cycleNumber; divisible by 3 → quarterly review
  cycleNumber Int
  isQuarterly Boolean  @default(false)

  // Overall rating — drives automatic point calculation on approval
  overallRating GoalRatingColor

  /// Which GRTemplate.version was current when this review was submitted —
  /// makes the released review self-describing forever, independent of later
  /// template edits (pairs with GRTemplateVersion's existing snapshot).
  templateVersion Int?
  /// Which rubric column/level (e.g. "Senior Instructor", or one of the
  /// Global Leadership columns) was used for this review, resolved by
  /// columnForAuthority() and snapshotted here so a later promotion never
  /// rewrites how a past review reads.
  columnLabel     String?

  // Per-goal ratings
  goalRatings GoalReviewRating[]

  // Required written sections
  overallComments String // Overall impression, strengths, dev areas, peer collab notes
  planOfAction    String // High-level objectives & action items for next month

  // Quarterly-only fields (unlocked every 3rd cycle; filled by full Mentor Committee)
  projectedFuturePath String?
  promotionReadiness  String?

  // Approval workflow
  status             GoalReviewStatus @default(DRAFT)
  chairReviewerId    String?
  chairReviewer      User?            @relation("GoalReviewsChairApproved", fields: [chairReviewerId], references: [id], onDelete: SetNull)
  chairComments      String?
  chairApprovedAt    DateTime?
  releasedToMenteeAt DateTime?

  // Character & Culture bonus points (mentor awards 0–25, chair can adjust)
  bonusPoints              Int     @default(0)
  bonusReason              String?
  chairAdjustedBonusPoints Int?

  // Points awarded (auto-set on chair approval based on overallRating × roleType table)
  pointsAwarded Int?

  pointLog         AchievementPointLog?
  feedbackRequests QuarterlyFeedbackRequest[] @relation("FeedbackRequests")

  /// True if the mentor used an AI-generated draft as a starting point for any comment field.
  aiDraftUsed Boolean @default(false)

  // G&R integration
  goalSnapshots  MentorGoalReviewGoalSnapshot[]
  spawnedGRGoals GRDocumentGoal[]               @relation("GRGoalsSpawnedByReview")
  reviewAck      MenteeReviewAck?
  peopleCheckIns CheckIn[]                      @relation("CheckInMentorGoalReview")
  /// Follow-up commitments created from this review's outcomes.
  followUpActionItems MentorshipActionItem[]    @relation("ActionItemsFromReview")

  /// Draft next-month goal proposals persisted between form saves. Cleared on submit.
  nextMonthGoalDraftsJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menteeId])
  @@index([mentorId])
  @@index([mentorshipId])
}

/// Per-goal color rating within a mentor goal review.
model GoalReviewRating {
  id               String                 @id @default(cuid())
  reviewId         String
  review           MentorGoalReview       @relation(fields: [reviewId], references: [id])
  /// Legacy: rating against the flat MentorshipProgramGoal list. Kept as fallback
  /// for reviews where the mentee had no active G&R document. Prefer grDocumentGoalId.
  goalId           String?
  goal             MentorshipProgramGoal? @relation(fields: [goalId], references: [id])
  /// Preferred: rating against the mentee's actual per-person G&R goal.
  grDocumentGoalId String?
  grDocumentGoal   GRDocumentGoal?        @relation(fields: [grDocumentGoalId], references: [id])

  rating   GoalRatingColor
  comments String?

  /// Proposed goal progress/lifecycle update, captured at submit time but
  /// applied to the live GRDocumentGoal only on chair approval/release (see
  /// approveGoalReview()) — the draft/pending review must never mutate the
  /// person's current G&R before it's approved.
  proposedProgressState   GoalProgressState?
  proposedLifecycleStatus GoalLifecycleStatus?

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([grDocumentGoalId])
}

/// Running achievement point total and current award tier per user.
/// One record per user; updated automatically when a goal review is approved.
model AchievementPointSummary {
  id                    String                @id @default(cuid())
  userId                String                @unique
  user                  User                  @relation("AchievementPointSummary", fields: [userId], references: [id], onDelete: Cascade)
  totalPoints           Int                   @default(0)
  currentTier           AchievementAwardTier?
  volunteerHoursAwarded Int                   @default(0)

  pointLogs   AchievementPointLog[]
  nominations AwardNomination[]

  updatedAt DateTime @updatedAt
}

/// One entry per approved goal review cycle recording points earned.
model AchievementPointLog {
  id        String                  @id @default(cuid())
  summaryId String
  summary   AchievementPointSummary @relation(fields: [summaryId], references: [id])
  reviewId  String                  @unique
  review    MentorGoalReview        @relation(fields: [reviewId], references: [id])

  points     Int
  /// Human-readable reason e.g. "Achieved (Green) – Instructor" or "Character & Culture bonus"
  reason     String?
  cycleMonth DateTime

  createdAt DateTime @default(now())

  @@index([summaryId])
}

/// Nomination for a YPP Achievement Award (Bronze → Lifetime).
/// Gold and Lifetime require Board approval in addition to Chair approval.
model AwardNomination {
  id          String                  @id @default(cuid())
  summaryId   String
  summary     AchievementPointSummary @relation(fields: [summaryId], references: [id])
  nomineeId   String
  nominee     User                    @relation("AwardNominations", fields: [nomineeId], references: [id], onDelete: Cascade)
  nominatedBy String
  nominator   User                    @relation("AwardNominationsGiven", fields: [nominatedBy], references: [id], onDelete: Cascade)

  tier   AchievementAwardTier
  status AwardNominationStatus @default(PENDING_CHAIR)

  chairApproverId String?
  chairApprover   User?     @relation("AwardNominationsChairApproved", fields: [chairApproverId], references: [id], onDelete: SetNull)
  chairApprovedAt DateTime?

  boardApproverId String?
  boardApprover   User?     @relation("AwardNominationsBoardApproved", fields: [boardApproverId], references: [id], onDelete: SetNull)
  boardApprovedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nomineeId])
}

/// The four named Role Committees from the Mentorship Process Overview —
/// Officers and Global Directors/Managers are today both roleType
/// GLOBAL_LEADERSHIP (shared points/rubric — see MenteeRoleType), but the
/// source document gives them distinct chairs and rosters. `lane` is that
/// orthogonal committee-identity dimension: it does NOT affect review
/// approval routing (still governed by `roleType`, unchanged, 3 buckets) —
/// it only distinguishes which named committee a chair leads / a member
/// sits on. Nullable because existing GLOBAL_LEADERSHIP chairs need an
/// admin to explicitly pick OFFICER vs GLOBAL_DIRECTOR_MANAGER; guessing
/// from title would silently misassign committee governance.
enum MentorCommitteeLane {
  OFFICER
  GLOBAL_DIRECTOR_MANAGER
  CHAPTER_PRESIDENT
  INSTRUCTOR
}

/// Designates which user is the Mentor Committee Chair for a given mentee role group.
/// Chairs approve goal reviews and award nominations for their role group.
model MentorCommitteeChair {
  id       String         @id @default(cuid())
  userId   String
  user     User           @relation("MentorCommitteeChairRoles", fields: [userId], references: [id], onDelete: Cascade)
  roleType MenteeRoleType
  /// The named committee this chair leads (see MentorCommitteeLane doc comment).
  lane     MentorCommitteeLane?
  isActive Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleType])
  @@unique([userId, lane])
  @@index([roleType])
  @@index([lane])
}


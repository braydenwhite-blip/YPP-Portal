  monthlyGoalReviewsChaired              MonthlyGoalReview[]             @relation("MonthlyGoalReviewChairs")
  achievementPointEntries                AchievementPointLedger[]        @relation("AchievementPointEntries")
  achievementPointApprovals              AchievementPointLedger[]        @relation("AchievementPointApprovals")
  quarterlyCommitteeReviews              QuarterlyCommitteeReview[]      @relation("QuarterlyReviewMentees")
  quarterlyCommitteeReviewsAuthored      QuarterlyCommitteeReview[]      @relation("QuarterlyReviewAuthors")
  mentorshipAwardRecommendationsReceived MentorshipAwardRecommendation[] @relation("MentorshipAwardRecommendationRecipients")
  mentorshipAwardRecommendationsMade     MentorshipAwardRecommendation[] @relation("MentorshipAwardRecommendationAuthors")
  mentorshipAwardRecommendationsApproved MentorshipAwardRecommendation[] @relation("MentorshipAwardRecommendationApprovers")
  promotionRecommendationsReceived       PromotionRecommendation[]       @relation("PromotionRecommendationRecipients")
  promotionRecommendationsMade           PromotionRecommendation[]       @relation("PromotionRecommendationAuthors")
  promotionRecommendationsApproved       PromotionRecommendation[]       @relation("PromotionRecommendationApprovers")
  specialProgramsLed                     SpecialProgram[]                @relation("ProgramsLed")
  specialProgramEnrollments              SpecialProgramEnrollment[]
  alumniProfile                          AlumniProfile?
  collegeAdvisor                         CollegeAdvisor?
  collegeAdviseeships                    CollegeAdvisorship[]            @relation("CollegeAdviseeships")
  profile                                UserProfile?

  // Video, Calendar, Parent, Certificate, Analytics relations
  videoProgress                   VideoProgress[]
  eventRsvps                      EventRsvp[]
  parentLinks                     ParentStudent[]               @relation("ParentLinks")
  studentLinks                    ParentStudent[]               @relation("StudentLinks")
  parentStudentIntakeCases        StudentIntakeCase[]           @relation("ParentStudentIntakeCases")

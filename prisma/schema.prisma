// Individual sessions within a workshop series
model WorkshopSession {
  id            String         @id @default(cuid())
  seriesId      String
  series        WorkshopSeries @relation(fields: [seriesId], references: [id])
  sessionNumber Int
  title         String
  description   String?
  videoUrl      String
  duration      Int // minutes
  resources     String[]
  assignments   String?
  quizData      Json? // Optional quiz/assessment
  order         Int
  createdAt     DateTime       @default(now())

  @@index([seriesId, sessionNumber])
}

// Student enrollment and progress in workshops
model WorkshopEnrollment {
  id                String         @id @default(cuid())
  studentId         String
  student           User           @relation("WorkshopEnrollments", fields: [studentId], references: [id])
  seriesId          String
  series            WorkshopSeries @relation(fields: [seriesId], references: [id])
  enrolledAt        DateTime       @default(now())
  lastAccessedAt    DateTime       @default(now())
  progress          Json // Track completed sessions, quiz scores
  completedSessions Int            @default(0)
  isCompleted       Boolean        @default(false)
  completedAt       DateTime?
  certificateEarned Boolean        @default(false)
  rating            Int? // 1-5 stars
  feedback          String?

  @@unique([studentId, seriesId])
  @@index([studentId])
  @@index([seriesId])
}

// Passion-specific certifications
model PassionCertification {
  id                     String     @id @default(cuid())
  passionId              String
  name                   String
  description            String
  level                  SkillLevel
  requirements           Json // What's needed to earn it
  badgeImageUrl          String?
  certificateTemplateUrl String?
  xpReward               Int        @default(0)
  isActive               Boolean    @default(true)
  order                  Int        @default(0)
  createdAt              DateTime   @default(now())

  studentCertifications StudentCertification[]

  @@index([passionId])
  @@index([level])
  @@index([isActive])
}

// Student's earned certifications
model StudentCertification {
  id               String               @id @default(cuid())
  studentId        String
  student          User                 @relation("EarnedCertifications", fields: [studentId], references: [id])
  certificationId  String
  certification    PassionCertification @relation(fields: [certificationId], references: [id])
  earnedAt         DateTime             @default(now())
  certificateUrl   String? // PDF/image URL
  verificationCode String               @unique @default(cuid())
  isPublic         Boolean              @default(true)
  isPinned         Boolean              @default(false)

  @@unique([studentId, certificationId])
  @@index([studentId])
  @@index([earnedAt])
}

// Project tracker - Long-term projects
model ProjectTracker {
  id            String                 @id @default(cuid())
  studentId     String
  student       User                   @relation("StudentProjects", fields: [studentId], references: [id])
  passionId     String
  title         String
  description   String?
  startDate     DateTime               @default(now())
  targetEndDate DateTime?
  status        ProjectStatus          @default(IN_PROGRESS)
  visibility    ProjectVisibility      @default(PRIVATE)
  thumbnailUrl  String?
  tags          String[]
  collaborators String[] // User IDs of collaborators
  milestones    ProjectMilestone[]
  documentation ProjectDocumentation[]
  progressNotes String?
  completedAt   DateTime?
  showcaseUrl   String? // URL to final showcase/presentation
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([studentId])
  @@index([passionId])
  @@index([status])
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectVisibility {
  PRIVATE
  MENTORS_ONLY
  PUBLIC
}

// Project milestones
model ProjectMilestone {
  id          String         @id @default(cuid())
  projectId   String
  project     ProjectTracker @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean        @default(false)
  completedAt DateTime?
  notes       String?
  mediaUrls   String[]
  order       Int
  createdAt   DateTime       @default(now())

  @@index([projectId, order])
}

// Project documentation
model ProjectDocumentation {
  id        String         @id @default(cuid())
  projectId String
  project   ProjectTracker @relation(fields: [projectId], references: [id], onDelete: Cascade)
  docType   ProjectDocType
  title     String
  content   String
  mediaUrls String[]
  tags      String[]
  version   Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([projectId, docType])
}

enum ProjectDocType {
  PLAN
  PROGRESS_UPDATE
  SKETCH
  RESEARCH_NOTES
  REFLECTION
  FINAL_REPORT
  PRESENTATION
  OTHER
}

// Before/After Progress Comparisons
model ProgressComparison {
  id             String   @id @default(cuid())
  studentId      String
  student        User     @relation("ProgressComparisons", fields: [studentId], references: [id])
  passionId      String
  title          String
  description    String?
  beforeDate     DateTime
  afterDate      DateTime
  beforeMediaUrl String // Photo/video showing "before" state
  afterMediaUrl  String // Photo/video showing "after" state
  improvements   String[] // List of specific improvements
  skillsGained   String[]
  reflectionText String?
  xpAwarded      Int      @default(0)
  isPublic       Boolean  @default(false)
  likes          Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([studentId])
  @@index([passionId])
  @@index([isPublic])
}

// ============================================
// PHASE 4: AWARDS & RECOGNITION
// ============================================

// Awards - Recognition categories
model RecognitionAward {
  id            String         @id @default(cuid())
  name          String
  description   String
  category      String // "PURSUIT", "BREAKTHROUGH", "PERSISTENCE", "IMPROVEMENT", "SHOWCASE"
  icon          String
  criteria      Json // What qualifies for this award
  xpReward      Int
  isActive      Boolean        @default(true)
  studentAwards StudentAward[]
  createdAt     DateTime       @default(now())

  @@index([category])
  @@index([isActive])
}

// Student awards received
model StudentAward {
  id          String           @id @default(cuid())
  studentId   String
  student     User             @relation("StudentAwards", fields: [studentId], references: [id])
  awardId     String
  award       RecognitionAward @relation(fields: [awardId], references: [id])
  passionId   String?
  reason      String
  awardedBy   String? // Instructor/admin who nominated
  nominatedBy User?            @relation("AwardNominations", fields: [awardedBy], references: [id])
  awardedAt   DateTime         @default(now())
  isPublic    Boolean          @default(true)
  mediaUrl    String? // Photo/certificate

  @@index([studentId])
  @@index([awardId])
  @@index([awardedAt])
}

// Breakthrough moments - "Aha!" moments
model BreakthroughMoment {
  id               String   @id @default(cuid())
  studentId        String
  student          User     @relation("BreakthroughMoments", fields: [studentId], references: [id])
  passionId        String
  title            String
  description      String
  date             DateTime @default(now())
  isRecognized     Boolean  @default(false)
  celebrationCount Int      @default(0) // How many people celebrated
  mediaUrls        String[]
  isPublic         Boolean  @default(true)

  @@index([studentId])
  @@index([passionId])
  @@index([date])
}

// Showcase events
model PassionShowcase {
  id                   String                 @id @default(cuid())
  title                String
  description          String?
  date                 DateTime
  location             String?
  isVirtual            Boolean                @default(true)
  chapterId            String?
  registrationDeadline DateTime?
  maxPresenters        Int?
  presentations        ShowcasePresentation[]
  status               String // "UPCOMING", "REGISTRATION_OPEN", "COMPLETED"
  createdAt            DateTime               @default(now())

  @@index([date])
  @@index([status])
  @@index([chapterId])
}

// Showcase presentations
model ShowcasePresentation {
  id              String          @id @default(cuid())
  showcaseId      String
  showcase        PassionShowcase @relation(fields: [showcaseId], references: [id])
  studentId       String
  student         User            @relation("ShowcasePresentations", fields: [studentId], references: [id])
  passionId       String
  title           String
  description     String
  presentationUrl String? // Video recording or slides
  thumbnailUrl    String?
  votes           Int             @default(0)
  registeredAt    DateTime        @default(now())

  @@index([showcaseId])
  @@index([studentId])
}

// Wall of Fame entries
model WallOfFame {
  id            String    @id @default(cuid())
  studentId     String
  student       User      @relation("WallOfFameEntries", fields: [studentId], references: [id])
  achievement   String
  passionId     String
  description   String
  date          DateTime
  mediaUrl      String?
  featuredUntil DateTime? // How long to display
  displayOrder  Int
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([studentId])
  @@index([passionId])
  @@index([displayOrder])
  @@index([isActive])
}

// Student of the Month
model StudentOfMonth {
  id           String   @id @default(cuid())
  studentId    String
  student      User     @relation("StudentOfMonthAwards", fields: [studentId], references: [id])
  month        DateTime
  chapterId    String?
  nomination   String // Why they were chosen
  achievements String[]
  storyUrl     String? // Featured story link
  photoUrl     String?
  announcedAt  DateTime @default(now())

  @@index([studentId])
  @@index([month])
  @@index([chapterId])
}

// Team Achievement Awards
model TeamAchievement {
  id                String   @id @default(cuid())
  name              String
  description       String
  category          String // "COLLABORATION", "COMMUNITY", "INNOVATION"
  teamMembers       String[] // User IDs
  passionIds        String[]
  projectId         String?
  reason            String
  awardedBy         String?
  awardedAt         DateTime @default(now())
  mediaUrl          String?
  xpRewardPerMember Int      @default(0)

  @@index([awardedAt])
  @@index([category])
}

// ============================================
// PHASE 5: MENTORSHIP LIGHT
// ============================================

// Mentor feedback requests
model MentorFeedbackRequest {
  id        String           @id @default(cuid())
  studentId String
  student   User             @relation("MentorFeedbackRequests", fields: [studentId], references: [id])
  passionId String
  projectId String?
  question  String
  mediaUrls String[] // Work samples
  status    String // "PENDING", "ANSWERED", "ARCHIVED"
  createdAt DateTime         @default(now())
  responses MentorResponse[]

  @@index([studentId])
  @@index([passionId])
  @@index([status])
}

// Mentor responses to feedback requests
model MentorResponse {
  id          String                @id @default(cuid())
  requestId   String
  request     MentorFeedbackRequest @relation(fields: [requestId], references: [id])
  mentorId    String
  mentor      User                  @relation("MentorResponsesGiven", fields: [mentorId], references: [id])
  feedback    String
  videoUrl    String? // Optional video response
  resources   String[] // Helpful links
  respondedAt DateTime              @default(now())
  isHelpful   Boolean? // Student rating

  @@index([requestId])
  @@index([mentorId])
}

// General mentor questions (Ask a Mentor)
model MentorQuestion {
  id          String         @id @default(cuid())
  studentId   String
  student     User           @relation("MentorQuestionsAsked", fields: [studentId], references: [id])
  passionId   String?
  question    String
  isAnonymous Boolean        @default(false)
  status      String // "PENDING", "ANSWERED"
  views       Int            @default(0)
  createdAt   DateTime       @default(now())
  answers     MentorAnswer[]

  @@index([studentId])
  @@index([passionId])
  @@index([status])
}

// Answers to mentor questions
model MentorAnswer {
  id         String         @id @default(cuid())
  questionId String
  question   MentorQuestion @relation(fields: [questionId], references: [id])
  mentorId   String
  mentor     User           @relation("MentorAnswersGiven", fields: [mentorId], references: [id])
  answer     String
  videoUrl   String?
  helpful    Int            @default(0) // Upvotes
  answeredAt DateTime       @default(now())

  @@index([questionId])
  @@index([mentorId])
}

// Success stories from alumni/students
model SuccessStory {
  id           String   @id @default(cuid())
  personId     String? // Can be user or external person
  person       User?    @relation("SuccessStories", fields: [personId], references: [id])
  name         String
  passionId    String
  title        String
  story        String
  videoUrl     String?
  thumbnailUrl String?
  currentRole  String? // What they do now
  advice       String?
  tags         String[]
  featured     Boolean  @default(false)
  views        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([passionId])
  @@index([featured])
  @@index([views])
}

// Curated resources from mentors
model CuratedResource {
  id           String   @id @default(cuid())
  mentorId     String
  mentor       User     @relation("CuratedResourcesShared", fields: [mentorId], references: [id])
  passionId    String
  title        String
  description  String?
  url          String
  resourceType String // "VIDEO", "ARTICLE", "BOOK", "COURSE", "TOOL"
  level        String // "BEGINNER", "INTERMEDIATE", "ADVANCED"
  rating       Float?
  saves        Int      @default(0)
  sharedAt     DateTime @default(now())

  @@index([passionId])
  @@index([resourceType])
  @@index([level])
}

// Motivation boost messages
model MotivationBoost {
  id        String                 @id @default(cuid())
  category  String // "STUCK", "FRUSTRATED", "DOUBTFUL", "BURNOUT", "GENERAL"
  message   String
  author    String?
  videoUrl  String?
  passionId String?
  useCount  Int                    @default(0)
  isActive  Boolean                @default(true)
  logs      StudentMotivationLog[]

  @@index([category])
  @@index([isActive])
}

// Track when students request motivation
model StudentMotivationLog {
  id          String          @id @default(cuid())
  studentId   String
  student     User            @relation("MotivationBoostsReceived", fields: [studentId], references: [id])
  boostId     String
  boost       MotivationBoost @relation(fields: [boostId], references: [id])
  requestedAt DateTime        @default(now())
  wasHelpful  Boolean?

  @@index([studentId])
  @@index([boostId])
}

// ============================================
// PHASE 6: PORTFOLIO & PROJECTS
// ============================================

// Resource requests for projects
model ResourceRequest {
  id            String    @id @default(cuid())
  studentId     String
  student       User      @relation("ResourceRequests", fields: [studentId], references: [id])
  projectId     String?
  passionId     String
  itemName      String
  description   String
  estimatedCost Float?
  reason        String // Why they need it
  status        String // "PENDING", "APPROVED", "DENIED", "FULFILLED"
  requestedAt   DateTime  @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?

  @@index([studentId])
  @@index([status])
  @@index([passionId])
}

// Project feedback cycles
model ProjectFeedbackCycle {
  id                String            @id @default(cuid())
  projectId         String
  cycleNumber       Int
  submittedAt       DateTime          @default(now())
  workSamples       String[] // URLs to photos/videos of work
  studentReflection String
  feedback          ProjectFeedback[]
  status            String // "AWAITING_FEEDBACK", "IN_PROGRESS", "COMPLETED"

  @@index([projectId])
  @@index([status])
}

// Individual feedback on project cycles
model ProjectFeedback {
  id            String               @id @default(cuid())
  cycleId       String
  cycle         ProjectFeedbackCycle @relation(fields: [cycleId], references: [id])
  reviewerId    String
  reviewer      User                 @relation("ProjectFeedbackGiven", fields: [reviewerId], references: [id])
  reviewerType  String // "PEER", "MENTOR", "INSTRUCTOR"
  strengths     String
  improvements  String
  suggestions   String?
  encouragement String
  givenAt       DateTime             @default(now())

  @@index([cycleId])
  @@index([reviewerId])
}

// Student portfolios (Note: Portfolio model already exists from previous phases)
// Adding portfolio-specific models for sections and items

model PortfolioSection {
  id          String                 @id @default(cuid())
  portfolioId String
  passionId   String?
  title       String
  description String?
  order       Int
  items       PortfolioSectionItem[]
  createdAt   DateTime               @default(now())

  @@index([portfolioId])
  @@index([order])
}

model PortfolioSectionItem {
  id          String           @id @default(cuid())
  sectionId   String
  section     PortfolioSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  mediaUrls   String[]
  projectLink String?
  date        DateTime?
  tags        String[]
  order       Int
  createdAt   DateTime         @default(now())

  @@index([sectionId, order])
}

// Public portfolio (shareable version)
model PublicPortfolio {
  id          String   @id @default(cuid())
  studentId   String   @unique
  student     User     @relation("PublicPortfolio", fields: [studentId], references: [id])
  title       String
  bio         String?
  theme       String   @default("default")
  customUrl   String?  @unique
  isPublic    Boolean  @default(false)
  sections    Json // Serialized portfolio sections
  views       Int      @default(0)
  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([customUrl])
  @@index([isPublic])
}

// ============================================
// PHASE 7: PARENT FEATURES
// ============================================

model ParentProfile {
  id            String                    @id @default(cuid())
  userId        String                    @unique
  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students      ParentStudentConnection[]
  notifications ParentNotification[]
  messages      ParentMessage[]
  settings      ParentSettings?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
}

model ParentStudentConnection {
  id                String        @id @default(cuid())
  parentId          String
  parent            ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId         String
  student           User          @relation("ParentStudentConnections", fields: [studentId], references: [id], onDelete: Cascade)
  relationship      String // "Mother", "Father", "Guardian", etc.
  isPrimary         Boolean       @default(false)
  canViewProgress   Boolean       @default(true)
  canReceiveReports Boolean       @default(true)
  approvedAt        DateTime?
  createdAt         DateTime      @default(now())

  @@unique([parentId, studentId])
}

model ParentNotification {
  id        String                 @id @default(cuid())
  parentId  String
  parent    ParentProfile          @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  type      ParentNotificationType
  title     String
  message   String
  actionUrl String?
  isRead    Boolean                @default(false)
  readAt    DateTime?
  createdAt DateTime               @default(now())
}

enum ParentNotificationType {
  ACHIEVEMENT
  MILESTONE
  ATTENDANCE
  SHOWCASE
  REPORT_READY
  NEW_PASSION
  AWARD_EARNED
  FEEDBACK_RECEIVED
  RESOURCE_APPROVED
  UPCOMING_EVENT
}

model ProgressReport {
  id          String     @id @default(cuid())
  studentId   String
  student     User       @relation("StudentProgressReports", fields: [studentId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  reportType  ReportType

  // Summary stats
  totalXPEarned     Int
  passionsActive    Int
  hoursLogged       Float
  projectsCompleted Int

  // Narrative sections
  highlights      String // Key achievements this period
  areasOfGrowth   String // Skills developing
  recommendations String // What to focus on next
  instructorNotes String? // Optional notes from instructors

  // Attachments
  showcaseItems String[] // URLs to notable work

  generatedAt   DateTime  @default(now())
  sentToParents Boolean   @default(false)
  sentAt        DateTime?
}

enum ReportType {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMESTER
  ANNUAL
}

model ParentMessage {
  id           String          @id @default(cuid())
  parentId     String
  parent       ParentProfile   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId    String
  instructorId String?
  subject      String
  message      String
  response     String?
  respondedBy  String?
  respondedAt  DateTime?
  status       MessageStatus
  priority     MessagePriority @default(NORMAL)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum MessageStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model ParentSettings {
  id       String        @id @default(cuid())
  parentId String        @unique
  parent   ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Notification preferences
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  weeklyDigest       Boolean @default(true)
  achievementAlerts  Boolean @default(true)
  attendanceAlerts   Boolean @default(true)

  // Privacy settings
  allowPhotoSharing    Boolean @default(true)
  allowPublicPortfolio Boolean @default(true)

  // Report preferences
  reportFrequency ReportFrequency @default(MONTHLY)

  updatedAt DateTime @updatedAt
}

enum ReportFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

model ParentResource {
  id           String                 @id @default(cuid())
  title        String
  description  String
  category     ParentResourceCategory
  content      String                 @db.Text
  resourceUrl  String?
  thumbnailUrl String?
  tags         String[]
  ageGroup     String[] // e.g., ["Elementary", "Middle School", "High School"]
  featured     Boolean                @default(false)
  viewCount    Int                    @default(0)
  createdBy    String
  publishedAt  DateTime
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

enum ParentResourceCategory {
  SUPPORTING_PASSION
  COLLEGE_PREP
  MENTAL_HEALTH
  YOUTH_DEVELOPMENT
  SCHOLARSHIPS
  TIME_MANAGEMENT
  PARENT_INVOLVEMENT
  SUCCESS_STORIES
}

// ============================================
// PHASE 8: EXPERIENCE & PERSONALIZATION
// ============================================

model StudentOnboarding {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("StudentOnboarding", fields: [userId], references: [id], onDelete: Cascade)

  // Onboarding steps
  completedIntro         Boolean @default(false)
  completedPassionQuiz   Boolean @default(false)
  completedProfileSetup  Boolean @default(false)
  completedFirstTryIt    Boolean @default(false)
  completedFirstPractice Boolean @default(false)

  // Preferences from onboarding
  learningGoals          String[] // e.g., ["college_prep", "hobby", "career"]
  availableHours         Int? // Hours per week they can dedicate
  preferredLearningStyle String? // "visual", "hands_on", "reading", "video"

  completedAt DateTime?
  currentStep String    @default("intro")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PersonalizationSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("PersonalizationSettings", fields: [userId], references: [id], onDelete: Cascade)

  // Dashboard preferences
  dashboardLayout    String  @default("default") // "default", "minimal", "detailed"
  showXPProgress     Boolean @default(true)
  showStreaks        Boolean @default(true)
  showUpcomingEvents Boolean @default(true)
  showPeerActivity   Boolean @default(true)

  // Content preferences
  autoPlayVideos Boolean @default(false)
  videoQuality   String  @default("auto") // "auto", "high", "medium", "low"

  // Notification preferences
  dailyReminders Boolean @default(true)
  reminderTime   String? // "09:00", "18:00", etc.
  weeklyDigest   Boolean @default(true)

  // Privacy preferences
  showProfilePublicly      Boolean @default(true)
  showProgressToClassmates Boolean @default(true)
  allowPeerMessages        Boolean @default(true)

  // Theme
  theme       String @default("light") // "light", "dark", "auto"
  accentColor String @default("#6366f1")

  updatedAt DateTime @updatedAt
}

model UserFeedback {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserFeedback", fields: [userId], references: [id], onDelete: Cascade)

  category      FeedbackCategory
  rating        Int? // 1-5 stars
  message       String           @db.Text
  page          String? // Which page they were on
  screenshotUrl String?

  status        UserFeedbackStatus @default(PENDING)
  adminResponse String?            @db.Text
  respondedBy   String?
  respondedAt   DateTime?

  createdAt DateTime @default(now())
}

enum FeedbackCategory {
  BUG_REPORT
  FEATURE_REQUEST
  USABILITY_ISSUE
  CONTENT_SUGGESTION
  GENERAL_FEEDBACK
  COMPLIMENT
}

enum UserFeedbackStatus {
  PENDING
  REVIEWING
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

model QuickAction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("QuickActions", fields: [userId], references: [id], onDelete: Cascade)

  actionType  String // "log_practice", "continue_module", "view_feedback", etc.
  actionData  Json // Flexible data for the action
  displayText String
  iconEmoji   String
  priority    Int    @default(0)

  expiresAt   DateTime?
  completedAt DateTime?
  dismissedAt DateTime?

  createdAt DateTime @default(now())
}

model Bookmark {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("Bookmarks", fields: [userId], references: [id], onDelete: Cascade)

  resourceType  String // "module", "video", "article", "mentor_resource", etc.
  resourceId    String
  resourceTitle String
  resourceUrl   String

  notes String?  @db.Text
  tags  String[]

  createdAt DateTime @default(now())

  @@unique([userId, resourceType, resourceId])
}

model DailyInspiration {
  id       String   @id @default(cuid())
  date     DateTime @unique
  quote    String   @db.Text
  author   String
  category String // "persistence", "creativity", "courage", etc.
  imageUrl String?

  createdAt DateTime @default(now())
}

// ============================================
// PHASE 9: CLASS MANAGEMENT & SCHEDULING
// ============================================

enum DifficultyLevel {
  LEVEL_101
  LEVEL_201
  LEVEL_301
  LEVEL_401
}

enum CurriculumSubmissionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  NEEDS_REVISION
}

enum DeliveryMode {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum ClassEnrollmentStatus {
  ENROLLED
  WAITLISTED
  DROPPED
  COMPLETED
}

enum ClassOfferingStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReminderType {
  TWENTY_FOUR_HOUR
  ONE_HOUR
  CUSTOM
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum LaunchTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum RolloutAudience {
  ALL
  INSTRUCTORS
  STUDENTS
  PARENTS
  CHAPTER_LEADS
  STAFF
  MENTORS
}

enum RolloutCampaignStatus {
  DRAFT
  SENT
  FAILED
}

enum FeatureGateScope {
  GLOBAL
  CHAPTER
  USER
  ROLE
}

enum ChapterPathwayRunStatus {
  NOT_OFFERED
  COMING_SOON
  ACTIVE
  PAUSED
}

enum PathwayFallbackRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ClassOfferingApprovalStatus {
  NOT_REQUESTED
  REQUESTED
  UNDER_REVIEW
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

// Class template: reusable curriculum design (Feature #61, #62, #63, #64)
model ClassTemplate {
  id                    String          @id @default(cuid())
  title                 String
  description           String          @db.Text
  interestArea          String // Passion area (matches existing pattern)
  difficultyLevel       DifficultyLevel @default(LEVEL_101)
  learnerFitLabel       String?
  learnerFitDescription String?         @db.Text
  prerequisites         String[] // e.g., ["ART-101", "ART-102"]

  // Curriculum (Feature #61)
  weeklyTopics     Json     @default("[]") // [{week, topic, milestone, materials}]
  learningOutcomes String[] // What students achieve (Feature #63)
  estimatedHours   Int      @default(0) // Total student time commitment
  durationWeeks    Int      @default(8) // Course length in weeks
  sessionsPerWeek  Int      @default(1)

  // Class size optimization (Feature #64)
  minStudents Int     @default(3)
  maxStudents Int     @default(25)
  idealSize   Int     @default(12)
  sizeNotes   String? // Why this size works

  // Delivery (Feature #83)
  deliveryModes String[] @default(["VIRTUAL"]) // IN_PERSON, VIRTUAL, HYBRID

  // YPP Curriculum Template fields (Phase 3)
  targetAgeGroup     String? // e.g., "12-14", "16-18"
  classDurationMin   Int? // Length of each class session in minutes
  engagementStrategy Json? // {energyStyle, differentiationPlan, technologyTools, studentVoiceMoments, assessmentApproach}

  // Submission & review workflow
  submissionStatus CurriculumSubmissionStatus @default(DRAFT)
  submittedAt      DateTime?
  reviewedById     String?
  reviewedBy       User?                      @relation("ClassTemplatesReviewed", fields: [reviewedById], references: [id])
  reviewNotes      String?                    @db.Text

  // Meta
  isPublished Boolean  @default(false)
  createdById String
  createdBy   User     @relation("ClassTemplatesCreated", fields: [createdById], references: [id])
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id])

  offerings    ClassOffering[]
  lessonPlans  LessonPlan[]
  pathwaySteps PathwayStep[]   @relation("ClassTemplateSteps")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interestArea])
  @@index([difficultyLevel])
  @@index([createdById])
  @@index([submissionStatus])
}

// Specific offering of a class template (Feature #80, #83)
model ClassOffering {
  id            String        @id @default(cuid())
  templateId    String
  template      ClassTemplate @relation(fields: [templateId], references: [id])
  instructorId  String
  instructor    User          @relation("ClassOfferingsInstructed", fields: [instructorId], references: [id])
  pathwayStepId String?
  pathwayStep   PathwayStep?  @relation("PathwayStepOfferings", fields: [pathwayStepId], references: [id])

  // Schedule (Feature #80)
  title       String // Can override template title
  startDate   DateTime
  endDate     DateTime
  meetingDays String[] // ["Monday", "Wednesday"]
  meetingTime String // "16:00-18:00"
  timezone    String   @default("America/New_York")

  // Location (Feature #83)
  deliveryMode    DeliveryMode @default(VIRTUAL)
  locationName    String? // Physical location name
  locationAddress String?
  zoomLink        String?
  meetingId       String? // Zoom/Teams meeting ID

  // Instructor class intro media
  introVideoTitle       String?
  introVideoDescription String?        @db.Text
  introVideoProvider    VideoProvider?
  introVideoUrl         String?
  introVideoThumbnail   String?

  // Enrollment
  capacity       Int     @default(25)
  enrollmentOpen Boolean @default(true)

  // Reminders (Feature #81)
  send24HrReminder Boolean @default(true)
  send1HrReminder  Boolean @default(true)

  // Status
  status                         ClassOfferingStatus @default(DRAFT)
  chapterId                      String?
  chapter                        Chapter?            @relation(fields: [chapterId], references: [id])
  semester                       String? // "Spring 2025", "Fall 2025"
  grandfatheredTrainingExemption Boolean             @default(false)

  // Relations
  sessions         ClassSession[]
  enrollments      ClassEnrollment[]
  reminders        ClassReminder[]
  assignments      ClassAssignment[]
  announcements    ClassAnnouncement[]
  fallbackRequests PathwayFallbackRequest[]
  approval         ClassOfferingApproval?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@index([instructorId])
  @@index([startDate])
  @@index([status])
  @@index([chapterId])
  @@index([pathwayStepId])
}

model ClassOfferingApproval {
  id            String                      @id @default(cuid())
  offeringId    String                      @unique
  offering      ClassOffering               @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  status        ClassOfferingApprovalStatus @default(NOT_REQUESTED)
  requestedById String?
  requestedBy   User?                       @relation("ClassOfferingApprovalRequests", fields: [requestedById], references: [id])
  requestNotes  String?                     @db.Text
  requestedAt   DateTime?
  reviewedById  String?
  reviewedBy    User?                       @relation("ClassOfferingApprovalReviews", fields: [reviewedById], references: [id])
  reviewNotes   String?                     @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([status])
  @@index([requestedById])
  @@index([reviewedById])
}

// Individual class session (meeting) within an offering
model ClassSession {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  sessionNumber    Int
  date             DateTime
  startTime        String // "16:00"
  endTime          String // "18:00"
  topic            String
  description      String?  @db.Text
  learningOutcomes String[]
  milestone        String? // Key milestone for this session

  // Materials
  materialsUrl String?
  recordingUrl String?
  notesUrl     String?

  // Status
  isCancelled  Boolean @default(false)
  cancelReason String?

  // Attendance
  attendance ClassAttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offeringId, sessionNumber])
  @@index([offeringId])
  @@index([date])
}

// Student enrollment in a class offering
model ClassEnrollment {
  id         String        @id @default(cuid())
  studentId  String
  student    User          @relation("ClassEnrollments", fields: [studentId], references: [id])
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id])

  status      ClassEnrollmentStatus @default(ENROLLED)
  enrolledAt  DateTime              @default(now())
  droppedAt   DateTime?
  completedAt DateTime?

  // Progress tracking (Feature #63)
  sessionsAttended Int      @default(0)
  outcomesAchieved String[] // IDs of achieved learning outcomes
  instructorNotes  String?  @db.Text

  // Waitlist position (if waitlisted)
  waitlistPosition Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, offeringId])
  @@index([studentId])
  @@index([offeringId])
  @@index([status])
}

// Attendance for individual class sessions
model ClassAttendanceRecord {
  id        String       @id @default(cuid())
  sessionId String
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User         @relation("ClassAttendanceRecords", fields: [studentId], references: [id])

  status      AttendanceStatus @default(PRESENT)
  notes       String?
  checkedInAt DateTime         @default(now())

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
}

// Class reminders (Feature #81)
model ClassReminder {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  sessionId  String? // Specific session, or null for general
  userId     String
  user       User          @relation("ClassRemindersReceived", fields: [userId], references: [id])

  type         ReminderType
  scheduledFor DateTime
  sentAt       DateTime?
  status       ReminderStatus @default(PENDING)

  // Content
  subject  String
  body     String  @db.Text
  zoomLink String?

  createdAt DateTime @default(now())

  @@index([offeringId])
  @@index([userId])
  @@index([scheduledFor])
  @@index([status])
}

model EventReminder {
  id           String         @id @default(cuid())
  eventId      String
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation("EventRemindersReceived", fields: [userId], references: [id])
  type         ReminderType
  scheduledFor DateTime
  sentAt       DateTime?
  status       ReminderStatus @default(PENDING)
  subject      String
  body         String         @db.Text
  createdAt    DateTime       @default(now())

  @@unique([eventId, userId, type])
  @@index([eventId])
  @@index([userId])
  @@index([scheduledFor])
  @@index([status])
}

model ChapterMilestone {
  id          String          @id @default(cuid())
  chapterId   String
  chapter     Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  dueDate     DateTime
  visibility  EventVisibility @default(INTERNAL)
  createdById String?
  createdBy   User?           @relation("ChapterMilestonesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?           @relation("ChapterMilestonesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  calendarUid String          @unique @default(cuid())
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([chapterId, dueDate])
  @@index([visibility, dueDate])
}

model ChapterCalendarSubscription {
  id        String   @id @default(cuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedToken String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, userId])
  @@index([userId])
}

// Launch timeline task for leadership + chapter rollout coordination
model LaunchTask {
  id          String           @id @default(cuid())
  title       String
  ownerLabel  String
  dueDate     DateTime?
  status      LaunchTaskStatus @default(NOT_STARTED)
  blocker     String?
  scope       String           @default("GLOBAL") // GLOBAL or CHAPTER
  chapterId   String?
  chapter     Chapter?         @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?            @relation("LaunchTasksCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?            @relation("LaunchTasksUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([scope, isActive])
  @@index([chapterId, isActive])
  @@index([status, dueDate])
}

// Outbound rollout campaign log with send metadata
model RolloutCampaign {
  id           String                @id @default(cuid())
  templateKey  String
  title        String
  content      String                @db.Text
  audience     RolloutAudience       @default(ALL)
  targetRoles  RoleType[]
  linkUrl      String?
  chapterId    String?
  chapter      Chapter?              @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                  @relation("RolloutCampaignsCreatedBy", fields: [createdById], references: [id])
  status       RolloutCampaignStatus @default(SENT)
  sentAt       DateTime?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([chapterId])
  @@index([audience, status])
  @@index([createdAt])
}

model FeatureGateRule {
  id          String           @id @default(cuid())
  featureKey  String
  scope       FeatureGateScope @default(GLOBAL)
  enabled     Boolean          @default(true)
  chapterId   String?
  chapter     Chapter?         @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?            @relation("FeatureGateRuleTargetUser", fields: [userId], references: [id], onDelete: SetNull)
  role        RoleType?
  startsAt    DateTime?
  endsAt      DateTime?
  note        String?
  createdById String?
  createdBy   User?            @relation("FeatureGateRuleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?            @relation("FeatureGateRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([featureKey, scope, enabled])
  @@index([featureKey, chapterId, enabled])
  @@index([featureKey, userId, enabled])
  @@index([featureKey, role, enabled])
  @@index([startsAt, endsAt])
}

// ============================================
// PHASE 10: ENJOYMENT-FOCUSED ASSIGNMENT SYSTEM
// ============================================

enum ClassAssignmentType {
  PRACTICE // Skill-building exercise
  PROJECT // Creative project
  EXPLORATION // Open-ended exploration
  GROUP // Group collaboration
  REFLECTION // Reflective writing
}

enum FeedbackStyle {
  NARRATIVE // Written narrative feedback
  CHECKLIST // Checklist of skills demonstrated
  VIDEO // Video feedback from instructor
  PEER_REVIEW // Peer-to-peer feedback
}

enum GradingStyle {
  COMPLETION // Completed or not (no judgment)
  FEEDBACK_ONLY // Narrative feedback, no score
  OPTIONAL_GRADE // Student can opt into receiving a grade
}

enum ClassSubmissionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  FEEDBACK_GIVEN
  REVISED
}

// Enjoyment-focused assignment tied to class offerings (Feature #43)
model ClassAssignment {
  id          String        @id @default(cuid())
  offeringId  String
  offering    ClassOffering @relation(fields: [offeringId], references: [id])
  createdById String
  createdBy   User          @relation("ClassAssignmentsCreated", fields: [createdById], references: [id])

  title       String
  description String              @db.Text
  type        ClassAssignmentType @default(PRACTICE)

  // Enjoyment-focused options
  feedbackStyle FeedbackStyle @default(NARRATIVE)
  gradingStyle  GradingStyle  @default(FEEDBACK_ONLY)

  // Flexible deadlines
  suggestedDueDate     DateTime? // "Aim to complete by..."
  hardDeadline         DateTime? // Only if truly time-sensitive
  allowLateSubmissions Boolean   @default(true)

  // Instructions & materials
  instructions    String?  @db.Text
  referenceLinks  String[] // Links to helpful resources
  exampleWorkUrls String[] // Show examples of what good looks like
  attachmentUrl   String?

  // Group settings
  isGroupAssignment Boolean @default(false)
  groupSize         Int? // Suggested group size
  allowSelfSelect   Boolean @default(true) // Can students pick groups?

  // Encouragement
  encouragementNote String? @db.Text // Instructor message to motivate

  isPublished Boolean @default(true)
  sessionId   String? // Optionally tied to a class session

  // Rubric for grading / self-assessment
  rubricId String?
  rubric   Rubric? @relation("ClassAssignmentRubric", fields: [rubricId], references: [id])

  // Relations
  submissions ClassAssignmentSubmission[]
  groups      GroupProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId])
}

// Student submission with enjoyment metrics instead of grades
model ClassAssignmentSubmission {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   ClassAssignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      User            @relation("ClassSubmissions", fields: [studentId], references: [id])
  groupId      String? // If group assignment
  group        GroupProject?   @relation(fields: [groupId], references: [id])

  // Submission
  workUrl     String? // Link to work (Drive, YouTube, etc.)
  workText    String?   @db.Text // Written work or description
  submittedAt DateTime?

  status ClassSubmissionStatus @default(NOT_STARTED)

  // Instructor feedback (NOT grades)
  instructorFeedback String?   @db.Text // Detailed narrative feedback
  celebratoryNote    String?   @db.Text // "I love how you experimented!"
  suggestionsForNext String?   @db.Text // "Try adding more contrast next time"
  feedbackGivenAt    DateTime?

  // Student self-reflection
  studentReflection String?  @db.Text // "What did you learn?"
  enjoymentRating   Int? // 1-5: "How much fun did you have?"
  difficultyRating  Int? // 1-5: "How challenging was this?"
  whatWentWell      String?  @db.Text
  whatToImprove     String?  @db.Text
  wouldRecommend    Boolean? // "Would you recommend this to a classmate?"

  // Completion celebration (not perfection)
  completionBadge Boolean @default(false) // Earned just for finishing!

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
}

// Group project for collaborative assignments (Feature #69)
model GroupProject {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   ClassAssignment @relation(fields: [assignmentId], references: [id])

  groupName   String
  description String? @db.Text

  // Members
  members GroupMember[]

  // Coordination
  communicationChannel String? // "Slack", "Discord", "Group Text"
  sharedDocLinks       String[] // Links to collaborative docs

  // Milestones
  milestones GroupMilestone[]

  // Final submission
  submissions ClassAssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignmentId])
}

model GroupMember {
  id      String       @id @default(cuid())
  groupId String
  group   GroupProject @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User         @relation("GroupMemberships", fields: [userId], references: [id])

  // Flexible roles (student-defined, not rigid)
  role     String? // e.g., "Visual Lead", "Research", "Presenter"
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupMilestone {
  id      String       @id @default(cuid())
  groupId String
  group   GroupProject @relation(fields: [groupId], references: [id], onDelete: Cascade)

  title       String
  description String?
  targetDate  DateTime?
  completedAt DateTime?
  isComplete  Boolean   @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
}

// ============================================
// PHASE 11: AI & PERSONALIZATION
// ============================================

enum LearningPathStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum PredictionType {
  LEVEL_UP
  SKILL_MASTERY
  COURSE_COMPLETION
  STREAK_MILESTONE
}

// AI-generated personalized learning roadmap (Feature #8)
model LearningPath {
  id          String @id @default(cuid())
  studentId   String
  student     User   @relation("LearningPaths", fields: [studentId], references: [id])
  passionArea String

  // Generation info
  generatedBy String @default("ai") // "ai", "instructor", "student"

  // Goals
  targetSkillLevel     String @default("intermediate") // beginner, intermediate, advanced, expert
  timeframeDays        Int    @default(90)
  weeklyHoursAvailable Int    @default(5)

  // Path structure
  milestones         Json     @default("[]") // [{week, goal, resources[], tasks[], isComplete}]
  recommendedClasses String[] // Class offering IDs
  recommendedModules String[] // Module IDs
  practiceGoals      Json     @default("{}") // {drawing: "30min/day", painting: "1hr 3x/week"}

  // Tracking
  status           LearningPathStatus @default(ACTIVE)
  startedAt        DateTime?
  completedAt      DateTime?
  currentMilestone Int                @default(0)
  completionPct    Float              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([passionArea])
  @@index([status])
}

// Point-in-time analytics snapshot for a student (Feature #22)
model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("AnalyticsSnapshots", fields: [studentId], references: [id])
  date      DateTime @default(now())

  // Core metrics
  totalXP        Int @default(0)
  level          Int @default(1)
  activePassions Int @default(0)

  // Time metrics
  practiceMinutesThisWeek Int   @default(0)
  practiceMinutesLastWeek Int   @default(0)
  practiceMinutesAvg      Float @default(0)
  longestStreak           Int   @default(0)
  currentStreak           Int   @default(0)

  // Productivity patterns
  mostProductiveDay      String? // "Wednesday"
  mostProductiveHour     Int? // 16 (4 PM)
  preferredSessionLength Int? // minutes
  totalSessionsThisMonth Int     @default(0)

  // Skill progression
  skillProgressions Json @default("{}") // {area: {level, weeksAtLevel, trend}}

  // Class engagement
  classesEnrolled        Int    @default(0)
  classesCompleted       Int    @default(0)
  assignmentsCompleted   Int    @default(0)
  averageEnjoymentRating Float?

  // Weekly comparison
  xpGainedThisWeek Int @default(0)
  xpGainedLastWeek Int @default(0)

  createdAt DateTime @default(now())

  @@index([studentId, date])
  @@index([date])
}

// Progress predictions (Feature #25)
model ProgressPrediction {
  id          String  @id @default(cuid())
  studentId   String
  student     User    @relation("ProgressPredictions", fields: [studentId], references: [id])
  passionArea String?

  predictionType PredictionType
  title          String // "Reach Advanced level in Watercolor"
  description    String?

  // Current and target state
  currentValue Float // e.g., current XP or skill level
  targetValue  Float // e.g., target XP or skill level
  progressPct  Float @default(0) // 0-100

  // Prediction
  predictedDate DateTime
  confidence    Float    @default(0.7) // 0.0 to 1.0

  // Assumptions
  assumedWeeklyHours Float  @default(5)
  assumedPace        String @default("current") // "current", "increased", "decreased"

  // Outcome tracking
  isAchieved    Boolean   @default(false)
  achievedAt    DateTime?
  accuracyScore Float? // How accurate was the prediction (0-1)?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([predictionType])
  @@index([predictedDate])
}

// ============================================
// PHASE 12: CHALLENGES & GAMIFICATION
// ============================================

enum ChallengeType {
  DAILY
  WEEKLY
  THIRTY_DAY
  SEASONAL
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ParticipantStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum StampSource {
  TRY_IT
  CLASS
  PROJECT
  PRACTICE_HOURS
}

enum RarityTier {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum CompetitionStatus {
  UPCOMING
  NEEDS_REVISION
  OPEN_FOR_SUBMISSIONS
  JUDGING
  VOTING
  COMPLETED
}

// 30-Day Challenges, Weekly Challenges, Seasonal Challenges
model Challenge {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  type        ChallengeType

  passionArea String?

  // Timing
  startDate DateTime
  endDate   DateTime

  // Requirements
  dailyGoal          String? // "Sketch for 15 minutes"
  weeklyGoal         String? // "Complete 3 paintings"
  submissionRequired Boolean @default(false)

  // Leaderboard
  trackProgress   Boolean @default(true)
  showLeaderboard Boolean @default(true)

  // Rewards
  completionBadgeId  String?
  xpReward           Int     @default(50)
  specialRecognition String? // "Featured in newsletter"

  // Status
  status ChallengeStatus @default(DRAFT)

  // Weekly challenge specific
  promptText     String?   @db.Text // Monday prompt for weekly challenges
  votingEnabled  Boolean   @default(false)
  votingDeadline DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants ChallengeParticipant[]
  submissions  ChallengeSubmission[]

  @@index([type, status])
  @@index([startDate, endDate])
  @@index([passionArea])
}

// Challenge participant with streak tracking
model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("ChallengeParticipations", fields: [studentId], references: [id])

  joinedAt      DateTime @default(now())
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  daysCompleted Int      @default(0)
  totalProgress Float    @default(0) // 0.0 to 1.0

  status      ParticipantStatus @default(ACTIVE)
  completedAt DateTime?

  leaderboardRank Int?
  lastCheckIn     DateTime?

  @@unique([challengeId, studentId])
  @@index([studentId])
  @@index([challengeId, status])
  @@index([leaderboardRank])
}

// Challenge submissions (daily check-ins, weekly submissions)
model ChallengeSubmission {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("ChallengeSubmissions", fields: [studentId], references: [id])

  // Content
  title       String?
  description String? @db.Text
  workUrl     String? // Link to work
  mediaUrl    String? // Image/video upload

  // Check-in data
  dayNumber        Int? // Day 1-30 for 30-day challenges
  minutesPracticed Int?
  reflection       String?

  // Voting (for weekly challenges)
  voteCount Int @default(0)

  submittedAt DateTime @default(now())

  @@index([challengeId, studentId])
  @@index([challengeId, voteCount])
  @@index([submittedAt])
}

// Passion Passport - collecting stamps for exploring sub-areas
model PassionPassport {
  id          String @id @default(cuid())
  studentId   String
  student     User   @relation("PassionPassports", fields: [studentId], references: [id])
  passionArea String // e.g., "Art", "Music", "Writing"

  totalStamps          Int   @default(0)
  completionPercentage Float @default(0) // 0-100

  stamps PassportStamp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, passionArea])
  @@index([studentId])
}

// Individual stamps in a passion passport
model PassportStamp {
  id         String          @id @default(cuid())
  passportId String
  passport   PassionPassport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  subArea     String // e.g., "Watercolor", "Oil Painting", "Digital Art"
  description String?

  earnedAt DateTime    @default(now())
  earnedBy StampSource

  hoursLogged       Int?
  projectsCompleted Int?
  evidence          String? // URL or description of what earned the stamp

  @@unique([passportId, subArea])
  @@index([passportId])
}

// Badge rarity tracking (updated periodically)
model BadgeRarity {
  id        String @id @default(cuid())
  badgeId   String @unique
  badgeName String

  totalAwarded     Int        @default(0)
  totalStudents    Int        @default(0)
  rarityPercentage Float      @default(100) // % of students who have this badge
  rarityTier       RarityTier @default(COMMON)

  updatedAt DateTime @updatedAt

  @@index([rarityTier])
  @@index([rarityPercentage])
}

// Seasonal competitions (quarterly themed events)
model SeasonalCompetition {
  id          String  @id @default(cuid())
  season      String // "Winter 2025"
  theme       String // "Winter Landscapes"
  passionArea String?

  startDate          DateTime
  endDate            DateTime
  submissionDeadline DateTime

  rules           String @db.Text
  planningDetails Json?
  judgingCriteria Json   @default("[]") // [{name, weight, description}]

  // Judging
  judges              User[]  @relation("CompetitionJudges")
  votingEnabled       Boolean @default(false)
  communityVoteWeight Float   @default(0.3) // 30% community, 70% judges

  status CompetitionStatus @default(UPCOMING)

  // Rewards
  xpReward          Int     @default(100)
  firstPlaceReward  String?
  secondPlaceReward String?
  thirdPlaceReward  String?

  // Instructor draft ownership
  createdById String?
  createdBy   User?   @relation("CompetitionsCreated", fields: [createdById], references: [id])

  // Review fields
  reviewNotes  String? @db.Text
  reviewedById String?
  reviewedBy   User?   @relation("CompetitionReviewer", fields: [reviewedById], references: [id])

  entries        CompetitionEntry[]
  votes          CompetitionVote[]
  prepMilestones CompetitionPrepMilestone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([passionArea])
  @@index([startDate, endDate])
}

// Competition entries
model CompetitionEntry {
  id            String              @id @default(cuid())
  competitionId String
  competition   SeasonalCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  studentId     String
  student       User                @relation("CompetitionEntries", fields: [studentId], references: [id])

  title       String
  description String? @db.Text
  workUrl     String?
  mediaUrl    String?

  // Scoring
  judgeScore     Float? // Average of judge scores
  communityScore Float? // Average community vote
  finalScore     Float? // Weighted combination
  placement      Int? // 1st, 2nd, 3rd, etc.

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  votes CompetitionVote[]

  @@unique([competitionId, studentId])
  @@index([competitionId, finalScore])
  @@index([studentId])
}

// Community votes for competition entries
model CompetitionVote {
  id            String              @id @default(cuid())
  competitionId String
  competition   SeasonalCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  entryId       String
  entry         CompetitionEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  voterId       String
  voter         User                @relation("CompetitionVotes", fields: [voterId], references: [id])

  score   Int // 1-5 stars
  comment String?

  votedAt DateTime @default(now())

  @@unique([entryId, voterId])
  @@index([competitionId])
  @@index([entryId])
}

// ============================================
// PHASE 2 ENGAGEMENT: STUDENT CONTENT SHOWCASE (#24)
// ============================================

enum ContentType {
  VIDEO
  ARTICLE
  PROJECT
  TUTORIAL
  ART
  MUSIC
  CODE
  OTHER
}

enum ContentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  FEATURED
  REJECTED
}

model StudentContent {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation("StudentContents", fields: [studentId], references: [id])

  title        String
  description  String?     @db.Text
  contentType  ContentType
  mediaUrl     String? // Link to uploaded content
  thumbnailUrl String?
  passionArea  String?

  // Moderation & status
  status       ContentStatus @default(DRAFT)
  reviewedById String?
  reviewNote   String?

  // Engagement
  viewCount  Int       @default(0)
  likeCount  Int       @default(0)
  isFeatured Boolean   @default(false)
  featuredAt DateTime?

  // Rewards
  xpAwarded Int @default(0)

  likes    ContentLike[]
  comments ContentComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([contentType])
  @@index([passionArea])
  @@index([isFeatured])
}

model ContentLike {
  id        String         @id @default(cuid())
  contentId String
  content   StudentContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation("ContentLikes", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([contentId, userId])
  @@index([userId])
}

model ContentComment {
  id        String         @id @default(cuid())
  contentId String
  content   StudentContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation("ContentComments", fields: [authorId], references: [id])

  text      String
  createdAt DateTime @default(now())

  @@index([contentId])
  @@index([authorId])
}

// ============================================
// PHASE 2 ENGAGEMENT: RANDOM ACTS OF LEARNING (#26)
// ============================================

model RandomReward {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("RandomRewards", fields: [userId], references: [id])

  rewardType  String // "BONUS_XP", "SURPRISE_BADGE", "STREAK_SHIELD", "DOUBLE_XP"
  title       String
  description String?
  xpAmount    Int     @default(0)
  badgeId     String? // If reward is a badge

  isRedeemed Boolean   @default(false)
  redeemedAt DateTime?
  expiresAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRedeemed])
}

// ============================================
// PHASE 2 ENGAGEMENT: LEADERBOARDS (#29)
// ============================================

enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

model LeaderboardEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("LeaderboardEntries", fields: [userId], references: [id])

  category    String // "XP", "STREAKS", "CHALLENGES", "PRACTICE_HOURS", "CONTENT_CREATED"
  period      LeaderboardPeriod
  periodStart DateTime // Start of the period window
  score       Float             @default(0)
  rank        Int?
  passionArea String? // null = global, otherwise passion-specific

  updatedAt DateTime @updatedAt

  @@unique([userId, category, period, periodStart, passionArea])
  @@index([category, period, periodStart])
  @@index([category, period, score])
  @@index([userId])
}

// ============================================
// PHASE 2 ENGAGEMENT: MYSTERY REWARDS (#30)
// ============================================

model MysteryBox {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("MysteryBoxes", fields: [userId], references: [id])

  // Trigger
  triggerType   String // "STREAK_MILESTONE", "LEVEL_UP", "CHALLENGE_COMPLETE", "RANDOM_DROP"
  triggerDetail String? // e.g. "7_day_streak", "level_5"

  // Reward inside
  rewardType        String // "XP_BOOST", "RARE_BADGE", "TITLE", "THEME_UNLOCK", "STREAK_SHIELD"
  rewardTitle       String
  rewardDescription String?
  xpAmount          Int     @default(0)
  badgeId           String?
  metadata          Json? // Extra reward data

  // State
  isOpened  Boolean   @default(false)
  openedAt  DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isOpened])
}

// ============================================
// PHASE 2 ENGAGEMENT: STUDENT-NOMINATED CHALLENGES (#31)
// ============================================

enum NominationStatus {
  PENDING
  APPROVED
  REJECTED
  PROMOTED // Promoted to official challenge
}

model StudentNominatedChallenge {
  id          String @id @default(cuid())
  nominatorId String
  nominator   User   @relation("ChallengesNominated", fields: [nominatorId], references: [id])

  title             String
  description       String  @db.Text
  category          String? // Passion area
  difficulty        String  @default("MEDIUM") // EASY, MEDIUM, HARD
  suggestedXp       Int     @default(25)
  suggestedDuration String? // "1 day", "1 week"

  // Voting by community
  upvotes   Int @default(0)
  downvotes Int @default(0)

  // Status
  status              NominationStatus @default(PENDING)
  reviewedById        String?
  reviewNote          String?
  promotedChallengeId String? // ID of created Challenge if promoted

  votes NominationVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nominatorId])
  @@index([status])
  @@index([upvotes])
}

model NominationVote {
  id           String                    @id @default(cuid())
  nominationId String
  nomination   StudentNominatedChallenge @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  userId       String
  user         User                      @relation("NominationVotes", fields: [userId], references: [id])

  isUpvote Boolean

  createdAt DateTime @default(now())

  @@unique([nominationId, userId])
  @@index([userId])
}

// ============================================
// PASSION PROJECT INCUBATOR (Feature #35)
// ============================================

enum IncubatorPhase {
  IDEATION // Brainstorm, research, define the project
  PLANNING // Set milestones, gather resources, find mentor
  BUILDING // Active work on the project
  FEEDBACK // Submit for peer/mentor feedback rounds
  POLISHING // Refine based on feedback
  SHOWCASE // Present / pitch the final project
}

enum IncubatorCohortStatus {
  DRAFT
  ACCEPTING_APPLICATIONS
  IN_PROGRESS
  SHOWCASE_PHASE
  COMPLETED
  ARCHIVED
}

enum IncubatorAppStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  WAITLISTED
  REJECTED
  WITHDRAWN
}

enum IncubatorMilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
}

enum IncubatorLaunchStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// A cohort / batch of the incubator program
model IncubatorCohort {
  id          String  @id @default(cuid())
  name        String // e.g. "Spring 2026 Cohort"
  description String? @db.Text
  season      String? // FALL, WINTER, SPRING, SUMMER
  year        Int

  // Timing
  applicationOpen  DateTime?
  applicationClose DateTime?
  startDate        DateTime
  endDate          DateTime
  showcaseDate     DateTime?

  // Config
  maxProjects    Int                   @default(20)
  passionAreas   String[] // Legacy values kept for compatibility
  passionAreaIds String[]              @default([]) // Canonical PassionArea IDs
  status         IncubatorCohortStatus @default(DRAFT)

  // Relations
  applications       IncubatorApplication[]
  projects           IncubatorProject[]
  mentorAssignments  IncubatorMentor[]
  milestoneTemplates IncubatorMilestoneTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([year, season])
}

// Student application to join an incubator cohort
model IncubatorApplication {
  id        String          @id @default(cuid())
  cohortId  String
  cohort    IncubatorCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  studentId String
  student   User            @relation("IncubatorApplications", fields: [studentId], references: [id])

  // Application content
  projectTitle     String
  projectIdea      String  @db.Text // What do you want to build?
  passionArea      String // Legacy label kept for compatibility
  passionId        String?
  whyThisProject   String  @db.Text // Why does this matter to you?
  priorExperience  String? @db.Text // What have you done so far?
  goals            String  @db.Text // What do you hope to achieve?
  needsMentor      Boolean @default(true)
  mentorPreference String? // What kind of mentor help?

  // Review
  status          IncubatorAppStatus @default(SUBMITTED)
  reviewedById    String?
  reviewedBy      User?              @relation("IncubatorApplicationReviewedBy", fields: [reviewedById], references: [id])
  reviewNote      String?
  reviewRubric    Json?
  reviewedAt      DateTime?
  acceptedProject IncubatorProject?  @relation("IncubatorAcceptedFrom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cohortId, studentId])
  @@index([studentId])
  @@index([status])
  @@index([passionId])
  @@index([reviewedById])
}

// An active project within the incubator (wraps ProjectTracker with incubator context)
model IncubatorProject {
  id               String                @id @default(cuid())
  cohortId         String
  cohort           IncubatorCohort       @relation(fields: [cohortId], references: [id])
  studentId        String
  student          User                  @relation("IncubatorProjects", fields: [studentId], references: [id])
  projectTrackerId String? // Links to existing ProjectTracker
  applicationId    String?               @unique
  application      IncubatorApplication? @relation("IncubatorAcceptedFrom", fields: [applicationId], references: [id], onDelete: SetNull)

  // Project info
  title            String
  description      String         @db.Text
  passionArea      String // Legacy label kept for compatibility
  passionId        String?
  currentPhase     IncubatorPhase @default(IDEATION)
  mentorRequired   Boolean        @default(true)
  mentorAssignedAt DateTime?

  // Progress tracking
  ideationComplete  Boolean @default(false)
  planningComplete  Boolean @default(false)
  buildingComplete  Boolean @default(false)
  feedbackComplete  Boolean @default(false)
  polishingComplete Boolean @default(false)
  showcaseComplete  Boolean @default(false)

  // Pitch / Showcase
  pitchVideoUrl      String?
  pitchDeckUrl       String?
  finalShowcaseUrl   String?
  pitchDate          DateTime?
  launchStatus       IncubatorLaunchStatus @default(DRAFT)
  publicSlug         String?               @unique
  launchTitle        String?
  launchTagline      String?
  launchSummary      String?               @db.Text
  problemStatement   String?               @db.Text
  solutionSummary    String?               @db.Text
  targetAudience     String?
  buildHighlights    String[]              @default([])
  launchGalleryUrls  String[]              @default([])
  demoUrl            String?
  repositoryUrl      String?
  waitlistUrl        String?
  launchSubmittedAt  DateTime?
  launchApprovedAt   DateTime?
  launchApprovedById String?
  launchApprovedBy   User?                 @relation("IncubatorLaunchApprovedBy", fields: [launchApprovedById], references: [id])

  // XP
  xpEarned Int @default(0)

  // Relations
  mentors       IncubatorMentor[]
  updates       IncubatorUpdate[]
  milestones    IncubatorMilestone[]
  pitchFeedback PitchFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cohortId, studentId])
  @@index([cohortId])
  @@index([studentId])
  @@index([currentPhase])
  @@index([passionId])
  @@index([launchStatus])
  @@index([launchApprovedById])
}

model IncubatorMilestoneTemplate {
  id                     String               @id @default(cuid())
  cohortId               String
  cohort                 IncubatorCohort      @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  phase                  IncubatorPhase
  title                  String
  description            String?              @db.Text
  deliverableLabel       String?
  dueDayOffset           Int?
  order                  Int
  requiresMentorApproval Boolean              @default(false)
  requiredForPhase       Boolean              @default(true)
  milestones             IncubatorMilestone[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([cohortId, phase, order])
}

model IncubatorMilestone {
  id                     String                      @id @default(cuid())
  projectId              String
  project                IncubatorProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId             String?
  template               IncubatorMilestoneTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  phase                  IncubatorPhase
  title                  String
  description            String?                     @db.Text
  deliverableLabel       String?
  order                  Int
  dueDate                DateTime?
  requiresMentorApproval Boolean                     @default(false)
  requiredForPhase       Boolean                     @default(true)
  status                 IncubatorMilestoneStatus    @default(NOT_STARTED)
  submissionNote         String?                     @db.Text
  artifactUrls           String[]                    @default([])
  submittedAt            DateTime?
  approvedAt             DateTime?
  approvedById           String?
  approvedBy             User?                       @relation("IncubatorMilestonesApprovedBy", fields: [approvedById], references: [id])
  completedAt            DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  @@index([projectId, phase, order])
  @@index([status])
  @@index([approvedById])
}

// Mentor assignment for incubator projects
model IncubatorMentor {
  id        String           @id @default(cuid())
  cohortId  String
  cohort    IncubatorCohort  @relation(fields: [cohortId], references: [id])
  projectId String
  project   IncubatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentorId  String
  mentor    User             @relation("IncubatorMentoring", fields: [mentorId], references: [id])

  role     String  @default("MENTOR") // MENTOR, ADVISOR, PEER_MENTOR
  notes    String?
  isActive Boolean @default(true)

  assignedAt DateTime @default(now())

  @@unique([projectId, mentorId])
  @@index([mentorId])
  @@index([cohortId])
}

// Progress updates / check-ins posted by students
model IncubatorUpdate {
  id        String           @id @default(cuid())
  projectId String
  project   IncubatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User             @relation("IncubatorUpdates", fields: [authorId], references: [id])

  title      String
  content    String         @db.Text
  phase      IncubatorPhase // Which phase this update is for
  mediaUrls  String[]
  hoursSpent Float?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

// Feedback on pitches / showcases
model PitchFeedback {
  id         String           @id @default(cuid())
  projectId  String
  project    IncubatorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User             @relation("PitchFeedbackGiven", fields: [reviewerId], references: [id])

  // Scoring (1-5)
  clarityScore   Int? // How clear is the project vision?
  passionScore   Int? // How passionate is the student?
  executionScore Int? // How well did they execute?
  impactScore    Int? // What's the potential impact?
  overallScore   Int?

  strengths     String? @db.Text
  improvements  String? @db.Text
  encouragement String? @db.Text

  createdAt DateTime @default(now())

  @@unique([projectId, reviewerId])
  @@index([projectId])
  @@index([reviewerId])
}

// ============================================
// PHASE 13: REAL-WORLD CONNECTIONS
// ============================================

enum InternshipType {
  IN_PERSON
  REMOTE
  HYBRID
}

enum InternshipStatus {
  OPEN
  CLOSED
  FILLED
}

enum ApplicationState {
  APPLIED
  REVIEWING
  INTERVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ServiceProjectStatus {
  RECRUITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CertificationStatus {
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  CERTIFIED
  EXPIRED
}

enum ExchangeListingType {
  OFFER
  REQUEST
}

enum ExchangeListingStatus {
  AVAILABLE
  PENDING
  CLAIMED
  COMPLETED
}

// Portfolio Templates
model PortfolioTemplate {
  id              String  @id @default(cuid())
  name            String
  description     String
  passionArea     String? // null = general template
  previewImageUrl String?

  // Template structure
  layout      String @default("grid") // "grid", "timeline", "showcase", "minimal"
  colorScheme String @default("default") // "default", "dark", "warm", "cool", "vibrant"
  sections    Json   @default("[]") // [{title, type, placeholder, order}]

  // Tips for this template
  tips Json @default("[]") // ["Tip 1", "Tip 2"]

  isActive   Boolean @default(true)
  order      Int     @default(0)
  usageCount Int     @default(0)

  createdAt DateTime @default(now())

  @@index([passionArea])
  @@index([isActive, order])
}

// Internship / Opportunity Board
model InternshipListing {
  id           String  @id @default(cuid())
  title        String
  organization String
  description  String  @db.Text
  passionArea  String?

  type         InternshipType
  location     String? // City, State or "Remote"
  duration     String? // "6 weeks", "Summer 2025"
  hoursPerWeek Int?
  isPaid       Boolean        @default(false)
  compensation String? // "$15/hr", "Stipend"

  // Requirements
  ageRange       String? // "14-18"
  requirements   Json    @default("[]") // ["Portfolio required", "Interview"]
  applicationUrl String? // External link

  // Contact
  contactName  String?
  contactEmail String?

  status   InternshipStatus @default(OPEN)
  deadline DateTime?

  postedById String
  postedBy   User   @relation("InternshipListingsPosted", fields: [postedById], references: [id])

  applications InternshipApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([passionArea])
  @@index([type])
  @@index([deadline])
}

model InternshipApplication {
  id        String            @id @default(cuid())
  listingId String
  listing   InternshipListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  studentId String
  student   User              @relation("InternshipApplications", fields: [studentId], references: [id])

  coverLetter  String? @db.Text
  portfolioUrl String?
  resumeUrl    String?

  status      ApplicationState @default(APPLIED)
  reviewNotes String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, studentId])
  @@index([studentId])
  @@index([status])
}

// Service Projects (Community Impact)
model ServiceProject {
  id          String  @id @default(cuid())
  title       String
  description String  @db.Text
  passionArea String?

  // Organization
  partnerOrg String? // "Local Library", "Habitat for Humanity"
  location   String?
  chapterId  String?

  // Timing
  startDate      DateTime?
  endDate        DateTime?
  totalHoursGoal Int? // Target volunteer hours

  // Impact tracking
  currentHours     Int     @default(0)
  volunteersNeeded Int     @default(5)
  impactSummary    String? @db.Text

  // Rewards
  xpReward              Int     @default(50)
  certificateOnComplete Boolean @default(false)

  status ServiceProjectStatus @default(RECRUITING)

  createdById String
  createdBy   User   @relation("ServiceProjectsCreated", fields: [createdById], references: [id])

  volunteers ServiceVolunteer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([passionArea])
  @@index([chapterId])
}

model ServiceVolunteer {
  id        String         @id @default(cuid())
  projectId String
  project   ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studentId String
  student   User           @relation("ServiceVolunteering", fields: [studentId], references: [id])

  hoursLogged Int       @default(0)
  role        String? // "Team Lead", "Volunteer", "Coordinator"
  reflection  String?   @db.Text
  completedAt DateTime?

  joinedAt DateTime @default(now())

  @@unique([projectId, studentId])
  @@index([studentId])
}

// Instructor Certifications
model InstructorCertification {
  id           String @id @default(cuid())
  instructorId String
  instructor   User   @relation("InstructorCertifications", fields: [instructorId], references: [id])

  certType    String // "Foundational", "Advanced", "Specialist"
  passionArea String?

  // Requirements tracking
  requirements   Json  @default("[]") // [{name, completed, evidence}]
  totalRequired  Int   @default(5)
  totalCompleted Int   @default(0)
  progressPct    Float @default(0)

  // Submission & Review
  status         CertificationStatus @default(IN_PROGRESS)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewerNotes  String?
  certificateUrl String?

  // Validity
  certifiedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instructorId, certType, passionArea])
  @@index([instructorId])
  @@index([status])
}

// Resource Exchange (Peer-to-Peer)
model ResourceExchangeListing {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("ResourceExchangeListings", fields: [userId], references: [id])

  title       String
  description String?
  type        ExchangeListingType // OFFER or REQUEST
  category    String // "Instrument", "Art Supplies", "Books", "Equipment", "Software"
  passionArea String?
  imageUrl    String?

  condition      String? // "New", "Like New", "Good", "Fair"
  estimatedValue Float?

  status ExchangeListingStatus @default(AVAILABLE)

  requests ResourceExchangeRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([category])
  @@index([passionArea])
  @@index([userId])
}

model ResourceExchangeRequest {
  id          String                  @id @default(cuid())
  listingId   String
  listing     ResourceExchangeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                    @relation("ResourceExchangeRequests", fields: [requesterId], references: [id])

  message String?
  status  String  @default("PENDING") // PENDING, ACCEPTED, DECLINED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, requesterId])
  @@index([requesterId])
}

// ============================================
// PATHWAY INTEGRATION MODELS
// ============================================

/// Cohort of students progressing through a pathway together
model PathwayCohort {
  id        String         @id @default(cuid())
  pathwayId String
  pathway   Pathway        @relation("PathwayCohorts", fields: [pathwayId], references: [id])
  name      String // e.g. "Spring 2026 Cohort"
  startDate DateTime?
  endDate   DateTime?
  members   CohortMember[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([pathwayId])
}

/// Membership of a user in a pathway cohort
model CohortMember {
  id       String        @id @default(cuid())
  cohortId String
  cohort   PathwayCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation("PathwayCohortMemberships", fields: [userId], references: [id])
  joinedAt DateTime      @default(now())

  @@unique([cohortId, userId])
  @@index([userId])
}

/// Student reflection written after completing a pathway step
model PathwayReflection {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("PathwayReflections", fields: [userId], references: [id])
  pathwayId       String
  pathway         Pathway  @relation("PathwayReflections", fields: [pathwayId], references: [id])
  stepOrder       Int // which step this reflection is for
  content         String // the reflection text
  visibleToMentor Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([userId, pathwayId])
}

/// Milestone event tied to a pathway step (e.g. workshops, showcases)
model PathwayEvent {
  id                String                     @id @default(cuid())
  pathwayId         String
  pathway           Pathway                    @relation("PathwayEvents", fields: [pathwayId], references: [id])
  chapterId         String?
  chapter           Chapter?                   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  pathwayStepId     String?
  pathwayStep       PathwayStep?               @relation(fields: [pathwayStepId], references: [id], onDelete: SetNull)
  title             String
  description       String?
  eventDate         DateTime?
  locationOrLink    String?
  maxAttendees      Int?
  requiredStepOrder Int? // student must have reached this step to register
  registrations     PathwayEventRegistration[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([pathwayId])
  @@index([chapterId])
  @@index([pathwayStepId])
}

/// Student registration for a pathway event
model PathwayEventRegistration {
  id           String       @id @default(cuid())
  eventId      String
  event        PathwayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String
  registeredAt DateTime     @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

/// Instructor specialization in a pathway (for mentor matching)
model InstructorPathwaySpec {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("InstructorPathwaySpecs", fields: [userId], references: [id])
  pathwayId String
  pathway   Pathway  @relation("PathwayInstructorSpecs", fields: [pathwayId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, pathwayId])
  @@index([pathwayId])
}

/// Chapter-level control over which pathways are visible and featured
model ChapterPathway {
  id           String                  @id @default(cuid())
  chapterId    String
  chapter      Chapter                 @relation(fields: [chapterId], references: [id])
  pathwayId    String
  pathway      Pathway                 @relation("PathwayChapterConfigs", fields: [pathwayId], references: [id])
  isAvailable  Boolean                 @default(true) // chapter can hide a global pathway
  isFeatured   Boolean                 @default(false) // featured pathways appear first
  runStatus    ChapterPathwayRunStatus @default(NOT_OFFERED)
  ownerId      String?
  owner        User?                   @relation("ChapterPathwayOwner", fields: [ownerId], references: [id])
  displayOrder Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([chapterId, pathwayId])
  @@index([chapterId])
}

model PathwayFallbackRequest {
  id               String                       @id @default(cuid())
  studentId        String
  student          User                         @relation("PathwayFallbackRequestStudent", fields: [studentId], references: [id])
  pathwayId        String
  pathway          Pathway                      @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  pathwayStepId    String
  pathwayStep      PathwayStep                  @relation(fields: [pathwayStepId], references: [id], onDelete: Cascade)
  fromChapterId    String?
  fromChapter      Chapter?                     @relation("PathwayFallbackFromChapter", fields: [fromChapterId], references: [id], onDelete: SetNull)
  toChapterId      String?
  toChapter        Chapter?                     @relation("PathwayFallbackToChapter", fields: [toChapterId], references: [id], onDelete: SetNull)
  targetOfferingId String?
  targetOffering   ClassOffering?               @relation(fields: [targetOfferingId], references: [id], onDelete: SetNull)
  status           PathwayFallbackRequestStatus @default(PENDING)
  note             String?
  reviewedById     String?
  reviewedBy       User?                        @relation("PathwayFallbackReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([studentId])
  @@index([pathwayId])
  @@index([pathwayStepId])
  @@index([targetOfferingId])
  @@index([status])
}

// ============================================
// MENTORSHIP PROGRAM MODELS
// ============================================

/// A goal defined for a specific YPP mentee role, authored by the Mentor Committee.
/// Used as the basis for both self-reflections and goal reviews.
model MentorshipProgramGoal {
  id          String         @id @default(cuid())
  title       String
  description String?
  roleType    MenteeRoleType
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdById String
  createdBy   User           @relation("MentorshipProgramGoalsCreated", fields: [createdById], references: [id])

  selfReflectionGoalResponses SelfReflectionGoalResponse[]
  goalReviewRatings           GoalReviewRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleType])
}

/// Monthly self-reflection submitted by a mentee (Instructor / CP / Global Leadership).
/// Covers 5 sections from the document. Per-goal responses stored in SelfReflectionGoalResponse.
model MonthlySelfReflection {
  id           String     @id @default(cuid())
  menteeId     String
  mentee       User       @relation("SelfReflectionsSubmitted", fields: [menteeId], references: [id])
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])

  /// First day of the month this reflection covers
  cycleMonth  DateTime
  /// Sequential cycle number (1, 2, 3…); multiples of 3 are quarterly cycles
  cycleNumber Int

  // Section 1 — Overall Reflection
  overallReflection String

  // Section 2 — Engagement & Fulfillment
  engagementOverall String
  workingWell       String
  supportNeeded     String
  mentorHelpfulness String

  // Section 3 — Leadership Team Collaboration
  collaborationAssessment   String
  teamMembersAboveAndBeyond String?
  collaborationImprovements String?

  // Section 4 — Goal Progress (per-goal responses below)
  goalResponses SelfReflectionGoalResponse[]

  // Section 5 — Additional Reflections
  additionalReflections String?

  submittedAt DateTime @default(now())

  goalReview MentorGoalReview?

  @@unique([mentorshipId, cycleNumber])
  @@index([menteeId])
  @@index([mentorshipId])
}

/// Per-goal answers within a monthly self-reflection (Section 4).
model SelfReflectionGoalResponse {
  id           String                @id @default(cuid())
  reflectionId String
  reflection   MonthlySelfReflection @relation(fields: [reflectionId], references: [id])
  goalId       String
  goal         MentorshipProgramGoal @relation(fields: [goalId], references: [id])

  progressMade      String
  objectiveAchieved Boolean
  accomplishments   String
  blockers          String?
  nextMonthPlans    String

  createdAt DateTime @default(now())

  @@unique([reflectionId, goalId])
}

/// Mentor's monthly goal review of a mentee, submitted for Mentor Committee Chair approval
/// before being released to the mentee.
model MentorGoalReview {
  id           String     @id @default(cuid())
  mentorId     String
  mentor       User       @relation("GoalReviewsAuthored", fields: [mentorId], references: [id])
  menteeId     String
  mentee       User       @relation("GoalReviewsReceived", fields: [menteeId], references: [id])
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])

  selfReflectionId String                @unique
  selfReflection   MonthlySelfReflection @relation(fields: [selfReflectionId], references: [id])

  /// First day of the month this review covers
  cycleMonth  DateTime
  /// Matches the self-reflection cycleNumber; divisible by 3 → quarterly review
  cycleNumber Int
  isQuarterly Boolean  @default(false)

  // Overall rating — drives automatic point calculation on approval
  overallRating GoalRatingColor

  // Per-goal ratings
  goalRatings GoalReviewRating[]

  // Required written sections
  overallComments String // Overall impression, strengths, dev areas, peer collab notes
  planOfAction    String // High-level objectives & action items for next month

  // Quarterly-only fields (unlocked every 3rd cycle; filled by full Mentor Committee)
  projectedFuturePath String?
  promotionReadiness  String?

  // Approval workflow
  status             GoalReviewStatus @default(DRAFT)
  chairReviewerId    String?
  chairReviewer      User?            @relation("GoalReviewsChairApproved", fields: [chairReviewerId], references: [id])
  chairComments      String?
  chairApprovedAt    DateTime?
  releasedToMenteeAt DateTime?

  // Character & Culture bonus points (mentor awards 0–25, chair can adjust)
  bonusPoints              Int     @default(0)
  bonusReason              String?
  chairAdjustedBonusPoints Int?

  // Points awarded (auto-set on chair approval based on overallRating × roleType table)
  pointsAwarded Int?

  pointLog         AchievementPointLog?
  feedbackRequests QuarterlyFeedbackRequest[] @relation("FeedbackRequests")

  /// True if the mentor used an AI-generated draft as a starting point for any comment field.
  aiDraftUsed Boolean @default(false)

  // G&R integration
  goalSnapshots  MentorGoalReviewGoalSnapshot[]
  spawnedGRGoals GRDocumentGoal[]               @relation("GRGoalsSpawnedByReview")
  reviewAck      MenteeReviewAck?

  /// Draft next-month goal proposals persisted between form saves. Cleared on submit.
  nextMonthGoalDraftsJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menteeId])
  @@index([mentorId])
  @@index([mentorshipId])
}

/// Per-goal color rating within a mentor goal review.
model GoalReviewRating {
  id               String                 @id @default(cuid())
  reviewId         String
  review           MentorGoalReview       @relation(fields: [reviewId], references: [id])
  /// Legacy: rating against the flat MentorshipProgramGoal list. Kept as fallback
  /// for reviews where the mentee had no active G&R document. Prefer grDocumentGoalId.
  goalId           String?
  goal             MentorshipProgramGoal? @relation(fields: [goalId], references: [id])
  /// Preferred: rating against the mentee's actual per-person G&R goal.
  grDocumentGoalId String?
  grDocumentGoal   GRDocumentGoal?        @relation(fields: [grDocumentGoalId], references: [id])

  rating   GoalRatingColor
  comments String?

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([grDocumentGoalId])
}

/// Running achievement point total and current award tier per user.
/// One record per user; updated automatically when a goal review is approved.
model AchievementPointSummary {
  id                    String                @id @default(cuid())
  userId                String                @unique
  user                  User                  @relation("AchievementPointSummary", fields: [userId], references: [id])
  totalPoints           Int                   @default(0)
  currentTier           AchievementAwardTier?
  volunteerHoursAwarded Int                   @default(0)

  pointLogs   AchievementPointLog[]
  nominations AwardNomination[]

  updatedAt DateTime @updatedAt
}

/// One entry per approved goal review cycle recording points earned.
model AchievementPointLog {
  id        String                  @id @default(cuid())
  summaryId String
  summary   AchievementPointSummary @relation(fields: [summaryId], references: [id])
  reviewId  String                  @unique
  review    MentorGoalReview        @relation(fields: [reviewId], references: [id])

  points     Int
  /// Human-readable reason e.g. "Achieved (Green) – Instructor" or "Character & Culture bonus"
  reason     String?
  cycleMonth DateTime

  createdAt DateTime @default(now())

  @@index([summaryId])
}

/// Nomination for a YPP Achievement Award (Bronze → Lifetime).
/// Gold and Lifetime require Board approval in addition to Chair approval.
model AwardNomination {
  id          String                  @id @default(cuid())
  summaryId   String
  summary     AchievementPointSummary @relation(fields: [summaryId], references: [id])
  nomineeId   String
  nominee     User                    @relation("AwardNominations", fields: [nomineeId], references: [id])
  nominatedBy String
  nominator   User                    @relation("AwardNominationsGiven", fields: [nominatedBy], references: [id])

  tier   AchievementAwardTier
  status AwardNominationStatus @default(PENDING_CHAIR)

  chairApproverId String?
  chairApprover   User?     @relation("AwardNominationsChairApproved", fields: [chairApproverId], references: [id])
  chairApprovedAt DateTime?

  boardApproverId String?
  boardApprover   User?     @relation("AwardNominationsBoardApproved", fields: [boardApproverId], references: [id])
  boardApprovedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nomineeId])
}

/// Designates which user is the Mentor Committee Chair for a given mentee role group.
/// Chairs approve goal reviews and award nominations for their role group.
model MentorCommitteeChair {
  id       String         @id @default(cuid())
  userId   String
  user     User           @relation("MentorCommitteeChairRoles", fields: [userId], references: [id])
  roleType MenteeRoleType
  isActive Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleType])
  @@index([roleType])
}

// ============================================
// INSTRUCTOR CONTENT CREATION MODELS
// ============================================

model Rubric {
  id               String            @id @default(cuid())
  title            String
  description      String?
  chapterId        String?
  chapter          Chapter?          @relation(fields: [chapterId], references: [id])
  createdById      String
  createdBy        User              @relation(fields: [createdById], references: [id])
  criteria         RubricCriterion[]
  assignments      Assignment[]      @relation("AssignmentRubric")
  classAssignments ClassAssignment[] @relation("ClassAssignmentRubric")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([createdById])
  @@index([chapterId])
}

model RubricCriterion {
  id          String   @id @default(cuid())
  rubricId    String
  rubric      Rubric   @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  name        String
  description String?
  pointValue  Int      @default(10)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([rubricId, sortOrder])
}

model InstructorCohort {
  id          String                   @id @default(cuid())
  name        String
  chapterId   String
  chapter     Chapter                  @relation(fields: [chapterId], references: [id])
  createdById String
  createdBy   User                     @relation("InstructorCohortsCreated", fields: [createdById], references: [id])
  members     InstructorCohortMember[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([chapterId])
  @@index([createdById])
}

model InstructorCohortMember {
  id       String           @id @default(cuid())
  cohortId String
  cohort   InstructorCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId   String
  user     User             @relation("InstructorCohortMemberships", fields: [userId], references: [id])
  addedAt  DateTime         @default(now())

  @@unique([cohortId, userId])
  @@index([userId])
}

// ============================================
// PASSION LAB PROGRESS TRACKING
// ============================================

model PassionLabProgress {
  id              String         @id @default(cuid())
  programId       String
  program         SpecialProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  studentId       String
  student         User           @relation("PassionLabProgressRecords", fields: [studentId], references: [id])
  sessionIndex    Int // 0-based index into sessionTopics array
  status          String         @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  artifactUrl     String?
  artifactNotes   String?        @db.Text
  instructorNotes String?        @db.Text
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([programId, studentId, sessionIndex])
  @@index([programId])
  @@index([studentId])
}

// ============================================
// COMPETITION PREP TIMELINE
// ============================================

model CompetitionPrepMilestone {
  id            String              @id @default(cuid())
  competitionId String
  competition   SeasonalCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  title         String
  description   String?             @db.Text
  dueDate       DateTime
  milestoneType String              @default("CHECKPOINT") // CHECKPOINT, PRACTICE_SUBMISSION, WORKSHOP, REVIEW
  resources     String?             @db.Text
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())

  studentProgress CompetitionPrepProgress[]

  @@index([competitionId, sortOrder])
}

model CompetitionPrepProgress {
  id              String                   @id @default(cuid())
  milestoneId     String
  milestone       CompetitionPrepMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  studentId       String
  student         User                     @relation("CompetitionPrepProgressRecords", fields: [studentId], references: [id])
  status          String                   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  submissionUrl   String?
  instructorNotes String?                  @db.Text
  completedAt     DateTime?
  createdAt       DateTime                 @default(now())

  @@unique([milestoneId, studentId])
  @@index([milestoneId])
  @@index([studentId])
}

// ============================================
// CHAPTER PRESIDENT APPLICATIONS
// ============================================

model ChapterPresidentApplication {
  id          String                            @id @default(cuid())
  applicantId String                            @unique
  applicant   User                              @relation("ChapterPresidentApplications", fields: [applicantId], references: [id])
  chapterId   String?
  chapter     Chapter?                          @relation(fields: [chapterId], references: [id])
  status      ChapterPresidentApplicationStatus @default(SUBMITTED)

  // --- Core application essays ---
  leadershipExperience String @db.Text
  chapterVision        String @db.Text
  availability         String

  // --- Personal Information ---
  legalName          String?
  preferredFirstName String?
  phoneNumber        String?
  dateOfBirth        String?
  hearAboutYPP       String?

  // --- Location ---
  city          String?
  stateProvince String?
  zipCode       String?
  country       String?

  // --- Academic Background ---
  schoolName     String?
  graduationYear Int?
  gpa            String?
  classRank      String?

  // --- Chapter-specific essays ---
  whyChapterPresident String? @db.Text
  partnerSchool       String?
  recruitmentPlan     String? @db.Text
  launchPlan          String? @db.Text
  extracurriculars    String? @db.Text
  priorOrganizing     String? @db.Text
  specialSkills       String? @db.Text

  // --- Referral ---
  referralEmails String? @db.Text

  // --- Supporting document ---
  documentUrl String? // uploaded résumé / credentials / awards

  // --- Instructor information (optional) ---
  instructorApplicantPosition String? // "Chapter President Only" | "Instructor Only" | "Both"
  classInMind                 String? // class they envision teaching (or N/A)
  instructorTeachingDesc      String? @db.Text // 250-word teaching/empowerment description

  // --- Availability details ---
  hoursPerWeek       Int?
  preferredStartDate String?

  // --- Optional demographics ---
  ethnicity String?

  // --- Reviewer scoring rubric ---
  scoreLeadership   Int?
  scoreVision       Int?
  scoreOrganization Int?
  scoreCommitment   Int?
  scoreFit          Int?

  // --- Interview-specific scoring rubric ---
  scoreCommunication Int?
  interviewSummary   String? @db.Text

  // --- Review workflow ---
  reviewerId           String?
  reviewer             User?                     @relation("ChapterPresidentApplicationReviews", fields: [reviewerId], references: [id])
  reviewerNotes        String?                   @db.Text
  infoRequest          String?                   @db.Text
  applicantResponse    String?                   @db.Text
  rejectionReason      String?                   @db.Text
  interviewScheduledAt DateTime?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  customResponses      ApplicationFormResponse[] @relation("CPAppFormResponses")
  cohortId             String?
  cohort               ApplicationCohort?        @relation("CPAppCohort", fields: [cohortId], references: [id])

  // --- Automated scheduling ---
  availabilityWindows ApplicantAvailabilityWindow[] @relation("CPAvailabilityWindows")
  schedulingNoMatchAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reviewerId])
  @@index([chapterId])
  @@index([cohortId])
  @@index([graduationYear])
  @@index([stateProvince])
}

// ============================================
// APPLICATION FORM BUILDER
// ============================================

model ApplicationFormTemplate {
  id        String                 @id @default(cuid())
  name      String
  roleType  PositionType
  isActive  Boolean                @default(true)
  fields    ApplicationFormField[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([roleType, isActive])
}

model ApplicationFormField {
  id          String                    @id @default(cuid())
  templateId  String
  template    ApplicationFormTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label       String
  fieldType   ApplicationFormFieldType
  required    Boolean                   @default(true)
  placeholder String?
  helpText    String?
  options     String?                   @db.Text // JSON array for MULTIPLE_CHOICE
  sortOrder   Int                       @default(0)
  responses   ApplicationFormResponse[]
  createdAt   DateTime                  @default(now())

  @@index([templateId, sortOrder])
}

model ApplicationFormResponse {
  id                            String                       @id @default(cuid())
  fieldId                       String
  field                         ApplicationFormField         @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  instructorApplicationId       String?
  instructorApplication         InstructorApplication?       @relation("InstructorAppFormResponses", fields: [instructorApplicationId], references: [id], onDelete: Cascade)
  chapterPresidentApplicationId String?
  chapterPresidentApplication   ChapterPresidentApplication? @relation("CPAppFormResponses", fields: [chapterPresidentApplicationId], references: [id], onDelete: Cascade)
  value                         String                       @db.Text
  fileUrl                       String?
  createdAt                     DateTime                     @default(now())

  @@index([fieldId])
  @@index([instructorApplicationId])
  @@index([chapterPresidentApplicationId])
}

// ============================================
// APPLICATION COHORTS
// ============================================

model ApplicationCohort {
  id                           String                        @id @default(cuid())
  name                         String
  type                         ApplicationCohortType
  roleType                     PositionType
  createdById                  String
  createdBy                    User                          @relation("ApplicationCohortsCreated", fields: [createdById], references: [id])

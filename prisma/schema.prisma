/// Recurring availability slots for college advisors
model AdvisorAvailabilitySlot {
  id            String         @id @default(cuid())
  advisorId     String
  advisor       CollegeAdvisor @relation(fields: [advisorId], references: [id])
  dayOfWeek     Int // 0=Sunday, 6=Saturday
  startTime     String // "14:00"
  endTime       String // "15:00"
  timezone      String         @default("America/New_York")
  slotDuration  Int            @default(30)
  bufferMinutes Int            @default(10)
  meetingLink   String?
  locationLabel String?
  isRecurring   Boolean        @default(true)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  overrides AdvisorAvailabilityOverride[]

  @@index([advisorId, isActive])
}

model AdvisorAvailabilityOverride {
  id            String                            @id @default(cuid())
  advisorId     String
  advisor       CollegeAdvisor                    @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  slotId        String?
  slot          AdvisorAvailabilitySlot?          @relation(fields: [slotId], references: [id], onDelete: SetNull)
  type          InterviewAvailabilityOverrideType
  startsAt      DateTime
  endsAt        DateTime
  timezone      String                            @default("America/New_York")
  slotDuration  Int?
  bufferMinutes Int?
  meetingLink   String?
  locationLabel String?
  note          String?
  isActive      Boolean                           @default(true)
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  @@index([advisorId, isActive, startsAt])
  @@index([slotId])
}


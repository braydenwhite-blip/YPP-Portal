// ============================================
// COURSE & PATHWAY MODELS
// ============================================

model Course {
  id                 String                  @id @default(cuid())
  title              String
  description        String
  format             CourseFormat
  level              CourseLevel?
  interestArea       String
  isVirtual          Boolean                 @default(false)
  maxEnrollment      Int? // null = unlimited
  chapterId          String?
  chapter            Chapter?                @relation(fields: [chapterId], references: [id])
  leadInstructorId   String?
  leadInstructor     User?                   @relation("InstructorCourses", fields: [leadInstructorId], references: [id])
  enrollments        Enrollment[]
  waitlistEntries    WaitlistEntry[]
  pathwaySteps       PathwayStep[]
  feedback           Feedback[]
  parentFeedbacks    ParentChapterFeedback[]
  certificates       Certificate[]
  attendanceSessions AttendanceSession[]
  resources          Resource[]
  studyGroups        StudyGroup[]
  learningNotes      LearningNote[]
  assignments        Assignment[]
  reviews            CourseReview[]
  portfolioItems     PortfolioItem[]
  proposals          CourseProposal[]
  coInstructors      CourseInstructor[]
  observations       PeerObservation[]
  substituteRequests SubstituteRequest[]
  curriculumFeedback CurriculumFeedback[]
  studentSpotlights  StudentSpotlight[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model Pathway {
  id                String        @id @default(cuid())
  name              String
  description       String
  interestArea      String
  isActive          Boolean       @default(true)
  sequenceBlueprint Json?
  createdById       String?
  createdBy         User?         @relation("PathwaysCreated", fields: [createdById], references: [id])
  steps             PathwayStep[]
  certificates      Certificate[]

  // Pathway Integration Relations
  cohorts          PathwayCohort[]          @relation("PathwayCohorts")
  reflections      PathwayReflection[]      @relation("PathwayReflections")
  events           PathwayEvent[]           @relation("PathwayEvents")
  instructorSpecs  InstructorPathwaySpec[]  @relation("PathwayInstructorSpecs")
  chapterConfigs   ChapterPathway[]         @relation("PathwayChapterConfigs")
  fallbackRequests PathwayFallbackRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PathwayStep {
  id          String                @id @default(cuid())
  pathwayId   String
  stepOrder   Int
  unlockType  PathwayStepUnlockType @default(AUTO)
  stepDetails Json?

  // Content pointer — one of these should be set
  courseId         String?
  classTemplateId  String?
  specialProgramId String?
  title            String? // for standalone steps with no linked content

  // DAG prerequisites: this step requires ALL of these to be completed
  prerequisites PathwayStep[] @relation("StepPrerequisites")
  dependents    PathwayStep[] @relation("StepPrerequisites")

  // Visual positioning for the DAG editor
  positionX Float? @default(0)
  positionY Float? @default(0)

  pathway          Pathway                  @relation(fields: [pathwayId], references: [id])
  course           Course?                  @relation(fields: [courseId], references: [id])
  classTemplate    ClassTemplate?           @relation("ClassTemplateSteps", fields: [classTemplateId], references: [id])
  specialProgram   SpecialProgram?          @relation("SpecialProgramSteps", fields: [specialProgramId], references: [id])
  stepUnlocks      PathwayStepUnlock[]
  classOfferings   ClassOffering[]          @relation("PathwayStepOfferings")
  pathwayEvents    PathwayEvent[]
  fallbackRequests PathwayFallbackRequest[]

  @@index([pathwayId, stepOrder])
}

model PathwayStepUnlock {
  id         String      @id @default(cuid())
  stepId     String
  step       PathwayStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation("PathwayStepUnlocks", fields: [userId], references: [id])
  unlockedAt DateTime    @default(now())

  @@unique([stepId, userId])
}

enum PathwayStepUnlockType {
  AUTO
  MANUAL
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  status    String   @default("ENROLLED")
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// TRAINING MODELS
// ============================================

model TrainingModule {
  id            String             @id @default(cuid())
  contentKey    String?            @unique
  title         String
  description   String
  materialUrl   String?
  materialNotes String?
  type          TrainingModuleType
  required      Boolean            @default(true)
  sortOrder     Int

  // Video Integration (Legacy - kept for backwards compatibility)
  videoUrl         String?
  videoProvider    VideoProvider?
  videoDuration    Int? // Duration in seconds
  videoThumbnail   String?
  requiresQuiz     Boolean        @default(false)
  requiresEvidence Boolean        @default(false)
  passScorePct     Int            @default(80)

  // New: Multiple videos and resources
  videos           TrainingVideo[]
  resources        TrainingResource[]
  discussions      ModuleDiscussion[]
  estimatedMinutes Int?

  assignments         TrainingAssignment[]
  videoProgress       VideoProgress[]
  checkpoints         TrainingCheckpoint[]
  quizQuestions       TrainingQuizQuestion[]
  quizAttempts        TrainingQuizAttempt[]
  evidenceSubmissions TrainingEvidenceSubmission[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  LOOM
  CUSTOM
}

model TrainingAssignment {
  id          String          @id @default(cuid())
  userId      String
  moduleId    String
  cohortId    String?
  status      TrainingStatus  @default(NOT_STARTED)
  completedAt DateTime?
  user        User            @relation(fields: [userId], references: [id])
  module      TrainingModule  @relation(fields: [moduleId], references: [id])
  cohort      TrainingCohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, moduleId])
  @@index([cohortId])
}

model VideoProgress {
  id             String         @id @default(cuid())
  userId         String
  moduleId       String
  user           User           @relation(fields: [userId], references: [id])
  module         TrainingModule @relation(fields: [moduleId], references: [id])
  watchedSeconds Int            @default(0)
  completed      Boolean        @default(false)
  lastPosition   Int            @default(0) // Last watched position in seconds
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, moduleId])
}

model InstructorApproval {
  id           String                    @id @default(cuid())
  instructorId String
  status       ApprovalStatus            @default(TRAINING_IN_PROGRESS)
  notes        String?
  instructor   User                      @relation(fields: [instructorId], references: [id])
  levels       InstructorApprovalLevel[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model InstructorApprovalLevel {
  id         String             @id @default(cuid())
  approvalId String
  level      CourseLevel
  approvedAt DateTime           @default(now())
  approval   InstructorApproval @relation(fields: [approvalId], references: [id])
}

model InstructorApplication {
  id          String                      @id @default(cuid())
  applicantId String                      @unique
  applicant   User                        @relation("InstructorApplications", fields: [applicantId], references: [id])
  status      InstructorApplicationStatus @default(SUBMITTED)

  // --- Core application responses ---
  motivation         String? @db.Text
  motivationVideoUrl String?
  teachingExperience String  @db.Text
  availability       String

  // --- Personal Information ---
  legalName          String?
  preferredFirstName String?
  phoneNumber        String?
  dateOfBirth        String?
  hearAboutYPP       String?

  // --- Location ---
  city          String?
  stateProvince String?
  zipCode       String?
  country       String?

  // --- Academic Background ---
  schoolName         String?
  graduationYear     Int?
  subjectsOfInterest String?

  // --- Referral ---
  referralEmails String? @db.Text

  // --- Availability details ---
  hoursPerWeek       Int?
  preferredStartDate String?

  // --- Reviewer scoring rubric ---
  scoreAcademic      Int?
  scoreCommunication Int?
  scoreLeadership    Int?
  scoreMotivation    Int?
  scoreFit           Int?

  // --- Curriculum review scoring rubric (replaces generic scores for instructor eval) ---
  scoreSubjectKnowledge    Int?
  scoreTeachingMethodology Int?
  scoreCurriculumAlignment Int?
  curriculumReviewSummary  String? @db.Text

  // --- Review workflow ---
  decisionRecommendation String?
  actionDueDate          DateTime?
  reviewerId             String?
  reviewer               User?                         @relation("InstructorApplicationReviews", fields: [reviewerId], references: [id])
  reviewerNotes          String?                       @db.Text
  infoRequest            String?                       @db.Text
  applicantResponse      String?                       @db.Text
  rejectionReason        String?                       @db.Text
  interviewScheduledAt   DateTime?
  approvedAt             DateTime?
  rejectedAt             DateTime?
  customResponses        ApplicationFormResponse[]     @relation("InstructorAppFormResponses")
  applicationReviews     InstructorApplicationReview[]
  interviewReviews       InstructorInterviewReview[]
  cohortId               String?
  cohort                 ApplicationCohort?            @relation("InstructorAppCohort", fields: [cohortId], references: [id])

  // --- Automated scheduling ---
  availabilityWindows ApplicantAvailabilityWindow[] @relation("InstructorAvailabilityWindows")
  schedulingNoMatchAt DateTime?

  // --- Reviewer-offered interview slots (new scheduling flow) ---
  offeredSlots OfferedInterviewSlot[]

  // --- Instructor Applicant Workflow V1 ---
  reviewerAssignedAt     DateTime?
  reviewerAssignedById   String?
  reviewerAssignedBy     User?                                    @relation("InstructorApplicationReviewerAssignedBy", fields: [reviewerAssignedById], references: [id])
  chairQueuedAt          DateTime?
  materialsReadyAt       DateTime?
  archivedAt             DateTime?
  interviewerAssignments InstructorApplicationInterviewer[]
  documents              ApplicantDocument[]
  chairDecision          InstructorApplicationChairDecision?
  timeline               InstructorApplicationTimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reviewerId])
  @@index([cohortId])
  @@index([graduationYear])
  @@index([stateProvince])
  @@index([reviewerAssignedById])
  @@index([chairQueuedAt])
  @@index([archivedAt])
}

model InstructorApplicationReview {
  id                  String                                @id @default(cuid())
  applicationId       String
  application         InstructorApplication                 @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId          String
  reviewer            User                                  @relation("InstructorApplicationStructuredReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  curriculumDraftId   String?
  curriculumDraft     CurriculumDraft?                      @relation("InstructorApplicationReviewDraft", fields: [curriculumDraftId], references: [id], onDelete: SetNull)
  status              StructuredReviewStatus                @default(DRAFT)
  isLeadReview        Boolean                               @default(false)
  overallRating       ProgressStatus?
  nextStep            InstructorApplicationNextStep?
  summary             String?                               @db.Text
  notes               String?                               @db.Text
  concerns            String?                               @db.Text
  applicantMessage    String?                               @db.Text
  flagForLeadership   Boolean                               @default(false)
  draftOverrideUsed   Boolean                               @default(false)
  draftOverrideReason String?                               @db.Text
  submittedAt         DateTime?
  categories          InstructorApplicationReviewCategory[]
  createdAt           DateTime                              @default(now())
  updatedAt           DateTime                              @updatedAt

  @@unique([applicationId, reviewerId])
  @@index([applicationId, isLeadReview])
  @@index([reviewerId, status])
  @@index([curriculumDraftId])
}

model InstructorApplicationReviewCategory {
  id        String                      @id @default(cuid())
  reviewId  String
  review    InstructorApplicationReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  category  InstructorReviewCategoryKey
  rating    ProgressStatus?
  notes     String?                     @db.Text
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  @@unique([reviewId, category])
  @@index([category])
}

model InstructorInterviewQuestionBank {
  id             String                                @id @default(cuid())
  slug           String                                @unique
  prompt         String                                @db.Text
  helperText     String?                               @db.Text
  followUpPrompt String?                               @db.Text
  topic          String?
  sortOrder      Int                                   @default(0)
  isActive       Boolean                               @default(true)
  responses      InstructorInterviewQuestionResponse[]
  createdAt      DateTime                              @default(now())
  updatedAt      DateTime                              @updatedAt

  @@index([isActive, sortOrder])
}

model InstructorInterviewReview {
  id                   String                                @id @default(cuid())
  applicationId        String
  application          InstructorApplication                 @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId           String
  reviewer             User                                  @relation("InstructorInterviewStructuredReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  curriculumDraftId    String?
  curriculumDraft      CurriculumDraft?                      @relation("InstructorInterviewReviewDraft", fields: [curriculumDraftId], references: [id], onDelete: SetNull)
  status               StructuredReviewStatus                @default(DRAFT)
  isLeadReview         Boolean                               @default(false)
  overallRating        ProgressStatus?
  recommendation       InstructorInterviewRecommendation?
  summary              String?                               @db.Text
  overallNotes         String?                               @db.Text
  curriculumFeedback   String?                               @db.Text
  revisionRequirements String?                               @db.Text
  applicantMessage     String?                               @db.Text
  flagForLeadership    Boolean                               @default(false)
  submittedAt          DateTime?
  categories           InstructorInterviewReviewCategory[]
  questionResponses    InstructorInterviewQuestionResponse[]
  createdAt            DateTime                              @default(now())
  updatedAt            DateTime                              @updatedAt

  @@unique([applicationId, reviewerId])
  @@index([applicationId, isLeadReview])
  @@index([reviewerId, status])
  @@index([curriculumDraftId])
}

model InstructorInterviewReviewCategory {
  id        String                      @id @default(cuid())
  reviewId  String
  review    InstructorInterviewReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  category  InstructorReviewCategoryKey
  rating    ProgressStatus?
  notes     String?                     @db.Text
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  @@unique([reviewId, category])
  @@index([category])
}

model InstructorInterviewQuestionResponse {
  id             String                           @id @default(cuid())
  reviewId       String
  review         InstructorInterviewReview        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  questionBankId String?
  questionBank   InstructorInterviewQuestionBank? @relation(fields: [questionBankId], references: [id], onDelete: SetNull)
  source         InterviewQuestionSource          @default(DEFAULT)
  prompt         String                           @db.Text
  followUpPrompt String?                          @db.Text
  notes          String?                          @db.Text
  sortOrder      Int                              @default(0)
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt

  @@index([reviewId, sortOrder])
  @@index([questionBankId])
}

model OfferedInterviewSlot {
  id                      String                @id @default(cuid())
  instructorApplicationId String
  instructorApplication   InstructorApplication @relation(fields: [instructorApplicationId], references: [id], onDelete: Cascade)
  scheduledAt             DateTime
  durationMinutes         Int                   @default(60)
  offeredByUserId         String
  offeredBy               User                  @relation("OfferedInterviewSlots", fields: [offeredByUserId], references: [id], onDelete: Cascade)
  confirmedAt             DateTime?

  createdAt DateTime @default(now())

  @@index([instructorApplicationId])
  @@index([offeredByUserId])
}

// ============================================
// INSTRUCTOR APPLICANT WORKFLOW V1 MODELS
// ============================================

model InstructorApplicationInterviewer {
  id            String                    @id @default(cuid())
  applicationId String
  application   InstructorApplication     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewerId String
  interviewer   User                      @relation("InterviewerAssignments", fields: [interviewerId], references: [id])
  role          InterviewerAssignmentRole
  assignedAt    DateTime                  @default(now())
  assignedById  String
  assignedBy    User                      @relation("InterviewerAssignedBy", fields: [assignedById], references: [id])
  removedAt     DateTime?

  @@unique([applicationId, role])
  @@index([interviewerId, removedAt])
  @@index([assignedById])
}

model ApplicantDocument {
  id            String                @id @default(cuid())
  applicationId String
  application   InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind          ApplicantDocumentKind
  fileUrl       String
  originalName  String?
  fileSize      Int?
  note          String?
  uploadedById  String
  uploadedBy    User                  @relation("ApplicantDocUploader", fields: [uploadedById], references: [id])
  uploadedAt    DateTime              @default(now())
  supersededAt  DateTime?

  @@index([applicationId, kind, supersededAt])
  @@index([uploadedById])
}

model InstructorApplicationChairDecision {
  id              String              @id @default(cuid())
  applicationId   String              @unique
  application     InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  chairId         String
  chair           User                @relation("ChairDecisions", fields: [chairId], references: [id])
  action          ChairDecisionAction
  rationale       String?
  comparisonNotes String?
  decidedAt       DateTime            @default(now())
  supersededAt    DateTime?

  @@index([chairId])
}

model InstructorApplicationTimelineEvent {
  id            String                @id @default(cuid())
  applicationId String
  application   InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind          String
  actorId       String?
  actor         User?                 @relation("TimelineActor", fields: [actorId], references: [id])
  payload       Json
  createdAt     DateTime              @default(now())

  @@index([applicationId, createdAt])
  @@index([actorId])
}

model TrainingCheckpoint {
  id          String                         @id @default(cuid())
  moduleId    String
  contentKey  String?
  module      TrainingModule                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int                            @default(1)
  required    Boolean                        @default(true)
  completions TrainingCheckpointCompletion[]
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt

  @@unique([moduleId, contentKey])
  @@index([moduleId, sortOrder])
}

model TrainingCheckpointCompletion {
  id           String             @id @default(cuid())
  checkpointId String
  checkpoint   TrainingCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  userId       String
  user         User               @relation("TrainingCheckpointCompletions", fields: [userId], references: [id])
  notes        String?
  completedAt  DateTime           @default(now())
  createdAt    DateTime           @default(now())

  @@unique([checkpointId, userId])
  @@index([userId])
}

model TrainingQuizQuestion {
  id            String         @id @default(cuid())
  moduleId      String
  contentKey    String?
  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  question      String
  options       Json
  correctAnswer String
  explanation   String?
  sortOrder     Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([moduleId, contentKey])
  @@index([moduleId, sortOrder])
}

model TrainingQuizAttempt {
  id          String         @id @default(cuid())
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation("TrainingQuizAttempts", fields: [userId], references: [id])
  scorePct    Int
  passed      Boolean
  answers     Json?
  attemptedAt DateTime       @default(now())
  createdAt   DateTime       @default(now())

  @@index([moduleId, userId])
}

model TrainingEvidenceSubmission {
  id           String                 @id @default(cuid())
  moduleId     String
  module       TrainingModule         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId       String
  user         User                   @relation("TrainingEvidenceSubmissions", fields: [userId], references: [id])
  fileUrl      String
  notes        String?
  status       TrainingEvidenceStatus @default(PENDING_REVIEW)
  reviewedById String?
  reviewedBy   User?                  @relation("TrainingEvidenceReviews", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?
  peerReviews  PeerReview[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([moduleId, userId])
  @@index([status])
}

// ============================================
// TRAINING ACADEMY ENHANCEMENTS
// ============================================

model TrainingVideo {
  id              String         @id @default(cuid())
  moduleId        String
  module          TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  videoUrl        String
  videoProvider   VideoProvider
  videoDuration   Int // Duration in seconds
  sortOrder       Int            @default(1)
  isSupplementary Boolean        @default(false)
  segments        VideoSegment[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([moduleId, sortOrder])
}

model VideoSegment {
  id        String        @id @default(cuid())
  videoId   String
  video     TrainingVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  title     String
  startTime Int // seconds
  endTime   Int // seconds
  sortOrder Int           @default(1)
  createdAt DateTime      @default(now())

  @@index([videoId, sortOrder])
}

model TrainingResource {
  id           String         @id @default(cuid())
  moduleId     String
  module       TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  resourceUrl  String
  resourceType String // PDF, DOC, SHEET, LINK, VIDEO
  sortOrder    Int            @default(1)
  downloads    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([moduleId, sortOrder])
}

model TrainingCohort {
  id            String               @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime?
  facilitatorId String?
  facilitator   User?                @relation("CohortFacilitator", fields: [facilitatorId], references: [id])
  assignments   TrainingAssignment[]
  discussions   ModuleDiscussion[]
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([isActive, startDate])
}

model PeerReview {
  id                  String                     @id @default(cuid())
  evidenceId          String
  evidence            TrainingEvidenceSubmission @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  reviewerId          String
  reviewer            User                       @relation("PeerReviewsGiven", fields: [reviewerId], references: [id])
  feedback            String?
  rating              Int? // 1-5 scale
  strengths           String?
  areasForImprovement String?
  submittedAt         DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([evidenceId, reviewerId])
  @@index([reviewerId])
}

model ModuleDiscussion {
  id        String             @id @default(cuid())
  moduleId  String
  module    TrainingModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  cohortId  String?
  cohort    TrainingCohort?    @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  threads   DiscussionThread[]
  createdAt DateTime           @default(now())

  @@unique([moduleId, cohortId])
  @@index([moduleId])
}

model DiscussionThread {
  id           String            @id @default(cuid())
  discussionId String
  discussion   ModuleDiscussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User              @relation("DiscussionThreads", fields: [authorId], references: [id])
  title        String
  content      String
  isPinned     Boolean           @default(false)
  isLocked     Boolean           @default(false)
  replies      DiscussionReply[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([discussionId, createdAt])
  @@index([authorId])
}

model DiscussionReply {
  id        String           @id @default(cuid())
  threadId  String
  thread    DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User             @relation("DiscussionReplies", fields: [authorId], references: [id])
  content   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId])
}

// ============================================

model ReadinessReviewRequest {
  id           String                @id @default(cuid())
  instructorId String
  instructor   User                  @relation("ReadinessReviewRequests", fields: [instructorId], references: [id])
  status       ReadinessReviewStatus @default(REQUESTED)
  notes        String?
  requestedAt  DateTime              @default(now())
  reviewedById String?
  reviewedBy   User?                 @relation("ReadinessReviewDecisions", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([instructorId, status])
  @@index([status])
}

model InstructorTeachingPermission {
  id           String      @id @default(cuid())
  instructorId String
  instructor   User        @relation("TeachingPermissions", fields: [instructorId], references: [id])
  level        CourseLevel
  grantedById  String
  grantedBy    User        @relation("TeachingPermissionGrants", fields: [grantedById], references: [id])
  reason       String?
  grantedAt    DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([instructorId, level])
}

model InstructorInterviewGate {
  id                   String                                   @id @default(cuid())
  instructorId         String                                   @unique
  instructor           User                                     @relation("InstructorInterviewGateOwner", fields: [instructorId], references: [id])
  status               InterviewGateStatus                      @default(REQUIRED)
  outcome              InterviewOutcome?
  scheduledAt          DateTime?
  completedAt          DateTime?
  reviewedById         String?
  reviewedBy           User?                                    @relation("InstructorInterviewGateReviews", fields: [reviewedById], references: [id])
  reviewedAt           DateTime?
  reviewNotes          String?
  slots                InstructorInterviewSlot[]
  availabilityRequests InstructorInterviewAvailabilityRequest[]
  schedulingRequests   InterviewSchedulingRequest[]
  createdAt            DateTime                                 @default(now())
  updatedAt            DateTime                                 @updatedAt
}

model InstructorInterviewSlot {
  id          String                  @id @default(cuid())
  gateId      String
  gate        InstructorInterviewGate @relation(fields: [gateId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User                    @relation("InstructorInterviewSlotsCreated", fields: [createdById], references: [id])
  source      InterviewSlotSource     @default(REVIEWER_POSTED)
  status      InterviewSlotStatus     @default(POSTED)
  scheduledAt DateTime
  duration    Int                     @default(30)
  meetingLink String?
  confirmedAt DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([gateId, scheduledAt])
  @@index([gateId, status])
  @@index([scheduledAt])
}

model InstructorInterviewAvailabilityRequest {
  id             String                  @id @default(cuid())
  gateId         String
  gate           InstructorInterviewGate @relation(fields: [gateId], references: [id], onDelete: Cascade)
  instructorId   String
  instructor     User                    @relation("InstructorInterviewAvailabilityRequests", fields: [instructorId], references: [id])
  preferredSlots Json
  note           String?
  status         InterviewRequestStatus  @default(PENDING)
  reviewedById   String?
  reviewedBy     User?                   @relation("InstructorInterviewAvailabilityReviews", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([gateId, status])
  @@index([instructorId, status])
}

model InterviewAvailabilityRule {
  id            String                     @id @default(cuid())
  interviewerId String
  interviewer   User                       @relation("InterviewAvailabilityRules", fields: [interviewerId], references: [id], onDelete: Cascade)
  chapterId     String?
  chapter       Chapter?                   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  scope         InterviewAvailabilityScope @default(ALL)
  dayOfWeek     Int
  startTime     String
  endTime       String
  timezone      String                     @default("America/New_York")
  slotDuration  Int                        @default(30)
  bufferMinutes Int                        @default(10)
  meetingLink   String?
  locationLabel String?
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  overrides InterviewAvailabilityOverride[]

  @@index([interviewerId, isActive])
  @@index([chapterId, isActive])
  @@index([scope, isActive])
}

model InterviewAvailabilityOverride {
  id            String                            @id @default(cuid())
  interviewerId String
  interviewer   User                              @relation("InterviewAvailabilityOverrides", fields: [interviewerId], references: [id], onDelete: Cascade)
  chapterId     String?
  chapter       Chapter?                          @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  ruleId        String?
  rule          InterviewAvailabilityRule?        @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  scope         InterviewAvailabilityScope        @default(ALL)
  type          InterviewAvailabilityOverrideType
  startsAt      DateTime
  endsAt        DateTime
  timezone      String                            @default("America/New_York")
  slotDuration  Int?
  bufferMinutes Int?
  meetingLink   String?
  locationLabel String?
  note          String?
  isActive      Boolean                           @default(true)
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  @@index([interviewerId, isActive, startsAt])
  @@index([chapterId, isActive, startsAt])
  @@index([ruleId])
}

model InterviewSchedulingRequest {
  id                    String                           @id @default(cuid())
  domain                InterviewDomain
  status                InterviewSchedulingRequestStatus @default(REQUESTED)
  chapterId             String?
  chapter               Chapter?                         @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  applicationId         String?
  application           Application?                     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  gateId                String?
  gate                  InstructorInterviewGate?         @relation(fields: [gateId], references: [id], onDelete: Cascade)
  intervieweeId         String
  interviewee           User                             @relation("InterviewSchedulingRequestsAsInterviewee", fields: [intervieweeId], references: [id], onDelete: Cascade)
  interviewerId         String
  interviewer           User                             @relation("InterviewSchedulingRequestsAsInterviewer", fields: [interviewerId], references: [id], onDelete: Cascade)
  requestedById         String
  requestedBy           User                             @relation("InterviewSchedulingRequestsCreated", fields: [requestedById], references: [id], onDelete: Cascade)
  requestedStartAt      DateTime
  requestedEndAt        DateTime?
  scheduledAt           DateTime?
  duration              Int                              @default(30)
  meetingLink           String?
  sourceTimezone        String                           @default("America/New_York")
  note                  String?
  conversationId        String?                          @unique
  conversation          Conversation?                    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  bookedAt              DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  rescheduleRequestedAt DateTime?
  chapterEscalatedAt    DateTime?
  adminEscalatedAt      DateTime?
  reminder24SentAt      DateTime?
  reminder2SentAt       DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  @@index([domain, status])
  @@index([chapterId, status, createdAt])
  @@index([intervieweeId, status])
  @@index([interviewerId, status])
  @@index([applicationId, status])
  @@index([gateId, status])
}

// ============================================
// MENTORSHIP MODELS
// ============================================

model Mentorship {
  id                      String                   @id @default(cuid())
  mentorId                String
  menteeId                String
  type                    MentorshipType
  programGroup            MentorshipProgramGroup   @default(INSTRUCTOR)
  governanceMode          MentorshipGovernanceMode @default(FULL_PROGRAM)
  status                  MentorshipStatus         @default(ACTIVE)
  startDate               DateTime                 @default(now())
  endDate                 DateTime?
  notes                   String?
  trackId                 String?
  chairId                 String?
  kickoffScheduledAt      DateTime?
  kickoffCompletedAt      DateTime?
  kickoffNotes            String?
  mentorTag               MentorTag?
  // Gamification streaks
  reflectionStreak        Int                      @default(0)
  longestReflectionStreak Int                      @default(0)
  reviewStreak            Int                      @default(0)
  longestReviewStreak     Int                      @default(0)
  /// Denormalized stage for fast Kanban queries. Recomputed on every state change.
  cycleStage              MentorshipCycleStage     @default(REFLECTION_DUE)
  mentor                  User                     @relation("MentorLinks", fields: [mentorId], references: [id])
  mentee                  User                     @relation("MenteeLinks", fields: [menteeId], references: [id])
  chair                   User?                    @relation("MentorshipChairs", fields: [chairId], references: [id])
  track                   MentorshipTrack?         @relation(fields: [trackId], references: [id])
  checkIns                MentorshipCheckIn[]

  // Mentorship Program relations
  selfReflections  MonthlySelfReflection[]
  goalReviews      MentorGoalReview[]
  monthlyReviews   MonthlyGoalReview[]
  circleMembers    MentorshipCircleMember[]
  sessions         MentorshipSession[]
  actionItems      MentorshipActionItem[]
  supportRequests  MentorshipRequest[]
  resources        MentorshipResource[]
  feedbackRequests QuarterlyFeedbackRequest[]
  scheduleRequests MentorshipScheduleRequest[]
  grDocuments      GRDocument[]

  @@index([trackId])
  @@index([chairId])
  @@index([cycleStage, status])
}

model MentorshipCheckIn {
  id           String     @id @default(cuid())
  mentorshipId String
  notes        String
  rating       Int?
  createdAt    DateTime   @default(now())
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])
}

model MentorshipCircleMember {
  id                String      @id @default(cuid())
  mentorshipId      String?
  mentorship        Mentorship? @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId          String
  mentee            User        @relation("SupportCircleMentees", fields: [menteeId], references: [id], onDelete: Cascade)
  userId            String
  user              User        @relation("SupportCircleUsers", fields: [userId], references: [id], onDelete: Cascade)
  role              SupportRole
  source            String?
  isPrimary         Boolean     @default(false)
  isActive          Boolean     @default(true)
  notes             String?
  availabilityNotes String?
  capacityOverride  Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([menteeId, userId, role])
  @@index([mentorshipId])
  @@index([menteeId, isActive])
  @@index([userId, isActive])
}

model MentorshipSession {
  id                       String                     @id @default(cuid())
  mentorshipId             String?
  mentorship               Mentorship?                @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  scheduleRequestId        String?                    @unique
  scheduleRequest          MentorshipScheduleRequest? @relation("MentorshipSessionScheduleRequest", fields: [scheduleRequestId], references: [id], onDelete: SetNull)
  menteeId                 String
  mentee                   User                       @relation("MentorshipSessionsForMentees", fields: [menteeId], references: [id], onDelete: Cascade)
  type                     MentorshipSessionType
  title                    String
  scheduledAt              DateTime
  completedAt              DateTime?
  cancelledAt              DateTime?
  durationMinutes          Int?
  agenda                   String?
  notes                    String?
  meetingLink              String?
  cancellationReason       String?
  schedulingOverrideReason String?
  reminder24SentAt         DateTime?
  reminder2SentAt          DateTime?
  participantIds           String[]                   @default([])
  attendedIds              String[]                   @default([])
  createdById              String
  createdBy                User                       @relation("MentorshipSessionsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  ledById                  String?
  ledBy                    User?                      @relation("MentorshipSessionsLed", fields: [ledById], references: [id], onDelete: SetNull)
  actionItems              MentorshipActionItem[]
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([mentorshipId])
  @@index([menteeId, scheduledAt])
  @@index([createdById])
}

model MentorAvailabilityRule {
  id            String   @id @default(cuid())
  mentorId      String
  mentor        User     @relation("MentorAvailabilityRules", fields: [mentorId], references: [id], onDelete: Cascade)
  dayOfWeek     Int
  startTime     String
  endTime       String
  timezone      String   @default("America/New_York")
  slotDuration  Int      @default(30)
  bufferMinutes Int      @default(10)
  meetingLink   String?
  locationLabel String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  overrides MentorAvailabilityOverride[]

  @@index([mentorId, isActive])
}

model MentorAvailabilityOverride {
  id            String                            @id @default(cuid())
  mentorId      String
  mentor        User                              @relation("MentorAvailabilityOverrides", fields: [mentorId], references: [id], onDelete: Cascade)
  ruleId        String?
  rule          MentorAvailabilityRule?           @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  type          InterviewAvailabilityOverrideType
  startsAt      DateTime
  endsAt        DateTime
  timezone      String                            @default("America/New_York")
  slotDuration  Int?
  bufferMinutes Int?
  meetingLink   String?
  locationLabel String?
  note          String?
  isActive      Boolean                           @default(true)
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  @@index([mentorId, isActive, startsAt])
  @@index([ruleId])
}

model MentorshipActionItem {
  id           String                     @id @default(cuid())
  mentorshipId String?
  mentorship   Mentorship?                @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId     String
  mentee       User                       @relation("MentorshipActionItemsForMentees", fields: [menteeId], references: [id], onDelete: Cascade)
  sessionId    String?
  session      MentorshipSession?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  title        String
  details      String?
  status       MentorshipActionItemStatus @default(OPEN)
  ownerId      String?
  owner        User?                      @relation("MentorshipActionItemsOwned", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                       @relation("MentorshipActionItemsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  dueAt        DateTime?
  completedAt  DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([mentorshipId])
  @@index([menteeId, status])
  @@index([ownerId, status])
  @@index([sessionId])
}

model MentorshipRequest {
  id             String                      @id @default(cuid())
  mentorshipId   String?
  mentorship     Mentorship?                 @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId       String
  mentee         User                        @relation("MentorshipRequestsForMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  requesterId    String
  requester      User                        @relation("MentorshipRequestsCreated", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedToId   String?
  assignedTo     User?                       @relation("MentorshipRequestsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  trackId        String?
  track          MentorshipTrack?            @relation(fields: [trackId], references: [id], onDelete: SetNull)
  kind           MentorshipRequestKind
  visibility     MentorshipRequestVisibility
  status         MentorshipRequestStatus     @default(OPEN)
  title          String
  details        String
  isAnonymous    Boolean                     @default(false)
  passionId      String?
  projectId      String?
  requestedAt    DateTime                    @default(now())
  resolvedAt     DateTime?
  lastResponseAt DateTime?
  responses      MentorshipRequestResponse[]
  resources      MentorshipResource[]

  @@index([mentorshipId])
  @@index([menteeId, status])
  @@index([assignedToId, status])
  @@index([visibility, status])
  @@index([kind, status])
  @@index([trackId])
}

model MentorshipRequestResponse {
  id                String               @id @default(cuid())
  requestId         String
  request           MentorshipRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  responderId       String
  responder         User                 @relation("MentorshipRequestResponses", fields: [responderId], references: [id], onDelete: Cascade)
  body              String
  videoUrl          String?
  resourceLinks     String[]             @default([])
  isHelpful         Boolean?
  helpfulCount      Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  promotedResources MentorshipResource[] @relation("MentorshipResourcesFromResponse")

  @@index([requestId, createdAt])
  @@index([responderId])
}

model MentorshipResource {
  id           String                     @id @default(cuid())
  mentorshipId String?
  mentorship   Mentorship?                @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId     String?
  mentee       User?                      @relation("MentorshipResourcesForMentee", fields: [menteeId], references: [id], onDelete: SetNull)
  requestId    String?
  request      MentorshipRequest?         @relation(fields: [requestId], references: [id], onDelete: SetNull)
  responseId   String?
  response     MentorshipRequestResponse? @relation("MentorshipResourcesFromResponse", fields: [responseId], references: [id], onDelete: SetNull)
  trackId      String?
  track        MentorshipTrack?           @relation(fields: [trackId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                       @relation("MentorshipResourcesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  type         MentorshipResourceType
  title        String
  description  String?
  url          String?
  body         String?
  passionId    String?
  isFeatured   Boolean                    @default(false)
  isPublished  Boolean                    @default(true)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([mentorshipId])
  @@index([menteeId])
  @@index([requestId])
  @@index([responseId])
  @@index([trackId])
  @@index([type, isPublished])
}

// ============================================
// EVENT & FEEDBACK MODELS
// ============================================

model Event {
  id                      String          @id @default(cuid())
  title                   String
  description             String
  eventType               EventType
  scope                   EventScope      @default(GLOBAL)
  visibility              EventVisibility @default(PUBLIC)
  startDate               DateTime
  endDate                 DateTime
  chapterId               String?
  chapter                 Chapter?        @relation(fields: [chapterId], references: [id])
  isAlumniOnly            Boolean         @default(false)
  createdById             String?
  createdBy               User?           @relation("EventsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById             String?
  updatedBy               User?           @relation("EventsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  seriesId                String?
  series                  EventSeries?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  occurrenceOriginalStart DateTime?
  isException             Boolean         @default(false)
  isCancelled             Boolean         @default(false)
  cancellationReason      String?
  reminder24Hr            Boolean         @default(true)
  reminder1Hr             Boolean         @default(true)

  // Calendar Integration
  location    String?
  meetingUrl  String?
  calendarUid String? @unique @default(cuid()) // For iCal UID

  // RSVP tracking
  rsvps              EventRsvp[]
  reminders          EventReminder[]
  attendanceSessions AttendanceSession[]
  checklists         CompetitionChecklist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId, startDate])
  @@index([scope, visibility, startDate])
  @@index([seriesId, startDate])
}

model EventSeries {
  id                  String                   @id @default(cuid())
  title               String
  description         String
  eventType           EventType
  scope               EventScope               @default(CHAPTER)
  visibility          EventVisibility          @default(INTERNAL)
  chapterId           String?
  chapter             Chapter?                 @relation(fields: [chapterId], references: [id])
  startDate           DateTime
  endDate             DateTime
  timezone            String                   @default("America/New_York")
  location            String?
  meetingUrl          String?
  recurrenceFrequency EventRecurrenceFrequency
  recurrenceInterval  Int                      @default(1)
  recurrenceDays      String[]
  recurrenceCount     Int?
  recurrenceUntil     DateTime?
  reminder24Hr        Boolean                  @default(true)
  reminder1Hr         Boolean                  @default(true)
  createdById         String?
  createdBy           User?                    @relation("EventSeriesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?
  updatedBy           User?                    @relation("EventSeriesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  events              Event[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([chapterId, recurrenceUntil])
  @@index([scope, visibility])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

model Feedback {
  id           String         @id @default(cuid())
  source       FeedbackSource
  rating       Int?
  comments     String
  courseId     String?
  instructorId String?
  chapterId    String?
  course       Course?        @relation(fields: [courseId], references: [id])
  instructor   User?          @relation("FeedbackTarget", fields: [instructorId], references: [id])
  chapter      Chapter?       @relation(fields: [chapterId], references: [id])
  authorId     String?
  author       User?          @relation("FeedbackSource", fields: [authorId], references: [id])
  createdAt    DateTime       @default(now())
}

model Award {
  id          String     @id @default(cuid())
  name        String
  description String
  type        AwardType?
  recipientId String
  awardedAt   DateTime   @default(now())
  recipient   User       @relation(fields: [recipientId], references: [id])
}

// ============================================
// APPLICATION & RECRUITMENT MODELS
// ============================================

model Position {
  id                  String             @id @default(cuid())
  title               String
  type                PositionType
  description         String?
  requirements        String?
  chapterId           String?
  chapter             Chapter?           @relation(fields: [chapterId], references: [id])
  openedById          String?
  openedBy            User?              @relation("PositionsOpenedBy", fields: [openedById], references: [id])
  hiringLeadId        String?
  hiringLead          User?              @relation("PositionsHiringLead", fields: [hiringLeadId], references: [id])
  visibility          PositionVisibility @default(CHAPTER_ONLY)
  interviewRequired   Boolean            @default(true)
  targetStartDate     DateTime?
  applicationDeadline DateTime?
  isOpen              Boolean            @default(true)
  applications        Application[]
  createdAt           DateTime           @default(now())
  closedAt            DateTime?
  updatedAt           DateTime           @updatedAt

  @@index([chapterId, isOpen, createdAt])
  @@index([chapterId, type, isOpen])
  @@index([openedById])
  @@index([hiringLeadId])
}

model Application {
  id                  String                       @id @default(cuid())
  positionId          String
  position            Position                     @relation(fields: [positionId], references: [id])
  applicantId         String
  applicant           User                         @relation(fields: [applicantId], references: [id])
  status              ApplicationStatus            @default(SUBMITTED)
  resumeUrl           String?
  coverLetter         String?
  additionalMaterials String?
  interviewSlots      InterviewSlot[]
  interviewNotes      InterviewNote[]
  schedulingRequests  InterviewSchedulingRequest[]
  decision            Decision?
  submittedAt         DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([positionId, status, submittedAt])
}

model InterviewSlot {
  id            String              @id @default(cuid())
  applicationId String
  application   Application         @relation(fields: [applicationId], references: [id])
  status        InterviewSlotStatus @default(POSTED)
  scheduledAt   DateTime
  duration      Int                 @default(30)
  meetingLink   String?
  isConfirmed   Boolean             @default(false)
  interviewerId String?
  interviewer   User?               @relation("ApplicationInterviewer", fields: [interviewerId], references: [id])
  confirmedAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())

  @@index([applicationId, status, scheduledAt])
  @@index([interviewerId])
}

model InterviewNote {
  id                 String                @id @default(cuid())
  applicationId      String
  application        Application           @relation(fields: [applicationId], references: [id])
  authorId           String
  author             User                  @relation("InterviewNotesAuthored", fields: [authorId], references: [id])
  content            String
  rating             Int?
  recommendation     HiringRecommendation?
  strengths          String?
  concerns           String?
  nextStepSuggestion String?
  createdAt          DateTime              @default(now())

  @@index([applicationId, createdAt])
}

model Decision {
  id                String      @id @default(cuid())
  applicationId     String      @unique
  application       Application @relation(fields: [applicationId], references: [id])
  decidedById       String
  decidedBy         User        @relation("DecisionsMade", fields: [decidedById], references: [id])
  accepted          Boolean
  notes             String?
  decidedAt         DateTime    @default(now())
  hiringChairStatus String?
  hiringChairNote   String?
  hiringChairId     String?
  hiringChair       User?       @relation("HiringChairDecisions", fields: [hiringChairId], references: [id])
  hiringChairAt     DateTime?
}

// ============================================
// ANNOUNCEMENTS MODEL
// ============================================

model Announcement {
  id                 String     @id @default(cuid())
  title              String
  content            String
  authorId           String
  author             User       @relation(fields: [authorId], references: [id])
  targetRoles        RoleType[]
  chapterId          String?
  chapter            Chapter?   @relation(fields: [chapterId], references: [id])
  publishedAt        DateTime   @default(now())
  scheduledPublishAt DateTime? // null = publish immediately
  expiresAt          DateTime?
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}


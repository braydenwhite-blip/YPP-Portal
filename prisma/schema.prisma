  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?
  avatarUrl          String?
  curriculumUrl      String?
  interests          String[]
  learningStyle      String?
  primaryGoal        String?
  grade              Int?
  school             String?
  parentEmail        String?
  parentPhone        String?
  dateOfBirth        String?
  city               String?
  stateProvince      String?
  usesParentPhone    Boolean  @default(false)
  mentorCapacity     Int?
  mentorAvailability String?
  hearAboutYPP       String? // for family signup conversion tracking
  // Mentorship 2.0 (Action Tracker 3.0, Phase M1): goal signals consumed by the
  // matching engine (Part C). Additive/nullable — existing rows are unaffected.
  careerGoal         String?
  leadershipGoal     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// COURSE & PATHWAY MODELS
// ============================================

model Course {
  id                 String                  @id @default(cuid())
  title              String
  description        String
  format             CourseFormat
  level              CourseLevel?
  interestArea       String
  isVirtual          Boolean                 @default(false)
  maxEnrollment      Int? // null = unlimited
  chapterId          String?
  chapter            Chapter?                @relation(fields: [chapterId], references: [id])
  leadInstructorId   String?
  leadInstructor     User?                   @relation("InstructorCourses", fields: [leadInstructorId], references: [id], onDelete: SetNull)
  enrollments        Enrollment[]
  waitlistEntries    WaitlistEntry[]
  pathwaySteps       PathwayStep[]
  feedback           Feedback[]
  parentFeedbacks    ParentChapterFeedback[]
  certificates       Certificate[]
  attendanceSessions AttendanceSession[]
  resources          Resource[]
  studyGroups        StudyGroup[]
  learningNotes      LearningNote[]
  assignments        Assignment[]
  reviews            CourseReview[]
  portfolioItems     PortfolioItem[]
  proposals          CourseProposal[]
  coInstructors      CourseInstructor[]
  observations       PeerObservation[]
  substituteRequests SubstituteRequest[]
  curriculumFeedback CurriculumFeedback[]
  studentSpotlights  StudentSpotlight[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([chapterId])
  @@index([leadInstructorId])
}

model Pathway {
  id                String        @id @default(cuid())
  name              String
  description       String
  interestArea      String
  isActive          Boolean       @default(true)
  sequenceBlueprint Json?
  createdById       String?
  createdBy         User?         @relation("PathwaysCreated", fields: [createdById], references: [id], onDelete: SetNull)
  steps             PathwayStep[]
  certificates      Certificate[]

  // Pathway Integration Relations
  cohorts          PathwayCohort[]          @relation("PathwayCohorts")
  reflections      PathwayReflection[]      @relation("PathwayReflections")
  events           PathwayEvent[]           @relation("PathwayEvents")
  instructorSpecs  InstructorPathwaySpec[]  @relation("PathwayInstructorSpecs")
  chapterConfigs   ChapterPathway[]         @relation("PathwayChapterConfigs")
  fallbackRequests PathwayFallbackRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PathwayStep {
  id          String                @id @default(cuid())
  pathwayId   String
  stepOrder   Int
  unlockType  PathwayStepUnlockType @default(AUTO)
  stepDetails Json?

  // Content pointer — one of these should be set
  courseId         String?
  classTemplateId  String?
  specialProgramId String?
  title            String? // for standalone steps with no linked content

  // DAG prerequisites: this step requires ALL of these to be completed
  prerequisites PathwayStep[] @relation("StepPrerequisites")
  dependents    PathwayStep[] @relation("StepPrerequisites")

  // Visual positioning for the DAG editor
  positionX Float? @default(0)
  positionY Float? @default(0)

  pathway          Pathway                  @relation(fields: [pathwayId], references: [id])
  course           Course?                  @relation(fields: [courseId], references: [id])
  classTemplate    ClassTemplate?           @relation("ClassTemplateSteps", fields: [classTemplateId], references: [id])
  specialProgram   SpecialProgram?          @relation("SpecialProgramSteps", fields: [specialProgramId], references: [id])
  stepUnlocks      PathwayStepUnlock[]
  classOfferings   ClassOffering[]          @relation("PathwayStepOfferings")
  pathwayEvents    PathwayEvent[]
  fallbackRequests PathwayFallbackRequest[]

  @@index([pathwayId, stepOrder])
}

model PathwayStepUnlock {
  id         String      @id @default(cuid())
  stepId     String
  step       PathwayStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation("PathwayStepUnlocks", fields: [userId], references: [id], onDelete: Cascade)
  unlockedAt DateTime    @default(now())

  @@unique([stepId, userId])
}

enum PathwayStepUnlockType {
  AUTO
  MANUAL
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  status    String   @default("ENROLLED")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
}

// ============================================
// TRAINING MODELS
// ============================================

model TrainingModule {
  id            String             @id @default(cuid())
  contentKey    String?            @unique
  title         String
  description   String
  materialUrl   String?
  materialNotes String?
  type          TrainingModuleType
  required      Boolean            @default(true)
  sortOrder     Int

  /// Maps the module to YPP's official role framework so the Academy roadmap
  /// can group and label sections by GOAL. One of:
  /// WELCOME | GOAL_1 | GOAL_2 | GOAL_3 | GOAL_4 | GOAL_5 | CAPSTONE.
  /// Null for legacy/admin-created modules that predate the framework.
  goalKey          String?
  /// One-line "what you'll be able to do" statement drawn from the GOAL's
  /// Instructor-column competency. Surfaced on the roadmap card.
  outcomeStatement String?

  // Video Integration (Legacy - kept for backwards compatibility)
  videoUrl         String?
  videoProvider    VideoProvider?
  videoDuration    Int? // Duration in seconds
  videoThumbnail   String?
  requiresQuiz     Boolean        @default(false)
  requiresEvidence Boolean        @default(false)
  passScorePct     Int            @default(80)

  // New: Multiple videos and resources
  videos           TrainingVideo[]
  resources        TrainingResource[]
  discussions      ModuleDiscussion[]
  estimatedMinutes Int?

  assignments         TrainingAssignment[]
  videoProgress       VideoProgress[]
  checkpoints         TrainingCheckpoint[]
  quizQuestions       TrainingQuizQuestion[]
  quizAttempts        TrainingQuizAttempt[]
  evidenceSubmissions TrainingEvidenceSubmission[]
  interactiveJourney  InteractiveJourney?
  journeyVersions     JourneyVersion[]
  archivedAt          DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([archivedAt])
  @@index([goalKey])
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  LOOM
  CUSTOM
}

model TrainingAssignment {
  id          String          @id @default(cuid())
  userId      String
  moduleId    String
  cohortId    String?
  status      TrainingStatus  @default(NOT_STARTED)
  completedAt DateTime?
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      TrainingModule  @relation(fields: [moduleId], references: [id])
  cohort      TrainingCohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, moduleId])
  @@index([cohortId])
}

model VideoProgress {
  id             String         @id @default(cuid())
  userId         String
  moduleId       String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  module         TrainingModule @relation(fields: [moduleId], references: [id])
  watchedSeconds Int            @default(0)
  completed      Boolean        @default(false)
  lastPosition   Int            @default(0) // Last watched position in seconds
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, moduleId])
}

model InstructorApproval {
  id           String                    @id @default(cuid())
  instructorId String
  status       ApprovalStatus            @default(TRAINING_IN_PROGRESS)
  notes        String?
  instructor   User                      @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  levels       InstructorApprovalLevel[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model InstructorApprovalLevel {
  id         String             @id @default(cuid())
  approvalId String
  level      CourseLevel
  approvedAt DateTime           @default(now())
  approval   InstructorApproval @relation(fields: [approvalId], references: [id])
}

model InstructorApplication {
  id          String                      @id @default(cuid())
  // Re-application enabled — same user may have multiple applications over
  // time (one terminal record per cycle). Applicant code paths must filter
  // by `status` to find the *active* application; admin code paths can
  // surface history via the `previousApplicationId` chain.
  applicantId String
  applicant   User                        @relation("InstructorApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  status      InstructorApplicationStatus @default(SUBMITTED)

  // --- Re-application chain ---
  // True when this row was created after a prior closed application from
  // the same applicant. `previousApplicationId` points at the most recent
  // closed application; reviewers can walk the chain via repeated lookups.
  isReapplication       Boolean                 @default(false)
  previousApplicationId String?
  previousApplication   InstructorApplication?  @relation("InstructorApplicationReapplyChain", fields: [previousApplicationId], references: [id])
  reapplications        InstructorApplication[] @relation("InstructorApplicationReapplyChain")

  // --- Core application responses ---
  motivation         String? @db.Text
  motivationVideoUrl String?
  teachingExperience String  @db.Text
  availability       String

  // --- Personal Information ---
  legalName          String?
  preferredFirstName String?
  lastName           String?
  phoneNumber        String?
  dateOfBirth        String?
  hearAboutYPP       String?

  // --- Location ---
  city          String?
  stateProvince String?
  zipCode       String?
  country       String?

  // --- Academic Background ---
  schoolName         String?
  graduationYear     Int?
  subjectsOfInterest String?

  // --- Referral ---
  referralEmails String? @db.Text

  // --- Availability details ---
  hoursPerWeek       Int?
  preferredStartDate String?

  // --- Course planning (collected at application time) ---
  courseIdea     String? @db.Text
  textbook       String? @db.Text
  courseOutline  String? @db.Text
  firstClassPlan String? @db.Text

  // --- Reviewer scoring rubric ---
  scoreAcademic      Int?
  scoreCommunication Int?
  scoreLeadership    Int?
  scoreMotivation    Int?
  scoreFit           Int?

  // --- Curriculum review scoring rubric (replaces generic scores for instructor eval) ---
  scoreSubjectKnowledge    Int?
  scoreTeachingMethodology Int?
  scoreCurriculumAlignment Int?
  curriculumReviewSummary  String? @db.Text

  // --- Review workflow ---
  decisionRecommendation String?
  actionDueDate          DateTime?
  reviewerId             String?
  reviewer               User?                         @relation("InstructorApplicationReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewerNotes          String?                       @db.Text
  infoRequest            String?                       @db.Text
  applicantResponse      String?                       @db.Text
  rejectionReason        String?                       @db.Text
  interviewScheduledAt   DateTime?
  approvedAt             DateTime?
  rejectedAt             DateTime?
  customResponses        ApplicationFormResponse[]     @relation("InstructorAppFormResponses")
  applicationReviews     InstructorApplicationReview[]
  interviewReviews       InstructorInterviewReview[]
  cohortId               String?
  cohort                 ApplicationCohort?            @relation("InstructorAppCohort", fields: [cohortId], references: [id])

  // --- Automated scheduling ---
  availabilityWindows ApplicantAvailabilityWindow[] @relation("InstructorAvailabilityWindows")
  schedulingNoMatchAt DateTime?

  // --- Reviewer-offered interview slots (new scheduling flow) ---
  offeredSlots OfferedInterviewSlot[]

  // --- Instructor Applicant Workflow V1 ---
  reviewerAssignedAt      DateTime?
  reviewerAssignedById    String?
  reviewerAssignedBy      User?                                @relation("InstructorApplicationReviewerAssignedBy", fields: [reviewerAssignedById], references: [id], onDelete: SetNull)
  chairQueuedAt           DateTime?
  materialsReadyAt        DateTime?
  archivedAt              DateTime?
  infoRequestReturnStatus InstructorApplicationStatus?
  interviewRound          Int                                  @default(1)
  interviewerAssignments  InstructorApplicationInterviewer[]
  documents               ApplicantDocument[]
  chairDecisions          InstructorApplicationChairDecision[]
  chairDrafts             InstructorApplicationChairDraft[]
  chairCommitAttempts     ChairDecisionCommitAttempt[]
  reviewSignals           ReviewSignal[]
  timeline                InstructorApplicationTimelineEvent[]

  // --- Notification failure tracking ---
  lastNotificationError   String?   @db.Text
  lastNotificationErrorAt DateTime?

  // --- Summer Workshop Instructor pathway (subtype, additive) ---
  // `applicationTrack` is set at submission and drives form variant + admin filter.
  // `instructorSubtype` is the post-acceptance subtype on the instructor side.
  // `workshopOutline` is a structured JSON payload required for summer workshop applicants.
  // `promotionEligibility` tracks readiness to be promoted from summer workshop -> standard.
  applicationTrack     ApplicationTrack  @default(STANDARD_INSTRUCTOR)
  instructorSubtype    InstructorSubtype @default(STANDARD)
  workshopOutline      Json?
  promotionEligibility Json?
  subtypeChangedAt     DateTime?
  subtypeChangedById   String?
  subtypeChangedBy     User?             @relation("InstructorApplicationSubtypeChangedBy", fields: [subtypeChangedById], references: [id], onDelete: SetNull)

  // --- External intake (Google Forms / CSV / manual admin entry) ---
  // `source` defaults to PORTAL so existing rows are unaffected. Non-PORTAL
  // values mark applications that came in through an external channel and
  // are managed internally through the same review workflow.
  source              ApplicationSource @default(PORTAL)
  externalSubmittedAt DateTime?
  externalImportedAt  DateTime?
  externalResponseUrl String?
  externalAnswersCopy String?           @db.Text
  internalNotes       String?           @db.Text
  importedById        String?
  importedBy          User?             @relation("InstructorApplicationImportedBy", fields: [importedById], references: [id], onDelete: SetNull)
  manualEmailTasks    ManualEmailTask[] @relation("ManualEmailTasksInstructorApplication")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([reviewerId])
  @@index([cohortId])
  @@index([graduationYear])
  @@index([stateProvince])
  @@index([reviewerAssignedById])
  @@index([chairQueuedAt])
  @@index([archivedAt])
  @@index([interviewRound])
  @@index([applicationTrack])
  @@index([instructorSubtype])
  @@index([source])
  @@index([importedById])
  @@index([applicantId])
}

model InstructorApplicationReview {
  id                  String                                @id @default(cuid())
  applicationId       String
  application         InstructorApplication                 @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId          String
  reviewer            User                                  @relation("InstructorApplicationStructuredReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  curriculumDraftId   String?
  curriculumDraft     CurriculumDraft?                      @relation("InstructorApplicationReviewDraft", fields: [curriculumDraftId], references: [id], onDelete: SetNull)
  status              StructuredReviewStatus                @default(DRAFT)

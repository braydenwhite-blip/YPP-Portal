  STARTED_PASSION
  FIRST_VIDEO
  PRACTICE_SESSION
  CHALLENGE_COMPLETED
  SKILL_MASTERED
  WORKSHOP_ATTENDED
  PROJECT_COMPLETED
  CERTIFICATION_EARNED
  MILESTONE_REACHED
  PERSONAL_BEST
  SHOWCASE
  AWARD_RECEIVED
  BREAKTHROUGH_MOMENT
  COLLABORATION
  CUSTOM
}

// Workshop Series - Multi-session learning experiences
model WorkshopSeries {
  id               String               @id @default(cuid())
  passionId        String
  title            String
  description      String
  instructorName   String?
  difficulty       SkillLevel
  totalSessions    Int
  estimatedHours   Float
  thumbnailUrl     String?
  prerequisites    String?
  learningOutcomes String[]
  materials        String?

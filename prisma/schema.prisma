model OfferedInterviewSlot {
  id                      String                @id @default(cuid())
  instructorApplicationId String
  instructorApplication   InstructorApplication @relation(fields: [instructorApplicationId], references: [id], onDelete: Cascade)
  scheduledAt             DateTime
  durationMinutes         Int                   @default(60)
  meetingUrl              String?               @db.Text
  offeredByUserId         String
  offeredBy               User                  @relation("OfferedInterviewSlots", fields: [offeredByUserId], references: [id], onDelete: Cascade)
  confirmedAt             DateTime?
  choiceReminderSentAt    DateTime?
  reminder24SentAt        DateTime?
  reminder2SentAt         DateTime?

  createdAt DateTime @default(now())

  // Two slots for the same application at the same instant are meaningless.
  // If a declined slot needs to be re-offered at the same time, delete it first
  // (or shift by ≥1 second). This prevents duplicate rows on concurrent writes.
  @@unique([instructorApplicationId, scheduledAt])
  @@index([instructorApplicationId])
  @@index([offeredByUserId])
  @@index([choiceReminderSentAt, createdAt])
  @@index([reminder24SentAt, scheduledAt])
  @@index([reminder2SentAt, scheduledAt])
}


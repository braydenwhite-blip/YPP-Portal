// ============================================
// PARENT FEEDBACK & SURVEYS
// ============================================

model ParentChapterFeedback {
  id             String             @id @default(cuid())
  parentId       String
  parent         User               @relation("ParentChapterFeedbacks", fields: [parentId], references: [id])
  chapterId      String
  chapter        Chapter            @relation(fields: [chapterId], references: [id])
  type           ParentFeedbackType
  targetUserId   String?
  targetUser     User?              @relation("ParentFeedbackTargets", fields: [targetUserId], references: [id])
  studentId      String?
  student        User?              @relation("ParentFeedbackStudents", fields: [studentId], references: [id])
  courseId       String?
  course         Course?            @relation(fields: [courseId], references: [id])
  rating         Int
  comments       String             @db.Text
  wouldRecommend Boolean?
  isAnonymous    Boolean            @default(false)
  createdAt      DateTime           @default(now())

  @@index([chapterId, type])
  @@index([parentId])
  @@index([targetUserId])
  @@index([studentId])
  @@index([courseId])
}

model ParentSurvey {
  id          String                 @id @default(cuid())
  title       String
  description String?
  status      SurveyStatus           @default(DRAFT)
  chapterId   String?
  chapter     Chapter?               @relation(fields: [chapterId], references: [id])
  questions   ParentSurveyQuestion[]
  responses   ParentSurveyResponse[]
  opensAt     DateTime?
  closesAt    DateTime?
  createdById String
  createdBy   User                   @relation("ParentSurveysCreated", fields: [createdById], references: [id])
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status])
  @@index([chapterId])
}

model ParentSurveyQuestion {
  id        String                   @id @default(cuid())
  surveyId  String
  survey    ParentSurvey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  label     String
  fieldType ApplicationFormFieldType
  required  Boolean                  @default(true)
  options   String?                  @db.Text // JSON for MULTIPLE_CHOICE
  sortOrder Int                      @default(0)
  answers   ParentSurveyAnswer[]

  @@index([surveyId, sortOrder])
}

model ParentSurveyResponse {
  id          String               @id @default(cuid())
  surveyId    String
  survey      ParentSurvey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  parentId    String
  parent      User                 @relation("ParentSurveyResponses", fields: [parentId], references: [id])
  answers     ParentSurveyAnswer[]
  submittedAt DateTime             @default(now())

  @@unique([surveyId, parentId])
  @@index([parentId])
}

model ParentSurveyAnswer {
  id         String               @id @default(cuid())
  responseId String
  response   ParentSurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   ParentSurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String               @db.Text
  createdAt  DateTime             @default(now())

  @@index([responseId])
  @@index([questionId])
}

// ============================================
// PORTAL INTERCONNECTION MODELS
// ============================================

model PortalUnlock {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("PortalUnlocks", fields: [userId], references: [id])
  sectionKey     String // e.g. "challenges", "projects", "opportunities", "people_support"
  unlockedAt     DateTime @default(now())
  unlockedBy     String? // "ACHIEVEMENT", "MENTOR", "ADMIN", "TIME"
  unlockerUserId String? // who triggered it (mentor/admin id)

  @@unique([userId, sectionKey])
  @@index([userId])
}

model UnlockRecommendation {
  id           String    @id @default(cuid())
  studentId    String
  student      User      @relation("UnlockRecommendations", fields: [studentId], references: [id])
  mentorId     String
  mentor       User      @relation("UnlockRecommender", fields: [mentorId], references: [id])
  sectionKey   String
  reason       String?
  status       String    @default("PENDING") // PENDING, APPROVED, DENIED
  reviewedById String?
  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?

  @@index([studentId, status])
  @@index([mentorId])
}

model Nudge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserNudges", fields: [userId], references: [id])
  type        String // "BADGE_CLOSE", "PATHWAY_PROGRESS", "MENTEE_UPDATE", "GOAL_REMINDER", "UNLOCK_NEW", "SECTION_UNLOCKED"
  title       String
  body        String
  link        String?
  context     Json? // metadata about what triggered it
  isDismissed Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, isDismissed, createdAt])
}

model JourneyMilestone {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("JourneyMilestones", fields: [userId], references: [id])
  milestoneKey String // "FIRST_LOGIN", "PATHWAY_101_COMPLETE", "FIRST_BADGE", "FIRST_GOAL_SET", etc.
  label        String
  reachedAt    DateTime @default(now())

  @@unique([userId, milestoneKey])
  @@index([userId])
}

// Instructor-posted announcements for a class offering
model ClassAnnouncement {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  authorId   String
  author     User          @relation("ClassAnnouncementsAuthored", fields: [authorId], references: [id])

  title    String
  body     String  @db.Text
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId, createdAt])
  @@index([authorId])
}

// ============================================
// CURRICULUM BUILDER STUDIO
// ============================================

enum CurriculumDraftStatus {
  IN_PROGRESS
  COMPLETED
  SUBMITTED
  NEEDS_REVISION
  APPROVED
  REJECTED
}

// ============================================
// PHASE 3: MENTORSHIP ENHANCEMENTS
// ============================================

/// Token-based stakeholder feedback request (360-degree quarterly review)
model QuarterlyFeedbackRequest {
  id            String                      @id @default(cuid())
  mentorshipId  String
  mentorship    Mentorship                  @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  reviewId      String?
  review        MentorGoalReview?           @relation("FeedbackRequests", fields: [reviewId], references: [id], onDelete: SetNull)
  quarterNumber Int
  requestedById String
  requestedBy   User                        @relation("FeedbackRequestsCreated", fields: [requestedById], references: [id])
  token         String                      @unique @default(cuid())
  responses     QuarterlyFeedbackResponse[]
  createdAt     DateTime                    @default(now())

  @@index([mentorshipId])
  @@index([reviewId])
}

/// External stakeholder response to a quarterly feedback request
model QuarterlyFeedbackResponse {
  id              String                   @id @default(cuid())
  requestId       String
  request         QuarterlyFeedbackRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  respondentName  String
  respondentEmail String?
  respondentRole  String // "Parent", "Student", "School Official", "Leadership"
  overallRating   Int // 1-5
  strengths       String
  areasForGrowth  String
  additionalNotes String?
  submittedAt     DateTime                 @default(now())

  @@index([requestId])
}

/// Mentee-initiated meeting scheduling request with mentor
model MentorshipScheduleRequest {
  id             String                @id @default(cuid())
  mentorshipId   String
  mentorship     Mentorship            @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                  @relation("ScheduleRequestsCreated", fields: [requestedById], references: [id])
  sessionType    MentorshipSessionType @default(CHECK_IN)
  title          String
  notes          String?
  preferredSlots Json                  @default("[]") // Array of ISO datetime strings the requester prefers
  status         String                @default("PENDING") // PENDING, CONFIRMED, DECLINED, CANCELLED
  confirmedAt    DateTime?
  scheduledAt    DateTime?
  meetingLink    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  scheduledSession MentorshipSession? @relation("MentorshipSessionScheduleRequest")

  @@index([mentorshipId])
  @@index([requestedById])
}

model CurriculumDraft {
  id                           String                        @id @default(cuid())
  authorId                     String
  author                       User                          @relation(fields: [authorId], references: [id])
  title                        String                        @default("")
  description                  String?                       @db.Text
  interestArea                 String                        @default("")
  outcomes                     String[]
  courseConfig                 Json                          @default("{\"durationWeeks\":8,\"sessionsPerWeek\":1,\"classDurationMin\":60,\"targetAgeGroup\":\"\",\"deliveryModes\":[\"VIRTUAL\"],\"difficultyLevel\":\"LEVEL_101\",\"learnerFitLabel\":\"Best for first-time learners\",\"learnerFitDescription\":\"No prior experience needed.\",\"minStudents\":3,\"maxStudents\":25,\"idealSize\":12,\"estimatedHours\":8}")
  weeklyPlans                  Json                          @default("[]")
  understandingChecks          Json                          @default("{\"answers\":{},\"lastScorePct\":null,\"passed\":false,\"completedAt\":null}")
  reviewRubric                 Json?
  reviewNotes                  String?                       @db.Text
  reviewedById                 String?
  reviewedAt                   DateTime?
  submittedAt                  DateTime?
  approvedAt                   DateTime?
  generatedTemplateId          String?
  status                       CurriculumDraftStatus         @default(IN_PROGRESS)
  completedAt                  DateTime?
  applicationReviewsReferenced InstructorApplicationReview[] @relation("InstructorApplicationReviewDraft")
  interviewReviewsReferenced   InstructorInterviewReview[]   @relation("InstructorInterviewReviewDraft")
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  comments                     CurriculumComment[]

  @@index([authorId])
  @@index([status])
  @@index([generatedTemplateId])
}

model CurriculumComment {
  id           String              @id @default(cuid())
  draftId      String
  draft        CurriculumDraft     @relation(fields: [draftId], references: [id], onDelete: Cascade)
  authorId     String
  author       User                @relation("CurriculumCommentsAuthored", fields: [authorId], references: [id])
  parentId     String?
  parent       CurriculumComment?  @relation("CurriculumCommentReplies", fields: [parentId], references: [id])
  replies      CurriculumComment[] @relation("CurriculumCommentReplies")
  anchorType   String
  anchorId     String?
  anchorField  String?
  body         String              @db.Text
  resolved     Boolean             @default(false)
  resolvedById String?
  resolvedBy   User?               @relation("CurriculumCommentsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([draftId])
  @@index([parentId])
  @@index([anchorType, anchorId, anchorField])
  @@index([draftId, resolved, createdAt])
}

// GOALS & RESPONSIBILITIES (G&R) SYSTEM
// ============================================

enum GRTimePhase {
  FIRST_MONTH
  FIRST_QUARTER
  FULL_YEAR /// @deprecated use LONG_TERM; kept for data compatibility
  LONG_TERM
  MONTHLY
}

enum GoalLifecycleStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum GoalProgressState {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum GoalPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum GRDocumentStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ARCHIVED
}

enum GRGoalChangeStatus {
  PROPOSED
  APPROVED
  REJECTED
}

// ============================================
// PHASE 3: GOVERNANCE & RISK CONTROLS
// ============================================

/// Periodic KPI snapshot per chapter for trend tracking and at-risk detection
model ChapterKpiSnapshot {
  id        String  @id @default(cuid())
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // Snapshot date (one per chapter per day max)
  snapshotDate DateTime @default(now())

  // Core KPIs
  activeStudents        Int    @default(0)
  activeInstructors     Int    @default(0)
  pendingApplications   Int    @default(0)
  overdueQueues         Int    @default(0)
  avgResponseHours      Float? // avg hours to first action on queues
  classesRunningCount   Int    @default(0)
  enrollmentFillPercent Float? // avg enrollment / capacity across classes
  mentorshipPairCount   Int    @default(0)

  // Growth & Engagement KPIs
  retentionRate      Float? // % members active in last 30 days
  newMembersThisWeek Int    @default(0)
  eventsThisWeek     Int    @default(0)
  postsThisWeek      Int    @default(0)

  // Risk flags
  isAtRisk  Boolean  @default(false)
  riskFlags String[] // e.g. ["no_active_instructors", "overdue_queues_high"]

  createdAt DateTime @default(now())

  @@unique([chapterId, snapshotDate])
  @@index([chapterId])
  @@index([snapshotDate])
  @@index([isAtRisk])
}

/// SLA and operational rule definitions for escalation workflows
enum OpsRuleSeverity {
  INFO
  WARNING
  CRITICAL
}

enum OpsRuleStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model OpsRule {
  id          String          @id @default(cuid())
  name        String
  description String?
  severity    OpsRuleSeverity @default(WARNING)
  status      OpsRuleStatus   @default(ACTIVE)

  // Rule definition
  metricKey      String // e.g. "overdue_queues", "pending_applications", "avg_response_hours"
  operator       String // "gt", "gte", "lt", "lte", "eq"
  thresholdValue Float // numeric threshold

  // Scope
  chapterId String? // null = global rule
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // Escalation
  escalateToRoles String[] // e.g. ["ADMIN", "CHAPTER_LEAD"]
  autoNotify      Boolean  @default(true)

  createdById String
  createdBy   User   @relation("OpsRulesCreated", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  violations OpsRuleViolation[]

  @@index([status])
  @@index([metricKey])
  @@index([chapterId])
}

/// Recorded violation when an ops rule is breached
model OpsRuleViolation {
  id        String  @id @default(cuid())
  ruleId    String
  rule      OpsRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  actualValue    Float
  thresholdValue Float
  snapshotDate   DateTime

  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  notes          String?

  createdAt DateTime @default(now())

  @@index([ruleId])
  @@index([chapterId])
  @@index([acknowledged])
  @@index([snapshotDate])
}

// ============================================
// CHAPTER DISCOVERY & JOIN FLOW
// ============================================

enum ChapterJoinPolicy {
  OPEN
  APPROVAL
  INVITE_ONLY
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GRBulkUpdatePolicy {
  NEW_ONLY
  IMMEDIATE_ALL
  NEXT_CYCLE
}

enum GRTemplateStatus {
  GR_DRAFT
  IN_REVIEW
  GR_APPROVED
  GR_ARCHIVED
}

enum KPISourceType {
  AUTO_PARENT_FEEDBACK
  AUTO_TRAINING_COMPLETION
  AUTO_COMMUNITY_ENGAGEMENT
  AUTO_ATTENDANCE
  MANUAL_MENTOR_RATING
  MANUAL_QUALITATIVE
}

/// Role-wide base template that admins author collaboratively
model GRTemplate {
  id                    String           @id @default(cuid())
  title                 String
  roleType              MenteeRoleType
  officerPosition       String?
  roleMission           String           @db.Text
  status                GRTemplateStatus @default(GR_DRAFT)
  version               Int              @default(1)
  publishedAt           DateTime?
  isActive              Boolean          @default(true)
  maxActiveMonthlyGoals Int              @default(5)

  createdById    String
  createdBy      User    @relation("GRTemplatesCreated", fields: [createdById], references: [id])
  lastEditedById String?
  lastEditedBy   User?   @relation("GRTemplatesLastEdited", fields: [lastEditedById], references: [id])

  goals           GRTemplateGoal[]
  successCriteria GRTemplateSuccessCriteria[]
  resources       GRTemplateResource[]
  comments        GRTemplateComment[]
  versions        GRTemplateVersion[]
  assignments     GRDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleType])
  @@index([officerPosition])
}

/// Individual goals within a template, organized by time phase
model GRTemplateGoal {
  id          String      @id @default(cuid())
  templateId  String
  template    GRTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String      @db.Text
  timePhase   GRTimePhase
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)

  kpiDefinitions GRKPIDefinition[]
  documentGoals  GRDocumentGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId, timePhase])
}

/// Structured success criteria per time phase on a template
model GRTemplateSuccessCriteria {
  id         String      @id @default(cuid())
  templateId String
  template   GRTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  timePhase  GRTimePhase
  criteria   String      @db.Text
  sortOrder  Int         @default(0)

  documentCriteria GRDocumentSuccessCriteria[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, timePhase])
}

/// Join table linking templates to resources from the shared library
model GRTemplateResource {
  id         String     @id @default(cuid())
  templateId String
  template   GRTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  resourceId String
  resource   GRResource @relation(fields: [resourceId], references: [id])
  sortOrder  Int        @default(0)

  @@unique([templateId, resourceId])
}

/// Shared resource library (uploads & links), reusable across G&Rs
model GRResource {
  id           String      @id @default(cuid())
  title        String
  description  String?
  url          String
  isUpload     Boolean     @default(false)
  fileUploadId String?
  fileUpload   FileUpload? @relation(fields: [fileUploadId], references: [id])
  tags         String[]
  isActive     Boolean     @default(true)
  createdById  String
  createdBy    User        @relation("GRResourcesCreated", fields: [createdById], references: [id])

  templateLinks GRTemplateResource[]
  documentLinks GRDocumentResource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tags])
}

/// Collaborative drafting comments on templates
model GRTemplateComment {
  id         String     @id @default(cuid())
  templateId String
  template   GRTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  authorId   String
  author     User       @relation("GRTemplateCommentsAuthored", fields: [authorId], references: [id])
  body       String     @db.Text
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([templateId])
}

/// Full version history for templates
model GRTemplateVersion {
  id         String     @id @default(cuid())
  templateId String
  template   GRTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json
  changedBy  String
  changeNote String?

  createdAt DateTime @default(now())

  @@unique([templateId, version])
  @@index([templateId])
}

/// Per-person G&R document, instantiated from a template plus individual customizations
model GRDocument {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation("GRDocuments", fields: [userId], references: [id])
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])
  templateId   String
  template     GRTemplate @relation(fields: [templateId], references: [id])

  roleMission   String           @db.Text
  mentorInfo    Json?
  officerInfo   Json?
  roleStartDate DateTime
  status        GRDocumentStatus @default(DRAFT)

  goals           GRDocumentGoal[]
  successCriteria GRDocumentSuccessCriteria[]
  resources       GRDocumentResource[]
  plansOfAction   GRPlanOfAction[]
  goalChanges     GRGoalChange[]
  versions        GRDocumentVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, templateId])
  @@index([userId])
  @@index([mentorshipId])
}

/// Individual goal instance on a person's G&R document
model GRDocumentGoal {
  id             String          @id @default(cuid())
  documentId     String
  document       GRDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  templateGoalId String?
  templateGoal   GRTemplateGoal? @relation(fields: [templateGoalId], references: [id])

  title       String
  description String      @db.Text
  timePhase   GRTimePhase
  sortOrder   Int         @default(0)
  isCustom    Boolean     @default(false)
  /// @deprecated use lifecycleStatus instead
  isActive    Boolean     @default(true)

  // Lifecycle & progress tracking
  lifecycleStatus GoalLifecycleStatus @default(ACTIVE)
  progressState   GoalProgressState   @default(NOT_STARTED)
  priority        GoalPriority        @default(NORMAL)
  dueDate         DateTime?
  completedAt     DateTime?

  // Which mentor review spawned this goal (for MONTHLY goals created via GRGoalChange)
  sourceReviewId String?
  sourceReview   MentorGoalReview? @relation("GRGoalsSpawnedByReview", fields: [sourceReviewId], references: [id])

  kpiValues       GRKPIValue[]
  reviewRatings   GoalReviewRating[]
  reviewSnapshots MentorGoalReviewGoalSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId, timePhase])
  @@index([documentId, lifecycleStatus, dueDate])
}

/// Per-person success criteria (copied from template, customizable)
model GRDocumentSuccessCriteria {
  id                 String                     @id @default(cuid())
  documentId         String
  document           GRDocument                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  templateCriteriaId String?
  templateCriteria   GRTemplateSuccessCriteria? @relation(fields: [templateCriteriaId], references: [id])
  timePhase          GRTimePhase
  criteria           String                     @db.Text

  @@unique([documentId, timePhase])
}

/// Links from the shared library attached to a specific person's G&R
model GRDocumentResource {
  id         String     @id @default(cuid())
  documentId String
  document   GRDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  resourceId String
  resource   GRResource @relation(fields: [resourceId], references: [id])
  sortOrder  Int        @default(0)

  @@unique([documentId, resourceId])
}

/// Mentee-written plan of action, revised monthly alongside self-reflection
model GRPlanOfAction {
  id           String     @id @default(cuid())
  documentId   String
  document     GRDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  cycleNumber  Int
  content      String     @db.Text
  reflectionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, cycleNumber])
  @@index([documentId])
}

/// Mentor-proposed changes to a person's goals, requiring admin approval
model GRGoalChange {
  id           String     @id @default(cuid())
  documentId   String
  document     GRDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  proposedById String
  proposedBy   User       @relation("GRGoalChangesProposed", fields: [proposedById], references: [id])

  changeType   String
  goalId       String?
  proposedData Json
  reason       String?

  status       GRGoalChangeStatus @default(PROPOSED)
  reviewedById String?
  reviewedBy   User?              @relation("GRGoalChangesReviewed", fields: [reviewedById], references: [id])
  reviewNote   String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([documentId, status])
}

/// Version history for individual G&R documents
model GRDocumentVersion {
  id          String     @id @default(cuid())
  documentId  String
  document    GRDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json
  changedById String
  changedBy   User       @relation("GRDocumentVersionsCreated", fields: [changedById], references: [id])
  changeNote  String?

  createdAt DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId])
}

/// Point-in-time snapshot of a G&R goal captured when a mentor review is submitted.
/// Preserves historical accuracy so Past Updates display the original goal text
/// even if the goal is later edited, completed, or archived.
model MentorGoalReviewGoalSnapshot {
  id       String           @id @default(cuid())
  reviewId String
  review   MentorGoalReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  /// Nullable — if the underlying goal is hard-deleted, snapshot is still preserved.
  grDocumentGoalId String?
  grDocumentGoal   GRDocumentGoal? @relation(fields: [grDocumentGoalId], references: [id], onDelete: SetNull)

  // Captured values at snapshot time
  title                     String
  description               String              @db.Text
  timePhase                 GRTimePhase
  priority                  GoalPriority        @default(NORMAL)
  dueDateAtSnapshot         DateTime?
  lifecycleStatusAtSnapshot GoalLifecycleStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([grDocumentGoalId])
}

/// KPI metric definitions attached to template goals
model GRKPIDefinition {
  id             String         @id @default(cuid())
  templateGoalId String
  templateGoal   GRTemplateGoal @relation(fields: [templateGoalId], references: [id], onDelete: Cascade)
  label          String
  sourceType     KPISourceType
  targetValue    String?
  unit           String?

  values GRKPIValue[]

  @@index([templateGoalId])
}

/// Actual KPI measurements per person per goal
model GRKPIValue {
  id           String          @id @default(cuid())
  goalId       String
  goal         GRDocumentGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  definitionId String
  definition   GRKPIDefinition @relation(fields: [definitionId], references: [id])
  value        String
  measuredAt   DateTime        @default(now())
  isAutomatic  Boolean         @default(false)
  notes        String?

  @@index([goalId])
  @@index([definitionId])
}

model ChapterJoinRequest {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  chapterId    String
  chapter      Chapter           @relation(fields: [chapterId], references: [id])
  message      String?
  status       JoinRequestStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?             @relation("JoinRequestReviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([userId, chapterId])
  @@index([chapterId, status])
}

// ============================================
// CHAPTER MEMBER ONBOARDING
// ============================================

enum OnboardingStepType {
  INTRO_VIDEO
  MEET_THE_TEAM
  JOIN_CHANNELS
  SET_INTERESTS
  INTRODUCE_SELF
  COMPLETE_PROFILE
  FIRST_PATHWAY
  CUSTOM
}

model ChapterOnboardingStep {
  id          String             @id @default(cuid())
  chapterId   String
  chapter     Chapter            @relation(fields: [chapterId], references: [id])
  title       String
  description String?
  type        OnboardingStepType
  sortOrder   Int
  isRequired  Boolean            @default(true)
  metadata    Json?
  createdAt   DateTime           @default(now())

  progress MemberOnboardingProgress[]

  @@index([chapterId, sortOrder])
}

model MemberOnboardingProgress {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation("MemberOnboardingProgress", fields: [userId], references: [id])
  chapterId   String
  chapter     Chapter               @relation(fields: [chapterId], references: [id])
  stepId      String
  step        ChapterOnboardingStep @relation(fields: [stepId], references: [id])
  completedAt DateTime?
  createdAt   DateTime              @default(now())

  @@unique([userId, stepId])
  @@index([userId, chapterId])
}

// ============================================
// CHAPTER CHANNELS & COMMUNITY
// ============================================

model ChapterChannel {
  id          String   @id @default(cuid())
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id])
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  messages ChapterChannelMessage[]

  @@unique([chapterId, name])
  @@index([chapterId])
}

model ChapterChannelMessage {
  id        String         @id @default(cuid())
  channelId String
  channel   ChapterChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation("ChapterChannelMessages", fields: [authorId], references: [id])
  content   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([channelId, createdAt])
}

// ============================================
// CHAPTER GOALS
// ============================================

model ChapterGoal {
  id           String     @id @default(cuid())
  chapterId    String
  chapter      Chapter    @relation(fields: [chapterId], references: [id])
  createdById  String
  createdBy    User       @relation("ChapterGoalCreator", fields: [createdById], references: [id])
  title        String
  description  String?
  targetValue  Int
  currentValue Int        @default(0)
  unit         String // "members", "events", "enrollments", "courses"
  deadline     DateTime?
  status       GoalStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([chapterId, status])
}

// ============================================
// CHAPTER INVITES & REFERRAL TRACKING
// ============================================

model ChapterInvite {
  id          String  @id @default(cuid())
  chapterId   String
  chapter     Chapter @relation(fields: [chapterId], references: [id])
  createdById String
  createdBy   User    @relation("ChapterInviteCreator", fields: [createdById], references: [id])

  code      String    @unique // Short shareable code (e.g. "abc123")
  label     String? // Friendly name (e.g. "Summer 2026 Open House")
  maxUses   Int? // null = unlimited
  useCount  Int       @default(0)
  expiresAt DateTime? // null = never expires
  isActive  Boolean   @default(true)

  // Who used this invite
  usedBy User[] @relation("ChapterInviteUsedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId])
  @@index([code])
}

// ============================================
// CHAPTER GAMIFICATION — MILESTONES
// ============================================

enum ChapterAchievementMilestoneType {
  MEMBER_COUNT // "Reach X members"
  EVENT_COUNT // "Host X events"
  COURSE_COUNT // "Offer X courses"
  PATHWAY_COMPLETE // "X members complete a pathway"
  STREAK // "X consecutive weeks of activity"
  CUSTOM // Lead-defined milestone
}

model ChapterAchievementMilestone {
  id        String  @id @default(cuid())
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id])

  type         ChapterAchievementMilestoneType
  title        String
  description  String?
  icon         String                          @default("🏆")
  threshold    Int // Target value to unlock
  currentValue Int                             @default(0)
  isUnlocked   Boolean                         @default(false)
  unlockedAt   DateTime?
  xpReward     Int                             @default(0) // Bonus XP for all members when unlocked

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId])
  @@index([chapterId, isUnlocked])
}

// ============================================
// PHASE 4: GAMIFICATION, COLLEGE PLATFORM, ALUMNI NETWORK
// ============================================

// ---- 4B: PEER RECOGNITION FEED ----

enum KudosCategory {
  HELPFULNESS
  LEADERSHIP
  CREATIVITY
  ABOVE_AND_BEYOND
  TEAMWORK
  PROBLEM_SOLVING
}

/// Public peer shout-out that feeds into Character & Culture bonus points
model PeerKudos {
  id                   String        @id @default(cuid())
  giverId              String
  giver                User          @relation("PeerKudosGiven", fields: [giverId], references: [id])
  receiverId           String
  receiver             User          @relation("PeerKudosReceived", fields: [receiverId], references: [id])
  category             KudosCategory
  message              String
  isPublic             Boolean       @default(true)
  referencedInReviewId String?
  createdAt            DateTime      @default(now())

  @@index([receiverId])
  @@index([giverId])
  @@index([createdAt])
}

// ---- 4E: COLLEGE READINESS ROADMAP ----

enum CollegeStage {
  EXPLORING
  BUILDING_PROFILE
  TEST_PREP
  COLLEGE_LIST
  APPLICATIONS
  FINANCIAL_AID
  DECISION
  TRANSITION
}

model CollegeReadinessRoadmap {
  id             String               @id @default(cuid())
  userId         String               @unique
  user           User                 @relation("CollegeRoadmap", fields: [userId], references: [id])
  currentStage   CollegeStage         @default(EXPLORING)
  graduationYear Int?
  dreamColleges  String[]
  intendedMajors String[]
  tasks          CollegeRoadmapTask[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([userId])
}

model CollegeRoadmapTask {
  id          String                  @id @default(cuid())
  roadmapId   String
  roadmap     CollegeReadinessRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  stage       CollegeStage
  title       String
  description String?
  category    String // "Research", "Testing", "Essays", "Financial", "Visits"
  isRequired  Boolean                 @default(false)
  isTemplate  Boolean                 @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  notes       String?
  sortOrder   Int                     @default(0)
  createdAt   DateTime                @default(now())

  @@index([roadmapId, stage])
}

// ---- 4F: ACTIVITIES & EXTRACURRICULAR BUILDER ----

enum ActivityCategory {
  LEADERSHIP
  COMMUNITY_SERVICE
  ATHLETICS
  ARTS_CREATIVE
  ACADEMIC
  WORK_INTERNSHIP
  PERSONAL_PROJECT
  STEM
  OTHER
}

model CollegeActivity {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation("CollegeActivities", fields: [userId], references: [id])
  name            String
  category        ActivityCategory
  organization    String?
  role            String?
  description     String?
  hoursPerWeek    Float?
  weeksPerYear    Int?
  yearsInvolved   Int?
  startDate       DateTime?
  endDate         DateTime?
  isOngoing       Boolean             @default(true)
  impactStatement String?
  advisorNotes    String?
  isYppActivity   Boolean             @default(false) // auto-populated from portal data
  sortOrder       Int                 @default(0)
  milestones      ActivityMilestone[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId])
}

model ActivityMilestone {
  id          String          @id @default(cuid())
  activityId  String
  activity    CollegeActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  title       String
  date        DateTime?
  description String?
  createdAt   DateTime        @default(now())

  @@index([activityId])
}

// ---- 4G: ALUMNI NETWORK HUB ----

model AlumniPanelEvent {
  id              String            @id @default(cuid())
  title           String
  description     String
  topic           String
  scheduledAt     DateTime
  durationMinutes Int               @default(60)
  meetingLink     String?
  maxAttendees    Int?
  recording       String?
  isPublic        Boolean           @default(false)
  createdById     String
  panelists       AlumniPanelist[]
  rsvps           AlumniPanelRsvp[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([scheduledAt])
}

model AlumniPanelist {
  id          String           @id @default(cuid())
  eventId     String
  event       AlumniPanelEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation("AlumniPanelists", fields: [userId], references: [id])
  college     String
  yearStarted Int?
  bio         String?

  @@unique([eventId, userId])
}

model AlumniPanelRsvp {
  id      String           @id @default(cuid())
  eventId String
  event   AlumniPanelEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User             @relation("AlumniPanelRsvps", fields: [userId], references: [id])
  status  String // "GOING", "MAYBE", "NOT_GOING"

  @@unique([eventId, userId])
  @@index([eventId])
}

model AlumniIntroRequest {
  id          String    @id @default(cuid())
  requesterId String
  requester   User      @relation("AlumniIntroRequestsSent", fields: [requesterId], references: [id])
  alumniId    String
  alumni      User      @relation("AlumniIntroRequestsReceived", fields: [alumniId], references: [id])
  message     String
  status      String    @default("PENDING") // PENDING, ACCEPTED, DECLINED
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([requesterId])
  @@index([alumniId])
}

// ---- 4H: AWARD CEREMONY ----

model AwardCertificate {
  id           String   @id @default(cuid())
  userId       String
  tier         String // AchievementAwardTier value
  nominationId String   @unique
  svgData      String   @db.Text
  issuedAt     DateTime @default(now())

  @@index([userId])
}

// ============================================
// MILESTONE EVENTS (celebrations / achievements)
// ============================================

/// One-time achievement moments for a mentee (e.g. first ABOVE_AND_BEYOND, goal completed, tenure).
/// seenAt is null until the mentee dismisses the celebration toast.
model MilestoneEvent {
  id        String    @id @default(cuid())
  userId    String
  kind      String // ABOVE_AND_BEYOND_FIRST | GOAL_COMPLETED | TENURE_6_MONTHS | TENURE_12_MONTHS
  payload   Json      @default("{}")
  seenAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, seenAt])
}

// ============================================
// MENTEE REVIEW ACKNOWLEDGEMENT
// ============================================

/// Mentee's reaction to a released mentor review — emoji + optional note.
model MenteeReviewAck {
  id        String           @id @default(cuid())
  reviewId  String           @unique
  review    MentorGoalReview @relation(fields: [reviewId], references: [id])
  userId    String
  reaction  String // GRATEFUL | MOTIVATED | UNCLEAR | UNSURE
  note      String?
  createdAt DateTime         @default(now())

  @@index([userId])
}

// ============================================
// APPLICANT AVAILABILITY WINDOWS
// ============================================

model ApplicantAvailabilityWindow {
  id                            String                       @id @default(cuid())
  chapterPresidentApplicationId String?
  chapterPresidentApplication   ChapterPresidentApplication? @relation("CPAvailabilityWindows", fields: [chapterPresidentApplicationId], references: [id])
  instructorApplicationId       String?
  instructorApplication         InstructorApplication?       @relation("InstructorAvailabilityWindows", fields: [instructorApplicationId], references: [id])
  /// 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  dayOfWeek                     Int
  /// "HH:MM" 24-hour in the applicant's chosen timezone
  startTime                     String
  /// "HH:MM" 24-hour in the applicant's chosen timezone
  endTime                       String
  /// IANA timezone string e.g. "America/New_York"
  timezone                      String
  createdAt                     DateTime                     @default(now())

  @@index([chapterPresidentApplicationId])
  @@index([instructorApplicationId])
}

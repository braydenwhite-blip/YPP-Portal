  @@index([mentorId])
}

model Nudge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserNudges", fields: [userId], references: [id], onDelete: Cascade)
  type        String // "BADGE_CLOSE", "PATHWAY_PROGRESS", "MENTEE_UPDATE", "GOAL_REMINDER", "UNLOCK_NEW", "SECTION_UNLOCKED"
  title       String
  body        String
  link        String?
  context     Json? // metadata about what triggered it
  isDismissed Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, isDismissed, createdAt])
}

model JourneyMilestone {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("JourneyMilestones", fields: [userId], references: [id], onDelete: Cascade)
  milestoneKey String // "FIRST_LOGIN", "PATHWAY_101_COMPLETE", "FIRST_BADGE", "FIRST_GOAL_SET", etc.
  label        String
  reachedAt    DateTime @default(now())

  @@unique([userId, milestoneKey])
  @@index([userId])
}

// Instructor-posted announcements for a class offering
model ClassAnnouncement {
  id         String        @id @default(cuid())
  offeringId String
  offering   ClassOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  authorId   String
  author     User          @relation("ClassAnnouncementsAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  title    String
  body     String  @db.Text
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offeringId, createdAt])
  @@index([authorId])
}


model InstructorApplicationChairDecision {
  id              String                @id @default(cuid())
  applicationId   String
  application     InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  chairId         String
  chair           User                  @relation("ChairDecisions", fields: [chairId], references: [id], onDelete: Cascade)
  action          ChairDecisionAction
  rationale       String?
  comparisonNotes String?
  conditions      Json?
  decidedAt       DateTime              @default(now())
  supersededAt    DateTime?

  @@index([applicationId, decidedAt])
  @@index([chairId])
}

/// Persisted draft rationale per (application, chair). The cockpit's
/// DraftRationaleField autosaves into this table via saveChairDraft().
/// One row per (applicationId, chairId).
model InstructorApplicationChairDraft {
  id              String                @id @default(cuid())
  applicationId   String
  application     InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  chairId         String
  chair           User                  @relation("ChairDrafts", fields: [chairId], references: [id], onDelete: Cascade)
  rationale       String                @default("")
  comparisonNotes String                @default("")
  savedAt         DateTime              @default(now()) @updatedAt

  @@unique([applicationId, chairId])
  @@index([chairId])
}

/// Records every chairDecide() commit attempt keyed by client-generated
/// idempotency key. Lets the server detect replays after a network drop and
/// return the prior result instead of double-committing.
model ChairDecisionCommitAttempt {
  id             String                @id @default(cuid())
  idempotencyKey String                @unique
  applicationId  String
  application    InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  chairId        String
  chair          User                  @relation("ChairDecisionCommitAttempts", fields: [chairId], references: [id], onDelete: Cascade)
  action         ChairDecisionAction
  result         String // "SUCCESS" | "FAILED"
  decidedAt      DateTime?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([applicationId, createdAt])
  @@index([chairId, createdAt])
}

model InstructorApplicationTimelineEvent {
  id            String                @id @default(cuid())
  applicationId String
  application   InstructorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind          String
  actorId       String?
  actor         User?                 @relation("TimelineActor", fields: [actorId], references: [id], onDelete: SetNull)
  payload       Json
  createdAt     DateTime              @default(now())

  @@index([applicationId, createdAt])
  @@index([actorId])
}

/// Single, app-wide "active Chair" — the one user with final applicant
/// decision authority at any given time. Stored centrally (one singleton row
/// keyed by a fixed `id`) rather than per-applicant, so reassigning the Chair
/// is a single write that instantly moves decision permission. There can only
/// ever be one row; `setActiveChair()` upserts it. Every change is mirrored
/// into `ChairAssignmentHistory` for audit.
model ActiveChairAssignment {
  id           String   @id
  chairUserId  String   @unique
  chair        User     @relation("ActiveChairUser", fields: [chairUserId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User     @relation("ActiveChairAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([chairUserId])
}

/// Append-only audit trail of every Chair reassignment: who the previous Chair
/// was, who the new Chair is, who made the change, and when.
model ChairAssignmentHistory {
  id              String   @id @default(cuid())
  previousChairId String?
  previousChair   User?    @relation("ChairAssignmentPrev", fields: [previousChairId], references: [id], onDelete: SetNull)
  newChairId      String
  newChair        User     @relation("ChairAssignmentNew", fields: [newChairId], references: [id], onDelete: Cascade)
  changedById     String
  changedBy       User     @relation("ChairAssignmentChangedBy", fields: [changedById], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([newChairId])
}

enum ReviewSignalKind {
  COMMENT
  PIN_NOTE
  HIGHLIGHT
  CONCERN
  CONSENSUS_NOTE
}

enum ReviewSignalSentiment {
  STRONG_HIRE
  HIRE
  MIXED
  CONCERN
  REJECT
}

/// Unified reviewer/chair signal for the Final Review Cockpit (§15).
/// Generalises threaded comments, pinned notes, highlights, and chair
/// observations into one stream so the cockpit's feed, pinned rail, and
/// audit drawer all read from the same shape.
model ReviewSignal {
  id            String                 @id @default(cuid())
  applicationId String
  application   InstructorApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User                   @relation("ReviewSignalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  kind          ReviewSignalKind       @default(COMMENT)
  sentiment     ReviewSignalSentiment?
  body          String
  pinned        Boolean                @default(false)
  pinnedAt      DateTime?
  pinnedById    String?
  pinnedBy      User?                  @relation("ReviewSignalPinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)
  parentId      String?
  parent        ReviewSignal?          @relation("ReviewSignalReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       ReviewSignal[]         @relation("ReviewSignalReplies")
  mentions      ReviewSignalMention[]  @relation("ReviewSignalMentions")
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?                  @relation("ReviewSignalResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([applicationId, createdAt])
  @@index([applicationId, pinned])
  @@index([authorId])
  @@index([parentId])
}

/// @mention edge between a `ReviewSignal` and a mentioned user. Drives the
/// notification fan-out in `lib/notifications.ts` via the new
/// REVIEW_MENTION notification type. Composite primary key prevents
/// duplicate mentions on the same signal.
model ReviewSignalMention {
  signalId       String
  signal         ReviewSignal @relation("ReviewSignalMentions", fields: [signalId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ReviewSignalMentionedUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  acknowledgedAt DateTime?

  @@id([signalId, userId])
  @@index([userId, acknowledgedAt])
}

model TrainingCheckpoint {

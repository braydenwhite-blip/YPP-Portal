// ============================================
// MENTORSHIP MODELS
// ============================================

model Mentorship {
  id                      String                   @id @default(cuid())
  mentorId                String
  menteeId                String
  type                    MentorshipType
  programGroup            MentorshipProgramGroup   @default(INSTRUCTOR)
  governanceMode          MentorshipGovernanceMode @default(FULL_PROGRAM)
  status                  MentorshipStatus         @default(ACTIVE)
  startDate               DateTime                 @default(now())
  endDate                 DateTime?
  notes                   String?
  /// Instruction-development vs organizational-leadership mentorship (Phase 4).
  focusArea               MentorshipFocusArea?
  /// Temporary assignment that is expected to be handed back / reassigned.
  isTemporary             Boolean                  @default(false)
  trackId                 String?
  chairId                 String?
  kickoffScheduledAt      DateTime?
  kickoffCompletedAt      DateTime?
  kickoffNotes            String?
  mentorTag               MentorTag?
  // Gamification streaks
  reflectionStreak        Int                      @default(0)
  longestReflectionStreak Int                      @default(0)
  reviewStreak            Int                      @default(0)
  longestReviewStreak     Int                      @default(0)
  /// Denormalized stage for fast Kanban queries. Recomputed on every state change.
  cycleStage              MentorshipCycleStage     @default(REFLECTION_DUE)
  mentor                  User                     @relation("MentorLinks", fields: [mentorId], references: [id], onDelete: Cascade)
  mentee                  User                     @relation("MenteeLinks", fields: [menteeId], references: [id], onDelete: Cascade)
  chair                   User?                    @relation("MentorshipChairs", fields: [chairId], references: [id], onDelete: SetNull)
  track                   MentorshipTrack?         @relation(fields: [trackId], references: [id])
  checkIns                MentorshipCheckIn[]

  // Mentorship Program relations
  selfReflections  MonthlySelfReflection[]
  goalReviews      MentorGoalReview[]
  monthlyReviews   MonthlyGoalReview[]
  circleMembers    MentorshipCircleMember[]
  sessions         MentorshipSession[]
  actionItems      MentorshipActionItem[]
  supportRequests  MentorshipRequest[]
  resources        MentorshipResource[]
  feedbackRequests QuarterlyFeedbackRequest[]
  scheduleRequests MentorshipScheduleRequest[]
  grDocuments      GRDocument[]
  reviewCycleParticipants ReviewCycleParticipant[]

  @@index([trackId])
  @@index([chairId])
  @@index([cycleStage, status])
  @@index([mentorId])
  @@index([menteeId])
}

/// A conversation record inside Mentorship — the single home for every logged
/// check-in / meeting / conversation between a leader and a person. Extended
/// (Mentorship consolidation V1) from a thin between-review touchpoint into the
/// structured record: it is anchored on the SUBJECT person (`subjectId`) so it
/// survives the eventual unification of the relationship tables, with optional
/// soft links to whichever relationship it came from (`mentorshipId` today,
/// `advisorAssignmentId` reserved for the advising fold-in). `kind`, note-body,
/// and the structured fields are validated in app code.
model MentorshipCheckIn {
  id                  String                    @id @default(cuid())
  /// The person being developed (mentee/advisee). Backfilled from Mentorship.menteeId.
  subjectId           String?
  /// Nullable since V1 — a record may be anchored on the person, not a pairing.
  mentorshipId        String?
  /// Reserved for the V2 advising fold-in; unused by the V1 UI.
  advisorAssignmentId String?
  /// Who logged the conversation (the leader). Null for legacy mentee-posted rows.
  authorId            String?
  /// CHECK_IN | MEETING | CONVERSATION
  kind                String                    @default("CHECK_IN")
  notes               String
  rating              Int?
  mentorResponse      String?
  acknowledgedAt      DateTime?
  /// Structured conversation fields (all optional/defaulted → additive).
  wins                String?                   @db.Text
  challenges          String?                   @db.Text
  discussion          String?                   @db.Text
  decisions           String?                   @db.Text
  commitments         String?                   @db.Text
  participantIds      String[]                  @default([])
  followUpDate        DateTime?
  occurredAt          DateTime                  @default(now())
  createdAt           DateTime                  @default(now())
  mentorship          Mentorship?               @relation(fields: [mentorshipId], references: [id])
  advisorAssignment   StudentAdvisorAssignment? @relation(fields: [advisorAssignmentId], references: [id], onDelete: SetNull)
  subject             User?                     @relation("MentorshipCheckInSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  author              User?                     @relation("MentorshipCheckInAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([mentorshipId, createdAt])
  @@index([subjectId, occurredAt])
  @@index([advisorAssignmentId, createdAt])
}

/// A review cycle launched for one person or a whole cohort. Tracks a set of
/// people through one review period — the participant's stage is DERIVED at
/// read time from the existing review artifacts (MonthlySelfReflection,
/// MentorGoalReview, QuarterlyReview); nothing here duplicates review state.
/// Statuses/kinds are strings validated in app code
/// (lib/mentorship/cycle-constants.ts) — mentorship-2 convention.
model ReviewCycle {
  id          String  @id @default(cuid())
  name        String
  /// "monthly" | "quarterly"
  kind        String  @default("monthly")
  /// Period targeted: "2026-07" (monthly) or "2026-Q3" (quarterly).
  periodLabel String
  /// "role-group" | "chapter" | "lane" | "custom"
  scopeType   String
  /// Human descriptor, e.g. "All chapter presidents" / "Scarsdale chapter".
  scopeLabel  String
  /// Snapshot of the launcher input for auditability.
  scopeJson   Json?
  dueDate     DateTime?
  /// "active" | "closed"
  status      String    @default("active")
  /// This cycle's actual monthly reflection question wording, editable by
  /// admin/Global Leadership before launch. Falls back to the participant's
  /// GRTemplate.reflectionQuestions default when null — the reflection form
  /// still writes to MonthlySelfReflection's fixed columns; only the
  /// displayed prompt text is templated/overridable per cycle.
  reflectionQuestionsJson Json?
  createdById String
  createdBy   User      @relation("ReviewCyclesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participants ReviewCycleParticipant[]

  @@index([status, createdAt])
  @@index([createdById])
}

model ReviewCycleParticipant {
  id           String      @id @default(cuid())
  cycleId      String
  cycle        ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation("ReviewCycleParticipations", fields: [userId], references: [id], onDelete: Cascade)
  /// Active pairing snapshotted at launch (null ⇒ "needs mentor" stage).
  mentorshipId String?
  mentorship   Mentorship? @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  /// Manual override: "waived" — normally null, stage is derived.
  stageOverride String?
  note          String?
  addedAt       DateTime @default(now())

  feedbackRequests FeedbackRequest[]

  @@unique([cycleId, userId])
  @@index([userId])
  @@index([mentorshipId])
}

model MentorshipCircleMember {
  id                String      @id @default(cuid())
  mentorshipId      String?
  mentorship        Mentorship? @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId          String
  mentee            User        @relation("SupportCircleMentees", fields: [menteeId], references: [id], onDelete: Cascade)
  userId            String
  user              User        @relation("SupportCircleUsers", fields: [userId], references: [id], onDelete: Cascade)
  role              SupportRole
  source            String?
  isPrimary         Boolean     @default(false)
  isActive          Boolean     @default(true)
  /// Temporary advisor assignment (Phase 4).
  isTemporary       Boolean     @default(false)
  notes             String?
  availabilityNotes String?
  capacityOverride  Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([menteeId, userId, role])
  @@index([mentorshipId])
  @@index([menteeId, isActive])
  @@index([userId, isActive])
}

model MentorshipSession {
  id                       String                     @id @default(cuid())
  mentorshipId             String?
  mentorship               Mentorship?                @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  scheduleRequestId        String?                    @unique
  scheduleRequest          MentorshipScheduleRequest? @relation("MentorshipSessionScheduleRequest", fields: [scheduleRequestId], references: [id], onDelete: SetNull)
  menteeId                 String
  mentee                   User                       @relation("MentorshipSessionsForMentees", fields: [menteeId], references: [id], onDelete: Cascade)
  type                     MentorshipSessionType
  title                    String
  scheduledAt              DateTime
  completedAt              DateTime?
  cancelledAt              DateTime?
  durationMinutes          Int?
  agenda                   String?
  notes                    String?
  meetingLink              String?
  cancellationReason       String?
  schedulingOverrideReason String?
  reminder24SentAt         DateTime?
  reminder2SentAt          DateTime?
  participantIds           String[]                   @default([])
  attendedIds              String[]                   @default([])
  createdById              String
  createdBy                User                       @relation("MentorshipSessionsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  ledById                  String?
  ledBy                    User?                      @relation("MentorshipSessionsLed", fields: [ledById], references: [id], onDelete: SetNull)
  actionItems              MentorshipActionItem[]
  canonicalActionItems     ActionItem[]               @relation("MentorshipSessionActionItems")
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([mentorshipId])
  @@index([menteeId, scheduledAt])
  @@index([createdById])
}

model MentorAvailabilityRule {
  id            String   @id @default(cuid())
  mentorId      String
  mentor        User     @relation("MentorAvailabilityRules", fields: [mentorId], references: [id], onDelete: Cascade)
  dayOfWeek     Int
  startTime     String
  endTime       String
  timezone      String   @default("America/New_York")
  slotDuration  Int      @default(30)
  bufferMinutes Int      @default(10)
  meetingLink   String?
  locationLabel String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  overrides MentorAvailabilityOverride[]

  @@index([mentorId, isActive])
}

model MentorAvailabilityOverride {
  id            String                            @id @default(cuid())
  mentorId      String
  mentor        User                              @relation("MentorAvailabilityOverrides", fields: [mentorId], references: [id], onDelete: Cascade)
  ruleId        String?
  rule          MentorAvailabilityRule?           @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  type          InterviewAvailabilityOverrideType
  startsAt      DateTime
  endsAt        DateTime
  timezone      String                            @default("America/New_York")
  slotDuration  Int?
  bufferMinutes Int?
  meetingLink   String?
  locationLabel String?
  note          String?
  isActive      Boolean                           @default(true)
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  @@index([mentorId, isActive, startsAt])
  @@index([ruleId])
}

model MentorshipActionItem {
  id             String                     @id @default(cuid())
  mentorshipId   String?
  mentorship     Mentorship?                @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId       String
  mentee         User                       @relation("MentorshipActionItemsForMentees", fields: [menteeId], references: [id], onDelete: Cascade)
  sessionId      String?
  session        MentorshipSession?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  title          String
  details        String?
  status         MentorshipActionItemStatus @default(OPEN)
  ownerId        String?
  owner          User?                      @relation("MentorshipActionItemsOwned", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User                       @relation("MentorshipActionItemsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  dueAt          DateTime?
  completedAt    DateTime?
  // Calm Mentorship (Phase 7): back-link to the org Action this commitment was
  // bridged into, so the "convert to Action" one-click is idempotent (a second
  // convert is a no-op). Nullable + backfill-free; cleared if the Action is
  // dropped, in which case a fresh convert creates a new one. No FK — the org
  // ActionItem links back via relatedEntityType:"MENTORSHIP", and this side
  // tolerates a stale id (the read path treats a missing target as unlinked).
  linkedActionId String?
  /// Follow-up spawned from a released mentor review — links the outcome back
  /// to the review, so "what came out of this review" is queryable.
  sourceReviewId String?
  sourceReview   MentorGoalReview?          @relation("ActionItemsFromReview", fields: [sourceReviewId], references: [id], onDelete: SetNull)
  /// The other direction: which current-G&R goal this action item advances.
  /// Completed items linked to a goal become that goal's evidence trail for
  /// the next review cycle — the minimum connection needed to close the loop
  /// from "review creates goal" to "work happens" to "next review evaluates
  /// progress," without a project-management system.
  grDocumentGoalId String?
  grDocumentGoal   GRDocumentGoal?          @relation("MentorshipActionItemsForGoal", fields: [grDocumentGoalId], references: [id], onDelete: SetNull)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([mentorshipId])
  @@index([menteeId, status])
  @@index([ownerId, status])
  @@index([sessionId])
  @@index([linkedActionId])
  @@index([sourceReviewId])
  @@index([grDocumentGoalId])
}

// ============================================
// MENTORSHIP 2.0 — Expertise taxonomy & mentee application intake
// (Action Tracker 3.0, Phase M1 — see docs/action-tracker-3.0/)
// Additive + flag-gated at runtime by ENABLE_MENTORSHIP_2. Status/proficiency
// vocabularies are TEXT validated in app code (lib/mentorship-2/constants.ts),
// matching the repo's actionType / partner.stage convention — no Postgres enums,
// so the vocabulary stays editable without a migration.
// ============================================

/// A reusable mentor specialization (e.g. "STEM Research", "College Essays").
/// Closes the audit's "no expertise taxonomy" gap; consumed by the matching
/// engine in Phase M2.
model ExpertiseArea {
  id        String            @id @default(cuid())
  slug      String            @unique
  name      String
  category  String?
  isActive  Boolean           @default(true)
  sortOrder Int               @default(0)
  mentors   MentorExpertise[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

/// Join: a mentor (User) claims an ExpertiseArea with an optional proficiency.
model MentorExpertise {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertiseAreaId String
  expertiseArea   ExpertiseArea @relation(fields: [expertiseAreaId], references: [id], onDelete: Cascade)
  proficiency     String? // FAMILIAR | PROFICIENT | EXPERT (app-validated)
  createdAt       DateTime      @default(now())

  @@unique([userId, expertiseAreaId])
  @@index([expertiseAreaId])
}

/// Mentee-initiated application for mentorship — the intake stage the audit
/// found missing (today mentees are assigned, never apply). Feeds the matching
/// queue; `matchedMentorshipId` records the resulting pairing when reviewed.
model MentorshipApplication {
  id                   String                          @id @default(cuid())
  applicantId          String
  applicant            User                            @relation("MentorshipApplicationsSubmitted", fields: [applicantId], references: [id], onDelete: Cascade)
  programGroup         MentorshipProgramGroup          @default(STUDENT)
  status               String                          @default("SUBMITTED") // SUBMITTED|UNDER_REVIEW|MATCHED|DECLINED|WITHDRAWN (app-validated)
  goals                String?
  interests            String[]
  preferredExpertise   String[] // ExpertiseArea slugs the mentee is seeking
  availability         String?
  motivation           String?
  reviewerId           String?
  reviewer             User?                           @relation("MentorshipApplicationsReviewed", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNotes          String?
  matchedMentorshipId  String? // app-validated id of the created Mentorship (no FK, mirrors repo convention)
  decidedAt            DateTime?
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt
  matchRecommendations MentorshipMatchRecommendation[]

  @@index([status])
  @@index([applicantId])
}

/// Mentorship 2.0 (Action Tracker 3.0, Phase M2) — a scored, explainable mentor
/// suggestion for a MentorshipApplication. One application fans out to many
/// SUGGESTED rows; at most one becomes APPROVED and drives the canonical
/// Mentorship pair (the losing siblings are auto-SUPERSEDED). `scoreBreakdownJson`
/// stores the matching engine's per-factor breakdown so admins can inspect *why*
/// a mentor was recommended — no opaque "AI match". `status` is a TEXT vocabulary
/// validated in app code (lib/mentorship-2/constants.ts), matching the repo's
/// actionType / partner.stage convention. Additive + flag-gated at runtime by
/// ENABLE_MENTORSHIP_2.
model MentorshipMatchRecommendation {
  id                      String                @id @default(cuid())
  mentorshipApplicationId String
  application             MentorshipApplication @relation(fields: [mentorshipApplicationId], references: [id], onDelete: Cascade)
  menteeUserId            String
  mentee                  User                  @relation("MatchRecommendationMentees", fields: [menteeUserId], references: [id], onDelete: Cascade)
  mentorUserId            String
  mentor                  User                  @relation("MatchRecommendationMentors", fields: [mentorUserId], references: [id], onDelete: Cascade)
  score                   Int                   @default(0)
  scoreBreakdownJson      Json                  @default("{}")
  status                  String                @default("SUGGESTED") // SUGGESTED|SHORTLISTED|APPROVED|REJECTED|HELD|SUPERSEDED (app-validated)
  adminNote               String?
  decidedAt               DateTime?
  decidedByUserId         String?
  decidedBy               User?                 @relation("MatchRecommendationDeciders", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  // Idempotent regeneration: re-running the engine upserts on this pair rather
  // than creating duplicate suggestions for the same application/mentor.
  @@unique([mentorshipApplicationId, mentorUserId])
  @@index([mentorshipApplicationId])
  @@index([menteeUserId])
  @@index([mentorUserId])
  @@index([status])
  @@index([score])
}

model MentorshipRequest {
  id             String                      @id @default(cuid())
  mentorshipId   String?
  mentorship     Mentorship?                 @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId       String
  mentee         User                        @relation("MentorshipRequestsForMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  requesterId    String
  requester      User                        @relation("MentorshipRequestsCreated", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedToId   String?
  assignedTo     User?                       @relation("MentorshipRequestsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  trackId        String?
  track          MentorshipTrack?            @relation(fields: [trackId], references: [id], onDelete: SetNull)
  kind           MentorshipRequestKind
  visibility     MentorshipRequestVisibility
  status         MentorshipRequestStatus     @default(OPEN)
  title          String
  details        String
  isAnonymous    Boolean                     @default(false)
  passionId      String?
  projectId      String?
  requestedAt    DateTime                    @default(now())
  resolvedAt     DateTime?
  lastResponseAt DateTime?
  responses      MentorshipRequestResponse[]
  resources      MentorshipResource[]

  @@index([mentorshipId])
  @@index([menteeId, status])
  @@index([assignedToId, status])
  @@index([visibility, status])
  @@index([kind, status])
  @@index([trackId])
}

model MentorshipRequestResponse {
  id                String               @id @default(cuid())
  requestId         String
  request           MentorshipRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  responderId       String
  responder         User                 @relation("MentorshipRequestResponses", fields: [responderId], references: [id], onDelete: Cascade)
  body              String
  videoUrl          String?
  resourceLinks     String[]             @default([])
  isHelpful         Boolean?
  helpfulCount      Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  promotedResources MentorshipResource[] @relation("MentorshipResourcesFromResponse")

  @@index([requestId, createdAt])
  @@index([responderId])
}

model MentorshipResource {
  id           String                     @id @default(cuid())
  mentorshipId String?
  mentorship   Mentorship?                @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  menteeId     String?
  mentee       User?                      @relation("MentorshipResourcesForMentee", fields: [menteeId], references: [id], onDelete: SetNull)
  requestId    String?
  request      MentorshipRequest?         @relation(fields: [requestId], references: [id], onDelete: SetNull)
  responseId   String?
  response     MentorshipRequestResponse? @relation("MentorshipResourcesFromResponse", fields: [responseId], references: [id], onDelete: SetNull)
  trackId      String?
  track        MentorshipTrack?           @relation(fields: [trackId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                       @relation("MentorshipResourcesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  type         MentorshipResourceType
  title        String
  description  String?
  url          String?
  body         String?
  passionId    String?
  isFeatured   Boolean                    @default(false)
  isPublished  Boolean                    @default(true)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([mentorshipId])
  @@index([menteeId])
  @@index([requestId])
  @@index([responseId])
  @@index([trackId])
  @@index([type, isPublished])
}

// ============================================
// EVENT & FEEDBACK MODELS
// ============================================

model Event {
  id                      String          @id @default(cuid())
  title                   String
  description             String
  eventType               EventType
  scope                   EventScope      @default(GLOBAL)
  visibility              EventVisibility @default(PUBLIC)
  startDate               DateTime
  endDate                 DateTime
  chapterId               String?
  chapter                 Chapter?        @relation(fields: [chapterId], references: [id])
  isAlumniOnly            Boolean         @default(false)
  createdById             String?
  createdBy               User?           @relation("EventsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById             String?
  updatedBy               User?           @relation("EventsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  seriesId                String?
  series                  EventSeries?    @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  occurrenceOriginalStart DateTime?
  isException             Boolean         @default(false)
  isCancelled             Boolean         @default(false)
  cancellationReason      String?
  reminder24Hr            Boolean         @default(true)
  reminder1Hr             Boolean         @default(true)

  // Calendar Integration
  location    String?
  meetingUrl  String?
  calendarUid String? @unique @default(cuid()) // For iCal UID

  // RSVP tracking
  rsvps              EventRsvp[]
  reminders          EventReminder[]
  attendanceSessions AttendanceSession[]
  checklists         CompetitionChecklist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId, startDate])
  @@index([scope, visibility, startDate])
  @@index([seriesId, startDate])
}

model EventSeries {
  id                  String                   @id @default(cuid())
  title               String
  description         String
  eventType           EventType
  scope               EventScope               @default(CHAPTER)
  visibility          EventVisibility          @default(INTERNAL)
  chapterId           String?
  chapter             Chapter?                 @relation(fields: [chapterId], references: [id])
  startDate           DateTime
  endDate             DateTime
  timezone            String                   @default("America/New_York")
  location            String?
  meetingUrl          String?
  recurrenceFrequency EventRecurrenceFrequency
  recurrenceInterval  Int                      @default(1)
  recurrenceDays      String[]
  recurrenceCount     Int?
  recurrenceUntil     DateTime?
  reminder24Hr        Boolean                  @default(true)
  reminder1Hr         Boolean                  @default(true)
  createdById         String?
  createdBy           User?                    @relation("EventSeriesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?
  updatedBy           User?                    @relation("EventSeriesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  events              Event[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([chapterId, recurrenceUntil])
  @@index([scope, visibility])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

model Feedback {
  id           String         @id @default(cuid())
  source       FeedbackSource
  rating       Int?
  comments     String
  courseId     String?
  instructorId String?
  chapterId    String?
  course       Course?        @relation(fields: [courseId], references: [id])
  instructor   User?          @relation("FeedbackTarget", fields: [instructorId], references: [id], onDelete: SetNull)
  chapter      Chapter?       @relation(fields: [chapterId], references: [id])
  authorId     String?
  author       User?          @relation("FeedbackSource", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
}

model Award {
  id          String     @id @default(cuid())
  name        String
  description String
  type        AwardType?
  recipientId String
  awardedAt   DateTime   @default(now())
  recipient   User       @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, awardedAt(sort: Desc)])
}

// ============================================
// APPLICATION & RECRUITMENT MODELS
// ============================================

model Position {
  id                  String             @id @default(cuid())
  title               String
  type                PositionType
  description         String?
  requirements        String?
  chapterId           String?
  chapter             Chapter?           @relation(fields: [chapterId], references: [id])
  openedById          String?
  openedBy            User?              @relation("PositionsOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  hiringLeadId        String?
  hiringLead          User?              @relation("PositionsHiringLead", fields: [hiringLeadId], references: [id], onDelete: SetNull)
  visibility          PositionVisibility @default(CHAPTER_ONLY)
  interviewRequired   Boolean            @default(true)
  targetStartDate     DateTime?
  applicationDeadline DateTime?
  isOpen              Boolean            @default(true)
  applications        Application[]
  createdAt           DateTime           @default(now())
  closedAt            DateTime?
  updatedAt           DateTime           @updatedAt

  @@index([chapterId, isOpen, createdAt])
  @@index([chapterId, type, isOpen])
  @@index([openedById])
  @@index([hiringLeadId])
}

model Application {
  id                  String                       @id @default(cuid())
  positionId          String
  position            Position                     @relation(fields: [positionId], references: [id])
  applicantId         String
  applicant           User                         @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  status              ApplicationStatus            @default(SUBMITTED)
  resumeUrl           String?
  coverLetter         String?
  additionalMaterials String?
  interviewSlots      InterviewSlot[]
  interviewNotes      InterviewNote[]
  schedulingRequests  InterviewSchedulingRequest[]
  decision            Decision?
  submittedAt         DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  archivedAt          DateTime?

  // --- External intake (Google Forms / CSV / manual admin entry) ---
  source              ApplicationSource @default(PORTAL)
  externalSubmittedAt DateTime?
  externalImportedAt  DateTime?
  externalResponseUrl String?
  externalAnswersCopy String?           @db.Text
  internalNotes       String?           @db.Text
  importedById        String?
  importedBy          User?             @relation("GenericApplicationImportedBy", fields: [importedById], references: [id], onDelete: SetNull)
  manualEmailTasks    ManualEmailTask[] @relation("ManualEmailTasksGenericApplication")

  @@index([positionId, status, submittedAt])
  @@index([source])
  @@index([importedById])
  @@index([archivedAt])
  @@index([applicantId])
}

model InterviewSlot {
  id            String              @id @default(cuid())
  applicationId String
  application   Application         @relation(fields: [applicationId], references: [id])
  status        InterviewSlotStatus @default(POSTED)
  scheduledAt   DateTime
  duration      Int                 @default(30)
  meetingLink   String?
  isConfirmed   Boolean             @default(false)
  interviewerId String?
  interviewer   User?               @relation("ApplicationInterviewer", fields: [interviewerId], references: [id], onDelete: SetNull)
  confirmedAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())

  @@index([applicationId, status, scheduledAt])
  @@index([interviewerId])
}

model InterviewNote {
  id                 String                @id @default(cuid())
  applicationId      String
  application        Application           @relation(fields: [applicationId], references: [id])
  authorId           String
  author             User                  @relation("InterviewNotesAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  content            String
  rating             Int?
  recommendation     HiringRecommendation?
  strengths          String?
  concerns           String?
  nextStepSuggestion String?
  createdAt          DateTime              @default(now())

  @@index([applicationId, createdAt])
}

model Decision {
  id                String      @id @default(cuid())
  applicationId     String      @unique
  application       Application @relation(fields: [applicationId], references: [id])
  decidedById       String
  decidedBy         User        @relation("DecisionsMade", fields: [decidedById], references: [id], onDelete: Cascade)
  accepted          Boolean
  notes             String?
  decidedAt         DateTime    @default(now())
  hiringChairStatus String?
  hiringChairNote   String?
  hiringChairId     String?
  hiringChair       User?       @relation("HiringChairDecisions", fields: [hiringChairId], references: [id], onDelete: SetNull)
  hiringChairAt     DateTime?
}


// ============================================
// ADMIN JOURNEY EDITOR — VERSIONING ENUMS
// (See docs/admin-journey-editor-plan.md §3)
// ============================================

enum JourneyVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum JourneyAudienceRole {
  STUDENT
  INSTRUCTOR
  CHAPTER_PRESIDENT
  LEADERSHIP
  SUMMER_WORKSHOP_INSTRUCTOR
  MENTOR
}

enum JourneyGateKind {
  READINESS_CHECK
  BEAT_COMPLETE
  MODULE_COMPLETE
  SCORE_THRESHOLD
}

enum JourneyAuditAction {
  CREATE
  UPDATE
  PUBLISH
  ROLLBACK
  ARCHIVE
  DELETE
  ASSIGNMENT_CHANGE
  GATE_CHANGE
}

model InteractiveJourney {
  id       String         @id @default(cuid())
  moduleId String         @unique
  module   TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  estimatedMinutes Int
  passScorePct     Int     @default(80)
  strictMode       Boolean @default(false)
  version          Int     @default(1)

  beats       InteractiveBeat[]
  completions InteractiveJourneyCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InteractiveBeat {
  id        String             @id @default(cuid())
  journeyId String
  journey   InteractiveJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  /// Nullable while legacy beats coexist with versioned snapshots.
  /// Backfilled to v1 PUBLISHED for every existing journey in the same
  /// migration. New beats authored through the admin editor MUST set
  /// this; learner runtime resolves beats by journeyVersionId once
  /// JOURNEY_VERSIONS_ENABLED flips on.
  journeyVersionId String?
  journeyVersion   JourneyVersion? @relation(fields: [journeyVersionId], references: [id], onDelete: SetNull)

  sourceKey String
  sortOrder Int
  kind      InteractiveBeatKind
  title     String
  prompt    String              @db.Text
  mediaUrl  String?

  config        Json
  schemaVersion Int  @default(1)

  scoringWeight Int     @default(10)
  scoringRule   String?

  parentBeatId String?
  parent       InteractiveBeat?  @relation("BeatBranch", fields: [parentBeatId], references: [id], onDelete: Cascade)
  children     InteractiveBeat[] @relation("BeatBranch")
  showWhen     Json?

  attempts InteractiveBeatAttempt[]

  removedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Legacy uniqueness on sourceKey within a journey is preserved so
  // the existing import script (npm run training:import) keeps working.
  @@unique([journeyId, sourceKey])
  // sourceKey is also unique inside a JourneyVersion snapshot. NULLs
  // do not collide in PostgreSQL composite unique indexes, so legacy
  // rows (journeyVersionId IS NULL) coexist safely.
  @@unique([journeyVersionId, sourceKey])
  // The previous @@unique([journeyId, sortOrder]) blocked drag-and-drop
  // reorder workflows (every reorder needed a temp shuffle). Replaced
  // with plain indexes; per-version sortOrder uniqueness is enforced
  // at validation time (lib/journey-editor/validation.ts).
  @@index([journeyId, sortOrder])
  @@index([journeyVersionId, sortOrder])
  @@index([parentBeatId])
}

model InteractiveBeatAttempt {
  id     String          @id @default(cuid())
  beatId String
  beat   InteractiveBeat @relation(fields: [beatId], references: [id], onDelete: Cascade)
  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  attemptNumber         Int
  response              Json
  responseSchemaVersion Int     @default(1)
  correct               Boolean
  score                 Int
  timeMs                Int?
  hintsShown            Int     @default(0)

  attemptedAt DateTime @default(now())

  @@unique([beatId, userId, attemptNumber])
  @@index([userId, beatId, attemptedAt])
  @@index([userId, attemptedAt])
}

model InteractiveJourneyCompletion {
  id        String             @id @default(cuid())
  journeyId String
  journey   InteractiveJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Snapshot the version a learner completed against. Nullable for
  /// legacy completions; backfilled to v1 PUBLISHED in the same
  /// migration. The runtime resolver added in Commit 12 will set this
  /// for every new completion so old snapshots stay queryable forever.
  journeyVersionId String?
  journeyVersion   JourneyVersion? @relation(fields: [journeyVersionId], references: [id], onDelete: SetNull)

  totalScore           Int
  maxScore             Int
  scorePct             Int
  passed               Boolean
  firstTryCorrectCount Int     @default(0)
  xpEarned             Int     @default(0)
  visitedBeatCount     Int

  moduleBreakdown  Json?
  personalizedTips Json?

  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([journeyId, userId])
  @@index([userId, completedAt])
  @@index([journeyVersionId])
}

// ============================================
// ADMIN JOURNEY EDITOR — VERSIONING MODELS
// ============================================
//
// `Journey` is the stable identity (slug, archive flag). It owns
// 1..N `JourneyVersion` rows, exactly one of which is PUBLISHED at a
// time. Beats live on a JourneyVersion snapshot so republish never
// mutates beats that learners already attempted (attempts FK to
// `InteractiveBeat.id`, which now belongs to a frozen snapshot).
//
// Legacy `InteractiveJourney`/`InteractiveBeat.journeyId` stay
// populated until the JOURNEY_VERSIONS_ENABLED resolver flag flips
// on in Commit 12. See docs/admin-journey-editor-plan.md §3.

model Journey {
  id          String  @id @default(cuid())
  /// URL-safe stable handle; backfilled from `TrainingModule.contentKey`
  /// when present, otherwise `journey-<id>`.
  slug        String  @unique
  title       String
  description String? @db.Text

  archivedAt DateTime?

  createdById String?
  createdBy   User?   @relation("JourneysCreated", fields: [createdById], references: [id], onDelete: SetNull)

  versions        JourneyVersion[]
  assignmentRules JourneyAssignmentRule[]
  auditLogs       JourneyAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
}

model JourneyVersion {
  id        String  @id @default(cuid())
  journeyId String
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  versionNumber Int
  status        JourneyVersionStatus @default(DRAFT)

  /// Optional pointer to the TrainingModule this version covers. Kept
  /// per-version so a future re-binding does not lose history. SetNull
  /// on module delete preserves the audit trail.
  moduleId String?
  module   TrainingModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  estimatedMinutes Int     @default(0)
  passScorePct     Int     @default(80)
  strictMode       Boolean @default(false)

  notes         String?   @db.Text
  publishedAt   DateTime?
  publishedById String?
  publishedBy   User?     @relation("JourneyVersionsPublished", fields: [publishedById], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("JourneyVersionsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  beats       InteractiveBeat[]
  completions InteractiveJourneyCompletion[]
  gates       JourneyGate[]
  auditLogs   JourneyAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([journeyId, versionNumber])
  @@index([journeyId, status, versionNumber])
  @@index([status])
  @@index([moduleId])
}

model JourneyGate {
  id               String         @id @default(cuid())
  journeyVersionId String
  journeyVersion   JourneyVersion @relation(fields: [journeyVersionId], references: [id], onDelete: Cascade)

  kind        JourneyGateKind
  /// e.g. "beat:lesson-design-studio-intro" or "module:academy_readiness_check_005".
  targetRef   String
  /// e.g. "module:academy_readiness_check_005".
  requiredRef String
  threshold   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journeyVersionId])
  @@index([kind])
}

model JourneyAssignmentRule {
  id        String  @id @default(cuid())
  journeyId String
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  audience   JourneyAudienceRole
  autoEnroll Boolean             @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([journeyId, audience])
  @@index([audience])
}

model JourneyAuditLog {
  id               String          @id @default(cuid())
  journeyId        String
  journey          Journey         @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyVersionId String?
  journeyVersion   JourneyVersion? @relation(fields: [journeyVersionId], references: [id], onDelete: SetNull)

  action  JourneyAuditAction
  /// Nullable so system-generated entries (backfills, scheduled jobs)
  /// can be attributed to "system".
  actorId String?
  actor   User?              @relation("JourneyAuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  summary String?
  /// Free-form diff payload — full prior + next state, set by the
  /// editor server actions in Commit 6.
  diff    Json?

  createdAt DateTime @default(now())

  @@index([journeyId, createdAt])
  @@index([journeyVersionId])
  @@index([action])
}

// ============================================
// SUMMER WORKSHOP INSTRUCTOR — WORKSHOP PROPOSALS
// ============================================
//
// Summer Workshop Instructor applicants finish the same training journeys as
// standard applicants but submit a one-off "workshop proposal" instead of a
// full Lesson Design Studio curriculum.
//
// Two source paths share one submission table:
//   * CUSTOM_DESIGN     — applicant authored their own outline in the
//                         Workshop Design Studio (data lives in `customWorkshop`)
//   * TEMPLATE_SELECTION — applicant picked one of the admin-curated templates
//                         in the library and answered the reflection
//                         questionnaire (the template id + reflection answers
//                         live on the same row)
//
// The naming "WorkshopProposal*" intentionally avoids the existing
// `WorkshopSeries`/`WorkshopSession`/`WorkshopEnrollment` models, which
// describe student-facing curriculum content and are unrelated.

/// Lifecycle of an admin-authored workshop template that applicants can pick.
enum WorkshopProposalTemplateStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

/// Difficulty scale aligned with the rest of the academy. Mirrors the
/// CourseConfig difficulty levels so reviewers see consistent labels.
enum WorkshopProposalDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

/// Where the proposal data came from. Drives applicant + reviewer UI.
enum WorkshopProposalSourceType {
  CUSTOM_DESIGN
  TEMPLATE_SELECTION
}

/// Reviewer-facing lifecycle of an applicant's submission.
enum WorkshopProposalSubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

/// Per-reviewer overall recommendation. Aggregates above into the parent
/// submission's status when the reviewer commits a decision.
enum WorkshopProposalReviewRecommendation {
  APPROVE
  REQUEST_CHANGES
  REJECT
}

/// Admin-curated workshop in the library. Only `APPROVED` rows are visible
/// to applicants; `DRAFT` and `ARCHIVED` are hidden in the picker.
model WorkshopProposalTemplate {
  id                 String                         @id @default(cuid())
  title              String
  category           String
  /// Free-text age range like "Grades 6–8" or "Ages 10–12".
  targetAgeRange     String
  /// Estimated workshop length in minutes. 60 by default.
  estimatedMinutes   Int                            @default(60)
  description        String                         @db.Text
  /// Bullet list rendered as ordered learning objectives.
  learningObjectives String[]                       @default([])
  /// Free-form activity plan (markdown allowed). Step-by-step facilitation guide.
  activityPlan       String                         @db.Text
  /// Materials checklist; each entry is a single line item.
  materials          String[]                       @default([])
  difficulty         WorkshopProposalDifficulty     @default(BEGINNER)
  tags               String[]                       @default([])
  status             WorkshopProposalTemplateStatus @default(DRAFT)

  createdById String
  createdBy   User    @relation("WorkshopProposalTemplatesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  updatedById String?
  updatedBy   User?   @relation("WorkshopProposalTemplatesUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  submissions WorkshopProposalSubmission[] @relation("WorkshopProposalSubmissionTemplate")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@index([status])
  @@index([category])
  @@index([difficulty])
}

/// Applicant's workshop proposal — either their own design or a selected
/// template + reflection. One submission per applicant; subsequent revisions
/// update the same row so the audit trail (reviews, history) stays anchored.
model WorkshopProposalSubmission {
  id            String  @id @default(cuid())
  authorId      String
  author        User    @relation("WorkshopProposalSubmissionsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  /// Optional pointer to the InstructorApplication for cohort/track context.
  /// Stored loosely (no FK) because the application id may not exist yet
  /// when an applicant resumes a draft.
  applicationId String?

  sourceType WorkshopProposalSourceType

  /// CUSTOM_DESIGN payload. Shape:
  ///   {
  ///     title, targetAgeGroup, lengthMinutes, category, learningObjective,
  ///     materials[], openingHook, mainActivity, participationPlan,
  ///     wrapUp, backupPlan
  ///   }
  customWorkshop Json?

  /// TEMPLATE_SELECTION pointer. Snapshotting the template id is enough —
  /// the template is read-fresh at view time so reviewers always see the
  /// current admin copy plus the applicant's reflection.
  templateId String?
  template   WorkshopProposalTemplate? @relation("WorkshopProposalSubmissionTemplate", fields: [templateId], references: [id], onDelete: SetNull)

  /// Reflection answers (always required). Shape:
  ///   {
  ///     whyChosen, audienceAdaptation, hardestPart, engagementPlan
  ///   }
  reflection Json?

  status WorkshopProposalSubmissionStatus @default(DRAFT)

  submittedAt  DateTime?
  /// Set when ANY reviewer first opens the submission with intent to score.
  inReviewAt   DateTime?
  reviewedAt   DateTime?
  /// Latest reviewer who committed a decision. Older decisions stay in
  /// `reviews` for the audit trail.
  reviewedById String?
  reviewedBy   User?     @relation("WorkshopProposalSubmissionsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  /// Applicant-facing feedback summary from the latest committed decision.
  applicantFeedback String? @db.Text
  /// Internal-only reviewer notes (not shown to applicant).
  internalNotes     String? @db.Text

  reviews WorkshopProposalReview[] @relation("WorkshopProposalReviewSubmission")

  /// Camp/workshop assignments using this proposal as curriculum. One proposal
  /// can power multiple assignments (reusable curriculum across opportunities).
  assignments InstructorAssignment[] @relation("WorkshopProposalSubmissionAssignments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId])
  @@index([status])
  @@index([sourceType])
  @@index([templateId])
  @@index([reviewedById])
}

/// Per-reviewer scored review of a submission. Multiple reviewers can score
/// the same submission; each row is preserved as audit history. The active
/// "decision" surfaces on `WorkshopProposalSubmission.status` when a reviewer
// ============================================
// EXTERNAL INTAKE — MANUAL EMAIL TASKS
// ============================================

/// A checklist row representing an email an admin should send manually
/// (outside the portal) for a given application. The portal does NOT
/// auto-send these — it only surfaces "what to send / when / suggested
/// copy", and tracks status when the admin marks it sent / not needed /
/// handled externally.
///
/// Exactly one of `instructorApplicationId`, `chapterPresidentApplicationId`,
/// or `genericApplicationId` is set per row, so the same model can attach
/// to all three application types without duplicating workflow code.
model ManualEmailTask {
  id String @id @default(cuid())

  // --- Polymorphic application link (exactly one set) ---
  instructorApplicationId String?
  instructorApplication   InstructorApplication? @relation("ManualEmailTasksInstructorApplication", fields: [instructorApplicationId], references: [id], onDelete: Cascade)

  chapterPresidentApplicationId String?
  chapterPresidentApplication   ChapterPresidentApplication? @relation("ManualEmailTasksChapterPresidentApplication", fields: [chapterPresidentApplicationId], references: [id], onDelete: Cascade)

  genericApplicationId String?
  genericApplication   Application? @relation("ManualEmailTasksGenericApplication", fields: [genericApplicationId], references: [id], onDelete: Cascade)

  // --- Content ---
  kind             ManualEmailKind
  status           ManualEmailStatus @default(PENDING)
  suggestedSubject String?           @db.Text
  suggestedBody    String?           @db.Text
  notes            String?           @db.Text

  // --- Status transitions (audit) ---
  markedSentAt   DateTime?
  markedSentById String?
  markedSentBy   User?     @relation("ManualEmailTasksMarkedSent", fields: [markedSentById], references: [id], onDelete: SetNull)

  // --- Creation ---
  createdById String?
  createdBy   User?   @relation("ManualEmailTasksCreated", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorApplicationId, status])
  @@index([chapterPresidentApplicationId, status])
  @@index([genericApplicationId, status])
  @@index([kind])
  @@index([status])
  @@index([markedSentById])
  @@index([createdById])
}

/// commits.
model WorkshopProposalReview {
  id           String                     @id @default(cuid())
  submissionId String
  submission   WorkshopProposalSubmission @relation("WorkshopProposalReviewSubmission", fields: [submissionId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User                       @relation("WorkshopProposalReviewsAuthored", fields: [reviewerId], references: [id], onDelete: Cascade)

  /// 1–5 ratings, nullable so an in-progress draft review can save partial work.
  clarityRating            Int?
  engagementRating         Int?
  feasibilityRating        Int?
  ageAppropriatenessRating Int?
  preparednessRating       Int?
  /// 1–5 alignment with YPP values rating.
  alignmentRating          Int?

  overallRecommendation WorkshopProposalReviewRecommendation?

  applicantFeedback String? @db.Text
  internalNote      String? @db.Text

  /// True when the reviewer has clicked "commit decision". Drafts (committed
  /// = false) are ignored when computing submission status.
  committed   Boolean   @default(false)
  committedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@index([reviewerId])
  @@index([overallRecommendation])
}

// ============================================
// INSTRUCTOR ASSIGNMENT SYSTEM (admin operations layer)
//
// Phase 1: admin-only operational tool that lets staff manage partner camps /
// workshops / programs that need instructors and track who is staffed where.
//
// A `WorkshopOpportunity` represents one real-world placement (a partner camp,
// a one-time workshop, a chapter program) that needs N instructor slots filled.
// An `InstructorAssignment` links a User (instructor) to one WorkshopOpportunity
// with a role + status + optional WorkshopProposalSubmission curriculum link.
//
// Out of scope for Phase 1 (deliberately):
//   - Instructor-side accept/decline UI (admins manage statuses)
//   - Email/notification dispatch
//   - Hard conflict detection across overlapping date ranges
//   - Calendar/Slack integration
// ============================================

/// Kind of placement an opportunity represents. Drives sort/filter on the
/// admin board and lets us evolve specialized views later.
enum OpportunityType {
  SUMMER_CAMP
  PARTNER_PROGRAM
  ONE_TIME_WORKSHOP
  MULTI_DAY_CAMP
  CHAPTER_CLASS_SERIES
  ONLINE_WORKSHOP
  OTHER
}

/// Lifecycle of an opportunity from admin's perspective.
///   DRAFT       — admin drafting, not yet visible as "open" on the board
///   OPEN        — needs instructors (partially or fully unstaffed)
///   CONFIRMED   — all required slots staffed and locked
///   COMPLETED   — placement happened
///   CANCELLED   — partner pulled out / never ran
///   ARCHIVED    — closed out for historical reference
enum OpportunityStatus {
  DRAFT
  OPEN
  CONFIRMED
  COMPLETED
  CANCELLED
  ARCHIVED
}

/// Urgency tag the admin sets manually to surface what needs attention first.
enum OpportunityUrgency {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// LEADERSHIP ACTION CENTER
// Internal operating-rhythm tracker that turns the spreadsheet + weekly
// email update into structured tasks the portal can read off of.
// ============================================

enum LeadershipActionCategory {
  INSTRUCTION
  TECHNOLOGY
  COMMUNICATION
  STAFF_MANAGEMENT
}

enum LeadershipActionStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum LeadershipActionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LeadershipActionSource {
  MANUAL
  SPREADSHEET
  EMAIL
  IMPORT
}

enum LeadershipMeetingKind {
  OFFICERS
  MARKETING
  TECH
  INSTRUCTION
  STAFF
  OTHER
}

enum LeadershipActionUpdateKind {
  COMMENT
  STATUS_CHANGE
  ASSIGNEE_CHANGE
  DEADLINE_CHANGE
  CREATED
  IMPORTED
}

/// Recurring or one-off leadership meeting (Officers, Marketing, Tech, etc.)
/// Tasks attach to a meeting so the meeting prep view can surface them and
/// build a suggested agenda from the live tracker.
model LeadershipMeeting {
  id          String                 @id @default(cuid())
  title       String
  kind        LeadershipMeetingKind  @default(OFFICERS)
  scheduledAt DateTime?
  notes       String?                @db.Text
  ownerId     String?
  owner       User?                  @relation("LeadershipMeetingsOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  archivedAt  DateTime?
  actionItems LeadershipActionItem[] @relation("LeadershipActionItemMeeting")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, scheduledAt])
  @@index([scheduledAt])
}

/// One row per action item in the leadership tracker. Replaces the columns
/// of the "Action Items Tracker" spreadsheet (Category, Item, Deadline,
/// Primary Owners, Get Input From, Status, Needs Officer Discussion?,
/// Officer Discussion Date) with structured fields the portal can query.
///
/// `weekStart` is the Monday of the operating week the task is attached to;
/// the weekly digest groups by this date.
model LeadershipActionItem {
  id          String                   @id @default(cuid())
  title       String
  description String?                  @db.Text
  category    LeadershipActionCategory @default(INSTRUCTION)
  status      LeadershipActionStatus   @default(NOT_STARTED)
  priority    LeadershipActionPriority @default(NORMAL)
  source      LeadershipActionSource   @default(MANUAL)
  /// Free-text label for the source row (spreadsheet row #, email subject, etc.)
  sourceLabel String?
  /// Free-text notes about how the row was imported.
  sourceNotes String?                  @db.Text

  /// Calendar deadline for the task. Used for due-today / due-this-week
  /// filters and the weekly digest grouping.
  dueDate   DateTime?
  /// Monday of the operating week the task belongs to. Optional so backlog
  /// items can exist without a week assignment.
  weekStart DateTime?

  /// Officer-discussion flag + the meeting it should be discussed at.
  needsOfficerDiscussion Boolean   @default(false)
  officerDiscussionDate  DateTime?

  /// Optional link to a structured meeting record (Officers, Tech, etc.).
  meetingId String?
  meeting   LeadershipMeeting? @relation("LeadershipActionItemMeeting", fields: [meetingId], references: [id], onDelete: SetNull)

  /// Primary owner is a single user (the row in the spreadsheet usually
  /// names one accountable person). Additional owners can be tracked via
  /// the secondaryOwners string list to avoid an extra join table for v1.
  primaryOwnerId String?
  primaryOwner   User?    @relation("LeadershipActionItemsOwned", fields: [primaryOwnerId], references: [id], onDelete: SetNull)
  /// Free-text fallback for owners that are not yet portal users.
  ownerNames     String[] @default([])

  /// Plain-text "input needed from" fallback when the people are not yet
  /// portal users. Structured `inputNeededFrom` rows below cover users.
  inputNeededNames String[] @default([])

  /// Notes / blocker description shown in the table and digest.
  notes       String?   @db.Text
  /// True when the task has been completed.
  completedAt DateTime?

  createdById String?
  createdBy   User?   @relation("LeadershipActionItemsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("LeadershipActionItemsUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  archivedAt DateTime?

  inputNeededFrom LeadershipActionItemInput[]  @relation("LeadershipActionItemInputItem")
  updates         LeadershipActionItemUpdate[] @relation("LeadershipActionItemUpdateItem")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueDate])
  @@index([category, status])
  @@index([weekStart, status])
  @@index([primaryOwnerId, status])
  @@index([needsOfficerDiscussion, officerDiscussionDate])
  @@index([meetingId])
  @@index([archivedAt])
}

/// Many-to-many link between an action item and the users who should give
/// input on it. Kept separate from `inputNeededNames` (free-text fallback)
/// so structured users can be filtered/notified independently.
model LeadershipActionItemInput {
  id           String               @id @default(cuid())
  actionItemId String
  actionItem   LeadershipActionItem @relation("LeadershipActionItemInputItem", fields: [actionItemId], references: [id], onDelete: Cascade)
  userId       String
  user         User                 @relation("LeadershipActionItemInputUser", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([actionItemId, userId])
  @@index([userId])
}

/// Activity log + comments for an action item. `kind` lets the UI render
/// human comments differently from system events (status changes, etc.).
model LeadershipActionItemUpdate {
  id           String                     @id @default(cuid())
  actionItemId String
  actionItem   LeadershipActionItem       @relation("LeadershipActionItemUpdateItem", fields: [actionItemId], references: [id], onDelete: Cascade)
  authorId     String?
  author       User?                      @relation("LeadershipActionItemUpdateAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  kind         LeadershipActionUpdateKind @default(COMMENT)
  body         String                     @db.Text

  createdAt DateTime @default(now())

  @@index([actionItemId, createdAt])
}

/// Role an instructor plays on a given assignment.
enum AssignmentRole {
  LEAD_INSTRUCTOR
  CO_INSTRUCTOR
  ASSISTANT
  SUBSTITUTE
  MENTOR
}

/// Admin-driven assignment lifecycle. The dual confirmation timestamps
/// (`instructorConfirmedAt` / `partnerConfirmedAt`) on the row let admins
/// record fine-grained state without a status explosion.
///
///   SUGGESTED      — admin shortlisted internally, not yet offered
///   PENDING        — offered to instructor (or partner), awaiting confirmation
///   CONFIRMED      — instructor + partner both locked in
///   WAITLISTED     — backup option
///   DECLINED       — instructor declined or no longer available
///   CANCELLED      — assignment voided
///   COMPLETED      — assignment fulfilled
enum AssignmentStatus {
  SUGGESTED
  PENDING
  CONFIRMED
  WAITLISTED
  DECLINED
  CANCELLED
  COMPLETED
}

/// A real-world placement that needs instructors. Distinct from `ClassOffering`
/// (which is a chapter class series with student enrollment) — opportunities
/// support multi-instructor staffing, partner contacts, and external programs.
model WorkshopOpportunity {
  id          String             @id @default(cuid())
  title       String
  partnerName String?
  type        OpportunityType    @default(PARTNER_PROGRAM)
  status      OpportunityStatus  @default(OPEN)
  urgency     OpportunityUrgency @default(NORMAL)

  /// Free-text summary shown in the detail drawer. Keep short.
  description String? @db.Text

  /// Reuses the existing DeliveryMode enum (IN_PERSON | VIRTUAL | HYBRID).
  deliveryMode DeliveryMode @default(IN_PERSON)

  /// Location fields are optional so online programs can omit them.
  locationName    String?
  locationCity    String?
  locationState   String?
  locationCountry String?

  /// Scheduling window. Both nullable so partial info can be drafted.
  startDate  DateTime?
  endDate    DateTime?
  /// Deadline by which staffing should be finalized.
  fillByDate DateTime?

  /// Number of instructor slots required. Coverage is derived from
  /// `assignments` filtered to active statuses (CONFIRMED / PENDING).
  slotsNeeded Int @default(1)

  /// Free-form audience descriptor (e.g. "Grades 6-8", "Ages 10-12").
  ageGroup String?

  /// Topic tags used for matching (lowercased on write). E.g. ["physics", "coding"].
  topicTags String[] @default([])

  /// Optional required teaching level (links to existing CourseLevel enum).
  requiredCourseLevel CourseLevel?

  /// Chapter scope (optional). If set, chapter presidents can manage this row.
  chapterId String?
  chapter   Chapter? @relation("WorkshopOpportunityChapter", fields: [chapterId], references: [id], onDelete: SetNull)

  /// Internal admin owner — the person on staff responsible for filling it.
  ownerId String?
  owner   User?   @relation("WorkshopOpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  /// Partner-facing contact info (kept admin-private).
  partnerContactName  String?
  partnerContactEmail String?
  partnerContactPhone String?

  /// Internal admin notes (never shown to instructors).
  internalNotes String? @db.Text

  createdById String
  createdBy   User   @relation("WorkshopOpportunityCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  assignments InstructorAssignment[] @relation("InstructorAssignmentOpportunity")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@index([status])
  @@index([urgency])
  @@index([startDate])
  @@index([fillByDate])
  @@index([chapterId])
  @@index([ownerId])
  @@index([type])
}

/// Links an instructor to a WorkshopOpportunity. One row per
/// (opportunity, instructor) pair — a single instructor cannot hold two
/// active slots on the same opportunity.
model InstructorAssignment {
  id String @id @default(cuid())

  opportunityId String
  opportunity   WorkshopOpportunity @relation("InstructorAssignmentOpportunity", fields: [opportunityId], references: [id], onDelete: Cascade)

  instructorId String
  instructor   User   @relation("InstructorAssignmentInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  /// Optional pointer to the approved WorkshopProposalSubmission the
  /// instructor will teach. Nullable so admins can stage assignments before
  /// curriculum is finalized.
  proposalId String?
  proposal   WorkshopProposalSubmission? @relation("WorkshopProposalSubmissionAssignments", fields: [proposalId], references: [id], onDelete: SetNull)

  role   AssignmentRole   @default(LEAD_INSTRUCTOR)
  status AssignmentStatus @default(SUGGESTED)

  assignedById String?
  assignedBy   User?    @relation("InstructorAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedAt   DateTime @default(now())

  instructorConfirmedAt DateTime?
  partnerConfirmedAt    DateTime?
  declinedAt            DateTime?
  cancelledAt           DateTime?
  completedAt           DateTime?

  /// Override for this assignment when it differs from the parent opportunity
  /// (e.g. one instructor covers a single day of a multi-day camp).
  startTime DateTime?
  endTime   DateTime?

  /// Internal admin notes (never shown to the instructor).
  internalNotes   String? @db.Text
  /// Instructor-visible notes about expectations / prep.
  instructorNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([opportunityId, instructorId])
  @@index([instructorId])
  @@index([status])
  @@index([proposalId])
  @@index([assignedById])
}

// ============================================
// REGULAR INSTRUCTOR ASSIGNMENTS (MVP)
// ============================================
// First-class join between a ClassOffering and an instructor User.
// Adds role + lifecycle status on top of the existing singular
// ClassOffering.instructorId (which remains the canonical "lead pointer"
// so downstream surfaces — reminders, attendance, my-classes, instructor
// gating — keep working unchanged). Co-instructors, assistants, and
// backups all live here.

/// Role an instructor holds on a class offering.
enum RegularInstructorAssignmentRole {
  LEAD
  CO_INSTRUCTOR
  ASSISTANT
  BACKUP
}

/// Lifecycle state for a regular instructor assignment.
enum RegularInstructorAssignmentStatus {
  SUGGESTED // Admin shortlisted via matching, not yet acted on
  PENDING_REVIEW // Created, awaiting admin action
  OFFERED // Sent to instructor; awaiting their acceptance
  INSTRUCTOR_CONFIRMED // Instructor accepted; chapter not yet confirmed
  CHAPTER_CONFIRMED // Chapter confirmed; instructor not yet accepted
  FULLY_CONFIRMED // Both sides confirmed
  NEEDS_TRAINING // Blocked on training requirement
  NEEDS_CURRICULUM // Blocked on curriculum review
  DECLINED // Instructor declined the offer
  REMOVED // Admin removed the assignment
  COMPLETED // Class run finished
}

model RegularInstructorAssignment {
  id           String        @id @default(cuid())
  offeringId   String
  offering     ClassOffering @relation("RegularInstructorAssignmentsForOffering", fields: [offeringId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User          @relation("RegularInstructorAssignments", fields: [instructorId], references: [id], onDelete: Cascade)

  role   RegularInstructorAssignmentRole   @default(LEAD)
  status RegularInstructorAssignmentStatus @default(PENDING_REVIEW)

  // Optional chapter/region — denormalized for filtering. Defaults from
  // the offering's chapter at create time.
  chapterId String?
  chapter   Chapter? @relation("RegularInstructorAssignmentsForChapter", fields: [chapterId], references: [id])

  // Optional curriculum link. Either a draft (in-flight curriculum) or the
  // template the offering was instantiated from. Both nullable so admins can
  // make assignments before curriculum is finalized.
  curriculumDraftId String?
  curriculumDraft   CurriculumDraft? @relation("CurriculumDraftAssignments", fields: [curriculumDraftId], references: [id])
  classTemplateId   String?
  classTemplate     ClassTemplate?   @relation("ClassTemplateAssignments", fields: [classTemplateId], references: [id])

  // Confirmation timestamps — null until each side confirms.
  offeredAt             DateTime?
  instructorConfirmedAt DateTime?
  chapterConfirmedAt    DateTime?
  declinedAt            DateTime?
  removedAt             DateTime?
  completedAt           DateTime?

  // Notes. `adminNotes` is admin-only; `instructorNote` is shown to the
  // assigned instructor on their assignment card.
  adminNotes     String? @db.Text
  instructorNote String? @db.Text

  // Audit
  createdById String?
  createdBy   User?   @relation("RegularInstructorAssignmentsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("RegularInstructorAssignmentsUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One row per (offering, instructor, role) — an instructor can hold
  // multiple distinct roles on the same offering only if we intentionally
  // create them (e.g. mentor + assistant), which is rare. The unique
  // constraint prevents accidental duplicate assignments.
  @@unique([offeringId, instructorId, role])
  @@index([offeringId])
  @@index([instructorId])
  @@index([status])
  @@index([chapterId])
  @@index([role])
}

// ============================================================
// INSTRUCTOR OPS V2 — operational layer for admin dashboards
// ============================================================

/// Top-level lifecycle stage for an instructor inside the platform.
enum InstructorLifecycleStage {
  APPLICANT // still in application funnel
  ONBOARDING // approved, completing training / shadow
  ACTIVE // teaching in rotation
  BENCH // available but not currently assigned
  PAUSED // temporary break (school, leave, etc.)
  ALUMNI // off-platform; record retained for history
}

/// One row per instructor — holds operational metadata that doesn't
/// belong on the enormous User model.  Created lazily on first admin
/// interaction; a missing row is treated as defaults.
model InstructorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lifecycleStage InstructorLifecycleStage @default(ACTIVE)
  stageEnteredAt DateTime                 @default(now())

  /// Rough weekly capacity the instructor self-reported.
  weeklyHoursAvail  Int?
  /// Hard cap on concurrent class assignments (default 2).
  maxConcurrent     Int     @default(2)
  /// True when admin has flagged this person for leadership development.
  isLeadershipTrack Boolean @default(false)
  /// Soft hold — excluded from assignment suggestions while true.
  isOnHold          Boolean @default(false)

  /// Cached readiness score 0-100, recomputed nightly.
  readinessScore   Int?
  /// Cached reliability score 0-100 (based on no-shows, completions).
  reliabilityScore Int?
  lastActiveAt     DateTime?

  notes   InstructorNote[]
  tasks   InstructorTask[]
  tags    InstructorTag[]
  metrics InstructorMetricSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lifecycleStage])
  @@index([isLeadershipTrack])
  @@index([isOnHold])
  @@index([readinessScore])
  @@index([lastActiveAt])
}

/// Namespace for a tag (used as a prefix when rendering chips).
enum TagNamespace {
  SKILL
  INTEREST
  LANGUAGE
  AVAILABILITY
  TRAIT
  CERTIFICATION
  CUSTOM
}

/// Reusable label that can be attached to any InstructorProfile.
/// Namespaced so skill:python, language:es, trait:reliable, etc.
model Tag {
  id        String       @id @default(cuid())
  namespace TagNamespace
  slug      String // lowercased, hyphenated, e.g. "public-speaking"
  label     String // display text, e.g. "Public Speaking"
  color     String? // optional hex for chip background
  isSystem  Boolean      @default(false) // system-managed (auto:idle, etc.)

  instructorTags InstructorTag[]

  createdAt DateTime @default(now())

  @@unique([namespace, slug])
  @@index([namespace])
}

/// M:M join between InstructorProfile and Tag.
model InstructorTag {
  profileId String
  tagId     String
  /// How was it added: manual (admin), imported (bulk), computed (nightly job).
  source    String   @default("manual")
  addedAt   DateTime @default(now())

  profile InstructorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tag     Tag               @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([profileId, tagId])
  @@index([tagId])
}

/// Admin-written notes attached to an instructor profile.
model InstructorNote {
  id        String            @id @default(cuid())
  profileId String
  profile   InstructorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("InstructorNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  body       String  @db.Text
  isPinned   Boolean @default(false)
  /// Visibility scope: chapter | global | private (author-only).
  visibility String  @default("global")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, isPinned, createdAt])
  @@index([authorId])
}

enum InstructorTaskKind {
  CERT_EXPIRING
  STALLED_STAGE
  IDLE_30D
  DECLINED_REPEAT
  GHOSTING_MENTEE
  TRAINING_OVERDUE
  MANUAL
}

/// Action item linked to an instructor profile. Auto-generated by nightly
/// jobs or manually created by admins.
model InstructorTask {
  id        String            @id @default(cuid())
  profileId String
  profile   InstructorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  kind        InstructorTaskKind @default(MANUAL)
  title       String
  description String?            @db.Text
  dueAt       DateTime?

  assigneeId String?
  assignee   User?   @relation("InstructorTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  resolvedAt   DateTime?
  resolvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, resolvedAt])
  @@index([dueAt])
  @@index([assigneeId, resolvedAt])
}

/// Saved filter/sort state for the instructor directory.
/// Admins can save personal views or share them within their chapter.
model InstructorSavedView {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("InstructorSavedViewOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  name     String
  /// JSON blob: { stage?, chapterId?, tagIds?, search?, sortKey?, sortDir? }
  filters  Json
  isShared Boolean @default(false)
  /// Scope: personal | chapter | global
  scope    String  @default("personal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([isShared, scope])
}

/// Weekly metric rollup per instructor, computed by a scheduled job.
/// Keeps a historical record for trending without bloating the profile.
model InstructorMetricSnapshot {
  id        String            @id @default(cuid())
  profileId String
  profile   InstructorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  weekStart      DateTime // Monday 00:00 UTC of the snapshot week
  classesTaught  Int      @default(0)
  hoursTaught    Int      @default(0)
  noShows        Int      @default(0)
  ratingAvg      Float?
  studentsServed Int      @default(0)

  createdAt DateTime @default(now())

  @@unique([profileId, weekStart])
  @@index([profileId, weekStart])
}

// ============================================
// ACTION TRACKER (People Strategy)
// New Action Items layer with explicit Lead / Executing / Input roles,
// per-item visibility, threaded comments, and file links. Gated at runtime
// behind ENABLE_ACTION_TRACKER (see lib/feature-flags.ts). Distinct from the
// older Leadership Action Center (`LeadershipActionItem`), which models the
// weekly operating spreadsheet rather than role-based People-Strategy
// ownership. Later phases add server actions, emails, UI, Feedback Requests,
// and Officer Meetings foundation behind the feature flags.
// ============================================

enum ActionItemStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  OVERDUE
  /// Work cannot proceed until an external blocker clears (Phase 7).
  BLOCKED
  /// Intentionally abandoned / no longer relevant (Phase 7). Keeps the record
  /// for history without counting against momentum or the overdue sweep.
  DROPPED
}

/// Relative urgency of an action item (Phase 7). Ported from the retired
/// Leadership Action Center's priority concept. Feeds the Command Center
/// attention queue + momentum weighting.
enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActionItemVisibility {
  OFFICERS_ONLY
  ALL_LEADERSHIP
}

/// Role a user plays on an action item. A single user can hold more than one
/// role on the same item (e.g. the lead is also an executor).
enum ActionAssignmentRole {
  LEAD
  EXECUTING
  INPUT
}

enum ActionCommentType {
  NOTE
  INPUT_REQUESTED
}

/// Minimal functional department (Instruction, Marketing, Technology, …) an
/// Action Item belongs to. The kickoff's "department" is a *functional* area,
/// which the geographic `Chapter` model does not represent, so a small
/// dedicated model is used here (permitted by the task's "otherwise minimal
/// Department model" fallback). Kept intentionally light for v1.
model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String?   @unique
  description String?   @db.Text
  archivedAt  DateTime?

  actionItems     ActionItem[]           @relation("DepartmentActionItems")
  actionItemLinks ActionItemDepartment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
}

/// Many-to-many link when an action spans more than one team. `ActionItem.departmentId`
/// remains the primary team for sorting and legacy callers; all linked teams are
/// stored here and used for filters + hub grouping.
model ActionItemDepartment {
  actionItemId String
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([actionItemId, departmentId])
  @@index([departmentId])
}

/// One People-Strategy action item. Ownership is expressed through
/// `ActionAssignment` rows (LEAD / EXECUTING / INPUT); `leadId` is the single
/// accountable lead denormalized onto the row for fast "My Actions" lookups
/// and display.
model ActionItem {
  id           String  @id @default(cuid())
  title        String
  description  String? @db.Text
  /// Free-text goal category this item ladders up to (kept as a string for
  /// v1, mirroring the loosely-typed category fields elsewhere in the schema).
  goalCategory String?

  /// Controlled-vocabulary KIND of work this action represents (outreach,
  /// follow-up, instructor onboarding, partnership, …). String-typed (no
  /// Postgres enum) to mirror `goalCategory` / `relatedEntityType` and keep the
  /// vocabulary editable without a migration; validated in application code
  /// (lib/people-strategy/action-types.ts). Null = untyped (renders no badge).
  actionType String?

  /// Functional department this item belongs to. Optional — an item can be
  /// created before it has been triaged into a department.
  departmentId String?
  department   Department? @relation("DepartmentActionItems", fields: [departmentId], references: [id])

  status        ActionItemStatus     @default(NOT_STARTED)
  priority      ActionPriority       @default(MEDIUM)
  deadlineStart DateTime
  deadlineEnd   DateTime?
  /// Set when the item transitions to COMPLETE; cleared if it is reopened. Gives
  /// the Win Log / pulse / momentum an exact completion timestamp instead of
  /// approximating with `updatedAt` (Phase 7).
  completedAt   DateTime?
  /// Officer sign-off after COMPLETE. Null = waiting for approval; set when an
  /// officer approves. Cleared if the item is reopened. Approved items roll off
  /// the hub after a short grace window but remain in the Approved list.
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?                @relation("ActionItemsApproved", fields: [approvedById], references: [id], onDelete: SetNull)
  visibility    ActionItemVisibility @default(ALL_LEADERSHIP)

  /// Single accountable lead (denormalized; also represented as an
  /// ActionAssignment row with role LEAD).
  leadId String
  lead   User   @relation("ActionItemsLed", fields: [leadId], references: [id], onDelete: Cascade)

  /// Optional source check-in for mentorship-created next steps. Mentorship
  /// check-ins stay in MentorshipSession; this only preserves provenance for
  /// canonical Action Tracker records.
  mentorshipSessionId String?
  mentorshipSession   MentorshipSession? @relation("MentorshipSessionActionItems", fields: [mentorshipSessionId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("ActionItemsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  /// Set when an item is escalated / flagged for officer attention.
  flaggedAt DateTime?

  /// People-Strategy escalation state. A flagged or OVERDUE item that goes
  /// unresolved for 48h+ is escalated to Leadership by the daily escalation
  /// cron, which sets `escalatedToLeadershipAt` (the dedupe guard ensuring
  /// Leadership is notified exactly once). `resolvedAt` is set when Leadership
  /// clears the item from the Escalation Queue. `boardRolledUpAt` is reserved
  /// for a later phase that rolls escalations up into a Board summary.
  escalatedToLeadershipAt DateTime?
  resolvedAt              DateTime?
  boardRolledUpAt         DateTime?

  /// Polymorphic link to a related domain entity (CLASS_OFFERING / MENTORSHIP /
  /// USER / INSTRUCTOR_APPLICATION). String-typed (no FK) to mirror the
  /// loosely-typed goalCategory field and keep cross-domain linking flexible.
  /// Validated by a TS union + Zod + a write-time existence check
  /// (lib/people-strategy/constants.ts). NOTE: department and officer-meeting
  /// links use the EXISTING departmentId / officerMeetingId FKs, NOT this field,
  /// to avoid two sources of truth.
  relatedEntityType String?
  relatedEntityId   String?

  /// Explicit assignment of this action to a Meeting (the new weekly-meetings
  /// `Meeting` model), set from the Actions hub "+ Add to meeting" picker. This
  /// is INDEPENDENT of sourceType/sourceId provenance — assigning an action to a
  /// meeting does not change how the action originated. SetNull keeps the action
  /// if the meeting is deleted.
  meetingId String?
  meeting   Meeting? @relation("ActionItemMeeting", fields: [meetingId], references: [id], onDelete: SetNull)

  // --- Action System 4.0 — honest source provenance + strategic linkage ------
  /// HOW this action came to exist. Controlled vocabulary (MANUAL / MEETING /
  /// MEETING_DECISION / PROJECT / INITIATIVE / ENTITY / WEEKLY_REVIEW /
  /// COMMAND_CENTER / FOLLOW_UP), string-typed to mirror actionType /
  /// relatedEntityType and stay editable without a migration. Validated in
  /// application code (lib/people-strategy/action-source.ts). Null on legacy
  /// rows → normalized to a derived source (MEETING when officerMeetingId is set,
  /// else MANUAL) so old actions still render an honest provenance.
  sourceType     String?
  /// The id of the source object when it is NOT already captured by a dedicated
  /// column — a MeetingDecision id, a strategic project/initiative registry id,
  /// or a free context id. The source MEETING itself stays on officerMeetingId
  /// (single source of truth); sourceId carries the finer-grained pointer.
  sourceId       String?
  /// Action → parent action link for FOLLOW_UP actions ("a follow-up to X").
  /// Self-relation; SetNull keeps the follow-up if its parent is deleted.
  sourceActionId String?
  sourceAction   ActionItem?  @relation("ActionFollowUps", fields: [sourceActionId], references: [id], onDelete: SetNull)
  followUps      ActionItem[] @relation("ActionFollowUps")

  /// Explicit, user-affirmed strategic link. Initiatives and projects are config
  /// registries (lib/people-strategy/strategic-initiatives.ts / strategic-projects.ts)
  /// with stable string ids, so these are validated strings (NOT FKs) — exactly
  /// like relatedEntityType. When set they are AUTHORITATIVE; when null the
  /// keyword matcher still SUGGESTS a context, clearly labeled as derived.
  strategicInitiativeId String?
  strategicProjectId    String?

  /// Definition of done — what "complete" actually means for this action.
  successDefinition String?   @db.Text
  /// Why this action is BLOCKED (paired with status = BLOCKED).
  blockedReason     String?   @db.Text
  /// Captured when the action is completed: the outcome note and a short
  /// controlled outcome (DELIVERED / PARTIAL / SUPERSEDED / ABANDONED).
  completionNote    String?   @db.Text
  completionOutcome String?
  /// The next time this action should be revisited (distinct from the deadline).
  nextFollowUpAt    DateTime?
  // ---------------------------------------------------------------------------

  assignments     ActionAssignment[]     @relation("ActionItemAssignments")
  departmentLinks ActionItemDepartment[]
  comments        ActionComment[]        @relation("ActionItemComments")
  fileLinks       ActionFileLink[]       @relation("ActionItemFileLinks")
  emailLogs       ActionEmailLog[]       @relation("ActionItemEmailLogs")

  // Optional chapter scope so chapter "next steps" are real, queryable actions
  // in the Action Tracker (launch checklist items, support-request follow-ups).
  chapterId String?
  chapter   Chapter? @relation("ChapterActionItems", fields: [chapterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deadlineStart])
  @@index([status])
  @@index([status, deadlineStart])
  @@index([priority])
  @@index([actionType])
  @@index([completedAt])
  @@index([departmentId, status])
  @@index([visibility])
  @@index([leadId])
  @@index([createdById])
  @@index([approvedById])
  @@index([approvedAt])
  @@index([meetingId])
  @@index([mentorshipSessionId])
  @@index([flaggedAt])
  @@index([escalatedToLeadershipAt])
  @@index([resolvedAt])
  @@index([relatedEntityType, relatedEntityId])
  @@index([sourceType])
  @@index([sourceActionId])
  @@index([strategicInitiativeId])
  @@index([strategicProjectId])
  @@index([nextFollowUpAt])
  @@index([chapterId])
}

/// Join row assigning a user to an action item in a specific role. The
/// (actionItemId, userId, role) uniqueness lets one user hold multiple roles
/// on the same item (e.g. LEAD + EXECUTING) without duplicate rows.
model ActionAssignment {
  id           String               @id @default(cuid())
  actionItemId String
  actionItem   ActionItem           @relation("ActionItemAssignments", fields: [actionItemId], references: [id], onDelete: Cascade)
  userId       String
  user         User                 @relation("ActionAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role         ActionAssignmentRole

  createdAt DateTime @default(now())

  @@unique([actionItemId, userId, role])
  @@index([userId, role])
  @@index([actionItemId])
}

/// Threaded note / input-request on an action item. `type` lets the UI render
/// a plain note differently from an explicit request for input.
model ActionComment {
  id           String            @id @default(cuid())
  actionItemId String
  actionItem   ActionItem        @relation("ActionItemComments", fields: [actionItemId], references: [id], onDelete: Cascade)
  /// Null for system-authored audit entries (e.g. the Board roll-up record),
  /// which have no human actor. Human comments always carry an author.
  authorId     String?
  author       User?             @relation("ActionComments", fields: [authorId], references: [id], onDelete: Cascade)
  body         String            @db.Text
  type         ActionCommentType @default(NOTE)

  createdAt DateTime @default(now())

  @@index([actionItemId, createdAt])
  @@index([authorId])
}

/// External file / document link attached to an action item (reuses existing
/// upload URLs rather than introducing a new storage model).
model ActionFileLink {
  id           String     @id @default(cuid())
  actionItemId String
  actionItem   ActionItem @relation("ActionItemFileLinks", fields: [actionItemId], references: [id], onDelete: Cascade)
  label        String
  url          String
  addedById    String
  addedBy      User       @relation("ActionFileLinksAdded", fields: [addedById], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@index([actionItemId])
  @@index([addedById])
}

/// Type of automated Action-Tracker email. Used by `ActionEmailLog` to keep
/// each deadline notification idempotent (one send per type/item/recipient/
/// deadline). Gated upstream by ENABLE_ACTION_TRACKER_EMAILS.
enum ActionEmailType {
  WEEKLY_DIGEST
  WARNING_24H
  DEADLINE_REACHED
  OVERDUE_LEAD
  LEADERSHIP_ESCALATION
  BOARD_ROLLUP
  LEADERSHIP_BRIEFING
  // DEPRECATED legacy alias for LEADERSHIP_ESCALATION. Retained so a client can
  // deserialize the pre-rename value without throwing. Do NOT write this value.
  CPO_ESCALATION
}

/// Idempotency ledger for the automated Action-Tracker cron emails (weekly
/// digest, 24-hour warning, deadline-reached, and the lead overdue notice).
/// Each row records that a specific email type was sent to a recipient for a
/// specific action item + deadline; the unique `dedupeKey` guarantees the same
/// (type, action, recipient, deadline) email is never sent twice, even if a
/// cron run is retried. Mirrors the `dedupeKey` convention on `Notification`,
/// but kept separate so the in-app notification feed is not polluted by purely
/// transactional email bookkeeping.
model ActionEmailLog {
  id           String          @id @default(cuid())
  type         ActionEmailType
  /// Null for the weekly digest, which is keyed by week rather than one item.
  actionItemId String?
  actionItem   ActionItem?     @relation("ActionItemEmailLogs", fields: [actionItemId], references: [id], onDelete: Cascade)
  recipientId  String
  recipient    User            @relation("ActionEmailLogRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  /// Deterministic idempotency key:
  ///   digest:<weekStartYYYY-MM-DD>:<recipientId>
  ///   briefing:<weekStartYYYY-MM-DD>:<recipientId>
  ///   warn24:<actionItemId>:<recipientId>:<deadlineYYYY-MM-DD>
  ///   deadline:<actionItemId>:<recipientId>:<deadlineYYYY-MM-DD>
  ///   overdue:<actionItemId>:<recipientId>:<deadlineYYYY-MM-DD>
  dedupeKey    String          @unique
  sentAt       DateTime        @default(now())

  @@index([recipientId])
  @@index([actionItemId])
  @@index([type, sentAt])
}

/// People Strategy — weekly Command Center pulse snapshot (Phase 7).
/// One row per operating week (Monday, UTC), written by the weekly Leadership
/// Briefing cron. It stores the leadership-wide pulse counts so the briefing can
/// report week-over-week trends ("overdue ↓2 vs last week") without
/// reconstructing historical state. Additive + low-risk: only the trend builder
/// reads it, and the unique `weekStart` makes the weekly upsert idempotent.
model ActionPulseSnapshot {
  id                String   @id @default(cuid())
  /// Monday of the operating week this snapshot summarizes (UTC). Unique so the
  /// weekly cron upserts exactly one row per week, even across retries.
  weekStart         DateTime @unique
  openTotal         Int
  completedThisWeek Int
  overdue           Int
  flagged           Int
  blocked           Int
  dueThisWeek       Int
  unowned           Int
  /// Total visible actions the pulse was composed from (the "based on N" figure).
  consideredCount   Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// People Strategy — 360-style monthly feedback request. One row per
/// (subject member, collaborator, month): a recent collaborator of the subject
/// is asked to submit confidential feedback about them. `responseBody` is the
/// collaborator's free-text answer; it is intentionally readable ONLY by the
/// CPO/Board (`requireCPO()`), never by the subject — so colleagues can be
/// candid. Gated at runtime by ENABLE_ACTION_TRACKER_EMAILS.
model FeedbackRequest {
  id             String    @id @default(cuid())
  /// The member the feedback is *about*.
  subjectUserId  String
  subjectUser    User      @relation("FeedbackRequestSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  /// The collaborator being asked to give feedback.
  collaboratorId String
  collaborator   User      @relation("FeedbackRequestCollaborator", fields: [collaboratorId], references: [id], onDelete: Cascade)
  /// First day of the feedback month (UTC), matching the cycleMonth convention.
  month          DateTime
  /// Collaborator's confidential answer. Null until they submit the form.
  responseBody   String?   @db.Text
  /// Set when the collaborator submits; null while the request is outstanding.
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())

  /// Who created the request (the Leadership/Board member who sent it).
  /// Null on legacy rows created before the reviewable request workflow.
  requestedById String?
  requestedBy   User?     @relation("MonthlyFeedbackRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  /// Why this collaborator was chosen ("Worked with X on 3 action items…").
  /// Shown to the recipient on the form and in the request email.
  reason        String?   @db.Text
  /// Display snapshot of the shared work connecting the collaborator to the
  /// subject at request time: [{ type, id, title, detail }]. Snapshot only —
  /// never re-read as live data.
  contextItems  Json?
  /// The reply-by date communicated in the request email.
  dueAt         DateTime?

  /// Set when Leadership withdraws an outstanding request — the collaborator's
  /// link stops working. "Extending the deadline" is simply updating dueAt.
  /// Comment collection never gates the review cycle (see ReviewCycleParticipant
  /// below); this exists only so leadership can clean up a request they no
  /// longer want an answer to.
  cancelledAt DateTime?

  /// Links this request to the universal review cycle it was raised from, when
  /// raised from inside a person's Review & G&R flow. Null for legacy/standalone
  /// requests not tied to a specific cycle.
  reviewCycleParticipantId String?
  reviewCycleParticipant   ReviewCycleParticipant? @relation(fields: [reviewCycleParticipantId], references: [id], onDelete: SetNull)

  /// One outstanding request per (subject, collaborator, month) — makes
  /// `sendFeedbackRequest` idempotent across re-runs.
  @@unique([subjectUserId, collaboratorId, month])
  @@index([subjectUserId, month])
  @@index([collaboratorId, submittedAt])
  @@index([requestedById])
  @@index([reviewCycleParticipantId])
}

// ============================================
// People Strategy — Growth Signals (Phase 8)
// Lightweight, human-curated tags on a member capturing where they are on the
// leadership pipeline. Distinct from the Quarterly Review's `successionFlag`
// (a point-in-time formal decision): these are quick, always-current signals
// leadership can attach from the Responsibility Map. Officer-tier and above
// curate them; they feed the People Risk Radar (e.g. a "ready for more" person
// carrying no current ownership surfaces as an opportunity). Gated behind
// ENABLE_ACTION_TRACKER alongside the rest of the People Strategy surfaces.
// ============================================

enum GrowthTag {
  READY_FOR_MORE
  NEEDS_TRAINING
  RELIABLE_EXECUTOR
  STRONG_COMMUNICATOR
  POTENTIAL_TEAM_LEAD
  AT_RISK_OF_DISENGAGING
}

/// One growth signal attached to a member. Unique per (member, tag) so a tag is
/// either present or not — toggling is idempotent. `note` is an optional short
/// rationale; `createdBy` records who attached it for accountability.
model MemberGrowthTag {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation("MemberGrowthTags", fields: [userId], references: [id], onDelete: Cascade)
  tag    GrowthTag
  note   String?   @db.Text

  createdById String
  createdBy   User   @relation("MemberGrowthTagsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tag])
  @@index([userId])
  @@index([tag])
  @@index([createdById])
}

// ============================================
// People Strategy — Action Templates & Saved Views (Phase 9)
// Templates remove the blank-page tax for recurring YPP leadership tasks; Saved
// Views persist a user's favourite filter sets on the Action Tracker. Both are
// gated behind ENABLE_ACTION_TRACKER. Standard templates are seeded (isStandard)
// so a fresh environment ships with the YPP playbook.
// ============================================

/// A reusable Action Item template. Pre-fills the new-action form with a
/// title/description, default priority/visibility, and an optional checklist
/// (appended into the description). `isStandard` marks the seeded YPP playbook
/// templates; `deadlineOffsetDays` seeds the deadline N days out from creation.
model ActionTemplate {
  id                  String               @id @default(cuid())
  name                String               @unique
  /// Short helper text shown in the template gallery.
  description         String?              @db.Text
  /// Playbook grouping (e.g. "Hiring", "Instruction") for the gallery.
  category            String?
  titleTemplate       String
  descriptionTemplate String?              @db.Text
  goalCategory        String?
  defaultPriority     ActionPriority       @default(MEDIUM)
  defaultVisibility   ActionItemVisibility @default(ALL_LEADERSHIP)
  /// Default deadline, in days from creation. Null leaves it blank.
  deadlineOffsetDays  Int?
  /// Suggested checklist steps, appended into the new item's description.
  checklist           String[]             @default([])
  isStandard          Boolean              @default(false)
  archivedAt          DateTime?

  createdById String?
  createdBy   User?   @relation("ActionTemplatesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
  @@index([category])
}

/// A stored customization of a portal email template, keyed by the stable
/// registry key (see lib/email-templates/registry.ts). When present and active,
/// its subject/body supersede the code-defined default. Deleting the row (or
/// setting isActive=false) reverts to the default. One row per template key.
model EmailTemplateOverride {
  id          String  @id @default(cuid())
  templateKey String  @unique
  subject     String
  /// Rendered inner-body HTML (with {{var}} placeholders) used at send time.
  body        String  @db.Text
  /// Tiptap JSON source for loss-free re-editing in the admin UI.
  bodyJson    Json?
  isActive    Boolean @default(true)

  createdById String?
  createdBy   User?   @relation("EmailTemplateOverridesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("EmailTemplateOverridesUpdated", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateKey])
}

/// A user's saved filter set on the Action Tracker (All Actions). `query` is the
/// serialized filter query string; loading a view just re-applies it.
model SavedActionView {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("SavedActionViews", fields: [userId], references: [id], onDelete: Cascade)
  name   String
  /// Serialized filter query string, e.g. "status=OVERDUE&dept=<id>&sort=priority_desc".
  query  String

  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

// ============================================
// Weekly Meetings — Teams, Weekly Impact, Meeting Runner
// Fresh rebuild (replaces the retired Weekly Team Briefs + Officer Meeting
// cluster). Teams are admin-configurable; a single generic Meeting entity
// powers all meeting types; the Weekly Impact form (per person, per week,
// per team or chapter) feeds the meeting's Impact Presentations table.
// ============================================

enum TeamStatus {
  ACTIVE
  ARCHIVED
}

enum MeetingType {
  OFFICER
  WEEKLY_TEAM_IMPACT
  CHAPTER_IMPACT
  GENERIC
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WeeklyImpactStatus {
  DRAFT
  SUBMITTED
}

enum WeeklyImpactRowStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum OfficerTopicStatus {
  OPEN
  DISCUSSED
  DECIDED
  DEFERRED
}

enum WeeklyFollowUpStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

/// An admin-configurable team (e.g. Tech, Expansion, Fundraising, Social Media).
/// Members are assigned many-to-many via TeamMembership.
model Team {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  status      TeamStatus @default(ACTIVE)
  sortOrder   Int        @default(0)

  createdById String?
  createdBy   User?   @relation("TeamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  memberships   TeamMembership[]    @relation("TeamMemberships")
  weeklyEntries WeeklyImpactEntry[] @relation("TeamWeeklyEntries")
  meetings      Meeting[]           @relation("TeamMeetings")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
  @@index([createdById])
}

/// Many-to-many membership join between Team and User.
model TeamMembership {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation("TeamMemberships", fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TeamMembershipUser", fields: [userId], references: [id], onDelete: Cascade)

  isLead Boolean @default(false)
  role   String?

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

/// A single generic meeting record. `type` drives which sections the runner shows.
model Meeting {
  id          String        @id @default(cuid())
  type        MeetingType   @default(GENERIC)
  status      MeetingStatus @default(SCHEDULED)
  title       String
  purpose     String?       @db.Text
  scheduledAt DateTime
  endAt       DateTime?
  location    String?
  notes       String?       @db.Text
  /// Prep outline — what we plan to cover (distinct from structured agenda items).
  agenda      String?       @db.Text
  /// Pre-read / proposal material shared before the meeting.
  proposal    String?       @db.Text
  /// Meeting-level next steps (summary after the session).
  nextSteps   String?       @db.Text
  /// What was decided / achieved — the honest meeting outcome.
  outcome     String?       @db.Text

  facilitatorId String?
  facilitator   User?   @relation("MeetingFacilitator", fields: [facilitatorId], references: [id], onDelete: SetNull)

  /// Optional partner this meeting is about (camp outreach, partnership review, …).
  partnerId String?
  partner   Partner? @relation("MeetingPartner", fields: [partnerId], references: [id], onDelete: SetNull)

  /// Set for CHAPTER_IMPACT meetings; scopes the presentations table.
  chapterId String?
  chapter   Chapter? @relation("ChapterMeetings", fields: [chapterId], references: [id], onDelete: SetNull)

  /// Optional team scope for WEEKLY_TEAM_IMPACT meetings (null = all teams).
  teamId String?
  team   Team?   @relation("TeamMeetings", fields: [teamId], references: [id], onDelete: SetNull)

  /// The reporting week this meeting reads impact rows from (Monday 00:00 UTC).
  weekStart DateTime?

  /// Honest provenance for meetings BORN from another object (mirrors
  /// ActionItem.sourceType/sourceId). String-typed (no FK) to keep cross-domain
  /// linking flexible. e.g. sourceType "INTERVIEW" + sourceId =
  /// InterviewSchedulingRequest.id, so scheduling an interview upserts exactly
  /// one meeting instead of creating duplicates. Null = created directly.
  sourceType String?
  sourceId   String?

  attendees     MeetingAttendee[]  @relation("MeetingAttendees")
  presentations WeeklyImpactRow[]  @relation("MeetingPresentationRows")
  officerTopics OfficerTopic[]     @relation("MeetingOfficerTopics")
  decisions     MeetingDecision[]  @relation("MeetingDecisions")
  followUps     MeetingFollowUp[]  @relation("MeetingFollowUps")

  /// Action items explicitly assigned to this meeting from the Actions hub
  /// "+ Add to meeting" picker (independent of any action's source provenance).
  actionItems   ActionItem[]       @relation("ActionItemMeeting")

  createdById String?
  createdBy   User?   @relation("MeetingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([scheduledAt])
  @@index([chapterId])
  @@index([teamId])
  @@index([facilitatorId])
  @@index([partnerId])
  @@index([weekStart])
  @@index([sourceType, sourceId])
}

/// Attendance row for a meeting.
model MeetingAttendee {
  id         String  @id @default(cuid())
  meetingId  String
  meeting    Meeting @relation("MeetingAttendees", fields: [meetingId], references: [id], onDelete: Cascade)
  userId     String
  user       User    @relation("MeetingAttendeeUser", fields: [userId], references: [id], onDelete: Cascade)
  present    Boolean @default(false)
  isOptional Boolean @default(false)
  note       String?

  createdAt DateTime @default(now())

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

/// One person's Weekly Impact form for a given reporting week. Scoped to exactly
/// one of team (Weekly Team Impact) or chapter (Chapter Impact Presentation).
model WeeklyImpactEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("WeeklyImpactEntryUser", fields: [userId], references: [id], onDelete: Cascade)

  teamId    String?
  team      Team?    @relation("TeamWeeklyEntries", fields: [teamId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter? @relation("ChapterWeeklyEntries", fields: [chapterId], references: [id], onDelete: Cascade)

  weekStart   DateTime
  status      WeeklyImpactStatus @default(DRAFT)
  submittedAt DateTime?

  /// The small separate "Input / help needed" box (header-level, free text).
  inputNeeded String? @db.Text

  rows WeeklyImpactRow[] @relation("EntryRows")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId, weekStart])
  @@unique([userId, chapterId, weekStart])
  @@index([teamId, weekStart])
  @@index([chapterId, weekStart])
  @@index([userId, weekStart])
  @@index([status])
}

/// A single flexible row in the Weekly Impact table.
model WeeklyImpactRow {
  id      String            @id @default(cuid())
  entryId String
  entry   WeeklyImpactEntry @relation("EntryRows", fields: [entryId], references: [id], onDelete: Cascade)

  type         String?
  whatGoal     String?               @db.Text
  evidenceNext String?               @db.Text
  due          DateTime?
  rowStatus    WeeklyImpactRowStatus @default(NOT_STARTED)
  sortOrder    Int                   @default(0)

  /// Curation flags the person sets to push a row into a meeting's agenda.
  presentToMeeting Boolean @default(false)
  decisionNeeded   Boolean @default(false)
  sendToBoard      Boolean @default(false)

  /// When pinned to a specific meeting, links the presentation row.
  meetingId String?
  meeting   Meeting? @relation("MeetingPresentationRows", fields: [meetingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entryId, sortOrder])
  @@index([meetingId])
  @@index([sendToBoard])
  @@index([presentToMeeting])
}

/// A numbered officer-meeting discussion topic with one or more owners.
model OfficerTopic {
  id        String             @id @default(cuid())
  meetingId String
  meeting   Meeting            @relation("MeetingOfficerTopics", fields: [meetingId], references: [id], onDelete: Cascade)

  sortOrder Int                @default(0)
  title     String
  detail    String?            @db.Text
  status    OfficerTopicStatus @default(OPEN)

  decisionNeeded Boolean @default(false)
  sendToBoard    Boolean @default(false)
  decision       String? @db.Text
  nextSteps      String? @db.Text

  owners OfficerTopicOwner[] @relation("TopicOwners")

  createdById String?
  createdBy   User?   @relation("OfficerTopicCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId, sortOrder])
  @@index([status])
  @@index([sendToBoard])
}

/// Many-to-many owners for an OfficerTopic.
model OfficerTopicOwner {
  id      String       @id @default(cuid())
  topicId String
  topic   OfficerTopic @relation("TopicOwners", fields: [topicId], references: [id], onDelete: Cascade)
  userId  String
  user    User         @relation("OfficerTopicOwnerUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([topicId])
  @@index([userId])
}

/// A decision captured during a meeting.
model MeetingDecision {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation("MeetingDecisions", fields: [meetingId], references: [id], onDelete: Cascade)
  decision  String  @db.Text
  rationale String? @db.Text

  decidedById String?
  decidedBy   User?   @relation("MeetingDecisionDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([meetingId, createdAt])
  @@index([decidedById])
}

/// A follow-up / next action captured during a meeting.
model MeetingFollowUp {
  id        String               @id @default(cuid())
  meetingId String
  meeting   Meeting              @relation("MeetingFollowUps", fields: [meetingId], references: [id], onDelete: Cascade)
  title     String
  detail    String?              @db.Text
  status    WeeklyFollowUpStatus @default(OPEN)
  dueDate   DateTime?

  ownerId String?
  owner   User?   @relation("MeetingFollowUpOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([ownerId])
  @@index([status])
}

// ============================================
// People Strategy — Monthly Check-Ins & Quarterly Reviews (ENABLE_QUARTERLY_REVIEWS)
// A CheckIn is a COMPILATION, not a new data-entry surface: it references the
// existing monthly self-reflection (`MonthlySelfReflection`) and the mentor's
// monthly goal review (`MentorGoalReview`), and stores a `performanceRating`
// DERIVED from the live `GoalRatingColor` goal-progress data (see
// `lib/people-strategy/check-in-rating.ts`). It deliberately reuses the existing
// `GoalRatingColor` enum rather than introducing a second monthly rating, and
// `@@unique([userId, month])` guarantees exactly one check-in per user/month.
// ============================================

/// One compiled monthly check-in for a user. Behind ENABLE_QUARTERLY_REVIEWS.
/// Does NOT add a second monthly performance input — it points at the existing
/// reflection + mentor review and carries a derived `performanceRating`.
model CheckIn {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserPeopleCheckIns", fields: [userId], references: [id], onDelete: Cascade)

  /// First day of the month this check-in covers.
  month DateTime

  /// Existing monthly reflection this check-in compiles from (if one exists).
  selfReflectionId String?
  selfReflection   MonthlySelfReflection? @relation("CheckInSelfReflection", fields: [selfReflectionId], references: [id], onDelete: SetNull)

  /// Existing mentorship feedback/session reference: the mentor's monthly goal
  /// review, which supplies the goal-progress ratings + written feedback.
  mentorGoalReviewId String?
  mentorGoalReview   MentorGoalReview? @relation("CheckInMentorGoalReview", fields: [mentorGoalReviewId], references: [id], onDelete: SetNull)

  /// Performance rating DERIVED from existing goal data (GoalReviewRating /
  /// MentorGoalReview.overallRating). Null when the user has no goal data yet.
  performanceRating GoalRatingColor?

  /// Optional compiled narrative assembled from the referenced sources.
  compiledNotes String? @db.Text

  createdAt DateTime @default(now())

  /// Exactly one check-in per user per month — prevents a duplicate monthly
  /// rating entry, and lets the compile action upsert idempotently.
  @@unique([userId, month])
  @@index([userId])
  @@index([selfReflectionId])
  @@index([mentorGoalReviewId])
}

/// Outcome of a Quarterly Review on the Performance x Potential matrix.
enum QuarterlyReviewDecision {
  PROMOTION
  ACHIEVEMENT_AWARD
  ROLE_CHANGE
  PIP
  CONTINUATION
}

/// People Strategy — Quarterly Review (ENABLE_QUARTERLY_REVIEWS). Places a user
/// on the 4x4 Performance x Potential succession matrix for a given quarter and
/// records the resulting decision. Both axes REUSE the live `GoalRatingColor`
/// enum (At Risk / Needs Attention / On Track / Above & Beyond) rather than
/// introducing a second rating concept. The matrix LABEL is never persisted —
/// it is derived purely from the two ratings via `lib/matrix.ts`.
model QuarterlyReview {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserQuarterlyReviews", fields: [userId], references: [id], onDelete: Cascade)

  /// The quarter this review covers, e.g. "2026-Q2".
  quarter String

  /// 4-level performance rating (reuses GoalRatingColor).
  performanceRating GoalRatingColor
  /// 4-level potential rating (reuses GoalRatingColor).
  potentialRating   GoalRatingColor

  decision QuarterlyReviewDecision

  /// Optional free-text rationale captured by the reviewer.
  notes String? @db.Text

  /// True when the user lands in the succession quadrant (performance AND
  /// potential both On Track or above). Derived from the two ratings; stored so
  /// the CPO dashboard can filter succession candidates without recomputing.
  successionFlag Boolean @default(false)

  createdById String
  createdBy   User   @relation("QuarterlyReviewsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  /// Exactly one review per user per quarter — lets the compile action upsert
  /// idempotently and prevents duplicate matrix placements.
  @@unique([userId, quarter])
  @@index([userId])
  @@index([createdById])
  @@index([successionFlag])
}

// ============================================================================
// GROWTH — Student Operating System (Action Tracker 3.0, Phase N1)
//
// The unified progression engine. Additive only: new Growth* models + two
// stable enums; the only touch to existing tables is User back-relations
// (declared in the User model). Runtime stays dark behind ENABLE_GROWTH_OS.
// Mirrors the InstructorGrowth* conventions (cuid ids, named User relations,
// dedupeKey idempotency, Json metadata). TEXT vocabularies (action status,
// achievement category, opportunity kind, event type) are validated in
// lib/growth/constants.ts, matching the repo's actionType/partner.stage style.
// ============================================================================

/// The progression track a node/event belongs to. Different tracks, one engine.
enum GrowthTrack {
  STUDENT
  MENTORSHIP
  INSTRUCTOR
  LEADERSHIP
  CHAPTER
  HIRING
  ALUMNI
}

/// Lifecycle status shared by Vision / Goal / Milestone (Actions use a TEXT
/// status vocabulary because they have a richer set: TODO/IN_PROGRESS/...).
enum GrowthObjectiveStatus {
  ACTIVE
  ACHIEVED
  ARCHIVED
}

/// Development profile (NOT demographics). 1:1 with User. The interest/skill
/// arrays are user-editable and additively merged; the counters are caches the
/// recompute step writes so dashboards never fan out on page load.
model GrowthProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation("GrowthProfile", fields: [userId], references: [id], onDelete: Cascade)
  headline             String?
  careerInterests      String[]  @default([])
  leadershipInterests  String[]  @default([])
  impactInterests      String[]  @default([])
  skills               String[]  @default([])
  confidenceAreas      String[]  @default([])
  growthAreas          String[]  @default([])
  achievementCount     Int       @default(0)
  completedExperiences Int       @default(0)
  lastEventAt          DateTime?
  lastRecomputedAt     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

/// Top-level "who I'm becoming". Optional: a Goal can stand alone (skip-level).
model GrowthVision {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation("GrowthVisions", fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  track       GrowthTrack           @default(STUDENT)
  status      GrowthObjectiveStatus @default(ACTIVE)
  order       Int                   @default(0)
  goals       GrowthGoal[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([userId, status])
}

/// A measurable outcome. Holds Milestones and/or direct Actions (skip-level).
/// `source`/`sourceRef` record provenance (e.g. mentorship + mentorshipId) so
/// seeded goals are idempotent and the UI can back-link them.
model GrowthGoal {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation("GrowthGoals", fields: [userId], references: [id], onDelete: Cascade)
  visionId    String?
  vision      GrowthVision?         @relation(fields: [visionId], references: [id], onDelete: SetNull)
  title       String
  description String?
  track       GrowthTrack           @default(STUDENT)
  status      GrowthObjectiveStatus @default(ACTIVE)
  order       Int                   @default(0)
  source      String                @default("manual")
  sourceRef   String?
  targetDate  DateTime?
  milestones  GrowthMilestone[]
  actions     GrowthAction[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([userId, status])
  @@index([visionId])
  @@index([source, sourceRef])
}

/// A checkpoint under a Goal.
model GrowthMilestone {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation("GrowthMilestones", fields: [userId], references: [id], onDelete: Cascade)
  goalId      String
  goal        GrowthGoal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      GrowthObjectiveStatus @default(ACTIVE)
  order       Int                   @default(0)
  source      String                @default("manual")
  sourceRef   String?
  achievedAt  DateTime?
  actions     GrowthAction[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([userId, status])
  @@index([goalId])
}

/// The leaf. Attaches to a Milestone, directly to a Goal, or floats (inbox).
/// `status` is a TEXT vocabulary (TODO | IN_PROGRESS | DONE | BLOCKED | DROPPED).
model GrowthAction {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("GrowthActions", fields: [userId], references: [id], onDelete: Cascade)
  goalId      String?
  goal        GrowthGoal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  milestoneId String?
  milestone   GrowthMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String           @default("TODO")
  order       Int              @default(0)
  source      String           @default("manual")
  sourceRef   String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, status])
  @@index([goalId])
  @@index([milestoneId])
}

/// A first-class earned achievement. `key` is the registry key; title/category
/// are snapshotted so history is stable. Idempotent: one award per (user, key).
model GrowthAchievement {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation("GrowthAchievements", fields: [userId], references: [id], onDelete: Cascade)
  key           String
  title         String
  category      String
  description   String?
  sourceEventId String?
  sourceEvent   GrowthProgressEvent? @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)
  metadata      Json?
  earnedAt      DateTime             @default(now())
  createdAt     DateTime             @default(now())

  @@unique([userId, key])
  @@index([userId, earnedAt])
  @@index([category])
}

/// A persisted, deterministic recommendation. `reason` is the WHY shown to the
/// student. Idempotent per (user, key); a DISMISSED row is not re-suggested.
model GrowthOpportunity {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("GrowthOpportunities", fields: [userId], references: [id], onDelete: Cascade)
  key        String
  kind       String
  title      String
  detail     String?
  href       String?
  reason     String
  score      Int      @default(0)
  status     String   @default("SUGGESTED")
  metadata   Json?
  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId, status])
}

/// The event log future systems emit into. The Growth Engine consumes these.
/// Idempotent per (user, dedupeKey) — null dedupeKeys always insert.
model GrowthProgressEvent {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation("GrowthProgressEvents", fields: [userId], references: [id], onDelete: Cascade)
  type         String
  track        GrowthTrack         @default(STUDENT)
  title        String
  description  String?
  dedupeKey    String?
  sourceType   String?
  sourceId     String?
  metadata     Json?
  occurredAt   DateTime            @default(now())
  achievements GrowthAchievement[]
  createdAt    DateTime            @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, occurredAt])
  @@index([type])
}

// ============================================================================
// LEADERSHIP ROLES & CONTRIBUTIONS (ENABLE_LEADERSHIP_ROLES)
//
// Concrete leadership/contribution roles instructors can hold beyond teaching
// (Student Advisor, instructor mentor, curriculum reviewer, interviewer,
// committee member, partner lead, …). Each role is a LeadershipContribution
// row with a status lifecycle, an expected level (Senior/Lead), a weight, and
// optional links to the student / class / partner / program it concerns.
// Activity (notes, check-ins, completed reviews/interviews) is an append-only
// LeadershipContributionActivity log so the work itself becomes review
// evidence. Student Advisor is first-class: StudentAdvisorAssignment +
// AdvisingNote + AdvisingRecommendation model the actual advising workflow,
// and every assignment back-links to the advisor's STUDENT_ADVISOR
// contribution so caseload work rolls up into reviews/promotions.
//
// Role *definitions* (default weight, level, ownership flag, examples) are a
// code catalog in lib/leadership/constants.ts — same convention as
// lib/growth/constants.ts — so new roles can be added without a migration;
// the OTHER category plus the free-text `title` covers anything custom.
// Additive only: new tables + four enums; existing tables only gain virtual
// Prisma back-relations.
// ============================================================================

/// What kind of leadership role/contribution this is. Display metadata,
/// default weights, and Senior/Lead expectations for each category live in
/// lib/leadership/constants.ts.
enum LeadershipRoleCategory {
  STUDENT_ADVISOR
  INSTRUCTOR_MENTOR
  CURRICULUM_REVIEWER
  INTERVIEWER
  ONBOARDING_HELPER
  CLASS_QUALITY_REVIEWER
  STUDENT_PROJECT_MENTOR
  INSTRUCTION_COMMITTEE
  LEAD_INSTRUCTOR
  PARTNER_RELATIONSHIP_LEAD
  RECRUITMENT_LEAD
  TRAINING_DEVELOPMENT_LEAD
  STUDENT_SUCCESS_LEAD
  MENTORSHIP_PROGRAM_LEAD
  CURRICULUM_LEAD
  INITIATIVE_OWNER
  OTHER
}

/// Lifecycle of a contribution. SUGGESTED = admin shortlisted, instructor not
/// yet committed; NEEDS_ATTENTION = stalled / no recent activity.
enum LeadershipContributionStatus {
  SUGGESTED
  ASSIGNED
  ACTIVE
  COMPLETED
  PAUSED
  NEEDS_ATTENTION
}

/// Which promotion track this contribution counts toward.
enum LeadershipExpectedLevel {
  SENIOR_INSTRUCTOR
  LEAD_INSTRUCTOR
  EITHER
}

/// Advisor-set engagement state for an advised student.
enum AdvisingStatus {
  ENGAGED
  NEEDS_ATTENTION
  INACTIVE
  READY_FOR_NEXT
}

/// One leadership role / contribution held by an instructor. Flexible by
/// design: `category` + free-text `title` describe the role; the optional
/// related* links tie it to the concrete student / class offering / partner /
/// program it concerns when applicable.
model LeadershipContribution {
  id           String @id @default(cuid())
  instructorId String
  instructor   User   @relation("LeadershipContributionInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  category    LeadershipRoleCategory
  title       String
  description String?                @db.Text

  status        LeadershipContributionStatus @default(ASSIGNED)
  /// Which promotion track this counts toward (Senior / Lead / either).
  expectedLevel LeadershipExpectedLevel      @default(EITHER)
  /// Contribution weight 1-3: 1 = light support, 2 = meaningful contribution,
  /// 3 = major ownership. Expectation math counts weight >= 2 as meaningful.
  weight        Int                          @default(2)
  /// True when the role involves real ownership (committee seat, subject lead,
  /// partner lead, initiative owner). Lead Instructor expectations require at
  /// least one ownership contribution.
  isOwnership   Boolean                      @default(false)

  // Optional links to what the role concerns. All nullable — a curriculum
  // reviewer links nothing; a Student Advisor's caseload lives on
  // StudentAdvisorAssignment rows that back-link here instead.
  relatedUserId     String?
  relatedUser       User?          @relation("LeadershipContributionSubject", fields: [relatedUserId], references: [id], onDelete: SetNull)
  relatedOfferingId String?
  relatedOffering   ClassOffering? @relation("LeadershipContributionOffering", fields: [relatedOfferingId], references: [id], onDelete: SetNull)
  relatedPartnerId  String?
  relatedPartner    Partner?       @relation("LeadershipContributionPartner", fields: [relatedPartnerId], references: [id], onDelete: SetNull)
  /// Free-text program / initiative name when no structured link exists.
  relatedProgram    String?

  startDate DateTime  @default(now())
  endDate   DateTime?

  /// Standing notes / evidence summary (the running log lives in activities).
  notes String? @db.Text

  /// Admin who owns/reviews this contribution.
  adminOwnerId String?
  adminOwner   User?   @relation("LeadershipContributionAdminOwner", fields: [adminOwnerId], references: [id], onDelete: SetNull)

  /// When true this contribution surfaces as evidence in instructor reviews.
  reviewVisible Boolean @default(true)

  createdById String?
  createdBy   User?   @relation("LeadershipContributionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  activities         LeadershipContributionActivity[]
  advisorAssignments StudentAdvisorAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId, status])
  @@index([category, status])
  @@index([status])
  @@index([adminOwnerId])
  @@index([relatedPartnerId])
  @@index([relatedOfferingId])
  @@index([relatedUserId])
}

/// Append-only activity log on a contribution — notes, check-ins, completed
/// reviews/interviews, recommendations, status changes. `kind` is a TEXT
/// vocabulary validated in lib/leadership/constants.ts (NOTE | CHECK_IN |
/// FEEDBACK | INTERVIEW_COMPLETED | REVIEW_COMPLETED | RECOMMENDATION |
/// STATUS_CHANGE | FOLLOW_UP), matching the repo's actionType convention.
model LeadershipContributionActivity {
  id             String                 @id @default(cuid())
  contributionId String
  contribution   LeadershipContribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("LeadershipContributionActivityAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  kind     String @default("NOTE")
  body     String @db.Text
  metadata Json?

  createdAt DateTime @default(now())

  @@index([contributionId, createdAt])
  @@index([authorId])
}

/// A Student Advisor's responsibility for one student. One row per
/// (advisor, student) pair, reactivated rather than duplicated on
/// re-assignment. Back-links to the advisor's STUDENT_ADVISOR contribution so
/// advising work counts as leadership/review evidence.
model StudentAdvisorAssignment {
  id        String @id @default(cuid())
  advisorId String
  advisor   User   @relation("StudentAdvisorAssignmentAdvisor", fields: [advisorId], references: [id], onDelete: Cascade)
  studentId String
  student   User   @relation("StudentAdvisorAssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)

  contributionId String?
  contribution   LeadershipContribution? @relation(fields: [contributionId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  advisingStatus     AdvisingStatus @default(ENGAGED)
  needsFollowUp      Boolean        @default(false)
  followUpNote       String?
  /// Advisor-maintained "what this student needs next" summary, shown on the
  /// student profile and admin views.
  nextSteps          String?        @db.Text
  lastCheckInAt      DateTime?
  /// Knowledge OS V2 — check-in scheduling so "check-in overdue" is a stored,
  /// queryable fact instead of a reactive lastCheckInAt read (plan §12).
  checkInCadenceDays Int            @default(14)
  nextCheckInDueAt   DateTime?

  assignedById String?
  assignedBy   User?   @relation("StudentAdvisorAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  startDate DateTime  @default(now())
  endedAt   DateTime?

  notes           AdvisingNote[]
  recommendations AdvisingRecommendation[]
  /// Conversation records logged against this advising relationship (V2 fold-in).
  checkIns        MentorshipCheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([advisorId, studentId])
  @@index([studentId, isActive])
  @@index([advisorId, isActive])
  @@index([isActive, needsFollowUp])
  @@index([isActive, advisingStatus])
}

/// Advising note or logged check-in on an assignment. `kind` is a TEXT
/// vocabulary (NOTE | CHECK_IN) validated in lib/leadership/constants.ts.
model AdvisingNote {
  id           String                   @id @default(cuid())
  assignmentId String
  assignment   StudentAdvisorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("AdvisingNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  kind String @default("NOTE")
  body String @db.Text

  createdAt DateTime @default(now())

  @@index([assignmentId, createdAt])
  @@index([authorId])
}

/// Advisor recommendation of a next step for the student — a class, project,
/// mentor, opportunity, or pathway (instructor track, leadership, …). `kind`
/// and `status` are TEXT vocabularies validated in
/// lib/leadership/constants.ts (kind: CLASS | PROJECT | MENTOR | OPPORTUNITY |
/// PATHWAY; status: SUGGESTED | IN_PROGRESS | DONE | DISMISSED).
model AdvisingRecommendation {
  id           String                   @id @default(cuid())
  assignmentId String
  assignment   StudentAdvisorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("AdvisingRecommendationAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  kind   String  @default("OPPORTUNITY")
  title  String
  detail String? @db.Text
  /// Optional in-portal link (e.g. /courses/xyz) for the student to act on.
  href   String?
  status String  @default("SUGGESTED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignmentId, status])
  @@index([authorId])
}

// ============================================================================
// YPP Help Agent — deterministic search infrastructure (Knowledge OS V2).
// docs/ypp-organizational-knowledge-os-master-plan.md §8/§24.
// User refs are FK-less per the repo's loosely-coupled-reference convention.
// ============================================================================

/// One indexed, searchable record per entity (person, partner, class, meeting,
/// action, initiative, application, mentorship). Display fields only —
/// authorization stays in the entity-360 loaders at hydration time; the
/// coarse `visibilityTier` (MEMBER | OFFICER) lets queries pre-filter.
/// Populated by scripts/backfill-search-documents.ts (re-runnable reconcile);
/// write-path upserts land in the next pass.
model SearchDocument {
  id             String    @id @default(cuid())
  /// Entity 360 type vocabulary: person | class | partner | initiative |
  /// meeting | action (matches lib/operations/entity-360.ts).
  entityType     String
  entityId       String
  title          String
  subtitle       String?
  /// Space-joined extra match terms (email, aliases, partner type…).
  keywords       String?
  /// MEMBER (any signed-in user) | OFFICER (officer-tier and above).
  visibilityTier String    @default("OFFICER")
  /// When the entity is time-anchored (a meeting's start), its event time —
  /// lets date-aware groups order/render real dates from the index.
  eventAt        DateTime?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@unique([entityType, entityId])
  @@index([visibilityTier, entityType])
}

/// A saved, named query: a target page plus serialized params. Generalizes
/// SavedActionView for the Help Agent and future master databases.
/// `scope`: PERSONAL | SHARED | SEEDED (TEXT vocabulary).
model SavedQuery {
  id         String   @id @default(cuid())
  ownerId    String?
  scope      String   @default("PERSONAL")
  name       String
  /// Where the query runs ("/people", "/admin/partners", "/help-agent"…).
  targetPage String
  /// Serialized query string / params for the target page.
  params     String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId])
  @@index([scope])
}

/// Recently viewed entities per user — powers Help Agent recents and the
/// sidebar "Recently Viewed". Written on Entity 360 opens; pruned to the
/// newest ~50 rows per user by the writer.
model RecentEntityView {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  viewedAt   DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId, viewedAt])
}

// ============================================
// ORG AUTHORITY SPINE (Phase 3)
// Roles/Mentorship/Reviews/Access plan — see
// docs/ROLES_ACCESS_REVIEWS_MENTORSHIP_PLAN.md. Person cohorts and general
// committees are transferable and non-destructive: leaving a committee or
// cohort is recorded via isActive / endDate, never by deleting history.
// ============================================

/// A people cohort (distinct from the training/application/incubator cohorts).
/// A person belongs to at most one at a time via `User.cohortId`; changing it
/// preserves the account and all history.
model Cohort {
  id        String    @id @default(cuid())
  name      String    @unique
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members User[]
}

/// A committee / additional role group, separate from a person's primary title
/// (Instruction Committee, Interview Committee, Review Committee, Outreach Team,
/// Board, Temporary Working Group, …). Membership adds the committee's
/// permissions without changing the person's title.
model Committee {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String?   @unique
  /// Free-text classification (validated in app code), e.g. "Instruction Committee".
  kind        String?
  description String?   @db.Text
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships CommitteeMembership[]

  @@index([archivedAt])
}

/// Join row: a person's membership in a committee. `isActive` / `endDate` make
/// leaving non-destructive (the row stays as history).
model CommitteeMembership {
  id          String    @id @default(cuid())
  committeeId String
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("CommitteeMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Optional role within the committee (e.g. "chair", "member").
  role        String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([committeeId, userId])
  @@index([userId, isActive])
  @@index([committeeId, isActive])
}

/// Explicit, queryable history of who mentored whom (Phase 4 of the
/// Roles/Mentorship/Reviews/Access plan). A new row opens when an assignment
/// starts; `endedAt` is stamped when it ends (on reassignment), so a person's
/// full mentor/mentee history survives any number of transfers without touching
/// the account, notes, or reviews. Append-only — rows are never deleted.
model MentorshipAssignmentHistory {
  id           String               @id @default(cuid())
  menteeId     String
  mentee       User                 @relation("MentorshipHistoryMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  mentorId     String
  mentor       User                 @relation("MentorshipHistoryMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  /// Mirrors Mentorship.focusArea so instruction vs leadership history is distinct.
  focusArea    MentorshipFocusArea?
  /// Role in the relationship, e.g. "PRIMARY_MENTOR" or "ADVISOR".
  role         String               @default("PRIMARY_MENTOR")
  /// Provenance link to the live Mentorship row, when one exists.
  mentorshipId String?
  isTemporary  Boolean              @default(false)
  startedAt    DateTime             @default(now())
  /// Null while the assignment is current; set when it ends (on reassignment).
  endedAt      DateTime?
  /// Why the change happened (free text), for the audit trail.
  reason       String?
  /// Who made the change (admin/officer), when known.
  actorId      String?
  actor        User?                @relation("MentorshipHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now())

  @@index([menteeId, endedAt])
  @@index([mentorId, endedAt])
  @@index([mentorshipId])
}

/// Tracks a record (instructor, class, partner, meeting, …) that is in the
/// temporary "Missing Chapter" status — it has no valid chapter assignment yet
/// (Phase 6 of the Roles/Mentorship/Reviews/Access plan). Central + additive so
/// the queue, age, auto-action, and "fully set up" gate work without retrofitting
/// a status column onto every domain model. `recordType`+`recordId` identify the
/// record; an unresolved row means the chapter still needs to be assigned.
model MissingChapterFlag {
  id           String    @id @default(cuid())
  /// Domain of the record, e.g. "USER" | "COURSE" | "PARTNER" | "CLASS_OFFERING" | "MEETING".
  recordType   String
  recordId     String
  /// Human label for the queue row (e.g. the person/class name).
  label        String
  /// The auto-created "assign a chapter" action this flag spawned.
  actionItemId String?
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("MissingChapterResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?     @relation("MissingChapterCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([recordType, recordId])
  @@index([resolvedAt])
}

/// An APPLIED promotion / role change (Phase 8 of the Roles/Mentorship/Reviews/
/// Access plan), distinct from the recommendation workflow. Captures the before
/// and after of a non-destructive change made from the person profile, plus the
/// reason, effective date, actor, and whether the new role's setup (mentor /
/// chapter / committee) is still pending — which drives the Promotion Setup
/// queue. Append-only history; nothing about the account is deleted.
model PromotionRecord {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation("PromotionRecordsUser", fields: [userId], references: [id], onDelete: Cascade)
  effectiveDate         DateTime
  reason                String?
  previousTitle         String?
  newTitle              String?
  previousInternalLevel Int?
  newInternalLevel      Int?
  previousLadder        OrgLadder?
  newLadder             OrgLadder?
  previousChapterId     String?
  newChapterId          String?
  previousCohortId      String?
  newCohortId           String?
  /// JSON arrays of committee names added / removed by this promotion.
  committeesAdded       String?
  committeesRemoved     String?
  /// Unresolved setup item codes (JSON array) and whether setup is finished.
  pendingSetup          String?
  setupComplete         Boolean    @default(false)
  actorId               String?
  actor                 User?      @relation("PromotionRecordsActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt             DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([setupComplete])
}

// ============================================================================
// UNIVERSAL WORKFLOW ENGINE  (lib/workflow-engine/*)
// ============================================================================
//
// The domain-agnostic execution engine that lets ANY business process —
// partner acquisition, instructor hiring, volunteer onboarding, program
// launch, grant applications, … — be modeled as a reusable WorkflowTemplate
// instead of hardcoded code. A template is a graph of WorkflowTemplateStage →
// WorkflowTemplateStep with WorkflowTransition edges, WorkflowAutomationRule
// side-effects (which REUSE the existing ActionItem / Meeting / Notification /
// WorkflowItem systems — never a parallel one), and WorkflowTrigger start
// conditions. A WorkflowInstance is one run; WorkflowStepExecution rows are the
// per-step runtime records (the "execution" layer, carrying the links back to
// the reused entities); WorkflowEvent is the history timeline; WorkflowSnapshot
// captures point-in-time state; WorkflowMetric stores rolled-up analytics.
//
// CONVENTION: user / chapter references on engine tables are loosely-coupled
// String columns (no FK, resolved in app code) — mirroring PartnerNote.authorId
// — so the 14.6k-line User/Chapter models stay untouched. Intra-engine links
// (template→stage→step, instance→execution/event/snapshot) are real FKs with
// cascade. Polymorphic subject links reuse the RELATED_ENTITY_TYPE vocabulary
// (lib/people-strategy/constants.ts), stored as validated strings.

enum WorkflowTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowInstanceStatus {
  ACTIVE
  BLOCKED
  ON_HOLD
  COMPLETED
  CANCELLED
}

/// The kind of a template step. Drives how the runner renders it and which
/// reuse adapter an automation may fire (e.g. MEETING → Meeting model).
enum WorkflowStepKind {
  TASK
  APPROVAL
  MEETING
  DOCUMENT
  FORM
  DECISION
  AUTOMATED
}

/// Per-instance runtime state of a single step.
enum WorkflowStepState {
  PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETE
  SKIPPED
}

/// When a WorkflowAutomationRule fires during instance execution.
enum WorkflowAutomationTrigger {
  ON_INSTANCE_START
  ON_STAGE_ENTER
  ON_STAGE_EXIT
  ON_STEP_COMPLETE
  ON_INSTANCE_COMPLETE
  ON_OVERDUE
  ON_FOLLOW_UP_DUE
}

/// What a WorkflowAutomationRule does — each maps to an EXISTING subsystem.
enum WorkflowAutomationAction {
  CREATE_ACTION        // → People-Strategy ActionItem (lib/people-strategy)
  CREATE_MEETING       // → weekly-meetings Meeting
  SEND_NOTIFICATION    // → lib/notifications.createNotification
  CREATE_WORKFLOW_ITEM // → lib/workflow.upsertWorkflowItem (home queue + routing)
  SCHEDULE_FOLLOW_UP   // → sets instance.followUpAt for the engine cron
  ESCALATE             // → notifies leadership (reuses notification system)
  ADVANCE_STAGE        // → auto-advances the instance when criteria are met
  START_WORKFLOW       // → starts another published template's instance (chaining)
}

/// How a WorkflowTrigger decides to START an instance.
enum WorkflowTriggerEvent {
  MANUAL
  ENTITY_CREATED
  ENTITY_STATUS_CHANGED
  SCHEDULED
}

/// History timeline event kind.
enum WorkflowEventKind {
  INSTANCE_CREATED
  STAGE_ENTERED
  STAGE_EXITED
  STEP_STARTED
  STEP_COMPLETED
  STEP_BLOCKED
  STEP_SKIPPED
  AUTOMATION_RAN
  OWNER_CHANGED
  FOLLOW_UP_SCHEDULED
  ESCALATED
  INSTANCE_COMPLETED
  INSTANCE_CANCELLED
  NOTE
}

/// A reusable, domain-agnostic process definition.
model WorkflowTemplate {
  id          String                 @id @default(cuid())
  /// Stable slug, unique across templates. Blueprints seed with a fixed key.
  key         String                 @unique
  name        String
  description String?                @db.Text
  /// Free-text domain lane (PARTNERS / INSTRUCTORS / PROGRAMS / …); validated
  /// in app code (lib/workflow-engine/constants.ts), not a Postgres enum.
  domain      String?
  status      WorkflowTemplateStatus @default(DRAFT)
  version     Int                    @default(1)
  /// True when this template was installed from a code blueprint (seedable),
  /// carrying the blueprint key for idempotent re-install/diff.
  isBlueprint  Boolean               @default(false)
  blueprintKey String?
  /// Default assignment for new instances when none is supplied. Strings
  /// validated against RoleType / AdminSubtype in app code.
  defaultOwnerRole       String?
  defaultOwnerSubtype    String?
  /// Default follow-up cadence + escalation thresholds (hours) for the cron.
  followUpCadenceHours   Int?
  escalateAfterHours     Int?
  /// Freeform template-level settings.
  config      Json?
  createdById String?
  updatedById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  stages          WorkflowTemplateStage[]   @relation("WorkflowTemplateStages")
  transitions     WorkflowTransition[]      @relation("WorkflowTemplateTransitions")
  automationRules WorkflowAutomationRule[]  @relation("WorkflowTemplateAutomationRules")
  triggers        WorkflowTrigger[]         @relation("WorkflowTemplateTriggers")
  instances       WorkflowInstance[]        @relation("WorkflowTemplateInstances")
  versionSnapshots WorkflowTemplateVersionSnapshot[] @relation("WorkflowTemplateVersionSnapshots")

  @@index([status])
  @@index([domain])
  @@index([blueprintKey])
}

/// A point-in-time snapshot of a template's full structure (stages, steps,
/// transitions, automation rules), captured every time the template is
/// published. Powers the builder's Versions tab: view any past version, or
/// restore one as the template's current DRAFT content. Snapshots are
/// additive history only — restoring never mutates a live PUBLISHED template
/// directly (it writes into DRAFT), so running WorkflowInstance /
/// WorkflowStepExecution rows (which denormalize stageKey/stepKey and don't
/// reference the template's live authoring state) are never put at risk.
model WorkflowTemplateVersionSnapshot {
  id          String           @id @default(cuid())
  templateId  String
  template    WorkflowTemplate @relation("WorkflowTemplateVersionSnapshots", fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  /// Full serialized WorkflowTemplateDefinition at publish time.
  snapshot    Json
  publishedAt DateTime         @default(now())
  publishedById String?

  @@index([templateId, publishedAt])
}

/// An ordered stage within a template (the spec's "WorkflowStage", renamed to
/// avoid colliding with the existing WorkflowStage enum used by WorkflowItem).
model WorkflowTemplateStage {
  id          String  @id @default(cuid())
  templateId  String
  template    WorkflowTemplate @relation("WorkflowTemplateStages", fields: [templateId], references: [id], onDelete: Cascade)
  /// Slug, unique within the template.
  key         String
  name        String
  description String? @db.Text
  order       Int     @default(0)
  /// Soft SLA: hours after entering this stage before it is "overdue".
  slaHours    Int?
  isInitial   Boolean @default(false)
  isTerminal  Boolean @default(false)
  /// Exit-criteria config: { requireAllRequiredSteps?: bool, minProgress?: int,
  /// custom?: string[] }. Evaluated by the pure runtime.
  exitCriteria Json?

  steps              WorkflowTemplateStep[]   @relation("WorkflowStageSteps")
  outgoingTransitions WorkflowTransition[]    @relation("WorkflowTransitionFrom")
  incomingTransitions WorkflowTransition[]    @relation("WorkflowTransitionTo")
  automationRules    WorkflowAutomationRule[] @relation("WorkflowStageAutomationRules")
  currentInstances   WorkflowInstance[]       @relation("WorkflowInstanceCurrentStage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, key])
  @@index([templateId, order])
}

/// A step within a stage (the spec's "WorkflowStep").
model WorkflowTemplateStep {
  id          String           @id @default(cuid())
  stageId     String
  stage       WorkflowTemplateStage @relation("WorkflowStageSteps", fields: [stageId], references: [id], onDelete: Cascade)
  key         String
  name        String
  description String?          @db.Text
  order       Int              @default(0)
  kind        WorkflowStepKind @default(TASK)
  /// Required steps gate stage exit; optional steps do not.
  isRequired  Boolean          @default(true)
  /// How the step's owner is resolved: OWNER | ROLE | SUBTYPE | SUBJECT.
  assigneeMode    String?
  assigneeRole    String?
  assigneeSubtype String?
  /// Hours after the stage is entered that this step is due.
  dueOffsetHours  Int?
  /// Step-kind config (meeting type, document key, form fields, automation
  /// action params, …).
  config      Json?

  executions WorkflowStepExecution[] @relation("WorkflowStepExecutions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stageId, key])
  @@index([stageId, order])
}

/// A directed edge between two stages. Conditions enable branching flows.
model WorkflowTransition {
  id          String @id @default(cuid())
  templateId  String
  template    WorkflowTemplate @relation("WorkflowTemplateTransitions", fields: [templateId], references: [id], onDelete: Cascade)
  fromStageId String
  fromStage   WorkflowTemplateStage @relation("WorkflowTransitionFrom", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStageId   String
  toStage     WorkflowTemplateStage @relation("WorkflowTransitionTo", fields: [toStageId], references: [id], onDelete: Cascade)
  label       String?
  /// Branch condition: { allRequiredStepsComplete?: bool, expr?: string }.
  condition   Json?
  /// The default outgoing edge taken when criteria are met.
  isDefault   Boolean @default(true)
  /// Whether the engine may take this edge automatically (vs. manual advance).
  isAutomatic Boolean @default(true)
  order       Int     @default(0)

  createdAt DateTime @default(now())

  @@index([templateId])
  @@index([fromStageId])
  @@index([toStageId])
}

/// Template-level automation: fires a reuse adapter on a lifecycle trigger.
model WorkflowAutomationRule {
  id         String                    @id @default(cuid())
  templateId String
  template   WorkflowTemplate          @relation("WorkflowTemplateAutomationRules", fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  trigger    WorkflowAutomationTrigger
  action     WorkflowAutomationAction
  /// Optional stage scope (null = whole template).
  stageId    String?
  stage      WorkflowTemplateStage?    @relation("WorkflowStageAutomationRules", fields: [stageId], references: [id], onDelete: Cascade)
  /// Optional step scope (loosely-coupled step key; null = stage/template).
  stepKey    String?
  enabled    Boolean                   @default(true)
  /// Action params: { title, assigneeMode, dueOffsetHours, notificationType,
  /// meetingType, escalateToRole, … }.
  config     Json?
  order      Int                       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId, trigger, enabled])
  @@index([stageId])
}

/// What can START an instance of a template (reference data; manual start
/// always works, these add automatic start hooks for domain events).
model WorkflowTrigger {
  id          String               @id @default(cuid())
  templateId  String
  template    WorkflowTemplate     @relation("WorkflowTemplateTriggers", fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  event       WorkflowTriggerEvent @default(MANUAL)
  /// For ENTITY_* events: the RELATED_ENTITY_TYPE this listens to.
  subjectType String?
  /// Match config: { status?, equals?, cron?, … }.
  matchConfig Json?
  enabled     Boolean              @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId, event, enabled])
  @@index([event, enabled])
}

/// A single running execution of a template.
model WorkflowInstance {
  id          String                 @id @default(cuid())
  templateId  String
  template    WorkflowTemplate       @relation("WorkflowTemplateInstances", fields: [templateId], references: [id], onDelete: Restrict)
  title       String
  status      WorkflowInstanceStatus @default(ACTIVE)
  /// The stage the instance is currently in (SetNull if the stage is deleted).
  currentStageId String?
  currentStage   WorkflowTemplateStage? @relation("WorkflowInstanceCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  /// Polymorphic subject (what the workflow is ABOUT) — reuses the
  /// RELATED_ENTITY_TYPE vocabulary; both-or-neither, validated in app code.
  subjectType String?
  subjectId   String?
  /// Loosely-coupled org links (resolved in app code, no FK).
  chapterId   String?
  ownerId     String?
  startedById String?
  /// Denormalized 0–100 completion, recomputed on every step change.
  completionPercent Int            @default(0)
  startedAt        DateTime        @default(now())
  dueAt            DateTime?
  followUpAt       DateTime?
  escalatedAt      DateTime?
  lastEscalationAt DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  metadata         Json?

  executions  WorkflowStepExecution[] @relation("WorkflowInstanceExecutions")
  events      WorkflowEvent[]         @relation("WorkflowInstanceEvents")
  snapshots   WorkflowSnapshot[]      @relation("WorkflowInstanceSnapshots")
  attachments WorkflowAttachment[]    @relation("WorkflowInstanceAttachments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([templateId, status])
  @@index([ownerId, status])
  @@index([chapterId, status])
  @@index([dueAt])
  @@index([followUpAt])
  @@index([subjectType, subjectId])
}

/// Per-step runtime record (the spec's "WorkflowExecution"). Carries the links
/// back to the REUSED entities the engine created (ActionItem / Meeting /
/// WorkflowItem) so nothing is duplicated.
model WorkflowStepExecution {
  id         String            @id @default(cuid())
  instanceId String
  instance   WorkflowInstance  @relation("WorkflowInstanceExecutions", fields: [instanceId], references: [id], onDelete: Cascade)
  /// The template step this realizes (SetNull if the step is later deleted).
  stepId     String?
  step       WorkflowTemplateStep? @relation("WorkflowStepExecutions", fields: [stepId], references: [id], onDelete: SetNull)
  /// Denormalized identity so executions survive template edits.
  stageKey   String
  stepKey    String
  title      String
  kind       WorkflowStepKind  @default(TASK)
  state      WorkflowStepState @default(PENDING)
  isRequired Boolean           @default(true)
  ownerId    String?
  dueAt      DateTime?
  startedAt  DateTime?
  completedAt   DateTime?
  completedById String?
  blockedReason String?        @db.Text
  output     Json?
  /// Reuse links — the engine never creates parallel task/meeting tables.
  linkedActionItemId   String?
  linkedMeetingId      String?
  linkedWorkflowItemId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instanceId, state])
  @@index([ownerId, state])
  @@index([stepId])
  @@index([linkedActionItemId])
  @@index([linkedMeetingId])
}

/// Secondary attachment layer for workflow instances. The PRIMARY subject
/// already lives on WorkflowInstance.subjectType/subjectId (one per
/// instance); this table lets the same instance also relate to OTHER YPP
/// objects — e.g. a Partner Acquisition workflow that also touches the
/// chapter running it, or an Instructor Hiring workflow staffing a specific
/// ClassOffering — without a hard FK per entity type. See
/// lib/workflow-engine/attachment.ts for the read/write API built on this
/// table (it also reads the primary subject so callers see one unified list).
model WorkflowAttachment {
  id                 String           @id @default(cuid())
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation("WorkflowInstanceAttachments", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  /// WORKFLOW_ENTITY_TYPE vocabulary (lib/workflow-engine/entity-types.ts).
  entityType String
  entityId   String
  /// SECONDARY | STAKEHOLDER | WATCHER — never PRIMARY (that's subjectType/subjectId on the instance itself).
  relationship String   @default("SECONDARY")
  createdById  String?
  createdAt    DateTime @default(now())

  @@unique([workflowInstanceId, entityType, entityId, relationship])
  @@index([entityType, entityId])
  @@index([workflowInstanceId])
}

/// Append-only history timeline for an instance.
model WorkflowEvent {
  id         String            @id @default(cuid())
  instanceId String
  instance   WorkflowInstance  @relation("WorkflowInstanceEvents", fields: [instanceId], references: [id], onDelete: Cascade)
  kind       WorkflowEventKind
  summary    String
  fromStageKey String?
  toStageKey   String?
  stepKey      String?
  actorId      String?
  data         Json?
  createdAt  DateTime          @default(now())

  @@index([instanceId, createdAt])
  @@index([kind])
}

/// Point-in-time serialized runtime state of an instance (audit + analytics).
model WorkflowSnapshot {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation("WorkflowInstanceSnapshots", fields: [instanceId], references: [id], onDelete: Cascade)
  stageKey   String?
  status     String
  completionPercent Int       @default(0)
  state      Json
  capturedAt DateTime         @default(now())

  @@index([instanceId, capturedAt])
}

/// Rolled-up analytics metric (completion rate, avg stage duration, velocity,
/// bottlenecks). bucketKey makes cron upserts idempotent.
model WorkflowMetric {
  id          String   @id @default(cuid())
  /// Null = org-wide; otherwise the template id (loosely-coupled, no FK).
  templateId  String?
  metricKey   String
  dimension   String?
  value       Float    @default(0)
  windowStart DateTime?
  windowEnd   DateTime?
  /// Deterministic idempotency key: templateId:metricKey:dimension:windowStart.
  bucketKey   String   @unique
  capturedAt  DateTime @default(now())

  @@index([templateId, metricKey, capturedAt])
}

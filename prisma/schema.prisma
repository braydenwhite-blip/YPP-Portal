  unlockRecommendationsBy UnlockRecommendation[] @relation("UnlockRecommender")
  nudges                  Nudge[]                @relation("UserNudges")
  journeyMilestones       JourneyMilestone[]     @relation("JourneyMilestones")

  // Curriculum Builder Studio
  curriculumDrafts           CurriculumDraft[]
  curriculumCommentsAuthored CurriculumComment[] @relation("CurriculumCommentsAuthored")
  curriculumCommentsResolved CurriculumComment[] @relation("CurriculumCommentsResolved")

  // Goals & Responsibilities (G&R) System
  grDocuments                GRDocument[]        @relation("GRDocuments")
  grResourcesCreated         GRResource[]        @relation("GRResourcesCreated")
  grTemplatesCreated         GRTemplate[]        @relation("GRTemplatesCreated")
  grTemplatesLastEdited      GRTemplate[]        @relation("GRTemplatesLastEdited")
  grTemplateCommentsAuthored GRTemplateComment[] @relation("GRTemplateCommentsAuthored")
  grGoalChangesProposed      GRGoalChange[]      @relation("GRGoalChangesProposed")
  grGoalChangesReviewed      GRGoalChange[]      @relation("GRGoalChangesReviewed")
  grDocumentVersionsCreated  GRDocumentVersion[] @relation("GRDocumentVersionsCreated")

  // Instructor Growth System
  instructorGrowthProfile         InstructorGrowthProfile?
  instructorGrowthEvents          InstructorGrowthEvent[]        @relation("InstructorGrowthEvents")
  instructorGrowthClaimsSubmitted InstructorGrowthEvent[]        @relation("InstructorGrowthEventsSubmittedBy")
  instructorGrowthMentorRoutes    InstructorGrowthEvent[]        @relation("InstructorGrowthEventsMentor")
  instructorGrowthEventsReviewed  InstructorGrowthEvent[]        @relation("InstructorGrowthEventsReviewedBy")
  instructorGrowthEventsRevoked   InstructorGrowthEvent[]        @relation("InstructorGrowthEventsRevokedBy")
  instructorGrowthEventsRelated   InstructorGrowthEvent[]        @relation("InstructorGrowthEventsRelatedUser")
  instructorGrowthBadgeAwards     InstructorGrowthBadgeAward[]   @relation("InstructorGrowthBadgeAwards")
  instructorGrowthSemesterStats   InstructorGrowthSemesterStat[] @relation("InstructorGrowthSemesterStats")

  // Student Operating System / Growth Engine (Phase N1)
  growthProfile        GrowthProfile?        @relation("GrowthProfile")
  growthVisions        GrowthVision[]        @relation("GrowthVisions")
  growthGoals          GrowthGoal[]          @relation("GrowthGoals")
  growthMilestones     GrowthMilestone[]     @relation("GrowthMilestones")
  growthActions        GrowthAction[]        @relation("GrowthActions")
  growthAchievements   GrowthAchievement[]   @relation("GrowthAchievements")
  growthOpportunities  GrowthOpportunity[]   @relation("GrowthOpportunities")
  growthProgressEvents GrowthProgressEvent[] @relation("GrowthProgressEvents")

  // Governance & Risk
  opsRulesCreated OpsRule[] @relation("OpsRulesCreated")

  // Supabase Auth integration
  supabaseAuthId String?   @unique @map("supabase_auth_id")
  archivedAt     DateTime?

  // Interactive Training Journey
  interactiveBeatAttempts       InteractiveBeatAttempt[]
  interactiveJourneyCompletions InteractiveJourneyCompletion[]

  // Admin Journey Editor (versioning)
  journeysCreated          Journey[]         @relation("JourneysCreated")
  journeyVersionsCreated   JourneyVersion[]  @relation("JourneyVersionsCreated")
  journeyVersionsPublished JourneyVersion[]  @relation("JourneyVersionsPublished")
  journeyAuditLogs         JourneyAuditLog[] @relation("JourneyAuditLogActor")

  // Summer Workshop Instructor pathway
  workshopProposalTemplatesCreated    WorkshopProposalTemplate[]   @relation("WorkshopProposalTemplatesCreated")
  workshopProposalTemplatesUpdated    WorkshopProposalTemplate[]   @relation("WorkshopProposalTemplatesUpdated")
  workshopProposalSubmissions         WorkshopProposalSubmission[] @relation("WorkshopProposalSubmissionsAuthored")
  workshopProposalSubmissionsReviewed WorkshopProposalSubmission[] @relation("WorkshopProposalSubmissionsReviewed")
  workshopProposalReviews             WorkshopProposalReview[]     @relation("WorkshopProposalReviewsAuthored")

  // Leadership Action Center
  leadershipActionItemsOwned     LeadershipActionItem[]       @relation("LeadershipActionItemsOwned")
  leadershipActionItemsCreated   LeadershipActionItem[]       @relation("LeadershipActionItemsCreated")
  leadershipActionItemsUpdated   LeadershipActionItem[]       @relation("LeadershipActionItemsUpdated")
  leadershipActionItemInputRoles LeadershipActionItemInput[]  @relation("LeadershipActionItemInputUser")
  leadershipActionItemUpdates    LeadershipActionItemUpdate[] @relation("LeadershipActionItemUpdateAuthor")
  leadershipMeetingsOwned        LeadershipMeeting[]          @relation("LeadershipMeetingsOwner")

  // Instructor-to-camp/workshop assignment system (admin operations layer)
  workshopOpportunitiesOwned    WorkshopOpportunity[]  @relation("WorkshopOpportunityOwner")
  workshopOpportunitiesCreated  WorkshopOpportunity[]  @relation("WorkshopOpportunityCreatedBy")
  instructorAssignments         InstructorAssignment[] @relation("InstructorAssignmentInstructor")
  instructorAssignmentsAssigned InstructorAssignment[] @relation("InstructorAssignmentAssignedBy")

  // Instructor Ops V2
  instructorProfile       InstructorProfile?
  instructorNotesAuthored InstructorNote[]      @relation("InstructorNoteAuthor")
  instructorTasksAssigned InstructorTask[]      @relation("InstructorTaskAssignee")
  instructorSavedViews    InstructorSavedView[] @relation("InstructorSavedViewOwner")

  // Partners (Relationship Lead for org/school partners)
  partnersAsRelationshipLead Partner[] @relation("PartnerRelationshipLead")

  // Action Tracker (People Strategy)
  actionItemsLed              ActionItem[]       @relation("ActionItemsLed")
  actionItemsCreated          ActionItem[]       @relation("ActionItemsCreated")
  actionItemsApproved         ActionItem[]       @relation("ActionItemsApproved")
  actionAssignments           ActionAssignment[] @relation("ActionAssignments")
  actionComments              ActionComment[]    @relation("ActionComments")
  actionFileLinksAdded        ActionFileLink[]   @relation("ActionFileLinksAdded")
  actionEmailLogs             ActionEmailLog[]   @relation("ActionEmailLogRecipient")
  feedbackRequestsAbout       FeedbackRequest[]  @relation("FeedbackRequestSubject")
  feedbackRequestsToAnswer    FeedbackRequest[]  @relation("FeedbackRequestCollaborator")
  monthlyFeedbackRequestsSent FeedbackRequest[]  @relation("MonthlyFeedbackRequestedBy")
  growthTags                  MemberGrowthTag[]  @relation("MemberGrowthTags")
  growthTagsCreated           MemberGrowthTag[]  @relation("MemberGrowthTagsCreated")
  actionTemplatesCreated      ActionTemplate[]   @relation("ActionTemplatesCreated")
  savedActionViews            SavedActionView[]  @relation("SavedActionViews")
  emailTemplateOverridesCreated EmailTemplateOverride[] @relation("EmailTemplateOverridesCreated")
  emailTemplateOverridesUpdated EmailTemplateOverride[] @relation("EmailTemplateOverridesUpdated")

  // Weekly Meetings — Teams, Weekly Impact, Meeting Runner
  teamsCreated            Team[]              @relation("TeamCreatedBy")
  teamMemberships         TeamMembership[]    @relation("TeamMembershipUser")
  weeklyImpactEntries     WeeklyImpactEntry[] @relation("WeeklyImpactEntryUser")
  meetingsFacilitated     Meeting[]           @relation("MeetingFacilitator")
  meetingsCreated         Meeting[]           @relation("MeetingCreatedBy")
  meetingAttendances      MeetingAttendee[]   @relation("MeetingAttendeeUser")
  officerTopicsCreated    OfficerTopic[]      @relation("OfficerTopicCreatedBy")
  officerTopicOwnerships  OfficerTopicOwner[] @relation("OfficerTopicOwnerUser")
  meetingDecisionsMade    MeetingDecision[]   @relation("MeetingDecisionDecidedBy")
  meetingFollowUpsOwned   MeetingFollowUp[]   @relation("MeetingFollowUpOwner")

  // People Strategy — provisional 3-month confirmation clock
  // (ENABLE_PROVISIONAL_CLOCK). `provisionalStart` is set when a hire is
  // confirmed (the applicant→instructor approval); the Month-3 confirmation
  // review is due 90 days later. `provisionalConfirmedAt` is set when senior
  // leadership / Board confirms the hire, which clears the provisional state.
  provisionalStart       DateTime?
  provisionalConfirmedAt DateTime?

  // Leadership Roles & Contributions (ENABLE_LEADERSHIP_ROLES)
  leadershipContributions          LeadershipContribution[]         @relation("LeadershipContributionInstructor")
  leadershipContributionsAsSubject LeadershipContribution[]         @relation("LeadershipContributionSubject")
  leadershipContributionsOwned     LeadershipContribution[]         @relation("LeadershipContributionAdminOwner")
  leadershipContributionsCreated   LeadershipContribution[]         @relation("LeadershipContributionCreatedBy")
  leadershipContributionActivities LeadershipContributionActivity[] @relation("LeadershipContributionActivityAuthor")
  advisorAssignments               StudentAdvisorAssignment[]       @relation("StudentAdvisorAssignmentAdvisor")
  adviseeAssignments               StudentAdvisorAssignment[]       @relation("StudentAdvisorAssignmentStudent")
  advisorAssignmentsCreated        StudentAdvisorAssignment[]       @relation("StudentAdvisorAssignmentAssignedBy")
  advisingNotesAuthored            AdvisingNote[]                   @relation("AdvisingNoteAuthor")
  advisingRecommendationsAuthored  AdvisingRecommendation[]         @relation("AdvisingRecommendationAuthor")

  // Single active Chair (final applicant decision authority)
  activeChairAssignment      ActiveChairAssignment?   @relation("ActiveChairUser")
  activeChairAssignmentsMade ActiveChairAssignment[]  @relation("ActiveChairAssignedBy")
  chairAssignmentsAsPrevious ChairAssignmentHistory[] @relation("ChairAssignmentPrev")
  chairAssignmentsAsNew      ChairAssignmentHistory[] @relation("ChairAssignmentNew")
  chairAssignmentChangesMade ChairAssignmentHistory[] @relation("ChairAssignmentChangedBy")

  // Admin-editable portal settings this user last updated
  portalSettingsUpdated PortalSetting[] @relation("PortalSettingUpdatedBy")

  // Mentorship review cycles (cohort review launches)
  reviewCyclesCreated       ReviewCycle[]            @relation("ReviewCyclesCreated")
  reviewCycleParticipations ReviewCycleParticipant[] @relation("ReviewCycleParticipations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
  @@index([provisionalStart])
  @@index([chapterId])
}

model TwoFactorRecovery {
  id       String    @id @default(cuid())
  userId   String
  codeHash String // bcrypt hash of single-use recovery code
  usedAt   DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRole {
  userId String
  role   RoleType
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
}

model UserAdminSubtype {
  userId         String
  subtype        AdminSubtype
  isDefaultOwner Boolean      @default(false)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, subtype])
  @@index([subtype, isDefaultOwner])
}

model WorkflowItem {
  id                   String                        @id @default(cuid())
  kind                 WorkflowKind
  stage                WorkflowStage                 @default(INBOX)
  status               WorkflowStatus                @default(OPEN)
  title                String
  summary              String?
  href                 String
  sourceId             String
  sourceType           String
  chapterId            String?
  chapter              Chapter?                      @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  subjectUserId        String?
  subjectUser          User?                         @relation("WorkflowItemsSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  dueAt                DateTime?
  assigneeUserId       String?
  assigneeUser         User?                         @relation("WorkflowItemsAssigned", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeSubtype      AdminSubtype?
  assignmentTargetType WorkflowAssignmentTargetType?
  allowedAssigneeRole  RoleType?
  allowedAdminSubtype  AdminSubtype?
  assignmentReason     String?
  manualOverrideById   String?
  manualOverrideBy     User?                         @relation("WorkflowItemsManualOverrideBy", fields: [manualOverrideById], references: [id], onDelete: SetNull)
  manualOverrideAt     DateTime?
  lastRoutedAt         DateTime?
  completedAt          DateTime?
  createdById          String?
  createdBy            User?                         @relation("WorkflowItemsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById          String?
  updatedBy            User?                         @relation("WorkflowItemsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  comments             WorkflowComment[]
  actionItems          WorkflowActionItem[]
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  @@unique([sourceType, sourceId, kind])
  @@index([kind, stage, status])
  @@index([chapterId, kind, stage, status])
  @@index([assigneeUserId, status, dueAt])
  @@index([subjectUserId, status, dueAt])
}

model WorkflowComment {
  id             String              @id @default(cuid())
  workflowItemId String
  workflowItem   WorkflowItem        @relation(fields: [workflowItemId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?               @relation("WorkflowCommentsAuthored", fields: [authorId], references: [id], onDelete: SetNull)
  kind           WorkflowCommentKind @default(COMMENT)
  body           String
  createdAt      DateTime            @default(now())

  @@index([workflowItemId, createdAt])
}

model WorkflowActionItem {
  id             String         @id @default(cuid())
  workflowItemId String
  workflowItem   WorkflowItem   @relation(fields: [workflowItemId], references: [id], onDelete: Cascade)
  title          String
  details        String?
  status         WorkflowStatus @default(OPEN)
  dueAt          DateTime?
  ownerId        String?
  owner          User?          @relation("WorkflowActionItemsOwned", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById    String?
  createdBy      User?          @relation("WorkflowActionItemsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([workflowItemId, status])
  @@index([ownerId, status, dueAt])
}

model WorkflowAssignmentRule {
  id              String        @id @default(cuid())
  kind            WorkflowKind
  stage           WorkflowStage
  chapterId       String?
  chapter         Chapter?      @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  priority        Int           @default(0)
  isActive        Boolean       @default(true)
  assigneeUserId  String?
  assigneeUser    User?         @relation("WorkflowAssignmentRulesAssigneeUser", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeSubtype AdminSubtype?
  assigneeRole    RoleType?
  note            String?
  createdById     String?
  createdBy       User?         @relation("WorkflowAssignmentRulesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?         @relation("WorkflowAssignmentRulesUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([kind, stage, chapterId, isActive, priority])
  @@index([assigneeSubtype, isActive])
}

model PasswordResetToken {

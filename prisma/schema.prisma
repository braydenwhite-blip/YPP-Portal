enum AssignmentType {
  INDIVIDUAL
  GROUP
  PEER_REVIEW
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  GRADED
  RETURNED
}

model Assignment {
  id                  String                 @id @default(cuid())
  courseId            String
  course              Course                 @relation(fields: [courseId], references: [id])
  title               String
  description         String
  type                AssignmentType         @default(INDIVIDUAL)
  maxPoints           Int?
  dueDate             DateTime?
  allowLateSubmission Boolean                @default(true)
  instructions        String?
  attachmentUrl       String?

  description              String?
  scope                    String                          @default("GLOBAL")
  chapterId                String?
  chapter                  Chapter?                        @relation(fields: [chapterId], references: [id])
  programGroup             MentorshipProgramGroup          @default(INSTRUCTOR)
  governanceMode           MentorshipGovernanceMode        @default(FULL_PROGRAM)
  committeeScope           MentorshipCommitteeScope        @default(GLOBAL)

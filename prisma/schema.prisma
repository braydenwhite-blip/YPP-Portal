// ============================================
// CORE MODELS
// ============================================

model Chapter {
  id                   String  @id @default(cuid())
  name                 String
  slug                 String? @unique
  city                 String?
  region               String?
  partnerSchool        String?
  programNotes         String?
  publicProfileEnabled Boolean @default(false)
  publicSummary        String? @db.Text
  publicStory          String? @db.Text
  publicContactEmail   String?
  publicContactUrl     String?
  calendarDescription  String? @db.Text
  calendarThemeColor   String?

  // Chapter Identity & Discovery
  description String?
  tagline     String?
  logoUrl     String?
  bannerUrl   String?
  isPublic    Boolean           @default(true)
  joinPolicy  ChapterJoinPolicy @default(OPEN)

  // Chapter lifecycle + operating system. `lifecycleStatus` is the canonical
  // stage leadership/system manages; a separate computed "health" label is
  // derived from concrete signals (see lib/chapters/health.ts). Setup fields
  // are filled from the originating Chapter President application on approval,
  // then editable in the guided setup flow.
  lifecycleStatus        ChapterLifecycleStatus @default(ACTIVE)
  lifecycleNote          String?                @db.Text
  lifecycleUpdatedAt     DateTime?
  state                  String?
  schoolType             ChapterSchoolType?
  facultyAdvisorName     String?
  facultyAdvisorEmail    String?
  foundingTeamNotes      String?                @db.Text
  recruitmentGoal        Int?
  supportNeeded          String?                @db.Text
  launchTargetDate       DateTime?
  expectedFirstMeetingAt DateTime?
  launchPlanText         String?                @db.Text
  launchPlanSubmittedAt  DateTime?
  launchPlanApprovedAt   DateTime?
  launchPlanApprovedById String?
  launchedAt             DateTime?
  presidentId            String?

  // Relations
  users                          User[]
  meetings                       Meeting[]                       @relation("ChapterMeetings")
  weeklyEntries                  WeeklyImpactEntry[]             @relation("ChapterWeeklyEntries")
  joinRequests                   ChapterJoinRequest[]
  goals                          ChapterGoal[]
  channels                       ChapterChannel[]
  onboardingSteps                ChapterOnboardingStep[]
  memberOnboardingProgress       MemberOnboardingProgress[]
  invites                        ChapterInvite[]
  achievementMilestones          ChapterAchievementMilestone[]
  courses                        Course[]
  partners                       Partner[]
  events                         Event[]
  eventSeries                    EventSeries[]
  feedbacks                      Feedback[]
  positions                      Position[]
  announcements                  Announcement[]
  goalTemplates                  GoalTemplate[]
  marketingStats                 MarketingStats[]
  marketingGoals                 MarketingGoal[]
  chapterUpdates                 ChapterUpdate[]
  classTemplates                 ClassTemplate[]
  regularInstructorAssignments   RegularInstructorAssignment[]   @relation("RegularInstructorAssignmentsForChapter")
  launchTasks                    LaunchTask[]
  mentorshipTracks               MentorshipTrack[]
  rolloutCampaigns               RolloutCampaign[]
  featureGateRules               FeatureGateRule[]
  interviewAvailabilityRules     InterviewAvailabilityRule[]
  interviewAvailabilityOverrides InterviewAvailabilityOverride[]
  interviewSchedulingRequests    InterviewSchedulingRequest[]
  pathwayConfigs                 ChapterPathway[]
  classOfferings                 ClassOffering[]
  pathwayEvents                  PathwayEvent[]
  pathwayFallbackRequestsFrom    PathwayFallbackRequest[]        @relation("PathwayFallbackFromChapter")
  pathwayFallbackRequestsTo      PathwayFallbackRequest[]        @relation("PathwayFallbackToChapter")
  specialPrograms                SpecialProgram[]                @relation("ChapterSpecialPrograms")
  rubrics                        Rubric[]
  instructorCohorts              InstructorCohort[]
  chapterMilestones              ChapterMilestone[]
  calendarSubscriptions          ChapterCalendarSubscription[]

  // Chapter President & Feedback Relations
  chapterPresidentApplications ChapterPresidentApplication[]
  chapterPresidentOnboardings  ChapterPresidentOnboarding[]
  president                    User?                         @relation("ChapterPresident", fields: [presidentId], references: [id], onDelete: SetNull)
  launchPlanApprovedBy         User?                         @relation("ChapterLaunchPlanApprover", fields: [launchPlanApprovedById], references: [id], onDelete: SetNull)
  actionItems                  ActionItem[]                  @relation("ChapterActionItems")
  supportRequests              ChapterSupportRequest[]
  notes                        ChapterNote[]
  parentChapterFeedbacks       ParentChapterFeedback[]
  parentSurveys                ParentSurvey[]
  studentIntakeCases           StudentIntakeCase[]
  workflowItems                WorkflowItem[]
  workflowAssignmentRules      WorkflowAssignmentRule[]

  // Governance & Risk
  kpiSnapshots       ChapterKpiSnapshot[]
  weeklyKpiSnapshots ChapterWeeklyKpiSnapshot[]
  opsRules           OpsRule[]
  opsRuleViolations  OpsRuleViolation[]

  // Instructor assignment system
  workshopOpportunities WorkshopOpportunity[] @relation("WorkshopOpportunityChapter")

  // Soft-delete / archive. Archiving hides the chapter from active lists and
  // selection menus but preserves member affiliation so a restore puts every
  // user back where they were. Hard delete remains available for empty chapters.
  archivedAt   DateTime?
  archivedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
  @@index([lifecycleStatus])
  @@index([presidentId])
  @@index([state])
}

/// Lifecycle stage of a chapter across the national pipeline. Canonical stage
/// managed by leadership/system; the displayed "health" label (On Track / Needs
/// Support / At Risk / Paused) is computed separately from concrete signals.
enum ChapterLifecycleStatus {
  PROSPECT
  APPROVED
  LAUNCHING
  ACTIVE
  NEEDS_SUPPORT
  AT_RISK
  PAUSED
  ALUMNI
}

enum ChapterSchoolType {
  PUBLIC
  PRIVATE
  CHARTER
  HOMESCHOOL
  COLLEGE
  OTHER
}

enum ChapterSupportCategory {
  CURRICULUM
  INSTRUCTOR
  PARTNER
  RECRUITMENT
  EVENT_PLANNING
  SCHOOL_APPROVAL
  GENERAL
}

enum ChapterSupportRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// A Chapter President's request for help from national leadership. Creating one
/// also spawns a leadership-visible ActionItem (linked via actionItemId) so the
/// ask shows up in the Action Tracker, not a separate queue.
model ChapterSupportRequest {
  id             String                      @id @default(cuid())
  chapterId      String
  chapter        Chapter                     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                        @relation("ChapterSupportRequestsRequested", fields: [requestedById], references: [id], onDelete: Cascade)
  category       ChapterSupportCategory      @default(GENERAL)
  title          String
  details        String?                     @db.Text
  status         ChapterSupportRequestStatus @default(OPEN)
  priority       ActionPriority              @default(MEDIUM)
  assignedToId   String?
  assignedTo     User?                       @relation("ChapterSupportRequestsAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  actionItemId   String?
  resolutionNote String?                     @db.Text
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?                       @relation("ChapterSupportRequestsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([chapterId, status])
  @@index([status])
  @@index([assignedToId])
  @@index([requestedById])
}

/// Leadership notes on a chapter (and optionally about a specific member).
/// `audience` controls whether the Chapter President can also see the note.
model ChapterNote {
  id          String   @id @default(cuid())
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ChapterNotesAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  aboutUserId String?
  aboutUser   User?    @relation("ChapterNotesAbout", fields: [aboutUserId], references: [id], onDelete: SetNull)
  body        String   @db.Text
  pinned      Boolean  @default(false)
  audience    String   @default("LEADERSHIP")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([chapterId, createdAt])
  @@index([aboutUserId])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  primaryRole  RoleType
  // Human-readable job/role title (e.g. "Lead Instructor", "VP of People").
  // Optional; when absent, `getUserTitle()` falls back to the admin-subtype
  // label or a formatted `primaryRole`. Surfaced on profiles and action cards.
  title        String?
  chapterId    String?
  chapter      Chapter? @relation(fields: [chapterId], references: [id])

  // Org authority spine (Phase 3 of the Roles/Mentorship/Reviews/Access plan).
  // All additive + nullable. `resolvePersonAuthority` (lib/org/levels.ts) reads
  // these first and otherwise derives them from primaryRole/title/adminSubtypes,
  // so existing rows keep working until the backfill populates them.
  internalLevel        Int?
  ladder               OrgLadder?
  canonicalTitle       String?
  cohortId             String?
  cohort               Cohort?               @relation(fields: [cohortId], references: [id])
  committeeMemberships CommitteeMembership[] @relation("CommitteeMembershipUser")

  // Existing relations
  roles                                    UserRole[]
  courses                                  Course[]                                 @relation("InstructorCourses")
  enrollments                              Enrollment[]
  trainings                                TrainingAssignment[]
  trainingCheckpointCompletions            TrainingCheckpointCompletion[]           @relation("TrainingCheckpointCompletions")
  trainingQuizAttempts                     TrainingQuizAttempt[]                    @relation("TrainingQuizAttempts")
  trainingEvidenceSubmissions              TrainingEvidenceSubmission[]             @relation("TrainingEvidenceSubmissions")
  trainingEvidenceReviews                  TrainingEvidenceSubmission[]             @relation("TrainingEvidenceReviews")
  readinessReviewRequests                  ReadinessReviewRequest[]                 @relation("ReadinessReviewRequests")
  readinessReviewDecisions                 ReadinessReviewRequest[]                 @relation("ReadinessReviewDecisions")
  teachingPermissions                      InstructorTeachingPermission[]           @relation("TeachingPermissions")
  teachingPermissionGrants                 InstructorTeachingPermission[]           @relation("TeachingPermissionGrants")
  offeringApprovalRequests                 ClassOfferingApproval[]                  @relation("ClassOfferingApprovalRequests")
  offeringApprovalReviews                  ClassOfferingApproval[]                  @relation("ClassOfferingApprovalReviews")
  offeringTimelineActions                  ClassOfferingTimelineEvent[]             @relation("ClassOfferingTimelineActor")
  interviewGate                            InstructorInterviewGate?                 @relation("InstructorInterviewGateOwner")
  interviewGateReviews                     InstructorInterviewGate[]                @relation("InstructorInterviewGateReviews")
  interviewSlotsCreated                    InstructorInterviewSlot[]                @relation("InstructorInterviewSlotsCreated")
  openedPositions                          Position[]                               @relation("PositionsOpenedBy")
  hiringLeadPositions                      Position[]                               @relation("PositionsHiringLead")
  applicationInterviewSlots                InterviewSlot[]                          @relation("ApplicationInterviewer")
  interviewAvailabilityRequests            InstructorInterviewAvailabilityRequest[] @relation("InstructorInterviewAvailabilityRequests")
  interviewAvailabilityReviews             InstructorInterviewAvailabilityRequest[] @relation("InstructorInterviewAvailabilityReviews")
  interviewAvailabilityRules               InterviewAvailabilityRule[]              @relation("InterviewAvailabilityRules")
  interviewAvailabilityOverrides           InterviewAvailabilityOverride[]          @relation("InterviewAvailabilityOverrides")
  interviewSchedulingRequestsCreated       InterviewSchedulingRequest[]             @relation("InterviewSchedulingRequestsCreated")
  interviewSchedulingRequestsAsInterviewee InterviewSchedulingRequest[]             @relation("InterviewSchedulingRequestsAsInterviewee")
